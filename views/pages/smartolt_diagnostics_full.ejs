<script type="text/javascript">

var smartoltCopyFlashTimeout = null;
var $smartoltCopyFlash = null;

function showSmartoltCopyFlash(clientX, clientY, message) {
	if (!$smartoltCopyFlash || !$smartoltCopyFlash.length) {
		$smartoltCopyFlash = $('<div class="smartolt-copy-flash" aria-live="polite"></div>').appendTo('body');
	}

	$smartoltCopyFlash
		.css({ left: clientX + 12, top: clientY + 12 })
		.addClass('is-visible');

	$smartoltCopyFlash.text('');
	window.setTimeout(function() {
		$smartoltCopyFlash.text(message);
	}, 30);

	clearTimeout(smartoltCopyFlashTimeout);
	smartoltCopyFlashTimeout = setTimeout(function() {
		$smartoltCopyFlash.removeClass('is-visible');
	}, 900);
}

function copySmartoltText(text, done) {
	if (navigator.clipboard && window.isSecureContext) {
		navigator.clipboard.writeText(text).then(function() {
			done(true);
		}, function() {
			copySmartoltTextFallback(text, done);
		});
		return;
	}

	copySmartoltTextFallback(text, done);
}

function copySmartoltTextFallback(text, done) {
	var copyTextArea = document.createElement('textarea');
	copyTextArea.value = text;
	copyTextArea.setAttribute('readonly', '');
	copyTextArea.style.position = 'absolute';
	copyTextArea.style.left = '-9999px';
	document.body.appendChild(copyTextArea);
	copyTextArea.select();

	var successful = false;
	try {
		successful = document.execCommand('copy');
	} catch (err) {
		successful = false;
	}

	document.body.removeChild(copyTextArea);
	done(successful);
}

$(document).on('click', '#diagnostics_list .onu-copy-cell', function(event) {
	event.preventDefault();
	event.stopPropagation();

	var text = $(this).attr('data-copy') || $.trim($(this).text());
	if (!text) {
		return;
	}

	copySmartoltText(text, function(successful) {
		if (successful) {
			showSmartoltCopyFlash(event.clientX, event.clientY, "Copied!");
		}
	});
});

