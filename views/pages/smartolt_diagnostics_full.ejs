		function capacityWarningHtml(data) {
			var counts = usageBreakdown(data);
			if (!counts.capacityExceeded) {
				return '';
			}
			var editUrl = '/odbs/edit/' + encodeURIComponent(data.id) + '?from=diagnostics';
			return '<a class="diag-odb-alert" href="' + editUrl + '" target="_blank"><i class="fa fa-exclamation-triangle"></i> ' + diagFormatCapacityExceeded(counts.used, counts.capacity) + '</a>';
		}

		function renderDiagOdbDetailModal(data, selectedIndex) {
			var ports = data.ports || [];
			var split = splitOdbPortItems(data);
			var counts = usageBreakdown(data);
			var used = counts.used;
			var total = parseInt(data.nr_of_ports, 10) || 0;
			var subtitle = counts.totalDefined
				? (total + ' ports &bull; ' + used + ' used &bull; ' + Math.max(0, total - used) + ' free')
				: ('Total ports not defined &bull; ' + used + ' used &bull; Unknown free');
				var selectedPort = selectedDetailPort(data, selectedIndex);
				var shellPortCount = total || split.assigned.length;
				var shellClass = shellPortCount <= 8 ? 'diag-odb-shell-compact' : (shellPortCount > 16 ? 'diag-odb-shell-wide' : 'diag-odb-shell-medium');
				var html = '<div class="diag-odb-detail-head">' +
				'<div>' +
					'<div class="diag-odb-detail-title">' + odbVisualIconHtml() + '<span>ODB: ' + diagEscape(data.name || '-') + '</span>' + odbMapIconHtml(data) + '</div>' +
					'<div class="diag-odb-detail-subtitle">' + subtitle + '</div>' +
				'</div>' +
				'<button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>' +
			'</div>' +
			'<div class="diag-odb-detail-splitter-row">' +
				'<div>' + splitterBadgeHtml(data, total) + '</div>' +
				'<div>' + capacityWarningHtml(data) + '</div>' +
				'</div>' +
				'<div class="diag-odb-detail-layout">' +
					'<div class="diag-odb-detail-ports-card diag-odb-shell ' + shellClass + '"><span class="diag-odb-fiber-gland" aria-hidden="true"></span>' +
					'<div class="diag-odb-detail-grid">';
			split.assigned.forEach(function(item) {
				html += detailPortHtml(item.port, item.index, selectedIndex);
			});
			html += '</div>' + renderDetailUnassignedSection(data, selectedIndex) + '</div>' +
				detailPanelHtml(data, selectedIndex) +
			'</div>' +
			'<div class="diag-odb-detail-footer">' +
				usageSummaryHtml(data, true) +
				'<div class="diag-odb-detail-actions">' +
					'<a class="btn btn-success btn-sm diag-odb-edit-btn" href="/odbs/edit/' + encodeURIComponent(data.id) + '?from=diagnostics" target="_blank"><i class="fa fa-external-link"></i> ' + diagEscape(diagLang.edit_odb) + '</a>' +
					odbMapLinkHtml(data) +
					'<button type="button" class="btn btn-default btn-sm" data-dismiss="modal">Close</button>' +
				'</div>' +
			'</div>';
			return html;
		}

		function showDiagOdbDetailModal(data, selectedIndex) {
			var $modal = ensureDiagOdbDetailModal();
			var index = typeof selectedIndex === 'number' ? selectedIndex : 0;
			if (!selectedDetailPort(data, index)) {
				var ports = data.ports || [];
				for (var i = 0; i < ports.length; i++) {
					if (!ports[i].free) {
						index = i;
						break;
					}
				}
			}
			$modal.data('odb-data', data);
			$modal.find('.modal-body').html(renderDiagOdbDetailModal(data, index));
			$modal.modal('show');
		}

		function refreshDiagOdbAfterAssign(odbId, selectedPort) {
			var $modal = ensureDiagOdbDetailModal();
			$.ajax({
				url: '/diagnostics/get_odb_details/' + encodeURIComponent(odbId),
				dataType: 'json'
			}).done(function(data) {
				if (!data || data.error) {
					window.location.reload();
					return;
				}
				diagOdbCache[odbId] = data;
				diagOdbSelectedPort[odbId] = parseInt(selectedPort, 10) || 0;
				diagOdbSelectedOnu[odbId] = 0;
				showDiagOdbDetailModal(data, selectedIndexForPort(data, selectedPort, 0));
				var $popover = diagOdbPopover();
				if ($popover.is(':visible')) {
					$popover.html(renderDiagOdbCard(data, diagOdbSelectedPort[odbId], diagOdbSelectedOnu[odbId]));
					window.requestAnimationFrame(function() {
						scrollDiagOdbSelectedPort($popover, diagOdbSelectedPort[odbId], diagOdbSelectedOnu[odbId]);
					});
				}
			}).fail(function() {
				window.location.reload();
			});
		}

			function loadDiagOdbCard(odbId, $target, forceRefresh) {
				var $popover = diagOdbPopover();
				var selectedPort = parseInt($target.attr('data-odb-port'), 10) || 0;
				var selectedOnu = parseInt($target.attr('data-odb-onu-id'), 10) || 0;
			if (selectedPort) {
				diagOdbSelectedPort[odbId] = selectedPort;
				diagOdbSelectedOnu[odbId] = 0;
			} else if (selectedOnu) {
				diagOdbSelectedPort[odbId] = 0;
				diagOdbSelectedOnu[odbId] = selectedOnu;
			}
			positionDiagOdbPopover($target);
			$popover.show();

					if (!forceRefresh && diagOdbCache[odbId]) {
						$popover.html(renderDiagOdbCard(diagOdbCache[odbId], diagOdbSelectedPort[odbId], diagOdbSelectedOnu[odbId]));
						window.requestAnimationFrame(function() {
							scrollDiagOdbSelectedPort($popover, diagOdbSelectedPort[odbId], diagOdbSelectedOnu[odbId]);
						});
						positionDiagOdbPopover($target);
						return;
					}

			$popover.html('<div style="padding:12px;text-align:center;"><i class="fa fa-spinner fa-spin"></i> ' + diagEscape(diagLang.loading_odb) + '</div>');
			$.ajax({
				url: '/diagnostics/get_odb_details/' + encodeURIComponent(odbId),
				dataType: 'json'
			}).done(function(data) {
				if (!data || data.error) {
					$popover.html('<div style="padding:12px;color:#b42318;">' + diagEscape(diagLang.odb_details_unavailable) + '</div>');
					return;
					}
					diagOdbCache[odbId] = data;
					$popover.html(renderDiagOdbCard(data, diagOdbSelectedPort[odbId], diagOdbSelectedOnu[odbId]));
					window.requestAnimationFrame(function() {
						scrollDiagOdbSelectedPort($popover, diagOdbSelectedPort[odbId], diagOdbSelectedOnu[odbId]);
					});
					positionDiagOdbPopover($target);
				}).fail(function() {
				$popover.html('<div style="padding:12px;color:#b42318;">' + diagEscape(diagLang.odb_details_unavailable) + '</div>');
			});
		}

		$(document).off('click.diagOdb', '.diag-odb-link').on('click.diagOdb', '.diag-odb-link', function(event) {
			event.preventDefault();
			event.stopPropagation();
			var $target = $(this);
			loadDiagOdbCard($target.data('odb-id'), $target, false);
		});

		$(document).off('click.diagOdbRefresh', '.diag-odb-refresh').on('click.diagOdbRefresh', '.diag-odb-refresh', function(event) {
			event.preventDefault();
			event.stopPropagation();
			var odbId = $(this).data('odb-id');
			var selectedPort = diagOdbSelectedPort[odbId] || 0;
			var selectedOnu = diagOdbSelectedOnu[odbId] || 0;
			var $target = selectedPort
				? $('.diag-odb-link[data-odb-id="' + odbId + '"][data-odb-port="' + selectedPort + '"]').first()
				: $();
			if (!$target.length && selectedOnu) {
				$target = $('.diag-odb-link[data-odb-id="' + odbId + '"][data-odb-onu-id="' + selectedOnu + '"]').first();
			}
			if (!$target.length) {
				$target = $('.diag-odb-link[data-odb-id="' + odbId + '"]').first();
			}
			if ($target.length) {
				loadDiagOdbCard(odbId, $target, true);
