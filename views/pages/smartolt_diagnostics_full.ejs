		function odbVisualIconHtml() {
			return '<span class="diag-odb-splitter-icon" aria-hidden="true"><svg viewBox="0 0 36 42" focusable="false"><defs><linearGradient id="diagOdbBox" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#f8fafc"></stop><stop offset="1" stop-color="#dbe3ee"></stop></linearGradient></defs><rect x="10" y="4" width="16" height="27" rx="4" fill="url(#diagOdbBox)" stroke="currentColor" stroke-width="1.4"></rect><rect x="8.6" y="9" width="2" height="6" rx=".8" fill="#cbd5e1" stroke="currentColor" stroke-width=".55"></rect><rect x="25.4" y="9" width="2" height="6" rx=".8" fill="#cbd5e1" stroke="currentColor" stroke-width=".55"></rect><rect x="8.6" y="22" width="2" height="6" rx=".8" fill="#cbd5e1" stroke="currentColor" stroke-width=".55"></rect><rect x="25.4" y="22" width="2" height="6" rx=".8" fill="#cbd5e1" stroke="currentColor" stroke-width=".55"></rect><path d="M14 21h8M14 24h8" stroke="#94a3b8" stroke-width="1.3" stroke-linecap="round"></path><path d="M18 31v8" stroke="#0064c8" stroke-width="2.5" stroke-linecap="round"></path><path d="M15.2 16.5h5.6l-2.8-6.2z" fill="none" stroke="#64748b" stroke-width="1.1" stroke-linejoin="round"></path><path d="M18 12.6v2.5M16.8 15.6h2.4" stroke="#64748b" stroke-width="1" stroke-linecap="round"></path></svg></span>';
		}

		function splitterBadgeHtml(data, total) {
				var editUrl = '/odbs/edit/' + encodeURIComponent(data.id) + '?from=diagnostics';
				if (total) {
					return '<a class="diag-odb-size" href="' + editUrl + '" target="_blank">1:' + diagEscape(total) + ' ' + "PLC splitter" + '</a>';
				}
			return '<div class="diag-odb-splitter-block">' +
				'<a class="diag-odb-size warning" href="' + editUrl + '" target="_blank">1:&infin; ' + "PLC splitter" + '</a>' +
				'<a class="diag-odb-alert" href="' + editUrl + '" target="_blank"><i class="fa fa-exclamation-triangle"></i> ' + diagEscape(diagLang.number_of_ports_not_set) + ' <i class="fa fa-pencil"></i></a>' +
			'</div>';
