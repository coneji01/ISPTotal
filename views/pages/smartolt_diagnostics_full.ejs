			});

				$(document).off('click.diagOdbAssignCancel', '.diag-odb-assign-cancel').on('click.diagOdbAssignCancel', '.diag-odb-assign-cancel', function(event) {
					event.preventDefault();
					var $row = $(this).closest('.diag-odb-port-assign-row');
					var $select = $row.find('.diag-odb-assign-port-select');
					var currentPort = $select.data('current-port');
					$select.val(currentPort ? String(currentPort) : '');
					$row.find('.diag-odb-assign-port-btn').prop('disabled', true);
					if ($row.hasClass('diag-odb-reassign-row')) {
						$row.removeClass('is-visible');
					}
				});

			$(document).off('change.diagOdbAssignPort', '.diag-odb-assign-port-select').on('change.diagOdbAssignPort', '.diag-odb-assign-port-select', function() {
				var $select = $(this);
				var $row = $select.closest('.diag-odb-port-assign-row');
				var currentPort = parseInt($select.data('current-port'), 10) || 0;
				var selectedPort = parseInt($select.val(), 10) || 0;
				var changed = currentPort ? selectedPort && selectedPort !== currentPort : !!selectedPort;
				$row.find('.diag-odb-assign-port-btn').prop('disabled', !changed);
			});

		$(document).off('click.diagOdbAssignPort', '.diag-odb-assign-port-btn').on('click.diagOdbAssignPort', '.diag-odb-assign-port-btn', function(event) {
			event.preventDefault();
			var $btn = $(this);
			var $modal = ensureDiagOdbDetailModal();
			var data = $modal.data('odb-data');
			if (!data || !data.id) {
				return;
			}
				var $row = $btn.closest('.diag-odb-port-assign-row');
				var port = $row.find('.diag-odb-assign-port-select').val();
				var onuId = $btn.data('onu-id');
			if (!port || !onuId) {
				return;
			}
			$btn.prop('disabled', true).text(diagLang.saving);
			$.ajax({
				type: 'POST',
				url: '/odbs/attach_onu_to_port/' + encodeURIComponent(data.id),
				dataType: 'json',
				data: { onu_id: onuId, odb_port: port },
				beforeSend: diagAjaxHeaders
			}).done(function(resp) {
				if (resp && resp.success) {
					refreshDiagOdbAfterAssign(data.id, port);
					return;
					}
					$.MessageBox((resp && resp.message) ? resp.message : diagLang.could_not_assign_onu);
					$btn.prop('disabled', false).text($btn.data('label') || diagAssignLabel);
				}).fail(function() {
					$.MessageBox(diagLang.could_not_assign_onu);
					$btn.prop('disabled', false).text($btn.data('label') || diagAssignLabel);
				});
		});

		$(document).off('click.diagOdbUsageFilter', '.diag-odb-usage-filter').on('click.diagOdbUsageFilter', '.diag-odb-usage-filter', function(event) {
			event.preventDefault();
			event.stopPropagation();
			var $link = $(this);
			var filterType = $link.data('filter-type');
			var filterValue = $link.data('filter-value');
			var odbId = $link.data('odb-id');
			if (!filterType || !filterValue || !odbId || typeof form_data === 'undefined') {
				return;
			}
			form_data.odb_id = String(odbId);
			form_data.page = 1;
			if (filterType === 'status') {
				form_data.status = String(filterValue);
				form_data.signal = '';
				$('.status-filter, .signal-filter').removeClass('active');
				String(filterValue).split(',').forEach(function(value) {
					$('.status-filter[value="' + value + '"]').addClass('active');
				});
			} else if (filterType === 'signal') {
				form_data.signal = String(filterValue);
				form_data.status = '';
				$('.status-filter, .signal-filter').removeClass('active');
				$('.signal-filter[value="' + filterValue + '"]').addClass('active');
			}
			diagOdbPopover().hide();
			$('#diag-odb-detail-modal').modal('hide');
			refreshUrlParameters(form_data, 'refreshDiagnosticsData');
		});

		$(document).off('click.diagOdbClose', '.diag-odb-close').on('click.diagOdbClose', '.diag-odb-close', function(event) {
			event.preventDefault();
			diagOdbPopover().hide();
		});

		$(document).off('click.diagOdbOutside').on('click.diagOdbOutside', function(event) {
			if (!$(event.target).closest('#diag-odb-popover, .diag-odb-link').length) {
				diagOdbPopover().hide();
			}
		});

		
	$("ul.pagination a").on('click', function (event) {
		event.preventDefault();

		var page = $(this).data('ci-pagination-page');

		if (typeof(page) !== 'undefined') {
			form_data['page'] =  page;

			refreshUrlParameters(form_data, 'refreshDiagnosticsData');
		}
	});

});
</script>
