function monToggleAlertaLog(){
    var el=document.getElementById('monAlertaLogList');
    var chev=document.getElementById('monAlertaLogChev');
    if(el.style.display==='none'){
        el.style.display='block';chev.style.transform='rotate(180deg)';
        monLoadAlertaLog();
    }else{el.style.display='none';chev.style.transform='rotate(0deg)';}
}

function monLoadAlertaLog(){
    monApi('get_alerta_log').then(function(d){
        var el=document.getElementById('monAlertaLogList');
        if(!d.success||!d.logs||d.logs.length===0){
            el.innerHTML='<div style="font-size:0.75rem;color:#94a3b8;padding:8px;text-align:center;">Sin alertas enviadas</div>';return;
        }
        var h='';
        d.logs.forEach(function(l){
            var isCorte=l.tipo==='corte';
            var bg=isCorte?'#fef2f2':'#f0fdf4';
            var color=isCorte?'#991b1b':'#166534';
            var icon=isCorte?'fa-times-circle':'fa-check-circle';
            var dt=new Date(l.created_at);
            var time=dt.toLocaleDateString('es-DO',{day:'2-digit',month:'short'})+' '+dt.toLocaleTimeString('es-DO',{hour:'2-digit',minute:'2-digit'});
            h+='<div style="padding:5px 8px;margin-bottom:3px;border-radius:4px;background:'+bg+';font-size:0.72rem;color:'+color+';">';
            h+='<i class="fas '+icon+'"></i> ';
            h+='<strong>'+(l.target_nombre||'?')+'</strong> ';
            h+='<span style="float:right;opacity:0.7;">'+time+'</span>';
            h+='</div>';
        });
        el.innerHTML=h;
    });
}

// ===== LIVE TRAFFIC MONITOR =====
var _monLiveTimer = null;
var _monLiveIfaceId = 0;
var _monLivePrev = null;
var _monLiveChart = null;
var _monLiveData = {labels:[], bpsIn:[], bpsOut:[]};
var _monLiveMaxPoints = 60;
var _monLiveEma = {in:0, out:0, samples:0};

function monLiveStart(ifaceId, ifName, eqName) {
    _monLiveIfaceId = ifaceId;
    _monLivePrev = null;
    _monLiveData = {labels:[], bpsIn:[], bpsOut:[]};
    _monLiveEma = {in:0, out:0, samples:0};
    if (_monLiveChart) { try{_monLiveChart.destroy();}catch(e){} _monLiveChart=null; }

    document.getElementById('monLiveTitle').textContent = ifName + ' - ' + eqName;
    document.getElementById('monLiveIn').textContent = '-- Mbps';
    document.getElementById('monLiveOut').textContent = '-- Mbps';
    document.getElementById('monLiveStatus').textContent = 'Conectando...';
    document.getElementById('monLiveStatus').style.color = '#f59e0b';
    document.getElementById('monLiveModal').style.display = 'flex';

    var ctx = document.getElementById('monLiveCanvas');
    _monLiveChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [
                {label:'IN', data:[], borderColor:'#2563eb', backgroundColor:'rgba(37,99,235,0.1)', fill:true, tension:0.3, pointRadius:0, borderWidth:2},
                {label:'OUT', data:[], borderColor:'#10b981', backgroundColor:'rgba(16,185,129,0.1)', fill:true, tension:0.3, pointRadius:0, borderWidth:2}
            ]
        },
        options: {
            responsive:true, maintainAspectRatio:false,
            animation:{duration:0},
            interaction:{intersect:false, mode:'index'},
            plugins:{legend:{labels:{font:{size:10},boxWidth:12,padding:8}}},
            scales:{
                x:{display:true, ticks:{maxTicksLimit:8, font:{size:9}, callback:function(v,i){return _monLiveData.labels[i]||'';}}},
                y:{beginAtZero:true, title:{display:true, text:'Mbps', font:{size:10}}, ticks:{font:{size:9}}}
            }
        }
    });

    monLivePoll();
    _monLiveTimer = setInterval(monLivePoll, 3000);
}

function monLivePoll() {
    monApi('snmp_live', {iface_id: _monLiveIfaceId}).then(function(d) {
        if (!d.success) {
            document.getElementById('monLiveStatus').textContent = 'Error: ' + (d.msg||'');
            document.getElementById('monLiveStatus').style.color = '#ef4444';
            return;
        }
        document.getElementById('monLiveStatus').textContent = 'En vivo';
        document.getElementById('monLiveStatus').style.color = '#10b981';

        var now = d.ts;
        var bytesIn = parseFloat(d.bps_in);
        var bytesOut = parseFloat(d.bps_out);

        if (_monLivePrev) {
            var dt = now - _monLivePrev.ts;
            if (dt >= 1.5) {
                var diffIn = bytesIn - _monLivePrev.bytesIn;
                var diffOut = bytesOut - _monLivePrev.bytesOut;

                if (diffIn < 0 || diffOut < 0) {
                    _monLivePrev = {ts: now, bytesIn: bytesIn, bytesOut: bytesOut};
                    return;
                }

                var rawBpsIn = (diffIn * 8) / dt;
                var rawBpsOut = (diffOut * 8) / dt;
                var rawMbpsIn = rawBpsIn / 1e6;
                var rawMbpsOut = rawBpsOut / 1e6;

                if (_monLiveEma.samples >= 3) {
                    var avgIn = _monLiveEma.in;
                    var avgOut = _monLiveEma.out;
                    var threshold = 5;
                    if (avgIn > 1 && rawMbpsIn > avgIn * threshold) { _monLivePrev = {ts: now, bytesIn: bytesIn, bytesOut: bytesOut}; return; }
                    if (avgOut > 1 && rawMbpsOut > avgOut * threshold) { _monLivePrev = {ts: now, bytesIn: bytesIn, bytesOut: bytesOut}; return; }
                }

                var alpha = 0.3;
                var mbpsIn, mbpsOut;
                if (_monLiveEma.samples === 0) { mbpsIn = rawMbpsIn; mbpsOut = rawMbpsOut; }
                else { mbpsIn = alpha * rawMbpsIn + (1 - alpha) * _monLiveEma.in; mbpsOut = alpha * rawMbpsOut + (1 - alpha) * _monLiveEma.out; }
                _monLiveEma.in = mbpsIn; _monLiveEma.out = mbpsOut; _monLiveEma.samples++;

                if (mbpsIn >= 1000) { document.getElementById('monLiveIn').textContent = (mbpsIn/1000).toFixed(2) + ' Gbps'; }
                else { document.getElementById('monLiveIn').textContent = mbpsIn.toFixed(2) + ' Mbps'; }
                if (mbpsOut >= 1000) { document.getElementById('monLiveOut').textContent = (mbpsOut/1000).toFixed(2) + ' Gbps'; }
                else { document.getElementById('monLiveOut').textContent = mbpsOut.toFixed(2) + ' Mbps'; }

                var timeLabel = new Date().toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
                _monLiveData.labels.push(timeLabel);
                _monLiveData.bpsIn.push(mbpsIn);
                _monLiveData.bpsOut.push(mbpsOut);

                if (_monLiveData.labels.length > _monLiveMaxPoints) {
                    _monLiveData.labels.shift(); _monLiveData.bpsIn.shift(); _monLiveData.bpsOut.shift();
                }

                _monLiveChart.data.labels = _monLiveData.labels;
                _monLiveChart.data.datasets[0].data = _monLiveData.bpsIn;
                _monLiveChart.data.datasets[1].data = _monLiveData.bpsOut;
                _monLiveChart.update('none');
            }
        }
        _monLivePrev = {ts: now, bytesIn: bytesIn, bytesOut: bytesOut};
    }).catch(function(e) {
        document.getElementById('monLiveStatus').textContent = 'Error de red';
        document.getElementById('monLiveStatus').style.color = '#ef4444';
    });
}

function monLiveStop() {
    if (_monLiveTimer) { clearInterval(_monLiveTimer); _monLiveTimer = null; }
    _monLivePrev = null; _monLiveIfaceId = 0;
    document.getElementById('monLiveModal').style.display = 'none';
    if (_monLiveChart) { try{_monLiveChart.destroy();}catch(e){} _monLiveChart=null; }
}

