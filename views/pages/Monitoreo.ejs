        r.style.display='block';
        if(d.success){
            r.style.background='#f0fdf4';r.style.border='1px solid #bbf7d0';r.style.color='#166534';
            r.innerHTML='<i class="fas fa-check-circle"></i> '+monEsc(d.msg);
        }else{
            r.style.background='#fef2f2';r.style.border='1px solid #fecaca';r.style.color='#991b1b';
            r.innerHTML='<i class="fas fa-times-circle"></i> '+monEsc(d.msg);
