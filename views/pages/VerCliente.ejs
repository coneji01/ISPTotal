    // ==================================================================
    // SYS DIALOG
    // ==================================================================
    var _sysDialogResolve = null;

    function sysAlert(msg, type) {
        var icons = { success: '<i class="fas fa-check-circle" style="color:#16a34a;"></i>', error: '<i class="fas fa-times-circle" style="color:#dc2626;"></i>', warning: '<i class="fas fa-exclamation-triangle" style="color:#d97706;"></i>', info: '<i class="fas fa-info-circle" style="color:var(--accent-primary);"></i>' };
        var titles = { success: 'Exitoso', error: 'Error', warning: 'Atención', info: 'Información' };
        var colors = { success: '#166534', error: '#991b1b', warning: '#92400e', info: '#1e40af' };
        var t = type || 'info';
        document.getElementById('sysDialogIcon').innerHTML = icons[t] || icons.info;
        document.getElementById('sysDialogTitle').textContent = titles[t] || 'Aviso';
        document.getElementById('sysDialogTitle').style.color = colors[t] || '#1e293b';
        document.getElementById('sysDialogMsg').innerHTML = msg;
        document.getElementById('sysDialogBtns').innerHTML = '<button class="btn-save" style="background:' + (colors[t] || 'var(--accent-primary)') + '; min-width:80px;" onclick="closeSysDialog()">Aceptar</button>';
        document.getElementById('sysDialog').style.display = 'flex';
    }

    function closeSysDialog() {
        document.getElementById('sysDialog').style.display = 'none';
        if (_sysDialogResolve) { _sysDialogResolve(true); _sysDialogResolve = null; }
    }

    function nsOnTipoChange() {
      var tipo = document.getElementById('nsTipoServicio').value;
      document.getElementById('nsInternetFields').style.display = tipo === 'internet' ? 'block' : 'none';
      document.getElementById('nsNetflixFields').style.display = tipo === 'netflix' ? 'block' : 'none';
      document.getElementById('ns247Fields').style.display = tipo === 'servicio_247' ? 'block' : 'none';
    }

    // ==================================================================
    // NUEVO SERVICIO (funciones originales)
    // ==================================================================
    let nsRoutersCache = [];
    let nsPlansCache = [];

    function openNuevoServicio() {
      document.getElementById('modalNuevoSrv').style.display = 'flex';
      nsOnTipoChange();
      loadNsRouters();
      loadNsPlans();
    }

    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    function loadNsRouters() {
      fetch('/api/routers')
        .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(function(routers) {
          nsRoutersCache = Array.isArray(routers) ? routers : [];
          const sel = document.getElementById('nsRouter');
          sel.innerHTML = '<option value="">-- Seleccionar --</option>';
          nsRoutersCache.forEach(function(r) {
            const auth = r.auth_type || 'dhcp';
            sel.innerHTML += '<option value="' + r.id + '" data-auth="' + auth.toLowerCase() + '">' + r.name + '</option>';
          });
          if (nsRoutersCache.length > 0) {
            sel.value = nsRoutersCache[0].id;
            nsOnRouterChange();
          }
        })
        .catch(function(e) { nsRoutersCache = []; });
    }

    function loadNsPlans() {
      fetch('/api/planes')
        .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(function(planes) {
          nsPlansCache = Array.isArray(planes) ? planes : (planes.data || []);
        })
        .catch(function(e) { nsPlansCache = []; });
    }

    function nsUpdateZonaRouter() {}

    function nsUpdatePlans() {
      const zonaId = document.getElementById('nsZona').value;
      const sel = document.getElementById('nsPlan');
      if (!zonaId) { sel.innerHTML = '<option value="">-- Seleccionar zona --</option>'; return; }
      sel.innerHTML = '<option value="">-- Seleccionar plan --</option>';
      nsPlansCache.forEach(function(p) {
        sel.innerHTML += '<option value="' + p.id + '">' + (p.nombre || p.name) + (p.velocidad ? ' - ' + p.velocidad : '') + '</option>';
      });
    }

    function nsOnRouterChange() {
      const sel = document.getElementById('nsRouter');
      const opt = sel.options[sel.selectedIndex];
      const authType = opt ? (opt.dataset.auth || 'dhcp') : 'dhcp';
      const metodo = document.getElementById('nsMetodo');
      if (authType === 'pppoe') metodo.value = 'pppoe';
      else metodo.value = 'dhcp';
      nsOnMetodoChange();
      nsLoadPools();
    }

    function nsOnMetodoChange() {
      var metodo = document.getElementById('nsMetodo').value;
      var pppoeFields = document.getElementById('nsPppoeFields');
      var staticFields = document.getElementById('nsStaticFields');
      pppoeFields.style.display = 'none';
      staticFields.style.display = 'none';
      if (metodo === 'pppoe') { pppoeFields.style.display = 'grid'; }
      if (metodo === 'static') { staticFields.style.display = 'grid'; }
    }

    function nsLoadPools() {
      const routerId = document.getElementById('nsRouter').value;
      const poolSel = document.getElementById('nsPool');
      const ipSel = document.getElementById('nsIpSelect');
      if (!routerId) {
        poolSel.innerHTML = '<option value="">-- Seleccionar router --</option>';
        ipSel.innerHTML = '<option value="">-- Seleccionar pool --</option>';
        return;
      }
      poolSel.innerHTML = '<option value="">Cargando rangos...</option>';
      fetch('/api/ip-pools/' + routerId)
        .then(function(r) { return r.json(); })
        .then(function(pools) {
          if (pools && pools.length > 0) {
            poolSel.innerHTML = '<option value="">-- Seleccionar rango --</option>';
            pools.forEach(function(p) {
              poolSel.innerHTML += '<option value="' + p.id + '">' + p.red + ' (' + (p.disponibles||0) + ' disp)</option>';
            });
            var first = pools.find(function(p) { return (p.disponibles || 0) > 0; });
            if (first) { poolSel.value = first.id; nsOnPoolChange(); }
          } else {
            poolSel.innerHTML = '<option value="">-- Sin rangos --</option>';
          }
        });
    }

    function nsOnPoolChange() {
      const poolId = document.getElementById('nsPool').value;
      const ipSel = document.getElementById('nsIpSelect');
      if (!poolId) { ipSel.innerHTML = '<option value="">-- Seleccionar --</option>'; return; }
      ipSel.innerHTML = '<option value="">Cargando IPs...</option>';
      fetch('/api/ip-pools/' + poolId + '/disponibles')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success && data.disponibles && data.disponibles.length > 0) {
            ipSel.innerHTML = '<option value="">-- Seleccionar IP --</option>';
            data.disponibles.forEach(function(ip) {
              ipSel.innerHTML += '<option value="' + ip + '">' + ip + '</option>';
            });
            ipSel.value = data.disponibles[0];
          } else {
            ipSel.innerHTML = '<option value="">No hay IPs disponibles</option>';
          }
        });
    }

    function nsOnCicloChange() {
      var sel = document.getElementById('nsCiclo');
      var val = sel.value;
      var info = document.getElementById('nsCicloInfo');
      var custom = document.getElementById('nsCicloCustom');
      if (val === 'custom') { info.style.display = 'none'; custom.style.display = 'block'; }
      else if (val) { custom.style.display = 'none'; info.style.display = 'block'; }
      else { info.style.display = 'none'; custom.style.display = 'none'; }
    }

    function nsGenerateCredentials() {
      var nombre = '<%= (cliente.nombre || "").replace(/'/g, "\\'") %>';
      if (nombre) {
        var parts = nombre.trim().split(/\s+/);
        var user = parts.map(function(p) { return p.charAt(0).toUpperCase() + p.slice(1).toLowerCase(); }).join('').replace(/[^a-zA-Z0-9]/g, '');
        document.getElementById('nsPppoeUser').value = user;
      }
      document.getElementById('nsPppoePass').value = '1320';
    }

    function esGenerateCredentials() {
      var nombre = '<%= (cliente.nombre || "").replace(/'/g, "\\'") %>';
      if (nombre) {
        var parts = nombre.trim().split(/\s+/);
        var user = parts.map(function(p) { return p.charAt(0).toUpperCase() + p.slice(1).toLowerCase(); }).join('').replace(/[^a-zA-Z0-9]/g, '');
        document.getElementById('esPppoeUser').value = user;
      }
      document.getElementById('esPppoePass').value = '1320';
    }

    function nsGuardar() {
      const routerId = document.getElementById('nsRouter').value;
      const metodo = document.getElementById('nsMetodo').value;
      var data = {
        cliente_id: <%= cliente.id %>,
        plan_id: parseInt(document.getElementById('nsPlan').value) || 0,
        zona_id: parseInt(document.getElementById('nsZona').value) || 0,
        router_id: routerId,
        auth_type: metodo,
        direccion: document.getElementById('nsAddress').value,
        observaciones: document.getElementById('nsObs').value
      };
      if (metodo === 'dhcp' || metodo === 'pppoe' || metodo === 'static') {
        data.ip = document.getElementById('nsIpSelect').value;
        data.pool = document.getElementById('nsPool').value;
      }
      if (metodo === 'pppoe') {
        data.pppoe_user = document.getElementById('nsPppoeUser').value;
        data.pppoe_pass = document.getElementById('nsPppoePass').value;
      }
      data.wifi_ssid = document.getElementById('nsWifiSsid') ? document.getElementById('nsWifiSsid').value : '';
      data.wifi_pass = document.getElementById('nsWifiPass') ? document.getElementById('nsWifiPass').value : '';
      
      var nsCicloVal = document.getElementById('nsCiclo') ? document.getElementById('nsCiclo').value : '';
      data.ciclo_id = nsCicloVal && nsCicloVal !== '' && nsCicloVal !== 'custom' ? parseInt(nsCicloVal) : null;
      
      fetch('/api/servicios/crear', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.success) {
          showToast('Servicio creado');
          closeModal('modalNuevoSrv');
          setTimeout(function() { location.reload(); }, 1000);
        } else {
          showToast('Error: ' + (res.error || res.message || 'desconocido'), 'error');
        }
      })
      .catch(function(e) {
        showToast('Error de conexión: ' + e.message, 'error');
      });
    }

    // ==================================================================
    // MODAL CLOSE ON OUTER CLICK
    // ==================================================================
    window.onclick = function(e) {
        var overlays = document.querySelectorAll('.modal-overlay, .cli-modal-overlay');
        overlays.forEach(function(el) {
            if (e.target === el) el.style.display = 'none';
        });
    };

    // ==================================================================
    // EDITAR SERVICIO (es*) — Reutiliza el modal editSrv
    // ==================================================================
    var _editSrvId = null;

    function openEditSrvModal(srvId) {
      _editSrvId = srvId;
      document.getElementById('editSrvModalId').textContent = srvId;
      openModal('modalEditSrv');
      
      // Show loading in relevant fields
      var planSel = document.getElementById('esPlan');
      planSel.innerHTML = '<option value="">Cargando planes...</option>';
      var routerSel = document.getElementById('esRouter');
      routerSel.innerHTML = '<option value="">Cargando routers...</option>';
      
      // Load service data via AJAX
      fetch('/api/servicios/' + srvId)
        .then(function(r) { return r.json(); })
        .then(function(resp) {
          if (!resp.success || !resp.data) {
            showToast('Error cargando datos del servicio', 'error');
            return;
          }
          var d = resp.data;
          
          // 1. Set simple fields first (all at once)
          document.getElementById('esTipoServicio').value = d.tipo_servicio || 'internet';
          esOnTipoChange();
          
          document.getElementById('esMetodo').value = d.auth_type || 'dhcp';
          esOnMetodoChange();
          
          document.getElementById('esPppoeUser').value = d.pppoe_user || '';
          document.getElementById('esPppoePass').value = d.pppoe_pass || '';
          document.getElementById('esIp').value = d.ip || '';
          document.getElementById('esWifiSsid').value = d.wifi_ssid || '';
          document.getElementById('esWifiPass').value = d.wifi_pass || '';
          document.getElementById('esAddress').value = d.direccion || '';
          document.getElementById('esObs').value = d.observaciones || '';
          
          document.getElementById('esNfEmail').value = d.netflix_email || '';
          document.getElementById('esNfPassword').value = d.netflix_password || '';
          document.getElementById('esNfPerfil').value = d.netflix_perfil || '';
          document.getElementById('esNfVencimiento').value = d.netflix_vencimiento || '';
          
          document.getElementById('es247Desc').value = d.descripcion_servicio || '';
          document.getElementById('es247Precio').value = d.precio_servicio || '';
          
          if (d.ciclo_id) document.getElementById('esCiclo').value = d.ciclo_id;
          
          // 2. Set zona (options are static from EJS, always available)
          if (d.zona_id) {
            document.getElementById('esZona').value = d.zona_id;
          }
          
          // 3. Load plans and routers from API, then set plan/router values
          esUpdatePlans(function() {
            if (d.plan_id) document.getElementById('esPlan').value = d.plan_id;
          });
          esUpdateZonaRouter(function() {
            if (d.router_id) document.getElementById('esRouter').value = d.router_id;
          });
        })
        .catch(function(e) {
          showToast('Error de conexión: ' + e.message, 'error');
        });
    }

    function esOnTipoChange() {
      var t = document.getElementById('esTipoServicio').value;
      document.getElementById('esInternetFields').style.display = (t === 'internet') ? '' : 'none';
      document.getElementById('esNetflixFields').style.display = (t === 'netflix') ? '' : 'none';
      document.getElementById('es247Fields').style.display = (t === 'servicio_247') ? '' : 'none';
    }

    function esUpdatePlans(callback) {
      var zonaId = document.getElementById('esZona').value;
      var planSel = document.getElementById('esPlan');
      planSel.innerHTML = '<option value="">-- Seleccionar --</option>';
      if (!zonaId) { if (callback) callback(); return; }
      fetch('/api/planes')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var list = Array.isArray(data) ? data : (data.planes || []);
          list.forEach(function(p) {
            var opt = document.createElement('option');
            opt.value = p.id;
            opt.textContent = (p.nombre || p.name) + ' - $' + (parseFloat(p.precio) || 0).toFixed(2);
            planSel.appendChild(opt);
          });
          if (callback) callback();
        })
        .catch(function(e) {
          console.log('esUpdatePlans error:', e);
          if (callback) callback();
        });
    }

    function esUpdateZonaRouter(callback) {
      var zonaId = document.getElementById('esZona').value;
      var routerSel = document.getElementById('esRouter');
      routerSel.innerHTML = '<option value="">-- Seleccionar --</option>';
      if (!zonaId) { if (callback) callback(); return; }
      fetch('/api/routers')
        .then(function(r) { return r.json(); })
        .then(function(d) {
          // /api/routers returns array directly
          var list = Array.isArray(d) ? d : (d.routers || []);
          list.forEach(function(r) {
            var opt = document.createElement('option');
            opt.value = r.id;
            opt.textContent = (r.name || r.nombre) + ' (' + (r.ip || '') + ')';
            routerSel.appendChild(opt);
          });
          if (callback) callback();
        })
        .catch(function() {
          if (callback) callback();
        });
    }

    function esOnRouterChange() {}

    function esOnMetodoChange() {
      var m = document.getElementById('esMetodo').value;
      document.getElementById('esPppoeFields').style.display = (m === 'pppoe') ? '' : 'none';
    }

    function esGuardar() {
      if (!_editSrvId) return;
      var btn = document.getElementById('btnGuardarES');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
      
      var metodo = document.getElementById('esMetodo').value;
      var data = {
        id: _editSrvId,
        plan_id: parseInt(document.getElementById('esPlan').value) || null,
        auth_type: metodo,
        ip: document.getElementById('esIp').value,
        pppoe_user: document.getElementById('esPppoeUser').value,
        pppoe_pass: document.getElementById('esPppoePass').value,
        wifi_ssid: document.getElementById('esWifiSsid').value,
        wifi_pass: document.getElementById('esWifiPass').value,
        direccion: document.getElementById('esAddress').value,
        tipo_servicio: document.getElementById('esTipoServicio').value,
        ciclo_id: parseInt(document.getElementById('esCiclo').value) || null,
        netflix_email: document.getElementById('esNfEmail').value,
        netflix_password: document.getElementById('esNfPassword').value,
        netflix_perfil: document.getElementById('esNfPerfil').value,
        netflix_vencimiento: document.getElementById('esNfVencimiento').value,
        descripcion_servicio: document.getElementById('es247Desc').value,
        precio_servicio: parseFloat(document.getElementById('es247Precio').value) || 0
      };
      
      fetch('/api/servicios/editar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
        if (res.success) {
          showToast('Servicio actualizado ✅ (WiFi/WAN enviado a ONU)');
          closeModal('modalEditSrv');
          setTimeout(function() { location.reload(); }, 1200);
        } else {
          showToast('Error: ' + (res.message || 'desconocido'), 'error');
        }
      })
      .catch(function(e) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
        showToast('Error de conexión: ' + e.message, 'error');
      });
    }
function enviarTR069(servicioId) {
