<script>
    // ==================================================================
    // DATA
    // ==================================================================
    const clientId = <%= cliente.id %>;
    const clientName = '<%= cliente.nombre.replace(/'/g, "\\'") %>';
    const _vcp = { editar_datos: true, crear_factura: true, pagar_factura: true, editar_factura: true, anular_factura: true, eliminar_factura: true };

    // ==================================================================
    // TOAST
    // ==================================================================
    function showToast(msg, type, duration) {
        type = type || 'info';
        duration = duration || 4000;
        var container = document.getElementById('toastContainer');
        if (!container) {
            container = document.createElement('div');
            container.className = 'toast-container';
            container.id = 'toastContainer';
            document.body.appendChild(container);
        }
        var icons = { success: 'fa-check-circle', error: 'fa-times-circle', warning: 'fa-exclamation-triangle', info: 'fa-info-circle' };
        var toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.innerHTML = '<i class="fas ' + (icons[type] || icons.info) + '"></i><span class="toast-msg">' + msg + '</span><span class="toast-close" onclick="this.parentElement.classList.add(\'removing\');setTimeout(function(){toast.remove()},300)">&times;</span>';
        container.appendChild(toast);
        setTimeout(function() { toast.classList.add('removing'); setTimeout(function() { toast.remove(); }, 300); }, duration);
    }

    // ==================================================================
    // TABS
    // ==================================================================
    function showTab(tab, btn) {
        // Remover active de todos los items del menu y tabs
        document.querySelectorAll('.p-item').forEach(function(i) { i.classList.remove('active'); });
        document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
        // Activar el tab clickeado
        if (btn) btn.classList.add('active');
        var el = document.getElementById('tab-' + tab);
        if (el) {
            el.classList.add('active');
            console.log('[Tab] Activado:', tab);
        } else {
            console.warn('[Tab] No encontrado: tab-' + tab);
        }
        // Cargar contenido dinamico si aplica
        if (tab === 'facturas') loadInvoices();
        if (tab === 'mensajeria') loadMessages(1);
    }

    // ==================================================================
    // SERVICE CARD TOGGLE
    // ==================================================================
    function toggleSvcDetail(id) {
        document.getElementById('svcCard_' + id).classList.toggle('open');
        document.getElementById('svcDetailBox_' + id).classList.toggle('open');
    }

    // ==================================================================
    // SERVICE ACTIONS (Confirm)
    // ==================================================================
    function confirmAction(tipo, id) {
        var title = document.getElementById('confirmTitle');
        var msg = document.getElementById('confirmMsg');
        var btn = document.getElementById('confBtnSubmit');
        document.getElementById('confActInput').value = tipo + '_servicio';
        document.getElementById('confSrvIdInput').value = id;
        
        // Store tipo for the submit handler
        document.getElementById('formConfirmAction').dataset.tipo = tipo;
        document.getElementById('formConfirmAction').dataset.srvId = id;

        if (tipo === 'suspender') {
            title.innerText = 'Suspender';
            title.style.color = '#d97706';
            msg.innerHTML = '¿Seguro que desea SUSPENDER este servicio?';
            btn.style.background = '#d97706';
            btn.innerHTML = '<i class="fas fa-pause"></i> Suspender';
        } else if (tipo === 'activar') {
            title.innerText = 'Reactivar';
            title.style.color = '#166534';
            msg.innerHTML = '¿Seguro que desea REACTIVAR este servicio?';
            btn.style.background = '#166534';
            btn.innerHTML = '<i class="fas fa-play"></i> Reactivar';
        } else if (tipo === 'eliminar') {
            title.innerText = 'Eliminar Servicio';
            title.style.color = '#991b1b';
            msg.innerHTML = '⚠️ ATENCIÓN: Se eliminará todo registro del servicio, facturas, pagos, ONU y el secreto PPPoE del MikroTik. La IP quedará liberada.<br><br><strong>¿Estás seguro?</strong>';
            btn.style.background = '#991b1b';
            btn.innerHTML = '<i class="fas fa-trash"></i> Eliminar permanentemente';
        }
        document.getElementById('modalConfirm').style.display = 'flex';
    }

    // Handle confirm form submit via fetch (for all actions)
    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('formConfirmAction').addEventListener('submit', function(e) {
            e.preventDefault();
            var tipo = this.dataset.tipo;
            var srvId = this.dataset.srvId;
            var btn = document.getElementById('confBtnSubmit');
            btn.disabled = true;
            
            var endpoint = '';
            if (tipo === 'eliminar') {
                endpoint = '/api/servicios/' + srvId + '/eliminar';
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Eliminando...';
            } else if (tipo === 'suspender') {
                endpoint = '/api/servicios/' + srvId + '/suspender';
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Suspendiendo...';
            } else if (tipo === 'activar') {
                endpoint = '/api/servicios/' + srvId + '/suspender';
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Reactivando...';
            }
            
            if (endpoint) {
                fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({})
                })
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    if (d.success) {
                        document.getElementById('modalConfirm').style.display = 'none';
                        location.reload();
                    } else {
                        alert('Error: ' + (d.message || d.error || 'desconocido'));
                        btn.disabled = false;
                        btn.innerHTML = tipo === 'eliminar' 
                            ? '<i class="fas fa-trash"></i> Eliminar permanentemente'
                            : (tipo === 'suspender' 
                                ? '<i class="fas fa-pause"></i> Suspender'
                                : '<i class="fas fa-play"></i> Reactivar');
                    }
                })
                .catch(function(e) {
                    alert('Error de conexión: ' + e.message);
                    btn.disabled = false;
                    btn.innerHTML = tipo === 'eliminar' 
                        ? '<i class="fas fa-trash"></i> Eliminar permanentemente'
                        : (tipo === 'suspender' 
                            ? '<i class="fas fa-pause"></i> Suspender'
                            : '<i class="fas fa-play"></i> Reactivar');
                });
            }
        });
    });

    function openRetireModal(id) {
        document.getElementById('idRetiro').value = id;
        document.getElementById('retiroResult').style.display = 'none';
        document.getElementById('motivoRetiro').value = '';
        document.getElementById('modalRetiro').style.display = 'flex';
    }

    function ejecutarRetiro(e) {
        e.preventDefault();
        var srvId = document.getElementById('idRetiro').value;
        var motivo = document.getElementById('motivoRetiro').value.trim();
        if (!srvId) { alert('Error: ID de servicio no encontrado'); return false; }
        if (!motivo) { alert('Debe especificar un motivo de retiro'); return false; }
        if (!confirm('¿Está seguro de retirar este servicio?\n\nMotivo: ' + motivo)) return false;

        var btn = document.getElementById('btnRetiroSubmit');
        var resultDiv = document.getElementById('retiroResult');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Retirando...';
        resultDiv.style.display = 'none';

        fetch('/api/servicios/' + srvId + '/retirar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ motivo: motivo })
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) {
                resultDiv.style.cssText = 'display:block;margin-bottom:10px;padding:8px 12px;border-radius:6px;font-size:0.85rem;background:#f0fdf4;color:#166534;';
                resultDiv.innerHTML = '<i class="fas fa-check-circle"></i> Servicio retirado correctamente';
                setTimeout(function() {
                    document.getElementById('modalRetiro').style.display = 'none';
                    location.reload();
                }, 1500);
            } else {
                resultDiv.style.cssText = 'display:block;margin-bottom:10px;padding:8px 12px;border-radius:6px;font-size:0.85rem;background:#fef2f2;color:#991b1b;';
                resultDiv.innerHTML = '<i class="fas fa-times-circle"></i> ' + (d.message || 'Error al retirar');
                btn.disabled = false;
                btn.innerHTML = 'Retirar Servicio';
            }
        })
        .catch(function(e) {
            resultDiv.style.cssText = 'display:block;margin-bottom:10px;padding:8px 12px;border-radius:6px;font-size:0.85rem;background:#fef2f2;color:#991b1b;';
            resultDiv.innerHTML = '<i class="fas fa-times-circle"></i> Error de conexión';
            btn.disabled = false;
            btn.innerHTML = 'Retirar Servicio';
        });
        return false;
    }

    // ==================================================================
    // EDITAR CLIENTE (via fetch)
    // ==================================================================
    function editarCliente(e) {
      e.preventDefault();
      var btn = document.getElementById('btnEditCliente');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

      var data = {
        cliente_id: parseInt(document.getElementById('editClienteId').value),
        nombre: document.getElementById('editClienteName').value.trim(),
        cedula: document.getElementById('editClienteCedula').value.trim(),
        telefono: document.getElementById('editClientePhone').value.trim(),
        telefono2: document.getElementById('editClientePhone2').value.trim(),
        direccion: document.getElementById('editClienteAddress').value.trim(),
        apodo: document.getElementById('editClienteAlias').value.trim()
      };

      if (!data.nombre || !data.cliente_id) {
        showToast('Nombre requerido', 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar Datos';
        return;
      }

      fetch('/api/clientes/editar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.success) {
          showToast(d.message, 'success');
          setTimeout(function() { location.reload(); }, 1000);
        } else {
          showToast(d.message || 'Error al guardar', 'error');
        }
      })
      .catch(function(e) {
        showToast('Error de conexión: ' + e.message, 'error');
      })
      .finally(function() {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar Datos';
      });

      return false;
    }

    // ==================================================================
    // GUARDAR SERVICIO (via fetch)
    // ==================================================================
    function guardarServicio(e, srvId, clientId) {
        e.preventDefault();
        var form = document.getElementById('formEditSrv_' + srvId);
        if (!form) return false;
        var fd = new FormData(form);
        fd.append('ajax', 'editar_servicio');

        var btn = form.querySelector('.btn-save');
        if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...'; }

        fetch('/modulo?pagina=VerCliente&id=' + clientId + '&ajax=editar_servicio', {
            method: 'POST',
            body: fd
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.status === 'success') {
                showToast(d.msg || 'Servicio actualizado', 'success');
                setTimeout(function() { location.reload(); }, 1000);
            } else {
                showToast(d.msg || 'Error al guardar', 'error');
                if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-check"></i> Guardar'; }
            }
        })
        .catch(function(err) {
            showToast('Error de conexión: ' + err.message, 'error');
            if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-check"></i> Guardar'; }
        });
        return false;
    }

    // ==================================================================
    // FACTURAS / INVOICES
    // ==================================================================
    function loadInvoices() {
        var list = document.getElementById('invList');
        var content = document.getElementById('invContent');
        var empty = document.getElementById('invEmpty');
        var svcFilter = document.getElementById('invServiceFilter');
        var serviceId = svcFilter ? svcFilter.value : '';

        if (!content) return;
        content.style.display = 'block';
        if (empty) empty.style.display = 'none';
        list.innerHTML = '<div style="padding:20px; text-align:center; color:#94a3b8;"><i class="fas fa-spinner fa-spin"></i> Cargando facturas...</div>';

        var url = '/modulo?pagina=VerCliente&id=' + clientId + '&ajax=get_invoices';
        if (serviceId) url += '&service_id=' + serviceId;

        fetch(url, {credentials: 'same-origin'})
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.status !== 'success') {
                list.innerHTML = '<div style="color:#ef4444; padding:20px; text-align:center;">' + (d.msg || 'Error') + '</div>';
                return;
            }
            if (!d.data || !d.data.length) {
                list.innerHTML = '<div style="padding:30px; text-align:center; color:#94a3b8;"><i class="fas fa-file-invoice" style="font-size:2rem; margin-bottom:10px; display:block; opacity:0.5;"></i>No hay facturas</div>';
                return;
            }
            var html = '<table class="inv-table"><thead><tr><th>#</th><th>Servicio</th><th>Vencimiento</th><th>Total</th><th>Pagado</th><th>Estado</th></tr></thead><tbody>';
            d.data.forEach(function(inv) {
                var total = parseFloat(inv.total || inv.monto || 0);
                var paid = parseFloat(inv.paid_amount || inv.pagado || 0);
                var badge = 'pending';
                var badgeText = 'Pendiente';
                if ((inv.status === 'paid') || total > 0 && paid >= total) { badge = 'paid'; badgeText = 'Pagada'; }
                else if (paid > 0 && paid < total) { badge = 'partial'; badgeText = 'Abonado'; }
                else if (inv.status === 'overdue') { badge = 'overdue'; badgeText = 'Vencida'; }
                var due = inv.due_date || inv.fecha_vencimiento || '-';
                html += '<tr><td style="font-weight:600; color:var(--text-muted);">' + inv.id + '</td>';
                html += '<td>' + (inv.plan_name || 'Servicio #' + inv.servicio_id) + '</td>';
                html += '<td>' + due + '</td>';
                html += '<td style="font-weight:600;">$' + total.toFixed(2) + '</td>';
                html += '<td>' + (paid > 0 ? '$' + paid.toFixed(2) : '-') + '</td>';
                html += '<td><span class="inv-badge ' + badge + '">' + badgeText + '</span></td></tr>';
            });
            html += '</tbody></table>';
            list.innerHTML = html;
        })
        .catch(function(e) {
            list.innerHTML = '<div style="color:#ef4444; padding:20px;">' + e.message + '</div>';
        });
    }

    // ==================================================================
    // MENSAJES / MESSAGING
    // ==================================================================
    function loadMessages(page) {
        page = page || 1;
        var list = document.getElementById('msgList');
        if (!list) return;
        list.innerHTML = '<div style="padding:30px; text-align:center; color:#94a3b8;"><i class="fas fa-spinner fa-spin"></i> Cargando mensajes...</div>';

        fetch('/modulo?pagina=VerCliente&id=' + clientId + '&ajax=get_messages&page=' + page)
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.status !== 'success') {
                list.innerHTML = '<div style="color:#ef4444; padding:20px; text-align:center;">' + (d.msg || 'Error') + '</div>';
                return;
            }
            if (!d.data || !d.data.length) {
                list.innerHTML = '<div style="padding:40px; text-align:center; color:#94a3b8;">' +
                    '<i class="fas fa-inbox" style="font-size:2rem; margin-bottom:10px; display:block; opacity:0.4;"></i>' +
                    'No hay mensajes enviados a este cliente</div>';
                return;
            }

            var html = '<div class="oru-scroll">';
            html += '<div style="font-size:0.8rem; color:#94a3b8; margin-bottom:8px;">' + d.total + ' mensaje' + (d.total !== 1 ? 's' : '') + '</div>';
            d.data.forEach(function(m) {
                var ch = (m.channel || 'sms').toLowerCase();
                var chLabel = ch === 'whatsapp' ? 'WhatsApp' : 'SMS';
                var chColor = ch === 'whatsapp' ? '#16a34a' : '#2563eb';
                var chBg = ch === 'whatsapp' ? '#dcfce7' : '#dbeafe';
                var chIcon = ch === 'whatsapp' ? 'fab fa-whatsapp' : 'fas fa-sms';
                var st = (m.status || '').toLowerCase();
                var stLabel = st === 'sent' ? 'Enviado' : (st === 'failed' ? 'Fallido' : (st || 'Desconocido'));
                var stColor = st === 'sent' ? '#16a34a' : (st === 'failed' ? '#dc2626' : '#64748b');
                var stBg = st === 'sent' ? '#dcfce7' : (st === 'failed' ? '#fee2e2' : '#f1f5f9');
                var fecha = m.created_at ? new Date(m.created_at.replace(' ', 'T')) : null;
                var fechaStr = fecha ? fecha.toLocaleString('es-DO', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-';
                var preview = m.message_preview || m.message || '';
                var previewSafe = preview.substring(0, 120);

                html += '<div class="msg-card">';
                html += '<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; gap:8px; flex-wrap:wrap;">';
                html += '<div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap;">';
                html += '<span style="padding:2px 8px; border-radius:4px; background:' + chBg + '; color:' + chColor + '; font-weight:700; font-size:0.72rem;"><i class="' + chIcon + '"></i> ' + chLabel + '</span>';
                html += '<span style="padding:2px 8px; border-radius:4px; background:' + stBg + '; color:' + stColor + '; font-weight:700; font-size:0.72rem;">' + stLabel + '</span>';
                if (m.phone) html += '<span style="font-size:0.75rem; color:var(--text-muted);"><i class="fas fa-phone" style="font-size:0.65rem;"></i> ' + m.phone + '</span>';
                html += '</div>';
                html += '<span style="font-size:0.74rem; color:#94a3b8;">' + fechaStr + '</span>';
                html += '</div>';
                html += '<div style="font-size:0.86rem; color:#334155; margin-bottom:8px; word-break:break-word;">' + previewSafe + '</div>';
                html += '<div style="text-align:right;">';
                html += '<button onclick="viewMessageDetail(' + m.id + ')" style="padding:5px 12px; background:#eff6ff; color:var(--accent-primary); border:1px solid #bfdbfe; border-radius:6px; font-weight:600; font-size:0.78rem; cursor:pointer;"><i class="fas fa-eye"></i> Ver completo</button>';
                html += '</div></div>';
            });
            // Paginator
            if (d.pages > 1) {
                html += '<div style="display:flex; align-items:center; justify-content:center; padding:12px 0; gap:3px;">';
                if (d.page > 1) html += '<button onclick="loadMessages(' + (d.page - 1) + ')" style="padding:5px 10px; border:1px solid var(--border-color); border-radius:5px; background:#fff; cursor:pointer; font-size:0.78rem;">«</button>';
                var sp = Math.max(1, d.page - 2);
                var ep = Math.min(d.pages, d.page + 2);
                for (var p = sp; p <= ep; p++) {
                    if (p === d.page) html += '<button style="padding:5px 10px; border:1px solid var(--accent-primary); border-radius:5px; background:var(--accent-primary); color:#fff; font-weight:700; font-size:0.78rem;">' + p + '</button>';
                    else html += '<button onclick="loadMessages(' + p + ')" style="padding:5px 10px; border:1px solid var(--border-color); border-radius:5px; background:#fff; cursor:pointer; font-size:0.78rem;">' + p + '</button>';
                }
                if (d.page < d.pages) html += '<button onclick="loadMessages(' + (d.page + 1) + ')" style="padding:5px 10px; border:1px solid var(--border-color); border-radius:5px; background:#fff; cursor:pointer; font-size:0.78rem;">»</button>';
                html += '</div>';
            }
            html += '</div>';
            list.innerHTML = html;
        })
        .catch(function(e) {
            list.innerHTML = '<div style="color:#ef4444; padding:20px;">' + e.message + '</div>';
        });
    }

