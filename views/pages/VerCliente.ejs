function authorizeOnu() {
  const oltId = document.getElementById('addOnuOltSelect').value;
  const serial = document.getElementById('addonu-sn').value;
  const model = document.getElementById('addonu-model').value;
  const desc = document.getElementById('addonu-desc').value;
  const srvId = document.getElementById('addOnuServicioId').value;
  
  if (!oltId || !serial) { showToast('Seleccione una ONU', 'error'); return; }
  
  // Mostrar barra de progreso
  var resultDiv = document.getElementById('addonu-result');
  resultDiv.innerHTML = '' +
    '<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:12px;">' +
      '<div style="font-weight:600;font-size:0.85rem;color:#475569;margin-bottom:8px;">' +
        '<i class="fas fa-sync-alt"></i> Autorizando ONU...' +
      '</div>' +
      '<div style="height:6px;background:#e2e8f0;border-radius:3px;overflow:hidden;margin-bottom:8px;">' +
        '<div id="authProgressBar" style="width:0%;height:100%;background:linear-gradient(90deg,#6366f1,#8b5cf6);border-radius:3px;transition:width 0.5s;"></div>' +
      '</div>' +
      '<div id="authProgressStep" style="font-size:0.78rem;color:#64748b;">Iniciando...</div>' +
    '</div>';

  // Construir URL con parámetros
  var params = new URLSearchParams();
  params.append('olt_id', oltId);
  params.append('serial', serial);
  if (model) params.append('model', model);
  params.append('vlan', document.getElementById('addonu-vlan').value || '');
  // Enviar ID real del cliente (no el servicio) para evitar FOREIGN KEY error
  params.append('cliente_id', addOnuClienteId || '');
  if (addOnuServicioId) params.append('servicio_id', addOnuServicioId);
  params.append('name', '<%= cliente.nombre.replace(/'/g, "\\'") %>' || desc || serial);
  if (addOnuSelectedBoard) params.append('board', addOnuSelectedBoard);
  if (addOnuSelectedPort) params.append('port', addOnuSelectedPort);
  params.append('onu_mode', addOnuMode || 'route');
  params.append('auth_type', addOnuAuthType || 'dhcp');
  if (addOnuPppoeUser) {
    params.append('pppoe_user', addOnuPppoeUser);
    params.append('pppoe_pass', addOnuPppoePass || '');
  }
  
  // Obtener perfiles del plan
  var planSelect = document.getElementById('authPlan');
  if (planSelect && planSelect.value) {
    params.append('plan_id', planSelect.value);
  }

  var evtSource = new EventSource('/api/smartolt/onu/authorize/progress?' + params.toString());
  var progressBar = document.getElementById('authProgressBar');
  var progressStep = document.getElementById('authProgressStep');
  var steps = { search: 15, delete: 25, authorize: 55, config: 65, speed: 75, tr069: 85, wan: 92, done: 100 };

  evtSource.onmessage = function(e) {
    var data = JSON.parse(e.data);
    if (data.step === 'error') {
      resultDiv.innerHTML = '<div style="color:#ef4444;font-weight:600;"><i class="fas fa-times-circle"></i> ' + data.msg + '</div>';
      evtSource.close();
      return;
    }
    if (progressStep) progressStep.textContent = data.msg;
    if (progressBar && steps[data.step]) {
      progressBar.style.width = steps[data.step] + '%';
    }
    if (data.step === 'done') {
      progressBar.style.width = '100%';
      progressStep.innerHTML = '<span style="color:#16a34a;"><i class="fas fa-check-circle"></i> ' + data.msg + '</span>';
      setTimeout(function() { closeModal('modalAddOnu'); location.reload(); }, 1500);
      evtSource.close();
    }
  };

  evtSource.onerror = function() {
    resultDiv.innerHTML = '<div style="color:#ef4444;font-weight:600;"><i class="fas fa-times-circle"></i> Error de conexión. La ONU pudo haberse autorizado, recargue la página.</div>';
    evtSource.close();
  };
}

