// ===== CONFIGURACION DE SERVICIOS (como DomISP) =====
var svcConfigData = [];
var svcConfigMode = '';

function loadSvcConfig() {
  document.getElementById('svcConfigLoading').style.display = 'block';
  document.getElementById('svcConfigContent').style.display = 'none';

  var clienteId = '<%= cliente.id %>';
  fetch('/api/servicios/config-data/' + clienteId)
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.success && d.data) {
      svcConfigData = d.data;
      renderSvcConfigCards();
    } else {
      document.getElementById('svcConfigLoading').innerHTML = '<div style="color:#ef4444;">Error al cargar configuración</div>';
    }
  })
  .catch(function() {
    document.getElementById('svcConfigLoading').innerHTML = '<div style="color:#ef4444;">Error de conexión</div>';
  });
}

function renderSvcConfigCards() {
  document.getElementById('svcConfigLoading').style.display = 'none';
  var content = document.getElementById('svcConfigContent');
  content.style.display = 'block';

  var activeSvcs = svcConfigData.filter(function(s) { return s.estado === 'activo' || s.estado === 'suspendido'; });
  var freeCount = svcConfigData.filter(function(s) { return s.free == 1; }).length;
  var noSuspendCount = svcConfigData.filter(function(s) { return s.no_suspend == 1; }).length;
  var totalDiscount = svcConfigData.reduce(function(sum, s) { return sum + (parseFloat(s.discount) || 0); }, 0);
  var notifyChecked = activeSvcs.length > 0 && !activeSvcs.some(function(s) { return s.notify_invoices == 0; });
  var consolidatedChecked = activeSvcs.length > 0 && !activeSvcs.some(function(s) { return s.consolidated == 0; });

  var html = '';
  html += '<div class="cfg-card" onclick="openSvcConfigModal(\'free\')"><div class="cfg-card-header">';
  html += '<div><div class="cfg-card-title"><i class="fas fa-gift" style="color:#10b981;"></i> Cliente Gratis</div>';
  html += '<div class="cfg-card-desc">Seleccionar servicios que no generan facturas ni se suspenden.</div></div>';
  html += '<div style="display:flex;align-items:center;gap:8px;"><span style="font-size:0.8rem;color:#10b981;font-weight:600;">' + (freeCount > 0 ? freeCount + ' servicio(s)' : 'Ninguno') + '</span><i class="fas fa-chevron-right" style="color:#94a3b8;"></i></div></div></div>';

  html += '<div class="cfg-card" onclick="openSvcConfigModal(\'nosuspend\')"><div class="cfg-card-header">';
  html += '<div><div class="cfg-card-title"><i class="fas fa-shield-alt" style="color:#f59e0b;"></i> No Suspender</div>';
  html += '<div class="cfg-card-desc">Seleccionar servicios que no se suspenden aunque tengan facturas vencidas.</div></div>';
  html += '<div style="display:flex;align-items:center;gap:8px;"><span style="font-size:0.8rem;color:#f59e0b;font-weight:600;">' + (noSuspendCount > 0 ? noSuspendCount + ' servicio(s)' : 'Ninguno') + '</span><i class="fas fa-chevron-right" style="color:#94a3b8;"></i></div></div></div>';

  html += '<div class="cfg-card" onclick="openSvcConfigModal(\'billing\')"><div class="cfg-card-header">';
  html += '<div><div class="cfg-card-title"><i class="fas fa-file-invoice" style="color:#2563eb;"></i> Facturación</div>';
  html += '<div class="cfg-card-desc">Configurar plantilla de facturación y día de corte por servicio.</div></div>';
  html += '<div><i class="fas fa-chevron-right" style="color:#94a3b8;"></i></div></div></div>';

  html += '<div class="cfg-card" onclick="openSvcConfigModal(\'discount\')"><div class="cfg-card-header">';
  html += '<div><div class="cfg-card-title"><i class="fas fa-percentage" style="color:#8b5cf6;"></i> Descuentos</div>';
  html += '<div class="cfg-card-desc">Aplicar un descuento fijo en pesos a la factura de cada servicio.</div></div>';
  html += '<div style="display:flex;align-items:center;gap:8px;"><span style="font-size:0.8rem;color:#8b5cf6;font-weight:600;">' + (totalDiscount > 0 ? '$' + totalDiscount.toFixed(2) + ' descuento' : 'Ninguno') + '</span><i class="fas fa-chevron-right" style="color:#94a3b8;"></i></div></div></div>';

  // Toggles
  html += '<div class="cfg-card" onclick="toggleNotify()" style="cursor:pointer;"><div class="cfg-card-header">';
  html += '<div><div class="cfg-card-title"><i class="fas fa-bell" style="color:#f59e0b;"></i> Notificar Facturas</div>';
  html += '<div class="cfg-card-desc">Enviar notificaciones automáticas al cliente sobre facturas pendientes.</div></div>';
  html += '<div id="cfgNotifyStatus" style="font-size:0.8rem;font-weight:600;padding:4px 12px;border-radius:12px;background:' + (notifyChecked ? '#dcfce7' : '#fef2f2') + ';color:' + (notifyChecked ? '#166534' : '#991b1b') + ';">' + (notifyChecked ? 'Activado' : 'Desactivado') + '</div></div></div>';

  html += '<div class="cfg-card" onclick="toggleConsolidated()" style="cursor:pointer;"><div class="cfg-card-header">';
  html += '<div><div class="cfg-card-title"><i class="fas fa-layer-group" style="color:#2563eb;"></i> Facturar Consolidado</div>';
  html += '<div class="cfg-card-desc">Agrupar todos los servicios en una sola factura mensual.</div></div>';
  html += '<div id="cfgConsolidatedStatus" style="font-size:0.8rem;font-weight:600;padding:4px 12px;border-radius:12px;background:' + (consolidatedChecked ? '#dcfce7' : '#fef2f2') + ';color:' + (consolidatedChecked ? '#166534' : '#991b1b') + ';">' + (consolidatedChecked ? 'Activado' : 'Desactivado') + '</div></div></div>';

  content.innerHTML = html;
}

function openSvcConfigModal(mode) {
  svcConfigMode = mode;
  var title = document.getElementById('svcCfgTitle');
  var body = document.getElementById('svcCfgBody');
  var html = '';

  if (mode === 'free' || mode === 'nosuspend') {
    var label = mode === 'free' ? 'Cliente Gratis' : 'No Suspender';
    var icon = mode === 'free' ? 'fa-gift' : 'fa-shield-alt';
    var color = mode === 'free' ? '#10b981' : '#f59e0b';
    var field = mode === 'free' ? 'free' : 'nosuspend';
    title.innerHTML = '<i class="fas ' + icon + '" style="color:' + color + ';margin-right:6px;"></i>' + label;
    html = '<p style="font-size:0.85rem;color:#64748b;margin:0 0 14px;">Seleccione los servicios:</p>';
    svcConfigData.forEach(function(s) {
      if (s.estado === 'retirado') return;
      var checked = (mode === 'free' ? s.free : s.no_suspend) == 1;
      html += '<label style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;cursor:pointer;">';
      html += '<input type="checkbox" class="svcCfgChk" data-id="' + s.id + '" data-field="' + field + '" ' + (checked ? 'checked' : '') + '>';
      html += '<div><div style="font-weight:600;font-size:0.88rem;">' + (s.plan || 'Sin plan') + '</div>';
      html += '<div style="font-size:0.78rem;color:#94a3b8;">ID: ' + s.id + ' | $' + parseFloat(s.price).toFixed(2) + '</div></div></label>';
    });

  } else if (mode === 'billing') {
    title.innerHTML = '<i class="fas fa-file-invoice" style="color:#2563eb;margin-right:6px;"></i>Facturación';
    html = '<p style="font-size:0.85rem;color:#64748b;margin:0 0 14px;">Configure el ciclo de facturación y día de corte por servicio:</p>';

    var ciclos = '<%= JSON.stringify(ciclos || []).replace(/</g,"\\u003C") %>';
    try { ciclos = JSON.parse(ciclos); } catch(e) { ciclos = []; }
    var ciclosOptions = '<option value="">-- Default --</option>';
    ciclos.forEach(function(c) {
      ciclosOptions += '<option value="' + c.id + '">' + (c.name || 'Ciclo #' + c.id) + '</option>';
    });

    svcConfigData.forEach(function(s) {
      if (s.estado === 'retirado') return;
      html += '<div style="padding:12px;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:8px;">';
      html += '<div style="font-weight:600;font-size:0.85rem;margin-bottom:8px;">' + (s.plan || 'Sin plan') + ' <span style="color:#94a3b8;font-weight:400;">#ID ' + s.id + '</span></div>';
      html += '<div style="display:flex;gap:10px;">';
      html += '<div style="flex:1;"><label style="font-size:0.78rem;color:#64748b;display:block;margin-bottom:4px;">Ciclo</label>';
      html += '<select class="svcBillingCycle" data-id="' + s.id + '" style="width:100%;padding:8px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.82rem;">' + ciclosOptions.replace('value="' + (s.billing_cycle_id || '') + '"', 'value="' + (s.billing_cycle_id || '') + '" selected') + '</select></div>';
      html += '<div style="flex:1;"><label style="font-size:0.78rem;color:#64748b;display:block;margin-bottom:4px;">Día de Corte</label>';
      html += '<input type="number" class="svcCutDay" data-id="' + s.id + '" value="' + (s.custom_suspend_day || '') + '" min="1" max="31" placeholder="Default" style="width:100%;padding:8px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.82rem;"></div>';
      html += '</div></div>';
    });

  } else if (mode === 'discount') {
    title.innerHTML = '<i class="fas fa-percentage" style="color:#8b5cf6;margin-right:6px;"></i>Descuentos';
    html = '<p style="font-size:0.85rem;color:#64748b;margin:0 0 14px;">Aplicar descuento fijo en pesos a cada servicio:</p>';
    svcConfigData.forEach(function(s) {
      if (s.estado === 'retirado') return;
      var price = parseFloat(s.price) || 0;
      var discount = parseFloat(s.discount) || 0;
      var final = Math.max(0, price - discount);
      html += '<div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;">';
      html += '<div style="flex:1;"><div style="font-weight:600;font-size:0.85rem;">' + (s.plan || 'Sin plan') + '</div>';
      html += '<div style="font-size:0.78rem;color:#94a3b8;">Precio: $' + price.toFixed(2) + '</div></div>';
      html += '<div style="text-align:right;"><label style="font-size:0.75rem;color:#64748b;display:block;">Descuento</label>';
      html += '<input type="number" class="svcDiscount" data-id="' + s.id + '" data-price="' + price + '" value="' + discount + '" min="0" max="' + price + '" step="50" onchange="updateDiscountPreview(this)" style="width:90px;padding:6px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.85rem;text-align:right;"></div>';
      html += '<div style="text-align:right;"><label style="font-size:0.75rem;color:#64748b;display:block;">Total</label>';
      html += '<span class="svcDiscountPreview" data-id="' + s.id + '" style="font-weight:700;color:' + (discount > 0 ? '#8b5cf6' : '#16a34a') + ';">$' + final.toFixed(2) + '</span></div></div>';
    });
  }

  body.innerHTML = html;
  document.getElementById('modalSvcConfig').style.display = 'flex';
}

function closeSvcConfigModal() {
  document.getElementById('modalSvcConfig').style.display = 'none';
}

function saveSvcConfig() {
  var promises = [];
  
  if (svcConfigMode === 'free' || svcConfigMode === 'nosuspend') {
    document.querySelectorAll('.svcCfgChk').forEach(function(chk) {
      var fd = new FormData();
      fd.append('service_id', chk.dataset.id);
      var svc = svcConfigData.find(function(s) { return String(s.id) === chk.dataset.id; });
      fd.append('free_service', chk.dataset.field === 'free' ? (chk.checked ? 1 : 0) : (svc ? svc.free : 0));
      fd.append('no_suspend', chk.dataset.field === 'nosuspend' ? (chk.checked ? 1 : 0) : (svc ? svc.no_suspend : 0));
      fd.append('billing_cycle_id', svc ? (svc.billing_cycle_id || '') : '');
      fd.append('custom_suspend_day', svc ? (svc.custom_suspend_day || '') : '');
      fd.append('discount', svc ? (svc.discount || 0) : 0);
      promises.push(fetch('/api/servicios/config/save', { method: 'POST', body: fd }).then(function(r) { return r.json(); }));
    });
  } else if (svcConfigMode === 'billing') {
    document.querySelectorAll('.svcBillingCycle').forEach(function(sel) {
      var sid = sel.dataset.id;
      var cutDay = document.querySelector('.svcCutDay[data-id="' + sid + '"]');
      var svc = svcConfigData.find(function(s) { return String(s.id) === sid; });
      var fd = new FormData();
      fd.append('service_id', sid);
      fd.append('free_service', svc ? svc.free : 0);
      fd.append('no_suspend', svc ? svc.no_suspend : 0);
      fd.append('billing_cycle_id', sel.value);
      fd.append('custom_suspend_day', cutDay ? cutDay.value : '');
      fd.append('discount', svc ? svc.discount : 0);
      promises.push(fetch('/api/servicios/config/save', { method: 'POST', body: fd }).then(function(r) { return r.json(); }));
    });
  } else if (svcConfigMode === 'discount') {
    document.querySelectorAll('.svcDiscount').forEach(function(inp) {
      var svc = svcConfigData.find(function(s) { return String(s.id) === inp.dataset.id; });
      var fd = new FormData();
      fd.append('service_id', inp.dataset.id);
      fd.append('free_service', svc ? svc.free : 0);
      fd.append('no_suspend', svc ? svc.no_suspend : 0);
      fd.append('billing_cycle_id', svc ? (svc.billing_cycle_id || '') : '');
      fd.append('custom_suspend_day', svc ? (svc.custom_suspend_day || '') : '');
      fd.append('discount', inp.value || 0);
      promises.push(fetch('/api/servicios/config/save', { method: 'POST', body: fd }).then(function(r) { return r.json(); }));
    });
  }

  var btn = document.getElementById('btnSvcCfgSave');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

  Promise.all(promises).then(function() {
    btn.innerHTML = '<i class="fas fa-check"></i> Guardado';
    showToast('Configuración guardada');
    closeSvcConfigModal();
    loadSvcConfig();
    setTimeout(function() { btn.disabled = false; btn.innerHTML = 'Guardar'; }, 1000);
  }).catch(function() {
    btn.innerHTML = 'Guardar';
    btn.disabled = false;
    showToast('Error al guardar', 'error');
  });
}

function updateDiscountPreview(input) {
  var sid = input.dataset.id;
  var price = parseFloat(input.dataset.price) || 0;
  var discount = parseFloat(input.value) || 0;
  if (discount > price) { discount = price; input.value = price; }
  if (discount < 0) { discount = 0; input.value = 0; }
  var final = Math.max(0, price - discount);
  var preview = document.querySelector('.svcDiscountPreview[data-id="' + sid + '"]');
  if (preview) {
    preview.textContent = '$' + final.toFixed(2);
    preview.style.color = discount > 0 ? '#8b5cf6' : '#16a34a';
  }
}

// Toggles simplificados (aplican a todos los servicios activos)
function toggleNotify() {
  var active = svcConfigData.filter(function(s) { return s.estado !== 'retirado'; });
  var currentVal = active.some(function(s) { return s.notify_invoices == 0; }) ? 0 : 1;
  var newVal = currentVal ? 0 : 1;
  var promises = [];
  active.forEach(function(s) {
    var fd = new FormData();
    fd.append('service_id', s.id);
    fd.append('notify_invoices', newVal);
    promises.push(fetch('/api/servicios/config/save', { method: 'POST', body: fd }));
  });
  Promise.all(promises).then(function() {
    showToast('Notificaciones ' + (newVal ? 'activadas' : 'desactivadas'));
    loadSvcConfig();
  });
}

function toggleConsolidated() {
  var active = svcConfigData.filter(function(s) { return s.estado !== 'retirado'; });
  var currentVal = active.some(function(s) { return s.consolidated == 0; }) ? 0 : 1;
  var newVal = currentVal ? 0 : 1;
  var promises = [];
  active.forEach(function(s) {
    var fd = new FormData();
    fd.append('service_id', s.id);
    fd.append('consolidated', newVal);
    promises.push(fetch('/api/servicios/config/save', { method: 'POST', body: fd }));
  });
  Promise.all(promises).then(function() {
    showToast('Facturación consolidada ' + (newVal ? 'activada' : 'desactivada'));
    loadSvcConfig();
  });
}

</script>
