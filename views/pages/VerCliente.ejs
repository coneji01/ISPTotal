<!-- Modal Configuración de Servicios -->
<div class="cli-modal-overlay" id="modalSvcConfig" style="display:none;">
  <div class="cli-modal-box" style="max-width:500px;border-top:5px solid #2563eb;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <h3 class="cli-modal-title" id="svcConfigModalTitle"><i class="fas fa-cog"></i> Configurar</h3>
      <span onclick="closeModal('modalSvcConfig')" style="cursor:pointer;font-size:1.5rem;color:#94a3b8;">&times;</span>
    </div>
    <p id="svcConfigModalDesc" style="font-size:0.85rem;color:#64748b;margin-bottom:14px;"></p>
    <div id="svcConfigList" style="max-height:320px;overflow-y:auto;">
      <div style="padding:30px;text-align:center;color:#94a3b8;">Cargando servicios...</div>
    </div>
    <div id="svcConfigDiscountFields" style="display:none;margin-top:10px;padding:12px;background:#f5f3ff;border-radius:8px;border:1px solid #e9d5ff;">
      <label style="font-weight:600;font-size:0.85rem;color:#6b21a8;">Monto de descuento (RD$)</label>
      <input type="number" id="svcDiscountAmount" class="f-input" step="0.01" min="0" placeholder="0.00" style="margin-top:4px;">
    </div>
    <div id="svcConfigBillingFields" style="display:none;margin-top:10px;padding:12px;background:#eff6ff;border-radius:8px;border:1px solid #dbeafe;">
      <label style="font-weight:600;font-size:0.85rem;color:#1e40af;">Ciclo de Facturación</label>
      <select id="svcBillingCiclo" class="f-input" style="margin-top:4px;">
        <option value="">-- Sin asignar --</option>
        <% if (typeof ciclos !== 'undefined' && ciclos) { ciclos.forEach(function(c) { %>
        <option value="<%= c.id %>" data-type="<%= c.billing_type %>" data-invoice="<%= c.invoice_day %>" data-suspend="<%= c.suspend_day %>"><%= c.name || (c.billing_type.toUpperCase()+' | Gen: Día '+c.invoice_day+' | Corte: Día '+c.suspend_day) %></option>
        <% }); } %>
      </select>
      <div id="svcBillingCicloInfo" style="margin-top:6px;font-size:0.8rem;font-weight:600;color:#1e40af;display:none;"></div>
    </div>
    <div class="cli-modal-footer">
      <button type="button" onclick="closeModal('modalSvcConfig')" class="cli-btn-cancel">Cerrar</button>
      <button type="button" onclick="saveSvcConfigAction()" class="cli-btn-confirm"><i class="fas fa-save"></i> Guardar</button>
    </div>
    <input type="hidden" id="svcConfigTipo" value="">
  </div>
</div>
<!-- Modal Nuevo Servicio Informal -->
<div class="cli-modal-overlay" id="modalNuevoSrv" style="display:none;">
  <div class="cli-modal-box" style="max-width:600px;border-top:5px solid #2563eb;">
    <h3 class="cli-modal-title" style="color:#1e40af;"><i class="fas fa-plus-circle"></i> Nuevo Servicio Informal</h3>
    <p style="font-size:0.85rem;color:#64748b;margin-bottom:18px;">Nuevo servicio para <b><%= cliente.nombre %></b></p>
    
    <!-- Tipo de Servicio -->
    <div class="f-group" style="margin-bottom:18px;">
      <label style="font-weight:600;font-size:0.88rem;color:#1e293b;display:block;margin-bottom:6px;">Tipo de Servicio <span style="color:#ef4444;">*</span></label>
      <select id="nsTipoServicio" class="f-input" onchange="nsOnTipoChange()" style="font-weight:600;padding:12px;border:2px solid #2563eb;border-radius:8px;">
        <option value="internet">🌐 Servicio de Internet</option>
        <option value="netflix">🎬 Cuenta de Netflix</option>
        <option value="servicio_247">🔄 Servicio 24/7</option>
      </select>
    </div>

    <!-- Campos para Internet -->
    <div id="nsInternetFields">
    <div class="form-grid">
      <div class="f-group">
        <label>Zona <span style="color:#ef4444;">*</span></label>
        <select id="nsZona" class="f-input" onchange="nsUpdatePlans(); nsUpdateZonaRouter();" required>
          <option value="">-- Seleccionar --</option>
          <% (zonas || []).forEach(function(z) { %>
          <option value="<%= z.id %>"><%= z.nombre %></option>
          <% }) %>
        </select>
      </div>
      <div class="f-group">
        <label>Plan <span style="color:#ef4444;">*</span></label>
        <select id="nsPlan" class="f-input" required>
          <option value="">-- Seleccionar zona --</option>
        </select>
      </div>
      <div class="f-group">
        <label>Router <span style="color:#ef4444;">*</span></label>
        <select id="nsRouter" class="f-input" onchange="nsOnRouterChange()" required>
          <option value="">-- Seleccionar --</option>
        </select>
      </div>
      <div class="f-group">
        <label>Método de Conexión</label>
        <select id="nsMetodo" class="f-input" onchange="nsOnMetodoChange()">
          <option value="dhcp">DHCP (IPoE)</option>
          <option value="pppoe">PPPoE</option>
          <option value="static">IP Estática</option>
        </select>
      </div>
      
      <!-- PPPoE Fields (shown when PPPoE selected) -->
      <div id="nsPppoeFields" class="form-grid" style="display:none;">
        <div class="f-group"><label>Usuario PPPoE</label><input type="text" id="nsPppoeUser" class="f-input" placeholder="Usuario"></div>
        <div class="f-group"><label>Contraseña</label><input type="text" id="nsPppoePass" class="f-input" placeholder="Contraseña"></div>
        <div class="f-group" style="display:flex;align-items:flex-end;">
          <button type="button" class="btn-gen" onclick="nsGenerateCredentials()" style="margin-bottom:10px;">Generar</button>
        </div>
      </div>
      
      <!-- IP Estática Fields (shown when IP Estática selected) -->
      <div id="nsStaticFields" class="form-grid" style="display:none;">
        <input type="hidden" id="nsStaticMask" value="24">
        <input type="hidden" id="nsStaticGw" value="">
        <input type="hidden" id="nsStaticDns1" value="8.8.8.8">
        <input type="hidden" id="nsStaticDns2" value="8.8.4.4">
      </div>
    </div>
      
      <!-- IP Selection (shared for DHCP and PPPoE) -->
      <div class="f-group" style="background:#f8fafc;padding:10px;border:1px solid #e2e8f0;border-radius:8px;">
        <div id="nsIpSectionLabel" style="font-weight:600;font-size:0.85rem;color:#334155;margin-bottom:5px;">SELECCIONE IP DISPONIBLE</div>
        <select id="nsPool" class="f-input" style="margin-bottom:5px;font-size:0.85rem;" onchange="nsOnPoolChange()">
          <option value="">-- Seleccionar router --</option>
        </select>
        <select id="nsIpSelect" class="f-input" style="font-size:0.85rem;font-family:monospace;" onchange="nsOnIpSelectChange()">
          <option value="">-- Seleccionar pool --</option>
        </select>
        <small id="nsIpMsg" style="color:#64748b;font-size:0.75rem;margin-top:3px;display:block;"></small>
      </div>
        <!-- WiFi Fields -->
        <div id="nsWifiFields">
          <div class="form-grid" style="margin-top:8px;background:#faf5ff;padding:12px;border-radius:8px;border:1px solid #e9d5ff;">
            <div class="f-group">
              <label><i class="fas fa-wifi" style="color:#7c3aed;"></i> Nombre WiFi (SSID)</label>
              <input type="text" id="nsWifiSsid" class="f-input" placeholder="Ej: ISP_Total_Fibra">
            </div>
            <div class="f-group">
              <label><i class="fas fa-lock" style="color:#7c3aed;"></i> Contraseña WiFi</label>
              <input type="text" id="nsWifiPass" class="f-input" minlength="8" placeholder="Mín. 8 caracteres">
            </div>
          </div>
        </div>
        <div class="f-group full-w" style="margin-top:8px;">
          <label>Dirección Exacta</label>
          <input type="text" id="nsAddress" class="f-input" placeholder="Dirección del servicio">
        </div>
        <div class="f-group full-w">
          <label>Observaciones</label>
          <input type="text" id="nsObs" class="f-input" placeholder="Notas adicionales">
        </div>
        <!-- Ciclo de Facturación -->
        <div class="f-group full-w" style="margin-top:8px;background:#f0f9ff;padding:12px;border-radius:8px;border:1px solid #dbeafe;">
          <label style="font-weight:600;font-size:0.88rem;color:#1e293b;display:block;margin-bottom:6px;">
            <i class="fas fa-file-invoice-dollar" style="color:#2563eb;"></i> Ciclo de Facturación
          </label>
          <select id="nsCiclo" class="f-input" onchange="nsOnCicloChange()">
            <option value="">-- Seleccionar plantilla --</option>
            <option value="custom">⚙️ Personalizada</option>
            <% if (typeof ciclos !== 'undefined' && ciclos) { ciclos.forEach(function(c) { %>
            <option value="<%= c.id %>" data-type="<%= c.billing_type %>" data-invoice="<%= c.invoice_day %>" data-suspend="<%= c.suspend_day %>"><%= c.name || (c.billing_type.toUpperCase()+' | Gen: Día '+c.invoice_day+' | Corte: Día '+c.suspend_day) %></option>
            <% }); } %>
          </select>
          <div id="nsCicloInfo" style="display:none;margin-top:6px;background:#fff;border-radius:6px;font-size:0.82rem;font-weight:600;"></div>
          <div id="nsCicloCustom" style="display:none;margin-top:8px;background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:12px;">
            <div class="form-grid" style="margin:0;">
              <div class="f-group" style="margin-bottom:0;">
                <label>Fecha para crear factura</label>
                <select id="nsCustomInvoiceDay" class="f-input">
                  <% for(var d=1; d<=31; d++) { %>
                  <option value="<%= d %>" <%= d===25?'selected':'' %>>Día <%= d %></option>
                  <% } %>
                </select>
              </div>
              <div class="f-group" style="margin-bottom:0;">
                <label>Fecha de suspensión</label>
                <select id="nsCustomSuspendDay" class="f-input">
                  <% for(var d=1; d<=31; d++) { %>
                  <option value="<%= d %>" <%= d===11?'selected':'' %>>Día <%= d %></option>
                  <% } %>
                </select>
              </div>
              <div class="f-group" style="margin-bottom:0;">
                <label>¿Suspender con cuántos meses vencidos?</label>
                <input type="number" id="nsCustomTolerance" class="f-input" min="1" max="12" value="1">
              </div>
            </div>
          </div>
        </div>
    </div>

    <!-- Campos para Netflix -->
    <div id="nsNetflixFields" style="display:none;">
      <div class="form-grid">
        <div class="f-group">
          <label>Correo Electrónico (Netflix) <span style="color:#ef4444;">*</span></label>
          <input type="email" id="nsNfEmail" class="f-input" placeholder="correo@ejemplo.com">
        </div>
        <div class="f-group">
          <label>Contraseña <span style="color:#ef4444;">*</span></label>
          <input type="text" id="nsNfPassword" class="f-input" placeholder="Contraseña">
        </div>
        <div class="f-group">
          <label>Perfil</label>
          <input type="text" id="nsNfPerfil" class="f-input" placeholder="Ej: Principal, Kids, etc.">
        </div>
        <div class="f-group">
          <label>Fecha de Vencimiento</label>
          <input type="date" id="nsNfVencimiento" class="f-input">
        </div>
      </div>
    </div>

    <!-- Campos para Servicio 24/7 -->
    <div id="ns247Fields" style="display:none;">
      <div class="form-grid">
        <div class="f-group full-w">
          <label>Descripción del Servicio <span style="color:#ef4444;">*</span></label>
          <textarea id="ns247Desc" class="f-input" rows="2" placeholder="Describe el servicio que se ofrece..."></textarea>
        </div>
        <div class="f-group">
          <label>Precio Mensual (RD$) <span style="color:#ef4444;">*</span></label>
          <input type="number" id="ns247Precio" class="f-input" step="0.01" min="0" placeholder="0.00">
        </div>
      </div>
    </div>

    <div class="cli-modal-footer" style="margin-top:20px;">
      <button type="button" onclick="closeModal('modalNuevoSrv')" class="cli-btn-cancel">Cancelar</button>
      <button type="button" onclick="nsGuardar()" id="btnGuardarNS" class="cli-btn-confirm" style="background:#2563eb;">
        <i class="fas fa-save"></i> Crear Servicio
      </button>
    </div>
  </div>
</div>

<script>
let nsRoutersCache = [];
let nsPlansCache = [];

function switchVcTab(tab) {
  document.querySelectorAll('.vc-tab').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.vc-tab-content').forEach(function(t) { t.style.display = 'none'; });
  document.querySelector('.vc-tab[data-tab="' + tab + '"]').classList.add('active');
  document.getElementById('vcTab-' + tab).style.display = 'block';
}

function openEditClient() {
  // Populate client fields from EJS data
  document.getElementById('editClienteId').value = '<%= cliente.id %>';
  document.getElementById('editNombre').value = '<%= (cliente.nombre||'').replace(/'/g, "\\'") %>';
  document.getElementById('editCedula').value = '<%= (cliente.cedula||'').replace(/'/g, "\\'") %>';
  document.getElementById('editTelefono').value = '<%= (cliente.telefono||'').replace(/'/g, "\\'") %>';
  document.getElementById('editTelefono2').value = '<%= (cliente.telefono2||'').replace(/'/g, "\\'") %>';
  document.getElementById('editDireccion').value = '<%= (cliente.direccion||'').replace(/'/g, "\\'") %>';
  document.getElementById('editApodo').value = '<%= (cliente.apodo||'').replace(/'/g, "\\'") %>';
  document.getElementById('editZona').value = '<%= cliente.zona_id || '' %>';

  // Build service rows
  var container = document.getElementById('editServicios');
  container.innerHTML = '';
  <% servicios.forEach(function(s) { %>
    var div = document.createElement('div');
    div.className = 'edit-svc-row';
    div.innerHTML = '<div class="form-grid" style="border:1px solid #e2e8f0;border-radius:8px;padding:10px;margin-bottom:8px;background:#f8fafc;">' +
      '<div class="f-group"><label>Plan</label><input type="text" class="f-input" value="<%= (s.plan_nombre||'').replace(/'/g, "\\'") %>" readonly style="background:#f1f5f9;font-weight:600;"></div>' +
      '<div class="f-group"><label>IP</label><input type="text" class="f-input edit-ip" value="<%= (s.ip||'').replace(/'/g, "\\'") %>"></div>' +
      '<div class="f-group"><label>Usuario PPPoE</label><input type="text" class="f-input edit-pppoe-user" value="<%= (s.pppoe_user||'').replace(/'/g, "\\'") %>"></div>' +
      '<div class="f-group"><label>Contraseña PPPoE</label><input type="text" class="f-input edit-pppoe-pass" value="<%= (s.pppoe_pass||'').replace(/'/g, "\\'") %>"></div>' +
      '<div class="f-group"><label>WiFi SSID</label><input type="text" class="f-input edit-wifi-ssid" value="<%= (s.wifi_ssid||'').replace(/'/g, "\\'") %>"></div>' +
      '<div class="f-group"><label>WiFi Pass</label><input type="text" class="f-input edit-wifi-pass" value="<%= (s.wifi_pass||'').replace(/'/g, "\\'") %>"></div>' +
      '<input type="hidden" class="edit-svc-id" value="<%= s.id %>">' +
      '</div>';
    container.appendChild(div);
  <% }); %>

  document.getElementById('modalEditCliente').style.display = 'flex';
}

function saveEditCliente() {
  var servicios = [];
  document.querySelectorAll('#editServicios .edit-svc-row').forEach(function(row) {
    servicios.push({
      id: parseInt(row.querySelector('.edit-svc-id').value),
      ip: row.querySelector('.edit-ip').value,
      pppoe_user: row.querySelector('.edit-pppoe-user').value,
      pppoe_pass: row.querySelector('.edit-pppoe-pass').value,
      wifi_ssid: row.querySelector('.edit-wifi-ssid').value,
      wifi_pass: row.querySelector('.edit-wifi-pass').value
    });
  });

  var data = {
    cliente_id: parseInt(document.getElementById('editClienteId').value),
    nombre: document.getElementById('editNombre').value,
    cedula: document.getElementById('editCedula').value,
    telefono: document.getElementById('editTelefono').value,
    telefono2: document.getElementById('editTelefono2').value || '',
    direccion: document.getElementById('editDireccion').value,
    apodo: document.getElementById('editApodo').value,
    zona_id: document.getElementById('editZona').value || null,
    servicios: servicios
  };

  var btn = document.querySelector('#modalEditCliente .cli-btn-confirm');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

  fetch('/api/clientes/editar', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(r => r.json())
  .then(function(res) {
    if (res.success) {
      showToast('Cliente actualizado correctamente');
      closeModal('modalEditCliente');
      setTimeout(function() { location.reload(); }, 800);
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
    }
  })
  .catch(function(e) {
    showToast('Error de conexión: ' + e.message, 'error');
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
  });
}

// ========== NUEVO SERVICIO ==========
function nsOnTipoChange() {
  var tipo = document.getElementById('nsTipoServicio').value;
  document.getElementById('nsInternetFields').style.display = tipo === 'internet' ? 'block' : 'none';
  document.getElementById('nsNetflixFields').style.display = tipo === 'netflix' ? 'block' : 'none';
  document.getElementById('ns247Fields').style.display = tipo === 'servicio_247' ? 'block' : 'none';
}

function openNuevoServicio() {
  document.getElementById('modalNuevoSrv').style.display = 'flex';
  nsOnTipoChange();
  loadNsRouters();
  loadNsPlans();
}

function closeModal(id) { document.getElementById(id).style.display = 'none'; }

function loadNsRouters() {
  fetch('/api/routers')
    .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function(routers) {
      nsRoutersCache = Array.isArray(routers) ? routers : [];
      const sel = document.getElementById('nsRouter');
      sel.innerHTML = '<option value="">-- Seleccionar --</option>';
      nsRoutersCache.forEach(function(r) {
        const auth = r.auth_type || 'dhcp';
        sel.innerHTML += '<option value="' + r.id + '" data-auth="' + auth.toLowerCase() + '">' + r.name + '</option>';
      });
      if (nsRoutersCache.length > 0) {
        sel.value = nsRoutersCache[0].id;
        nsOnRouterChange();
      }
    })
    .catch(function(e) {
      nsRoutersCache = [];
    });
}

function loadNsPlans() {
  fetch('/api/planes')
    .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function(planes) {
      nsPlansCache = Array.isArray(planes) ? planes : (planes.data || []);
    })
    .catch(function(e) {
      nsPlansCache = [];
    });
}

function nsUpdatePlans() {
  const zonaId = document.getElementById('nsZona').value;
  const sel = document.getElementById('nsPlan');
  if (!zonaId) { sel.innerHTML = '<option value="">-- Seleccionar zona --</option>'; return; }
  sel.innerHTML = '<option value="">-- Cargando planes... --</option>';
  // Filter plans by zona (or show all)
  const plans = nsPlansCache;
  sel.innerHTML = '<option value="">-- Seleccionar plan --</option>';
  plans.forEach(function(p) {
    sel.innerHTML += '<option value="' + p.id + '">' + (p.nombre || p.name) + (p.velocidad ? ' - ' + p.velocidad : '') + '</option>';
  });
}

function nsUpdateZonaRouter() {
  // Optionally filter routers by zone
}

function nsOnRouterChange() {
  const sel = document.getElementById('nsRouter');
  const opt = sel.options[sel.selectedIndex];
  const authType = opt ? (opt.dataset.auth || 'dhcp') : 'dhcp';
  
  // Set the method dropdown based on router's auth type
  const metodo = document.getElementById('nsMetodo');
  if (authType === 'pppoe') metodo.value = 'pppoe';
  else metodo.value = 'dhcp';
  nsOnMetodoChange();
  
  // Load pools for this router
  nsLoadPools();
}

function nsOnMetodoChange() {
  var metodo = document.getElementById('nsMetodo').value;
  var pppoeFields = document.getElementById('nsPppoeFields');
  var staticFields = document.getElementById('nsStaticFields');
  
  // Hide all special fields
  pppoeFields.style.display = 'none';
  staticFields.style.display = 'none';
  
  if (metodo === 'pppoe') {
    pppoeFields.style.display = 'grid';
    nsLoadPppPlans();
  } else {
    nsUpdatePlans();
  }
  if (metodo === 'static') {
    staticFields.style.display = 'grid';
    // Pool/IP dropdowns are the same for all methods
  }
}

function nsLoadPools() {
  const routerId = document.getElementById('nsRouter').value;
  const poolSel = document.getElementById('nsPool');
  const ipSel = document.getElementById('nsIpSelect');
  
  if (!routerId) {
    poolSel.innerHTML = '<option value="">-- Seleccionar router --</option>';
    ipSel.innerHTML = '<option value="">-- Seleccionar pool --</option>';
    return;
  }
  
  poolSel.innerHTML = '<option value=""><i class="fas fa-spinner fa-spin"></i> Cargando rangos...</option>';
  
  fetch('/api/ip-pools/' + routerId)
    .then(r => r.json())
    .then(function(pools) {
      if (pools && pools.length > 0) {
        poolSel.innerHTML = '<option value="">-- Seleccionar rango --</option>';
        pools.forEach(function(p) {
          var disp = p.disponibles || 0;
          poolSel.innerHTML += '<option value="' + p.id + '">' + p.red + ' (' + p.total + ' IPs, ' + disp + ' disponibles)</option>';
        });
        // Auto-seleccionar el primer pool con IPs disponibles
        var firstWithIps = pools.find(function(p) { return (p.disponibles || 0) > 0; });
        if (firstWithIps) {
          poolSel.value = firstWithIps.id;
          nsOnPoolChange();
        }
      } else {
        poolSel.innerHTML = '<option value="">-- Sin rangos configurados --</option>';
        ipSel.innerHTML = '<option value=""></option>';
      }
    })
    .catch(function() {
      poolSel.innerHTML = '<option value="">-- Error al cargar --</option>';
    });
}


function nsOnPoolChange() {
  const poolId = document.getElementById('nsPool').value;
  const ipSel = document.getElementById('nsIpSelect');
  if (!poolId) { ipSel.innerHTML = '<option value="">-- Seleccionar rango --</option>'; return; }
  ipSel.innerHTML = '<option value=""><i class="fas fa-spinner fa-spin"></i> Cargando IPs...</option>';
  
  fetch('/api/ip-pools/' + poolId + '/disponibles')
    .then(r => r.json())
    .then(function(data) {
      if (data.success && data.disponibles && data.disponibles.length > 0) {
        ipSel.innerHTML = '<option value="">-- Seleccionar IP --</option>';
        document.getElementById('nsIpMsg').textContent = (data.total || 0) + ' IPs disponibles';
        for (var i = 0; i < data.disponibles.length; i++) {
          ipSel.innerHTML += '<option value="' + data.disponibles[i] + '">' + data.disponibles[i] + '</option>';
        }
        // Auto-seleccionar la primera IP disponible
        ipSel.value = data.disponibles[0];
        nsOnIpSelectChange();
      } else {
        ipSel.innerHTML = '<option value="">No hay IPs disponibles</option>';
        document.getElementById('nsIpMsg').textContent = 'Todas las IPs estan asignadas';
      }
    })
    .catch(function() {
      ipSel.innerHTML = '<option value="">-- Error al cargar --</option>';
    });
}

function nsOnIpSelectChange() {
  var metodo = document.getElementById('nsMetodo').value;
  if (metodo !== 'static') return;
  var ip = document.getElementById('nsIpSelect').value;
  if (ip) {
    var parts = ip.split('.');
    if (parts.length === 4) {
      parts[3] = '1';
      document.getElementById('nsStaticGw').value = parts.join('.');
    }
  }
}



function nsOnCicloChange() {
  var sel = document.getElementById('nsCiclo');
  var val = sel.value;
  var info = document.getElementById('nsCicloInfo');
  var custom = document.getElementById('nsCicloCustom');
  if (val === 'custom') {
    info.style.display = 'none';
    custom.style.display = 'block';
  } else if (val && val !== '') {
    custom.style.display = 'none';
    info.style.display = 'block';
    var opt = sel.options[sel.selectedIndex];
    var tipo = opt.getAttribute('data-type');
    var inv = opt.getAttribute('data-invoice');
    var susp = opt.getAttribute('data-suspend');
    info.innerHTML = '<span style="background:' + (tipo==='postpago'?'#fef3c7':'#dcfce7') + ';color:' + (tipo==='postpago'?'#92400e':'#166534') + ';padding:2px 8px;border-radius:4px;">' + tipo.toUpperCase() + '</span> 📄 Gen: Día ' + inv + ' 🚫 Corte: Día ' + susp;
  } else {
    info.style.display = 'none';
    custom.style.display = 'none';
  }
}

function nsGenerateCredentials() {
  // Obtener nombre del cliente
  var nombre = '<%= (cliente.nombre || "").replace(/'/g, "\\'") %>';
  if (nombre) {
    var parts = nombre.trim().split(/\s+/);
    var userParts = parts.map(function(p) { return p.charAt(0).toUpperCase() + p.slice(1).toLowerCase(); });
    var user = userParts.join('').replace(/[^a-zA-Z0-9]/g, '');
    document.getElementById('nsPppoeUser').value = user;
  } else {
    document.getElementById('nsPppoeUser').value = 'CLI' + Math.random().toString(36).substring(2, 8).toUpperCase();
  }
  document.getElementById('nsPppoePass').value = '1320';
}

function nsGuardar() {
  const routerId = document.getElementById('nsRouter').value;
  const router = nsRoutersCache.find(function(r) { return r.id == routerId; });
  const metodo = document.getElementById('nsMetodo').value;
  
  var planValue = document.getElementById('nsPlan').value;
  
  var data = {
    cliente_id: <%= cliente.id %>,
    plan_id: metodo === 'pppoe' ? planValue : (parseInt(planValue) || 0),
    zona_id: parseInt(document.getElementById('nsZona').value) || 0,
    router_id: routerId,
    auth_type: metodo,
    direccion: document.getElementById('nsAddress').value,
    observaciones: document.getElementById('nsObs').value,
    router_ip: router ? router.ip : '',
    router_port: router ? (router.port || 8728) : 8728,
    router_user: router ? (router.user || 'admin') : 'admin',
    router_pass: router ? (router.password || '') : ''
  };
  
  if (metodo === 'dhcp' || metodo === 'pppoe') {
    data.ip = document.getElementById('nsIpSelect').value;
    data.pool = document.getElementById('nsPool').value;
  }
  
  if (metodo === 'pppoe') {
    data.pppoe_user = document.getElementById('nsPppoeUser').value;
    data.pppoe_pass = document.getElementById('nsPppoePass').value;
  }
  
  // WiFi fields (para todos los servicios de internet)
  data.wifi_ssid = document.getElementById('nsWifiSsid') ? document.getElementById('nsWifiSsid').value : '';
  data.wifi_pass = document.getElementById('nsWifiPass') ? document.getElementById('nsWifiPass').value : '';
  
  if (metodo === 'static') {
    data.ip = document.getElementById('nsIpSelect').value;
    data.pool = document.getElementById('nsPool').value;
    data.static_mask = '24';
    data.static_gw = document.getElementById('nsStaticGw').value || data.ip.replace(/\.\d+$/, '.1');
    data.dns1 = '8.8.8.8';
    data.dns2 = '8.8.4.4';
  }
  
  const btn = document.getElementById('btnGuardarNS');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creando...';
  
  fetch('/api/servicios/crear', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(r => r.json())
  .then(function(res) {
    if (res.success) {
      showToast('Servicio creado (' + metodo + ')');
      closeModal('modalNuevoSrv');
      setTimeout(function() { location.reload(); }, 1000);
    } else {
      showToast('Error: ' + (res.error || res.message || 'desconocido'), 'error');
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Crear Servicio';
    }
  })
  .catch(function(e) {
    showToast('Error de conexión: ' + e.message, 'error');
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Crear Servicio';
  });
}

// ========== EDITAR SERVICIO ==========
function onEditTipoChange() {
  var tipo = document.getElementById('editSrvTipo').value;
  document.getElementById('editInternetFields').style.display = tipo === 'internet' ? 'block' : 'none';
  document.getElementById('editNetflixFields').style.display = tipo === 'netflix' ? 'block' : 'none';
  document.getElementById('edit247Fields').style.display = tipo === 'servicio_247' ? 'block' : 'none';
}

function onEditCicloChange() {
  var sel = document.getElementById('editSrvCiclo');
  var val = sel.value;
  var info = document.getElementById('editCicloInfo');
  var custom = document.getElementById('editCicloCustom');
  if (val === 'custom') {
    info.style.display = 'none';
    custom.style.display = 'block';
  } else if (val && val !== '') {
    custom.style.display = 'none';
    info.style.display = 'block';
    var opt = sel.options[sel.selectedIndex];
    var tipo = opt.getAttribute('data-type');
    var inv = opt.getAttribute('data-invoice');
    var susp = opt.getAttribute('data-suspend');
    info.innerHTML = '<span style="background:' + (tipo==='postpago'?'#fef3c7':'#dcfce7') + ';color:' + (tipo==='postpago'?'#92400e':'#166534') + ';padding:2px 8px;border-radius:4px;">' + tipo.toUpperCase() + '</span> 📄 Gen: Día ' + inv + ' 🚫 Corte: Día ' + susp;
  } else {
    info.style.display = 'none';
    custom.style.display = 'none';
  }
}

function openEditServicio(id, planNombre, ip, pppoeUser, pppoePass, wifiSsid, wifiPass, authType, planId, direccion, tipoServicio, cicloId, nfEmail, nfPass, nfPerfil, nfVenc, svc247Desc, svc247Precio) {
  document.getElementById('editSrvId').value = id;
  document.getElementById('editSrvIp').value = ip || '';
  document.getElementById('editSrvAuthType').value = authType || 'dhcp';
  document.getElementById('editSrvPppoeUser').value = pppoeUser || '';
  document.getElementById('editSrvPppoePass').value = pppoePass || '';
  document.getElementById('editSrvWifiSsid').value = wifiSsid || '';
  document.getElementById('editSrvWifiPass').value = wifiPass || '';
  document.getElementById('editSrvDireccion').value = direccion || '';
  
  // Tipo de servicio
  var tipoSel = document.getElementById('editSrvTipo');
  tipoSel.value = tipoServicio || 'internet';
  onEditTipoChange();
  
  // Ciclo de facturación
  var cicloSel = document.getElementById('editSrvCiclo');
  if (cicloId) {
    for (var i = 0; i < cicloSel.options.length; i++) {
      if (cicloSel.options[i].value == cicloId) {
        cicloSel.selectedIndex = i;
        break;
      }
    }
  } else {
    cicloSel.selectedIndex = 0;
  }
  onEditCicloChange();
  
  // Netflix fields
  document.getElementById('editNfEmail').value = nfEmail || '';
  document.getElementById('editNfPassword').value = nfPass || '';
  document.getElementById('editNfPerfil').value = nfPerfil || '';
  document.getElementById('editNfVencimiento').value = nfVenc || '';
  
  // 24/7 fields
  document.getElementById('edit247Desc').value = svc247Desc || '';
  document.getElementById('edit247Precio').value = svc247Precio || '';
  
  // Set plan dropdown
  var planSel = document.getElementById('editSrvPlan');
  if (planId) {
    for (var i = 0; i < planSel.options.length; i++) {
      if (planSel.options[i].value == planId) {
        planSel.selectedIndex = i;
        break;
      }
    }
  } else {
    planSel.selectedIndex = 0;
  }
  
  openModal('modalEditServicio');
}

function saveEditServicio() {
  var id = document.getElementById('editSrvId').value;
  var plan_id = document.getElementById('editSrvPlan').value || null;
  var ip = document.getElementById('editSrvIp').value;
  var auth_type = document.getElementById('editSrvAuthType').value;
  var pppoe_user = document.getElementById('editSrvPppoeUser').value;
  var pppoe_pass = document.getElementById('editSrvPppoePass').value;
  var wifi_ssid = document.getElementById('editSrvWifiSsid').value;
  var wifi_pass = document.getElementById('editSrvWifiPass').value;
  var direccion = document.getElementById('editSrvDireccion').value;
  var tipo_servicio = document.getElementById('editSrvTipo').value;
  var ciclo_id = document.getElementById('editSrvCiclo').value;
  var netflix_email = document.getElementById('editNfEmail').value;
  var netflix_password = document.getElementById('editNfPassword').value;
  var netflix_perfil = document.getElementById('editNfPerfil').value;
  var netflix_vencimiento = document.getElementById('editNfVencimiento').value;
  var descripcion_servicio = document.getElementById('edit247Desc').value;
  var precio_servicio = document.getElementById('edit247Precio').value;
  
  if (!id) { showToast('Error: ID de servicio no encontrado', 'error'); return; }
  
  var btn = document.querySelector('#modalEditServicio .cli-btn-confirm');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
  
  fetch('/api/servicios/editar', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: parseInt(id), ip: ip, plan_id: plan_id, auth_type: auth_type, pppoe_user: pppoe_user, pppoe_pass: pppoe_pass, wifi_ssid: wifi_ssid, wifi_pass: wifi_pass, direccion: direccion, tipo_servicio: tipo_servicio, ciclo_id: ciclo_id !== '' && ciclo_id !== 'custom' ? parseInt(ciclo_id) : null, netflix_email: netflix_email, netflix_password: netflix_password, netflix_perfil: netflix_perfil, netflix_vencimiento: netflix_vencimiento, descripcion_servicio: descripcion_servicio, precio_servicio: parseFloat(precio_servicio) || 0 })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Servicio actualizado correctamente');
      closeModal('modalEditServicio');
      setTimeout(function() { location.reload(); }, 800);
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
    }
  })
  .catch(function(e) {
    showToast('Error de conexión: ' + e.message, 'error');
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
  });
}
</script>

<!-- ========== MENSAJERÍA JS ========== -->
<script>
function loadMensajes() {
  const container = document.getElementById('msjContainer');
  if (!container) return;
  container.innerHTML = '<div class="vc-msj-empty"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;display:block;margin-bottom:8px;"></i>Cargando mensajes...</div>';
  
  const clienteId = <%= cliente.id %>;
  fetch('/api/clientes/' + clienteId + '/mensajes')
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!res.success || !res.data || res.data.length === 0) {
        container.innerHTML = '<div class="vc-msj-empty"><i class="fas fa-comment-dots" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:8px;"></i>No hay mensajes registrados</div>';
        return;
      }
      
      var tipos = {
        nota: { icon: 'fa-sticky-note', color: '#64748b', bg: '#f8fafc', border: '#e2e8f0' },
        whatsapp: { icon: 'fab fa-whatsapp', color: '#16a34a', bg: '#f0fdf4', border: '#86efac' },
        email: { icon: 'fa-envelope', color: '#2563eb', bg: '#eff6ff', border: '#bfdbfe' },
        sms: { icon: 'fa-sms', color: '#d97706', bg: '#fefce8', border: '#fde68a' }
      };
      
      var etiquetas = { nota: 'Nota interna', whatsapp: 'WhatsApp', email: 'Email', sms: 'SMS' };
      
      var html = '';
      res.data.forEach(function(m) {
        var tipo = tipos[m.tipo] || tipos.nota;
        var fecha = '';
        if (m.created_at) {
          try {
            var d = new Date(m.created_at.replace(' ', 'T'));
            if (!isNaN(d.getTime())) {
              fecha = d.toLocaleDateString('es-DO', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            } else {
              fecha = m.created_at;
            }
          } catch(e) { fecha = m.created_at; }
        }
        
        html += '<div class="vc-msj-card" style="background:' + tipo.bg + ';border-left-color:' + tipo.border + ';">';
        html += '  <div class="vc-msj-icon" style="background:' + tipo.bg + ';color:' + tipo.color + ';"><i class="' + tipo.icon + '"></i></div>';
        html += '  <div class="vc-msj-body">';
        html += '    <div class="vc-msj-text">' + escapeHtml(m.mensaje) + '</div>';
        html += '    <div class="vc-msj-meta">';
        html += '      <span style="color:' + tipo.color + ';font-weight:600;">' + (etiquetas[m.tipo] || m.tipo) + '</span>';
        html += '      <span>' + fecha + '</span>';
        if (m.enviado_por_nombre) {
          html += '      <span>Por: ' + escapeHtml(m.enviado_por_nombre) + '</span>';
        }
        html += '    </div>';
        html += '  </div>';
        html += '</div>';
      });
      container.innerHTML = html;
    })
    .catch(function() {
      container.innerHTML = '<div class="vc-msj-empty" style="color:#ef4444;"><i class="fas fa-exclamation-triangle" style="font-size:1.5rem;display:block;margin-bottom:8px;"></i>Error al cargar mensajes</div>';
    });
}

function enviarMensaje() {
  var tipo = document.getElementById('msjTipo').value;
  var mensaje = document.getElementById('msjTexto').value.trim();
  
  if (!mensaje) {
    showToast('El mensaje no puede estar vacío', 'error');
    return;
  }
  
  var clienteId = <%= cliente.id %>;
  var btn = document.querySelector('#vcTab-mensajes .vc-btn-primary');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
  
  fetch('/api/clientes/' + clienteId + '/mensajes', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ tipo: tipo, mensaje: mensaje })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Mensaje enviado correctamente');
      document.getElementById('msjTexto').value = '';
      
      // Si es WhatsApp, abrir WhatsApp Web
      if (tipo === 'whatsapp') {
        var telefono = '<%= (cliente.telefono || "").replace(/[^\d]/g, "") %>';
        if (telefono) {
          var url = 'https://wa.me/' + telefono + '?text=' + encodeURIComponent(mensaje);
          window.open(url, '_blank');
        } else {
          showToast('El cliente no tiene teléfono registrado', 'error');
        }
      }
      
      // Recargar historial
      loadMensajes();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-paper-plane"></i> Enviar Mensaje';
  })
  .catch(function(e) {
    showToast('Error de conexión: ' + e.message, 'error');
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-paper-plane"></i> Enviar Mensaje';
  });
}

// Mostrar alerta de WhatsApp cuando se selecciona ese tipo
document.addEventListener('change', function(e) {
  if (e.target && e.target.id === 'msjTipo') {
    var alertEl = document.getElementById('msjWhatsappAlert');
    if (alertEl) {
      alertEl.style.display = e.target.value === 'whatsapp' ? 'block' : 'none';
    }
  }
});

function escapeHtml(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
</script>

