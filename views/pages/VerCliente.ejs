<!-- Tab Servicios -->
<div id="vcTab-servicios" class="vc-tab-content">
  <div class="vc-card">
    <div class="vc-card-head"><h3><i class="fas fa-wifi"></i> Servicios Contratados</h3><div style="display:flex;gap:8px;"><button class="vc-btn vc-btn-success vc-btn-sm" onclick="openNuevoServicio()"><i class="fas fa-plus"></i> Nuevo Informal</button></div></div>
    <div class="vc-card-body">
      <% if (servicios.length === 0) { %>
        <div class="vc-empty"><i class="fas fa-wifi" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:8px;"></i>No tiene servicios contratados.</div>
      <% } else { %>
        <% servicios.forEach(function(s) { %>
        <div class="svc-card" data-svc-id="<%= s.id %>">
          <div class="svc-summary" onclick="toggleSvcDetail(<%= s.id %>)">
            <div class="svc-summary-left">
              <div class="svc-expand-icon" id="svcIcon_<%= s.id %>"><i class="fas fa-chevron-down"></i></div>
              <span class="svc-plan-name"><%= s.plan_nombre || 'Sin plan' %></span>
              <span class="svc-badge svc-badge-<%= s.estado==='activo'?'activo':s.estado==='suspendido'?'suspendido':'retirado' %>"><%= s.estado.charAt(0).toUpperCase()+s.estado.slice(1) %></span>
              <% if (s.deuda_total && s.deuda_total > 0) { %>
              <span class="svc-badge" style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca;"><%= 'RD$' + s.deuda_total.toFixed(2) %></span>
              <% } else if (s.estado === 'activo') { %>
              <span class="svc-badge" style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;">Al día</span>
              <% } %>
              <span class="svc-nic">NIC: <%= s.id %></span>
            </div>
            <div class="svc-summary-right">
              <% if (s.ip) { %><span class="svc-ip-badge"><%= s.ip %></span><% } %>
              <span class="svc-zona"><%= s.zona_nombre || '' %></span>
            </div>
          </div>
          <div id="svcDetail_<%= s.id %>" class="svc-detail" style="display:none;">
            <div class="svc-detail-grid">
              <div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">IP del Servicio</span>
                  <span class="svc-detail-value"><%= s.ip || '—' %></span>
                </div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">Fecha Activaci&oacute;n</span>
                  <span class="svc-detail-value"><%= s.fecha_activacion ? new Date(s.fecha_activacion+'T00:00:00').toLocaleDateString('es-DO',{day:'numeric',month:'short',year:'numeric'}) : '—' %></span>
                </div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">Plan</span>
                  <span class="svc-detail-value"><%= s.plan_nombre || '—' %></span>
                </div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">Tipo Conexi&oacute;n</span>
                  <span class="svc-detail-value"><%= (s.auth_type||'dhcp').toUpperCase() %></span>
                </div>
                <% if (s.pppoe_user) { %>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">PPPoE Usuario</span>
                  <span class="svc-detail-value svc-mono"><%= s.pppoe_user %></span>
                </div>
                <% } %>
                <% if (s.pppoe_pass) { %>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">PPPoE Contrase&ntilde;a</span>
                  <span class="svc-detail-value svc-mono"><%= s.pppoe_pass %></span>
                </div>
                <% } %>
              </div>
              <div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">Ciclo Facturaci&oacute;n</span>
                  <span class="svc-detail-value"><%= s.ciclo_name ? s.ciclo_name : (s.ciclo_tipo ? (s.ciclo_tipo.toUpperCase()+' | Gen: Día '+s.ciclo_factura_dia+' | Corte: Día '+s.ciclo_corte_dia) : '—') %></span>
                </div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">Direcci&oacute;n</span>
                  <span class="svc-detail-value"><%= s.direccion || '—' %></span>
                </div>
                <% if (s.onu_sn) { %>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">ONU Serial</span>
                  <span class="svc-detail-value svc-mono"><%= s.onu_sn %></span>
                </div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">ONU Modelo</span>
                  <span class="svc-detail-value"><%= s.onu_nombre || '—' %></span>
                </div>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">OLT</span>
                  <span class="svc-detail-value"><%= s.olt_nombre || '—' %></span>
                </div>
                <% if (s.onu_senial) { %>
                <div class="svc-detail-item">
                  <span class="svc-detail-label">Se&ntilde;al &Oacute;ptica</span>
                  <span class="svc-detail-value"><%= s.onu_senial %> dBm</span>
                </div>
                <% } %>
                <% } %>
              </div>
            </div>
            <div class="svc-actions">
              <div class="svc-actions-left">
                <button class="svc-btn svc-btn-onu" onclick="openAddOnuModal(<%= s.id %>,<%= cliente.id %>,'<%= (s.plan_nombre||'').replace(/'/g,"\\'") %>','<%= (s.auth_type||'dhcp') %>','<%= (s.pppoe_user||'').replace(/'/g,"\\'") %>','<%= (s.pppoe_pass||'').replace(/'/g,"\\'") %>')"><i class="fas fa-plus-circle"></i> ONU</button>
                <button class="svc-btn svc-btn-edit" onclick="openEditServicio(<%= s.id %>,'<%= (s.plan_nombre||'').replace(/'/g,"\\'") %>','<%= (s.ip||'').replace(/'/g,"\\'") %>','<%= (s.pppoe_user||'').replace(/'/g,"\\'") %>','<%= (s.pppoe_pass||'').replace(/'/g,"\\'") %>','<%= (s.wifi_ssid||'').replace(/'/g,"\\'") %>','<%= (s.wifi_pass||'').replace(/'/g,"\\'") %>','<%= (s.auth_type||'dhcp') %>','<%= s.plan_id||'' %>','<%= (s.direccion||'').replace(/'/g,"\\'") %>','<%= (s.tipo_servicio||'internet') %>','<%= s.ciclo_id||'' %>','<%= (s.netflix_email||'').replace(/'/g,"\\'") %>','<%= (s.netflix_password||'').replace(/'/g,"\\'") %>','<%= (s.netflix_perfil||'').replace(/'/g,"\\'") %>','<%= (s.netflix_vencimiento||'') %>','<%= (s.descripcion_servicio||'').replace(/'/g,"\\'") %>','<%= s.precio_servicio||'' %>')"><i class="fas fa-pencil-alt"></i> Editar</button>
                <button class="svc-btn svc-btn-edit" onclick="openTransferModal(<%= s.id %>,'<%= (cliente.nombre||'').replace(/'/g,"\\'") %>')"><i class="fas fa-user-friends"></i> Titular</button>
              </div>
              <div class="svc-actions-right">
                <% if (s.estado === 'activo') { %>
                <button class="svc-btn svc-btn-suspender" onclick="if(confirm('Suspender servicio #<%= s.id %>?'))accionServicio(<%= s.id %>,'suspender')"><i class="fas fa-pause"></i> Suspender</button>
                <% } else if (s.estado === 'suspendido') { %>
                <button class="svc-btn svc-btn-activar" onclick="accionServicio(<%= s.id %>,'activar')"><i class="fas fa-play"></i> Reactivar</button>
                <% } %>
                <% if (s.estado !== 'retirado') { %>
                <button class="svc-btn svc-btn-retirar" onclick="if(confirm('Retirar servicio #<%= s.id %>?'))accionServicio(<%= s.id %>,'retirar')"><i class="fas fa-minus-circle"></i> Retirar</button>
                <% } %>
                <button class="svc-btn svc-btn-tr069" onclick="enviarTR069(<%= s.id %>)"><i class="fas fa-satellite-dish"></i> TR069</button>
                <button class="svc-btn svc-btn-danger" onclick="if(confirm('Eliminar servicio #<%= s.id %> permanentemente?'))accionServicio(<%= s.id %>,'eliminar')"><i class="fas fa-trash-alt"></i> Eliminar</button>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<!-- Tab Facturas -->
<div id="vcTab-facturas" class="vc-tab-content" style="display:none;">
  <div class="vc-card">
    <div class="vc-card-head"><h3><i class="fas fa-file-invoice"></i> Facturas</h3></div>
    <div class="vc-card-body">
      <% if (!facturas || facturas.length === 0) { %>
        <div class="vc-empty"><i class="fas fa-file-invoice" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:8px;"></i>No tiene facturas registradas.</div>
      <% } else { %>
        <div class="table-container" style="overflow-x:auto;">
          <table class="vc-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Periodo</th>
                <th>Plan / Servicio</th>
                <th>Vencimiento</th>
                <th>Monto</th>
                <th>Pagado</th>
                <th>Saldo</th>
                <th>Estado</th>
                <th style="width:120px;">Pagos</th>
              </tr>
            </thead>
            <tbody>
              <% var totalPendiente = 0, totalCobrado = 0, totalFacturado = 0; %>
              <% facturas.forEach(function(f) { %>
                <%
                  var remaining = parseFloat(f.remaining || f.monto);
                  var paid = parseFloat(f.paid_amount || 0);
                  totalCobrado += paid;
                  totalFacturado += parseFloat(f.monto || 0);
                  var estado = remaining <= 0.01 ? 'pagada' : (f.estado === 'pagada' ? 'pagada' : 'pendiente');
                  var badgeClass = estado === 'pagada' ? 'vc-badge-ok' : 'vc-badge-err';
                  var badgeLabel = estado === 'pagada' ? 'Pagada' : 'Pendiente';
                  if (remaining <= 0.01) totalPendiente += 0;
                  else totalPendiente += remaining;
                  var periodo = f.periodo || '';
                  var dueDate = f.fecha_vencimiento ? new Date(f.fecha_vencimiento+'T00:00:00').toLocaleDateString('es-DO',{day:'numeric',month:'short',year:'numeric'}) : '—';
                %>
                <tr>
                  <td style="font-weight:600;"><%= f.id %></td>
                  <td><%= periodo %></td>
                  <td><%= f.plan_name || 'Servicio #' + f.servicio_id %></td>
                  <td><%= dueDate %></td>
                  <td style="font-weight:600;">$<%= parseFloat(f.monto).toFixed(2) %></td>
                  <td style="color:#16a34a;font-weight:600;">$<%= paid.toFixed(2) %></td>
                  <td style="font-weight:600;color:<%= remaining > 0.01 ? '#dc2626' : '#16a34a' %>;">$<%= remaining.toFixed(2) %></td>
                  <td><span class="vc-badge <%= badgeClass %>"><%= badgeLabel %></span></td>
                  <td>
                    <%
                      var pagosFactura = pagos ? pagos.filter(function(p) { return p.factura_id == f.id; }) : [];
                    %>
                    <% if (pagosFactura.length > 0) { %>
                      <div style="font-size:0.75rem;line-height:1.6;">
                        <% pagosFactura.forEach(function(p) { %>
                          <div style="display:flex;justify-content:space-between;gap:6px;padding:1px 0;">
                            <span style="color:#64748b;"><%= new Date(p.created_at).toLocaleDateString('es-DO',{day:'numeric',month:'short'}) %></span>
                            <span style="color:#16a34a;font-weight:600;">$<%= parseFloat(p.monto).toFixed(2) %></span>
                            <span style="color:#94a3b8;font-size:0.7rem;"><%= p.metodo || '' %></span>
                          </div>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <span style="color:#94a3b8;font-size:0.75rem;">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr style="background:#f0fdf4;font-weight:700;">
                <td colspan="4" style="text-align:right;color:#166534;">✅ Total Cobrado:</td>
                <td style="color:#16a34a;font-size:1rem;">$<%= totalCobrado.toFixed(2) %></td>
                <td colspan="5"></td>
              </tr>
              <tr style="background:#fef2f2;font-weight:700;">
                <td colspan="4" style="text-align:right;color:#991b1b;">⚠️ Total Pendiente:</td>
                <td style="color:#dc2626;font-size:1rem;">$<%= totalPendiente.toFixed(2) %></td>
                <td colspan="5"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>
