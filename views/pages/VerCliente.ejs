      <button type="button" onclick="saveEditCliente()" class="cli-btn-confirm" style="background:#2563eb;"><i class="fas fa-save"></i> Guardar Cambios</button>
    </div>
  </div>
</div>

<script>
function toggleSvcDetail(id) {
  const el = document.getElementById('svcDetail_' + id);
  const icon = document.getElementById('svcIcon_' + id);
  if (!el) return;
  const isOpen = el.style.display !== 'none';
  el.style.display = isOpen ? 'none' : 'block';
  if (icon) {
    icon.classList.toggle('open', !isOpen);
  }
}

function accionServicio(id, accion) {
  fetch('/api/servicios/' + id + '/' + accion, { method: 'POST' })
    .then(r => r.json())
    .then(d => {
      if (d.success) {
        showToast('✅ ' + d.message);
        location.reload();
      } else {
        showToast('❌ Error: ' + (d.message || 'desconocido'), 'error');
      }
    })
    .catch(e => showToast('❌ Error de conexión: ' + e.message, 'error'));
}

function enviarTR069(servicioId) {
  var btn = event.target;
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> TR069...';
  showToast('Enviando configuración TR-069...');
  
  fetch('/api/smartolt/onu/enviar-tr069', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ servicio_id: servicioId })
  })
  .then(r => r.json())
  .then(function(d) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-satellite-dish"></i> TR069';
    if (d.success) {
      showToast('TR-069 configurado exitosamente');
    } else {
      showToast('Error: ' + (d.message || 'desconocido'), 'error');
    }
  })
  .catch(function(e) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-satellite-dish"></i> TR069';
    showToast('Error de conexión: ' + e.message, 'error');
  });
}

function eliminarOnuSmartolt(servicioId) {
  if (!confirm('¿Estás seguro? Esta acción RESETEARÁ la ONU a fábrica y la ELIMINARÁ de SmartOLT.')) return;
  var btn = event.target;
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Reset+Eliminar...';
  showToast('Eliminando ONU de SmartOLT...');
  
  fetch('/api/smartolt/onu/reset-y-eliminar', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ servicio_id: servicioId })
  })
  .then(r => r.json())
  .then(function(d) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-microchip"></i> Reset+Eliminar ONU';
    if (d.success) {
      showToast('ONU eliminada de SmartOLT correctamente');
    } else {
      showToast('Error: ' + (d.message || 'desconocido'), 'error');
    }
  })
  .catch(function(e) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-microchip"></i> Reset+Eliminar ONU';
    showToast('Error de conexión: ' + e.message, 'error');
  });
}

// ========== AÑADIR ONU ==========
var addOnuServicioId = 0;
var addOnuSelectedSerial = '';
var addOnuSelectedPort = '';
var addOnuSelectedBoard = '';
var addOnuAuthType = 'dhcp';
var addOnuPppoeUser = '';
var addOnuPppoePass = '';

function openAddOnuModal(srvId, clId, planName, authType, pppoeUser, pppoePass) {
  addOnuServicioId = srvId;
  addOnuAuthType = authType || 'dhcp';
  addOnuPppoeUser = pppoeUser || '';
  addOnuPppoePass = pppoePass || '';
  document.getElementById('addOnuServicioId').value = srvId;
  document.getElementById('addonu-step1').style.display = 'block';
  document.getElementById('addonu-step2').style.display = 'none';
  document.getElementById('addonu-list').innerHTML = '<div style="padding:30px;text-align:center;color:#94a3b8;"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;"></i><br>Cargando OLTs...</div>';
  
  // Load OLTs
  fetch('/api/olts')
    .then(r => r.json())
    .then(olts => {
      const sel = document.getElementById('addOnuOltSelect');
      sel.innerHTML = '<option value="">-- Seleccionar OLT --</option>';
      olts.forEach(function(o) {
        if (o.smartolt_subdomain && o.smartolt_api_key) {
          sel.innerHTML += '<option value="' + o.id + '">' + o.nombre + ' (' + o.smartolt_subdomain + '.smartolt.com)</option>';
        }
      });
      sel.innerHTML += '<option value="new">+ Agregar nueva OLT...</option>';
      document.getElementById('addonu-list').innerHTML = '<div style="padding:30px;text-align:center;color:#94a3b8;"><i class="fas fa-satellite-dish" style="font-size:2rem;margin-bottom:10px;display:block;"></i>Seleccione una OLT y presione <b>Escanear</b></div>';
    })
    .catch(() => {
      document.getElementById('addonu-list').innerHTML = '<div style="padding:20px;color:#ef4444;text-align:center;">Error al cargar OLTs</div>';
    });
  
  document.getElementById('addonu-result').innerHTML = '';
  openModal('modalAddOnu');
}

function addOnuOltChanged() {
  const val = document.getElementById('addOnuOltSelect').value;
  if (val === 'new') {
    closeModal('modalAddOnu');
    showToast('Vaya a Configuración > SmartOLT para agregar una nueva OLT');
    return;
  }
  // Load OLT details to get default VLAN
  fetch('/api/olts')
    .then(r => r.json())
    .then(olts => {
      const olt = olts.find(function(o) { return o.id == val; });
      if (olt && olt.vlan_default) {
        document.getElementById('addonu-vlan').value = olt.vlan_default;
      } else {
        document.getElementById('addonu-vlan').value = '';
      }
    })
    .catch(function() {});
}

function scanOnus() {
  const oltId = document.getElementById('addOnuOltSelect').value;
  if (!oltId) { showToast('Seleccione una OLT primero', 'error'); return; }
  
  const listEl = document.getElementById('addonu-list');
  listEl.innerHTML = '<div style="padding:30px;text-align:center;color:#94a3b8;"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;"></i><br>Escanenado ONUs...</div>';
  
  fetch('/api/smartolt/onu/scan', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ olt_id: parseInt(oltId) })
  })
  .then(r => r.json())
  .then(d => {
    if (d.success && d.onus && d.onus.length > 0) {
      let h = '';
      d.onus.forEach(function(o) {
        const sn = o.sn || o.serial || o.serial_number || '';
        const nombre = o.name || o.nombre || '';
        const port = o.port || o.puerto || o.pon_port || '';
        const board = o.board || '';
        const scanNombre = o.name || o.nombre || '';
        h += '<div class="onu-scan-item" onclick="selectOnu(\'' + sn + '\',\'' + port + '\',\'' + (scanNombre || sn).replace(/'/g,'') + '\',\'' + ((o.onu_type_name||o.model||'')).replace(/'/g,'') + '\',\'' + board + '\')" style="padding:8px 12px;cursor:pointer;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center;" onmouseover="this.style.background=\'#eff6ff\'" onmouseout="this.style.background=\'\'">';
        var modelo = o.onu_type_name || o.model || '';
        h += '<div><span style="font-family:monospace;font-weight:600;color:#1e293b;">' + sn + '</span><br><span style="font-size:0.8rem;color:#64748b;">' + (modelo ? modelo + ' | ' : '') + (nombre || '') + '</span></div>';
        h += '<div style="text-align:right;"><span style="font-size:0.8rem;color:#6366f1;">' + (port ? 'Puerto ' + port : '') + '</span></div>';
        h += '</div>';
      });
      listEl.innerHTML = h;
    } else {
      listEl.innerHTML = '<div style="padding:30px;text-align:center;color:#94a3b8;"><i class="fas fa-satellite-dish" style="font-size:2rem;margin-bottom:10px;display:block;"></i>No hay ONUs pendientes<br><small>' + (d.message || '') + '</small></div>';
    }
  })
  .catch(e => {
    listEl.innerHTML = '<div style="padding:20px;color:#ef4444;text-align:center;">Error: ' + e.message + '</div>';
  });
}

function selectOnu(sn, port, nombre, model, board) {
  addOnuSelectedSerial = sn;
  addOnuSelectedPort = port;
  addOnuSelectedBoard = board;
  document.getElementById('addonu-board').value = board || '';
  document.getElementById('addonu-port').value = port || '';
  document.getElementById('addonu-sn').value = sn;
  document.getElementById('addonu-desc').value = nombre || '';
  document.getElementById('addonu-srvprofile').value = '';
  
  // Load ONU models and auto-select the one from SmartOLT
  var modeloDetectado = model || '';
  fetch('/api/smartolt/onu-types')
    .then(r => r.json())
    .then(d => {
      const sel = document.getElementById('addonu-model');
      sel.innerHTML = '<option value="">Seleccionar modelo</option>';
      var encontrado = false;
      if (d.success && d.data) {
        d.data.forEach(function(t) {
          var selected = (t.name === modeloDetectado) ? 'selected' : '';
          if (selected) encontrado = true;
          sel.innerHTML += '<option value="' + (t.name||'') + '" ' + selected + '>' + (t.name||'') + '</option>';
        });
      }
      // If model was detected but not in list, add it as selected
      if (modeloDetectado && !encontrado) {
        sel.innerHTML += '<option value="' + modeloDetectado + '" selected>' + modeloDetectado + ' (detectado)</option>';
      }
    })
    .catch(() => {
      // If failed to load types, still set the detected model
      if (modeloDetectado) {
        document.getElementById('addonu-model').innerHTML = '<option value="' + modeloDetectado + '" selected>' + modeloDetectado + '</option>';
      }
    });
  
  document.getElementById('addonu-step1').style.display = 'none';
  document.getElementById('addonu-step2').style.display = 'block';
}

var addOnuMode = 'route';

function seleccionarModoONU(mode) {
  addOnuMode = mode;
  var r = document.getElementById('onuModeRoute');
  var b = document.getElementById('onuModeBridge');
  if (mode === 'route') {
    r.style.borderColor = '#2563eb'; r.style.background = '#eff6ff'; r.style.fontWeight = '600';
    b.style.borderColor = '#e2e8f0'; b.style.background = '#fff'; b.style.fontWeight = '400';
  } else {
    b.style.borderColor = '#2563eb'; b.style.background = '#eff6ff'; b.style.fontWeight = '600';
    r.style.borderColor = '#e2e8f0'; r.style.background = '#fff'; r.style.fontWeight = '400';
  }
}

function addOnuBackToStep1() {
  document.getElementById('addonu-step2').style.display = 'none';
  document.getElementById('addonu-step1').style.display = 'block';
}

function authorizeOnu() {
  const oltId = document.getElementById('addOnuOltSelect').value;
  const serial = document.getElementById('addonu-sn').value;
  const model = document.getElementById('addonu-model').value;
  const desc = document.getElementById('addonu-desc').value;
  const srvId = document.getElementById('addOnuServicioId').value;
  
  if (!oltId || !serial) { showToast('Seleccione una ONU', 'error'); return; }
  
  document.getElementById('addonu-result').innerHTML = '<div style="color:#6366f1;font-weight:600;"><i class="fas fa-spinner fa-spin"></i> Autorizando ONU...</div>';
  
  fetch('/api/smartolt/onu/authorize', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      olt_id: parseInt(oltId),
      serial: serial,
      model: model,
      descripcion: desc,
      vlan: document.getElementById('addonu-vlan').value || null,
      servicio_id: parseInt(srvId) || null,
      cliente_nombre: '<%= cliente.nombre.replace(/'/g, "\\'") %>',
      board: addOnuSelectedBoard || null,
      port: addOnuSelectedPort || null,
      onu_mode: addOnuMode || 'route',
      auth_type: addOnuAuthType || 'dhcp',
      pppoe_user: addOnuPppoeUser || '',
      pppoe_pass: addOnuPppoePass || ''
    })
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      document.getElementById('addonu-result').innerHTML = '<div style="color:#16a34a;font-weight:600;"><i class="fas fa-check-circle"></i> ONU autorizada exitosamente</div>';
      setTimeout(function() { closeModal('modalAddOnu'); location.reload(); }, 1500);
    } else {
      document.getElementById('addonu-result').innerHTML = '<div style="color:#ef4444;">' + (d.message || 'Error') + '</div>';
    }
  })
  .catch(e => {
    document.getElementById('addonu-result').innerHTML = '<div style="color:#ef4444;">Error: ' + e.message + '</div>';
  });
}

// ========== CAMBIAR TITULAR ==========
var tfSelectedClient = null;

function openTransferModal(srvId, currentOwner) {
  tfSelectedClient = null;
  document.getElementById('tfServicioId').value = srvId;
  document.getElementById('tfCurrentOwner').textContent = currentOwner;
  document.getElementById('tfSearch').value = '';
  document.getElementById('tfResults').innerHTML = '<div style="padding:20px;text-align:center;color:#94a3b8;">Escriba al menos 2 caracteres para buscar</div>';
  document.getElementById('tfConfirmBtn').disabled = true;
  document.getElementById('tfResultMsg').innerHTML = '';
  openModal('modalTransfer');
}

var tfSearchTimeout = null;
function searchTransferClients() {
  if (tfSearchTimeout) clearTimeout(tfSearchTimeout);
  var q = document.getElementById('tfSearch').value.trim();
  if (q.length < 2) {
    document.getElementById('tfResults').innerHTML = '<div style="padding:20px;text-align:center;color:#94a3b8;">Escriba al menos 2 caracteres para buscar</div>';
    return;
  }
  tfSearchTimeout = setTimeout(function() {
    fetch('/api/clientes/buscar?q=' + encodeURIComponent(q))
      .then(function(r) { return r.json(); })
      .then(function(clientes) {
        var h = '';
        if (!clientes || clientes.length === 0) {
          h = '<div style="padding:20px;text-align:center;color:#94a3b8;">No se encontraron clientes</div>';
        } else {
          for (var ci = 0; ci < clientes.length; ci++) {
            var cl = clientes[ci];
            var nom = (cl.nombre || '').replace(/'/g, '');
          h += '<div class="tf-result-item" onclick="selectTransferClient.call(this, ' + cl.id + ')" data-nombre="' + nom + '" style="padding:10px 14px;cursor:pointer;border-bottom:1px solid #f1f5f9;">';
            h += '<div style="font-weight:600;">' + nom + '</div>';
            h += '<div style="font-size:0.78rem;color:#64748b;">' + (cl.cedula || '') + ' | ' + (cl.telefono || '') + '</div>';
            h += '</div>';
          }
        }
        document.getElementById('tfResults').innerHTML = h;
      })
      .catch(function() {
        document.getElementById('tfResults').innerHTML = '<div style="padding:20px;text-align:center;color:#ef4444;">Error de conexion</div>';
      });
  }, 300);
}// ========== CONFIGURACIÓN ==========
var clientConfigCache = null;

function loadClientConfig() {
  var cid = <%= cliente.id %>;
  fetch('/api/clientes/' + cid + '/config')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.success) return;
      clientConfigCache = data;

      // Update free services description
      var freeSvc = data.gratis || [];
      document.getElementById('cfg-free-desc').textContent = freeSvc.length > 0
        ? freeSvc.map(function(s) { return s.plan_nombre || ('Svc #' + s.id); }).join(', ')
        : 'Ninguno';

      // Update no-suspend services description
      var noSuspSvc = data.no_suspend || [];
      document.getElementById('cfg-nosuspend-desc').textContent = noSuspSvc.length > 0
        ? noSuspSvc.map(function(s) { return s.plan_nombre || ('Svc #' + s.id); }).join(', ')
        : 'Ninguno';

      // Update discounts description
      var descSvc = data.descuentos || [];
      document.getElementById('cfg-discount-desc').textContent = descSvc.length > 0
        ? descSvc.map(function(s) { return (s.plan_nombre || 'Svc #' + s.id) + ' ($' + parseFloat(s.descuento_monto).toFixed(2) + ')'; }).join(', ')
        : 'Ninguno';

      // Notificar facturas toggle
      document.getElementById('cfg-notificar-facturas').checked = data.cliente.notificar_facturas === 1 || data.cliente.notificar_facturas === true;

      // Facturar consolidado toggle
      document.getElementById('cfg-facturar-consolidado').checked = data.cliente.facturar_consolidado === 1 || data.cliente.facturar_consolidado === true;

      // Comprobante fiscal
      var cf = data.cliente.comprobante_fiscal || 'ninguno';
      var radios = document.querySelectorAll('input[name="cfg-comprobante"]');
      radios.forEach(function(r) { r.checked = (r.value === cf); });
    })
    .catch(function(e) {
      showToast('Error al cargar configuración: ' + e.message, 'error');
    });
}

function openSvcConfigModal(tipo) {
  var cid = <%= cliente.id %>;
  var titleEl = document.getElementById('svcConfigModalTitle');
  var descEl = document.getElementById('svcConfigModalDesc');
  var tipoEl = document.getElementById('svcConfigTipo');
  var listEl = document.getElementById('svcConfigList');
  var discountFields = document.getElementById('svcConfigDiscountFields');
  var billingFields = document.getElementById('svcConfigBillingFields');

  tipoEl.value = tipo;
  discountFields.style.display = 'none';
  billingFields.style.display = 'none';

  var titles = {
    free: '<span style="color:#10b981;">🎁</span> Cliente Gratis',
    nosuspend: '<span style="color:#f59e0b;">🛡️</span> No Suspender',
    billing: '<span style="color:#2563eb;">📄</span> Facturación',
    discount: '<span style="color:#8b5cf6;">🏷️</span> Descuentos'
  };
  var descs = {
    free: 'Selecciona los servicios que serán gratis (no generan factura ni se suspenden).',
    nosuspend: 'Selecciona los servicios protegidos contra suspensión automática.',
    billing: 'Configura el ciclo de facturación para cada servicio.',
    discount: 'Aplica un descuento fijo en RD$ a la factura de cada servicio.'
  };

  titleEl.innerHTML = titles[tipo] || 'Configurar';
  descEl.textContent = descs[tipo] || '';

  if (tipo === 'discount') {
    discountFields.style.display = 'block';
  }
  if (tipo === 'billing') {
    billingFields.style.display = 'block';
    // Update the ciclo select with available cycles
    var cicloSel = document.getElementById('svcBillingCiclo');
    // Keep existing options from EJS rendering
  }

  // Fetch config to get services
  fetch('/api/clientes/' + cid + '/config')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.success) { listEl.innerHTML = '<div style="padding:20px;color:#ef4444;">Error al cargar servicios</div>'; return; }
      var servicios = data.servicios || [];
      if (servicios.length === 0) {
        listEl.innerHTML = '<div style="padding:20px;text-align:center;color:#94a3b8;">Este cliente no tiene servicios</div>';
        return;
      }
      var html = '';
      servicios.forEach(function(s) {
        var isActive = false;
        var extraHtml = '';
        if (tipo === 'free') {
          isActive = s.es_gratis === 1;
        } else if (tipo === 'nosuspend') {
          isActive = s.no_suspender === 1;
        } else if (tipo === 'discount') {
          isActive = parseFloat(s.descuento_monto || 0) > 0;
          extraHtml = isActive ? ' ($' + parseFloat(s.descuento_monto).toFixed(2) + ')' : '';
        } else if (tipo === 'billing') {
          // Show cycle info
          var cicloId = s.ciclo_id || '';
          extraHtml = cicloId ? ' | Ciclo: #' + cicloId : '';
        }
        var statusBadge = s.estado === 'activo' ? '<span class="vc-badge vc-badge-ok">Activo</span>'
          : s.estado === 'suspendido' ? '<span class="vc-badge vc-badge-err">Susp.</span>'
          : '<span class="vc-badge vc-badge-warn">' + (s.estado || '—') + '</span>';
        html += '<div class="cfg-svc-item" data-svc-id="' + s.id + '">';
        html += '<div><div class="cfg-svc-name">' + (s.plan_nombre || 'Servicio #' + s.id) + '</div><div class="cfg-svc-status">' + statusBadge + extraHtml + '</div></div>';
        if (tipo === 'discount') {
          html += '<div><input type="number" class="cfg-input-discount" data-svc-id="' + s.id + '" value="' + (parseFloat(s.descuento_monto || 0).toFixed(2)) + '" min="0" step="0.01" placeholder="0.00"></div>';
        } else if (tipo === 'billing') {
          html += '<div><span style="font-size:0.78rem;color:#64748b;">Configura el ciclo en <strong>Editar Servicio</strong></span></div>';
        } else {
          html += '<label class="cfg-toggle"><input type="checkbox" class="svc-config-check" data-svc-id="' + s.id + '" ' + (isActive ? 'checked' : '') + '><span class="cfg-toggle-slider"></span></label>';
        }
        html += '</div>';
      });
      listEl.innerHTML = html;

      // For billing, update the ciclo select info
      if (tipo === 'billing') {
        var cicloSel = document.getElementById('svcBillingCiclo');
        if (cicloSel) {
          cicloSel.onchange = function() {
            var opt = cicloSel.options[cicloSel.selectedIndex];
            var info = document.getElementById('svcBillingCicloInfo');
            if (opt && opt.value) {
              info.style.display = 'block';
              info.innerHTML = '📄 Gen: Día ' + (opt.getAttribute('data-invoice') || '—') + ' | Corte: Día ' + (opt.getAttribute('data-suspend') || '—');
            } else {
              info.style.display = 'none';
            }
          };
        }
      }
    })
    .catch(function(e) {
      listEl.innerHTML = '<div style="padding:20px;color:#ef4444;">Error: ' + e.message + '</div>';
    });

  openModal('modalSvcConfig');
}

function saveSvcConfigAction() {
  var tipo = document.getElementById('svcConfigTipo').value;
  var cid = <%= cliente.id %>;
  var promises = [];

  if (tipo === 'discount') {
    // Collect discount amounts
    var inputs = document.querySelectorAll('#svcConfigList .cfg-input-discount');
    inputs.forEach(function(inp) {
      var svcId = parseInt(inp.getAttribute('data-svc-id'));
      var monto = parseFloat(inp.value) || 0;
      promises.push(
        fetch('/api/clientes/' + cid + '/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tipo: 'discount', servicio_id: svcId, valor: monto })
        }).then(function(r) { return r.json(); })
      );
    });
  } else if (tipo === 'billing') {
    // Use the current ciclo selection from the modal
    var cicloSel = document.getElementById('svcBillingCiclo');
    if (cicloSel && cicloSel.value) {
      var cicloId = cicloSel.value;
      var allSvcIds = [];
      document.querySelectorAll('#svcConfigList .cfg-svc-item').forEach(function(item) {
        allSvcIds.push(parseInt(item.getAttribute('data-svc-id')));
      });
      allSvcIds.forEach(function(svcId) {
        promises.push(
          fetch('/api/clientes/' + cid + '/config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tipo: 'billing', servicio_id: svcId, ciclo_id: cicloId })
          }).then(function(r) { return r.json(); })
        );
      });
    }
  } else {
    // Collect checkboxes
    var checks = document.querySelectorAll('#svcConfigList .svc-config-check');
    checks.forEach(function(chk) {
      var svcId = parseInt(chk.getAttribute('data-svc-id'));
      var valor = chk.checked ? 1 : 0;
      promises.push(
        fetch('/api/clientes/' + cid + '/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tipo: tipo, servicio_id: svcId, valor: valor })
        }).then(function(r) { return r.json(); })
      );
    });
  }

  // Also handle the global discount/billing fields in the modal
  if (tipo === 'discount' && document.getElementById('svcConfigDiscountFields').style.display === 'block') {
    var globalAmount = parseFloat(document.getElementById('svcDiscountAmount').value) || 0;
    if (globalAmount > 0) {
      // Apply to all services without individual discounts
      document.querySelectorAll('#svcConfigList .cfg-input-discount').forEach(function(inp) {
        var svcId = parseInt(inp.getAttribute('data-svc-id'));
        var currentVal = parseFloat(inp.value) || 0;
        if (currentVal === 0) {
          promises.push(
            fetch('/api/clientes/' + cid + '/config', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ tipo: 'discount', servicio_id: svcId, valor: globalAmount })
            }).then(function(r) { return r.json(); })
          );
        }
      });
    }
  }

  Promise.all(promises).then(function() {
    showToast('Configuración guardada');
    closeModal('modalSvcConfig');
    loadClientConfig();
  }).catch(function(e) {
    showToast('Error al guardar: ' + e.message, 'error');
  });
}

function toggleClienteConfig(campo, valor) {
  var cid = <%= cliente.id %>;
  fetch('/api/clientes/' + cid + '/toggle', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ campo: campo, valor: valor })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      showToast('Configuración actualizada');
    } else {
      showToast('Error: ' + (data.message || 'desconocido'), 'error');
    }
  })
  .catch(function(e) {
    showToast('Error de conexión: ' + e.message, 'error');
  });
}

function guardarConfigGlobal() {
  // Gather all toggles state and save
  var cid = <%= cliente.id %>;
  var notif = document.getElementById('cfg-notificar-facturas').checked ? 1 : 0;
  var consolidado = document.getElementById('cfg-facturar-consolidado').checked ? 1 : 0;
  var comprobante = document.querySelector('input[name="cfg-comprobante"]:checked');
  var cfVal = comprobante ? comprobante.value : 'ninguno';

  var btn = document.querySelector('#vcTab-configuracion .vc-btn-primary');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

  var p1 = fetch('/api/clientes/' + cid + '/toggle', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ campo: 'notificar_facturas', valor: notif })
  }).then(function(r) { return r.json(); });

  var p2 = fetch('/api/clientes/' + cid + '/toggle', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ campo: 'facturar_consolidado', valor: consolidado })
  }).then(function(r) { return r.json(); });

  var p3 = fetch('/api/clientes/' + cid + '/toggle', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ campo: 'comprobante_fiscal', valor: cfVal })
  }).then(function(r) { return r.json(); });

  Promise.all([p1, p2, p3]).then(function() {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
    var msg = document.getElementById('cfg-saved-msg');
    msg.style.display = 'block';
    setTimeout(function() { msg.style.display = 'none'; }, 2000);
    showToast('✓ Configuración guardada');
  }).catch(function(e) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
    showToast('Error: ' + e.message, 'error');
  });
}
function selectTransferClient(id, nombre) {
  if (typeof nombre === "undefined" && this && this.dataset) nombre = this.dataset.nombre;
  tfSelectedClient = { id: id, nombre: nombre };
  document.getElementById('tfConfirmBtn').disabled = false;
  document.getElementById('tfResultMsg').innerHTML = '<div style="padding:8px;background:#f0fdf4;border-radius:6px;color:#166534;font-weight:600;">Cliente seleccionado: <strong>' + nombre + '</strong></div>';
}

function confirmTransfer() {
  if (!tfSelectedClient) return;
  const srvId = parseInt(document.getElementById('tfServicioId').value);
  
  fetch('/api/servicios/transferir', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ servicio_id: srvId, nuevo_cliente_id: tfSelectedClient.id })
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      showToast('Servicio transferido a ' + tfSelectedClient.nombre);
      closeModal('modalTransfer');
      location.reload();
    } else {
      document.getElementById('tfResultMsg').innerHTML = '<div style="color:#ef4444;">' + (d.message || 'Error') + '</div>';
    }
  })
  .catch(e => {
    document.getElementById('tfResultMsg').innerHTML = '<div style="color:#ef4444;">Error: ' + e.message + '</div>';
  });
}
</script>
