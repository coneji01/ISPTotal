<script>
var bulkSelectedIds = [];
var _bulkServicioIds = [];
var currentPage = 1;
var totalPages = 1;
var statusFilter = 'todos';
var sortColumn = '';
var sortDirection = 'asc';
var _bulkPendingAction = '';
var _bulkWhatsappData = [];
var _deleteId = null;
var _deleteNombre = '';
var _buscarTimer = null;

var MONTHS = ['','Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,"&#039;");
}

function trimStr(str, max) {
  if (!str) return '';
  return str.length > max ? str.substring(0, max) + '...' : str;
}

function formatDate(dateStr) {
  if (!dateStr) return '';
  try {
    var ds = String(dateStr).replace(' ', 'T');
    if (!ds.includes('T')) ds += 'T00:00:00';
    var d = new Date(ds);
    return d.getDate() + ' ' + (MONTHS[d.getMonth()] || '') + ' ' + d.getFullYear();
  } catch(e) {
    return String(dateStr).substring(0, 10);
  }
}

function formatFechaCorta(dateStr) {
  if (!dateStr) return '';
  try {
    var parts = String(dateStr).substring(0, 10).split('-');
    if (parts.length === 3) {
      return parts[2] + ' ' + (MONTHS[parseInt(parts[1])] || '') + ' ' + parts[0].substring(2);
    }
    return String(dateStr).substring(0, 10);
  } catch(e) {
    return String(dateStr).substring(0, 10);
  }
}

// ===== FILTER PILLS =====
function cambiarFiltro(valor, btn) {
  statusFilter = valor;
  document.querySelectorAll('.tab-pill').forEach(function(p) {
    p.classList.toggle('active', p.dataset.value === valor);
  });
  currentPage = 1;
  cargarTabla();
}

function resetPagina() {
  currentPage = 1;
  cargarTabla();
}

// ===== SEARCH DEBOUNCE =====
function buscarDebounce() {
  clearTimeout(_buscarTimer);
  _buscarTimer = setTimeout(function() {
    currentPage = 1;
    cargarTabla();
  }, 350);
}

// ===== SORT =====
function ordenarPor(col) {
  if (sortColumn === col) {
    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
  } else {
    sortColumn = col;
    sortDirection = 'asc';
  }
  // Update sort icons
  document.querySelectorAll('[id^="sortIcon_"]').forEach(function(ic) {
    ic.className = 'fas fa-sort';
    ic.style.color = 'var(--border-color)';
  });
  var icon = document.getElementById('sortIcon_' + col);
  if (icon) {
    icon.className = 'fas fa-sort-' + (sortDirection === 'asc' ? 'up' : 'down');
    icon.style.color = 'var(--accent)';
  }
  cargarTabla();
}

// ===== MAIN TABLE LOAD =====
function cargarTabla(pagina) {
  if (pagina) currentPage = pagina;
  var zona = document.getElementById('filtroZona').value;
  var facturas = document.getElementById('filtroFacturas').value;
  var fecha = document.getElementById('filtroFecha').value;
  var q = document.getElementById('buscador').value;
  var mostrar = document.getElementById('filtroMostrar').value;

  var params = new URLSearchParams();
  params.set('ajax', 'list');
  params.set('status', statusFilter);
  params.set('search', q);
  params.set('zona', zona);
  params.set('facturas', facturas);
  if (fecha) params.set('fecha', fecha);
  params.set('page', currentPage);
  params.set('per_page', mostrar === 'all' ? '9999' : mostrar);
  if (sortColumn) { params.set('sort', sortColumn); params.set('dir', sortDirection); }
  params.set('_t', Date.now());

  fetch('/modulo?pagina=Clientes&' + params.toString())
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status === 'success') {
        document.getElementById('tablaResultados').innerHTML = data.html;
        var total = data.total || 0;
        var el = document.getElementById('totalClientesText');
        el.textContent = 'Total: ' + total + ' titulares';
        var pp = parseInt(mostrar) || 15;
        totalPages = Math.max(1, Math.ceil(total / pp));
        renderPaginacion();
        updateBulkCount();
      } else {
        document.getElementById('tablaResultados').innerHTML = '<tr><td colspan="9" style="text-align:center; padding:30px; color:var(--accent-danger);">Error al cargar datos</td></tr>';
      }
    })
    .catch(function(err) {
      document.getElementById('tablaResultados').innerHTML = '<tr><td colspan="9" style="text-align:center; padding:30px; color:var(--accent-danger);">Error de conexión</td></tr>';
    });
}

// ===== PAGINATION =====
function renderPaginacion() {
  var h = '<div style="display:flex; gap:4px; align-items:center;">';
  if (currentPage > 1) {
    h += '<button class="btn btn-sm btn-secondary" onclick="cargarTabla(' + (currentPage - 1) + ')" style="border-radius:6px; padding:5px 10px; font-size:0.78rem;">«</button>';
  }
  var start = Math.max(1, currentPage - 2);
  var end = Math.min(totalPages, currentPage + 2);
  for (var i = start; i <= end; i++) {
    h += '<button class="btn btn-sm ' + (i === currentPage ? 'btn-primary' : 'btn-secondary') + '" onclick="cargarTabla(' + i + ')" style="border-radius:6px; padding:5px 10px; font-size:0.78rem;">' + i + '</button>';
  }
  if (currentPage < totalPages) {
    h += '<button class="btn btn-sm btn-secondary" onclick="cargarTabla(' + (currentPage + 1) + ')" style="border-radius:6px; padding:5px 10px; font-size:0.78rem;">»</button>';
  }
  h += '</div>';
  document.getElementById('paginacion').innerHTML = h;
}

// ===== EXPAND TOGGLE =====
function toggleExpand(btn, clienteId) {
  var isOpen = btn.classList.contains('open');
  btn.classList.toggle('open');
  
  var row = document.getElementById('expand-' + clienteId);
  if (row) {
    row.style.display = isOpen ? 'none' : '';
    return;
  }
  
  // Fetch services and create expand row
  fetch('/api/clientes/' + clienteId + '/servicios')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (!d.success || !d.data || d.data.length === 0) {
        showToast('No hay servicios', 'error');
        btn.classList.remove('open');
        return;
      }
      var svcs = d.data;
      var tbody = document.getElementById('tablaResultados');
      var tr = document.getElementById('row-' + clienteId);
      if (!tr) return;
      
      var expandHtml = '<tr id="expand-' + clienteId + '" class="expand-tr"><td colspan="9" class="expand-td"><div class="svc-expand-panel">';
      svcs.forEach(function(s) {
        var estadoClass = s.estado === 'activo' ? 'svc-dot-active' : (s.estado === 'suspendido' ? 'svc-dot-suspended' : 'svc-dot-retired');
        var deudaColor = '';
        // No tenemos deuda aquí, lo omitimos
        var ipHtml = s.ip ? '<a href="http://' + s.ip + '/" target="_blank" class="svc-tag svc-tag-ip" title="Abrir ' + s.ip + '"><i class="fas fa-network-wired"></i>' + s.ip + '</a>' : '';
        var onuHtml = s.onu_sn ? '<span class="svc-tag svc-tag-nic"><i class="fas fa-microchip"></i> ' + s.onu_sn + '</span>' : '';
        expandHtml += '<div class="svc-expand-row">';
        expandHtml += '<span class="svc-dot ' + estadoClass + '"></span>';
        expandHtml += '<span class="svc-plan">' + escapeHtml(s.plan_nombre || 'Sin plan') + '</span>';
        expandHtml += '<span class="svc-tag svc-tag-nic">#' + s.id + '</span>';
        expandHtml += ipHtml;
        expandHtml += onuHtml;
        expandHtml += '</div>';
      });
      expandHtml += '</div></td></tr>';
      
      // Insert after the row
      tr.insertAdjacentHTML('afterend', expandHtml);
    })
    .catch(function() {
      showToast('Error al cargar servicios', 'error');
      btn.classList.remove('open');
    });
}

// ===== BULK SELECTION =====
function toggleSelectAll(el) {
  var checked = el.checked;
  document.querySelectorAll('.clienteCheck').forEach(function(cb) {
    cb.checked = checked;
  });
  updateBulkCount();
}

function updateBulkCount() {
  bulkSelectedIds = [];
  document.querySelectorAll('.clienteCheck:checked').forEach(function(cb) {
    bulkSelectedIds.push(parseInt(cb.value));
  });
  var count = bulkSelectedIds.length;
  var wrapper = document.getElementById('bulkActionsWrapper');
  document.getElementById('bulkCount').textContent = count;
  wrapper.style.display = count > 0 ? 'flex' : 'none';
}

// ===== MODALS =====
function abrirModal(id) { document.getElementById(id).style.display = 'flex'; }
function cerrarModal(id) { var el = document.getElementById(id); if (el) el.style.display = 'none'; }

function abrirModalNuevo() {
  document.getElementById('formCliente').reset();
  document.getElementById('modalNuevoCliente').style.display = 'flex';
}

// ===== SAVE CLIENTE =====
function guardarCliente(e) {
  e.preventDefault();
  var fd = new FormData(document.getElementById('formCliente'));
  fetch('/modulo?pagina=Clientes&ajax=save', {
    method: 'POST',
    body: fd
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Cliente guardado correctamente');
      cerrarModal('modalNuevoCliente');
      cargarTabla();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

// ===== SAVE INFORMAL =====
// ===== DELETE CLIENTE =====
function borrarCliente(id, nombre) {
  _deleteId = id;
  _deleteNombre = nombre || '';
  abrirModal('modalConfirmDelete');
}

function confirmarEliminar() {
  if (!_deleteId) return;
  var eliminarOnu = document.getElementById('chkEliminarOnuSmartolt').checked;
  var fd = new FormData();
  fd.append('id', _deleteId);
  fd.append('eliminar_onu_smartolt', eliminarOnu ? '1' : '0');

  fetch('/modulo?pagina=Clientes&ajax=delete', {
    method: 'POST',
    body: fd
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Cliente eliminado');
      _deleteId = null;
      cerrarModal('modalConfirmDelete');
      cargarTabla();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

// ===== INDIVIDUAL ACTION (select service modal) =====
function accionIndividual(clienteId, accion) {
  var nombreAccion = { 'activar':'Activar', 'suspender':'Suspender', 'retirar':'Retirar', 'eliminar':'Eliminar' }[accion] || accion;
  
  if (accion === 'eliminar') {
    var nombre = '';
    var nameEl = document.querySelector('#row-' + clienteId + ' .row-name-link');
    if (nameEl) nombre = nameEl.textContent.trim();
    borrarCliente(clienteId, nombre);
    return;
  }
  
  // Fetch services for this client
  fetch('/api/clientes/' + clienteId + '/servicios')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.success || !data.data || data.data.length === 0) {
        showToast('El cliente no tiene servicios', 'error');
        return;
      }
      var servicios = data.data;
      
      if (servicios.length === 1) {
        ejecutarAccion(clienteId, servicios[0].id, accion);
        return;
      }
      
      // Show service selector modal
      var modal = document.getElementById('modalSelectorServicios');
      document.getElementById('modalSelectorTitulo').textContent = nombreAccion + ' - Seleccionar Servicio';
      var lista = document.getElementById('modalSelectorLista');
      lista.innerHTML = '';
      servicios.forEach(function(s) {
        var div = document.createElement('div');
        div.style.cssText = 'padding:10px 14px;border:1px solid var(--border-color);border-radius:8px;margin-bottom:6px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:all 0.15s;';
        div.onmouseover = function() { this.style.borderColor = 'var(--accent)'; this.style.background = 'var(--bg-body)'; };
        div.onmouseout = function() { this.style.borderColor = 'var(--border-color)'; this.style.background = ''; };
        div.onclick = function() { ejecutarAccion(clienteId, s.id, accion); cerrarModal('modalSelectorServicios'); };
        var estado = s.estado || 'activo';
        var color = estado === 'activo' ? '#16a34a' : (estado === 'suspendido' ? '#d97706' : '#94a3b8');
        div.innerHTML = '<div><strong>' + escapeHtml(s.plan_nombre || 'Servicio #' + s.id) + '</strong><br><small style="color:var(--text-muted);">' + escapeHtml(s.direccion || '') + ' | IP: ' + (s.ip || '—') + '</small></div><span style="color:' + color + ';font-weight:600;font-size:0.78rem;">' + estado.toUpperCase() + '</span>';
        lista.appendChild(div);
      });
      abrirModal('modalSelectorServicios');
    })
    .catch(function() { showToast('Error al cargar servicios', 'error'); });
}

function ejecutarAccion(clienteId, servicioId, accion) {
  var url = '/api/servicios/' + servicioId + '/' + accion;
  if (accion === 'retirar') url = '/api/servicios/' + servicioId + '/retirar';
  if (accion === 'eliminar') url = '/api/servicios/' + servicioId + '/eliminar';
  
  fetch(url, { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.success) {
        showToast('Servicio ' + (accion === 'retirar' ? 'retirado' : accion + 'do'));
        cargarTabla();
      } else {
        showToast('Error: ' + (d.message || 'desconocido'), 'error');
      }
    })
    .catch(function() { showToast('Error de conexión', 'error'); });
}

// ===== WHATSAPP BIENVENIDA =====
function enviarBienvenida(clienteId, telefono, nombre) {
  if (!telefono) {
    showToast('El cliente no tiene teléfono registrado', 'error');
    return;
  }
  
  fetch('/api/template/get?key=bienvenida_sms')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.status !== 'success' || !d.content) {
        showToast('Error al cargar plantilla de bienvenida', 'error');
        return;
      }
      
      var msg = d.content
        .replace(/{client_name}/g, nombre)
        .replace(/{company_name}/g, 'ISP Total')
        .replace(/{company_phone}/g, '')
        .replace(/{current_date}/g, new Date().toLocaleDateString('es-DO'));
      
      // Show preview modal for single client
      var modal = document.getElementById('modalWhatsApp');
      document.getElementById('whatsappPreview').textContent = msg;
      modal.dataset.clientId = clienteId;
      modal.dataset.telefono = telefono;
      modal.dataset.nombre = nombre;
      modal.dataset.msg = msg;
      abrirModal('modalWhatsApp');
    })
    .catch(function() { showToast('Error al cargar plantilla', 'error'); });
}

function confirmarEnvioWhatsApp() {
  var modal = document.getElementById('modalWhatsApp');
  var telefono = modal.dataset.telefono;
  var nombre = modal.dataset.nombre;
  var msg = modal.dataset.msg;
  
  cerrarModal('modalWhatsApp');
  
  fetch('/api/openwa/test', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ phone: telefono, message: msg })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) showToast('Mensaje enviado a ' + nombre);
    else showToast('Error: ' + (res.msg || 'desconocido'), 'error');
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

// ===== EXPORT PDF =====
function exportarListaPDF() {
  window.print();
}

// ===== BULK ACTIONS =====
function ejecutarBulk(action) {
  if (bulkSelectedIds.length === 0) {
    showToast('Selecciona al menos un cliente', 'error');
    return;
  }
  _bulkPendingAction = action;
  var count = bulkSelectedIds.length;
  var modal = document.getElementById('bulkConfirmModal');
  var icon = document.getElementById('bulkConfirmIcon');
  var title = document.getElementById('bulkConfirmTitle');
  var msg = document.getElementById('bulkConfirmMsg');
  var btn = document.getElementById('bulkConfirmBtn');

  if (action === 'suspender') {
    icon.innerHTML = '<i class="fas fa-pause-circle" style="color:#dc2626; font-size:2rem;"></i>';
    title.textContent = 'Suspender servicios';
    msg.innerHTML = '<div id="bulkSuspenderContent" style="text-align:center;"><i class="fas fa-spinner fa-spin"></i> Cargando servicios...</div>';
    btn.style.display = 'none';
    btn.style.background = '';
    // Fetch services info
    fetch('/api/clientes/servicios-info', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: bulkSelectedIds })
    }).then(function(r) { return r.json(); }).then(function(resp) {
      if (!resp.success || !resp.data || resp.data.length === 0) {
        document.getElementById('bulkSuspenderContent').innerHTML = '<div style="color:#dc2626;">No se encontraron servicios activos.</div>';
        return;
      }
      var html = '<div style="max-height:350px;overflow-y:auto;text-align:left;">';
      resp.data.forEach(function(cli) {
        html += '<div style="font-weight:700;font-size:0.85rem;color:var(--text-dark);padding:8px 0 4px;border-top:1px solid var(--border-color);">' + escapeHtml(cli.cliente_nombre) + '</div>';
        cli.servicios.forEach(function(svc) {
          var bg = svc.estado === 'activo' ? (svc.deuda > 0 ? '#fef2f2' : '#f0fdf4') : '#fef3c7';
          var label = svc.estado === 'activo' ? (svc.deuda > 0 ? 'RD$' + svc.deuda.toFixed(2) : 'Al día') : 'Suspendido';
          var labelColor = svc.estado === 'activo' ? (svc.deuda > 0 ? '#dc2626' : '#16a34a') : '#d97706';
          html += '<label style="display:flex;align-items:center;gap:8px;padding:6px 8px;margin:3px 0;border-radius:6px;background:' + bg + ';cursor:pointer;">';
          html += '<input type="checkbox" class="svc-suspender-check" data-cliente="' + cli.cliente_id + '" data-svc="' + svc.id + '" value="' + svc.id + '" checked style="width:16px;height:16px;">';
          html += '<span style="flex:1;font-size:0.82rem;"><b>#' + svc.id + '</b> ' + escapeHtml(svc.plan_nombre) + ' ' + (svc.direccion ? '- ' + escapeHtml(svc.direccion) : '') + '</span>';
          html += '<span style="font-size:0.72rem;font-weight:600;color:' + labelColor + ';background:#fff;padding:2px 8px;border-radius:10px;border:1px solid ' + labelColor + ';">' + label + '</span>';
          html += '</label>';
        });
      });
      html += '</div><div style="margin-top:8px; display:flex; gap:6px; justify-content:center;">';
      html += '<button class="btn btn-sm btn-secondary" onclick="document.querySelectorAll(\'.svc-suspender-check\').forEach(function(c){c.checked=true})">Seleccionar todos</button>';
      html += '<button class="btn btn-sm btn-secondary" onclick="document.querySelectorAll(\'.svc-suspender-check\').forEach(function(c){c.checked=false})">Deseleccionar todos</button></div>';
      document.getElementById('bulkSuspenderContent').innerHTML = html;
      btn.style.display = 'inline-flex';
      btn.textContent = 'Sí, Suspender seleccionados';
    }).catch(function() {
      document.getElementById('bulkSuspenderContent').innerHTML = '<div style="color:#dc2626;">Error al cargar servicios.</div>';
    });
  } else if (action === 'activar') {
    icon.innerHTML = '<i class="fas fa-play-circle" style="color:#16a34a; font-size:2rem;"></i>';
    title.textContent = 'Activar clientes';
    msg.innerHTML = '<div style="text-align:center;">¿Estás seguro que deseas activar los servicios de <b>' + count + '</b> cliente(s)?</div>';
    btn.style.display = 'inline-flex';
    btn.style.background = '#16a34a';
    btn.textContent = 'Sí, Activar';
  } else if (action === 'retirar') {
    icon.innerHTML = '<i class="fas fa-exclamation-triangle" style="color:#ea580c; font-size:2rem;"></i>';
    title.textContent = 'Retirar titulares';
    msg.innerHTML = '<div style="background:#fff7ed; border:1px solid #fed7aa; border-radius:8px; padding:12px;"><b>Estás retirando ' + count + ' titular(es).</b><br>Los servicios se eliminarán del MikroTik y de la OLT. ¿Seguro que deseas continuar?</div>';
    btn.style.display = 'inline-flex';
    btn.style.background = '#ea580c';
    btn.textContent = 'Sí, Retirar';
  } else if (action === 'eliminar') {
    icon.innerHTML = '<i class="fas fa-exclamation-triangle" style="color:#991b1b; font-size:2rem;"></i>';
    title.textContent = 'Eliminar titulares';
    msg.innerHTML = '<div style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; padding:12px;color:#7f1d1d;"><b>Estás eliminando ' + count + ' titular(es).</b><br>Esta acción es irrevocable y borrará todos los servicios del MikroTik. ¿Seguro?</div>';
    btn.style.display = 'inline-flex';
    btn.style.background = '#991b1b';
    btn.textContent = 'Sí, Eliminar';
  } else if (action === 'whatsapp') {
    icon.innerHTML = '<i class="fab fa-whatsapp" style="color:#25D366; font-size:2rem;"></i>';
    title.textContent = 'Enviar WhatsApp Masivo';
    msg.innerHTML = '<div style="text-align:center;">¿Enviar mensaje de bienvenida a <b>' + count + '</b> cliente(s)?<br><small style="color:var(--text-muted);">Se enviará con 2 segundos de diferencia entre cada mensaje.</small></div>';
    btn.style.display = 'inline-flex';
    btn.style.background = '#25D366';
    btn.textContent = 'Sí, Enviar';
  } else if (action === 'facturar') {
    icon.innerHTML = '<i class="fas fa-file-invoice-dollar" style="color:#2563eb; font-size:2rem;"></i>';
    title.textContent = 'Generar Facturas';
    msg.innerHTML = '<div style="text-align:center;">¿Generar factura para <b>' + count + '</b> cliente(s)?<br><small style="color:var(--text-muted);">Se creará una factura por cada servicio activo.</small></div>';
    btn.style.display = 'inline-flex';
    btn.style.background = '#2563eb';
    btn.textContent = 'Sí, Facturar';
  }
  abrirModal('bulkConfirmModal');
}

function confirmarBulk() {
  if (!_bulkPendingAction || bulkSelectedIds.length === 0) return;
  var action = _bulkPendingAction;

  if (action === 'whatsapp') {
    enviarWhatsappBulk();
    return;
  }

  if (action === 'facturar') {
    facturarBulk();
    return;
  }

  if (action === 'suspender') {
    var checks = document.querySelectorAll('.svc-suspender-check:checked');
    var servicioIds = [];
    checks.forEach(function(c) { servicioIds.push(parseInt(c.value)); });

    if (servicioIds.length === 0) {
      showToast('Selecciona al menos un servicio para suspender', 'error');
      return;
    }

    fetch('/api/servicios/batch-suspender', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ servicio_ids: servicioIds })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) {
        showToast(res.message || servicioIds.length + ' servicio(s) suspendido(s)');
        cerrarModal('bulkConfirmModal');
        cargarTabla();
      } else {
        showToast('Error: ' + (res.message || 'desconocido'), 'error');
      }
    })
    .catch(function() { showToast('Error de conexión', 'error'); });
    return;
  }

  // Acciones normales: activar, retirar, eliminar
  fetch('/modulo?pagina=Clientes&ajax=toggle_status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: action, ids: bulkSelectedIds })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Operación completada en ' + bulkSelectedIds.length + ' clientes');
      cerrarModal('bulkConfirmModal');
      cargarTabla();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

function enviarWhatsappBulk() {
  cerrarModal('bulkConfirmModal');
  showToast('Enviando mensajes...');
  var total = bulkSelectedIds.length;
  var enviados = 0;
  var errores = 0;
  var idx = 0;

  function enviarSiguiente() {
    if (idx >= total) {
      showToast('WhatsApp: ' + enviados + ' enviados, ' + errores + ' errores');
      return;
    }
    var id = bulkSelectedIds[idx];

    fetch('/api/clientes/' + id + '/info')
      .then(function(r) { return r.json(); })
      .then(function(cliente) {
        if (cliente.success && cliente.data.telefono) {
          enviarBienvenidaDirecta(cliente.data.telefono, cliente.data.nombre, function(ok) {
            if (ok) enviados++; else errores++;
            idx++;
            setTimeout(enviarSiguiente, 2000);
          });
        } else {
          errores++;
          idx++;
          setTimeout(enviarSiguiente, 500);
        }
      })
      .catch(function() {
        errores++;
        idx++;
        setTimeout(enviarSiguiente, 500);
      });
  }

  enviarSiguiente();
}

function enviarBienvenidaDirecta(telefono, nombre, callback) {
  if (!telefono) { if (callback) callback(false); return; }
  fetch('/api/template/get?key=bienvenida_sms')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var msg = (d.content || 'Hola {client_name}, bienvenido!')
        .replace(/{client_name}/g, nombre)
        .replace(/{company_name}/g, 'ISP Total')
        .replace(/{current_date}/g, new Date().toLocaleDateString('es-DO'));

      fetch('/api/openwa/test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: telefono, message: msg })
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (callback) callback(res.success === true);
        else callback(false);
      })
      .catch(function() { if (callback) callback(false); });
    })
    .catch(function() { if (callback) callback(false); });
}

function facturarBulk() {
  cerrarModal('bulkConfirmModal');
  showToast('Generando facturas...');
  fetch('/api/facturar/bulk', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ clientes: bulkSelectedIds })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.success) showToast(d.message || 'Facturas generadas');
    else showToast('Error: ' + (d.message || ''), 'error');
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

// ===== INIT =====
cargarTabla();
</script>
</div>