</style>

<script>
let bulkSelectedIds
let _bulkServicioIds = [];
let currentPage = 1;
let totalPages = 1;
let statusFilter = 'todos';
let sortColumn = '';
let sortDirection = 'asc';
let _bulkPendingAction = '';

function abrirModalNuevo() { document.getElementById('formCliente').reset(); abrirModal('modalNuevoCliente'); }
function abrirModalInformal() { document.getElementById('formInformal').reset(); abrirModal('modalInformal'); }

function setFiltroEstado(valor) {
  statusFilter = valor;
  document.querySelectorAll('.filter-pill').forEach(function(p) {
    p.classList.toggle('active', p.dataset.value === valor);
  });
  currentPage = 1;
  cargarTabla();
}

function ordenarPor(col) {
  if (sortColumn === col) {
    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
  } else {
    sortColumn = col;
    sortDirection = 'asc';
  }
  document.querySelectorAll('.sort-icon').forEach(function(ic) {
    ic.classList.toggle('active', ic.dataset.col === col);
  });
  cargarTabla();
}

function cargarTabla(pagina) {
  if (pagina) currentPage = pagina;
  const zona = document.getElementById('filtroZona').value;
  const facturas = document.getElementById('filtroFacturas').value;
  const fecha = document.getElementById('filtroFecha').value;
  const q = document.getElementById('buscador').value;
  const mostrar = document.getElementById('filtroMostrar').value;
  
  const pagEl = document.getElementById('paginacion');
  pagEl.style.display = (mostrar === 'all') ? 'none' : 'flex';
  
  var params = new URLSearchParams();
  params.set('ajax', 'list');
  params.set('status', statusFilter);
  params.set('search', q);
  params.set('zona', zona);
  params.set('facturas', facturas);
  if (fecha) params.set('fecha', fecha);
  params.set('page', currentPage);
  params.set('per_page', mostrar === 'all' ? '9999' : mostrar);
  if (sortColumn) { params.set('sort', sortColumn); params.set('dir', sortDirection); }
  params.set('_t', Date.now());
  
  fetch('/modulo?pagina=Clientes&' + params.toString())
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status === 'success') {
        document.getElementById('tablaResultados').innerHTML = data.html;
        var total = data.total || 0;
        var el = document.getElementById('totalClientesText');
        el.textContent = 'Total: ' + total + ' titulares';
        el.style.display = 'inline';
        var pp = parseInt(mostrar) || 15;
        totalPages = Math.max(1, Math.ceil(total / pp));
        renderPaginacion();
      } else {
        document.getElementById('tablaResultados').innerHTML = '<tr><td colspan="9" style="text-align:center; padding:30px; color:#ef4444;">Error al cargar datos</td></tr>';
      }
    })
    .catch(function(err) {
      document.getElementById('tablaResultados').innerHTML = '<tr><td colspan="9" style="text-align:center; padding:30px; color:#ef4444;">Error de conexión</td></tr>';
    });
}

function toggleExpand(btn, clienteId) {
  btn.classList.toggle("open");
  var row = document.querySelector(".svc-row[data-cliente='" + clienteId + "']");
  if (row) {
    row.style.display = (row.style.display === "none") ? "" : "none";
  }
}

function renderPaginacion() {
  var h = '<div style="display:flex; gap:4px; align-items:center;">';
  if (currentPage > 1) {
    h += '<button class="btn btn-sm btn-secondary" onclick="cargarTabla(' + (currentPage - 1) + ')" style="border-radius:6px; padding:5px 10px; font-size:0.78rem;">«</button>';
  }
  var start = Math.max(1, currentPage - 2);
  var end = Math.min(totalPages, currentPage + 2);
  for (let i = start; i <= end; i++) {
    h += '<button class="btn btn-sm ' + (i === currentPage ? 'btn-primary' : 'btn-secondary') + '" onclick="cargarTabla(' + i + ')" style="border-radius:6px; padding:5px 10px; font-size:0.78rem;">' + i + '</button>';
  }
  if (currentPage < totalPages) {
    h += '<button class="btn btn-sm btn-secondary" onclick="cargarTabla(' + (currentPage + 1) + ')" style="border-radius:6px; padding:5px 10px; font-size:0.78rem;">»</button>';
  }
  h += '</div>';
  document.getElementById('paginacion').innerHTML = h;
}

function toggleAll() {
  var checked = document.getElementById('selectAll').checked;
  document.querySelectorAll('.clienteCheck').forEach(function(cb) { cb.checked = checked; cb.dispatchEvent(new Event('change')); });
  actualizarBulkSelection();
}

function toggleCliente(id) {
  var cb = document.querySelector('.clienteCheck[data-id="' + id + '"]');
  if (cb) { cb.checked = !cb.checked; }
  actualizarBulkSelection();
}

function actualizarBulkSelection() {
  bulkSelectedIds = [];
  document.querySelectorAll('.clienteCheck:checked').forEach(function(cb) {
    bulkSelectedIds.push(parseInt(cb.dataset.id));
  });
  document.getElementById('bulkCount').textContent = (bulkSelectedIds.length > 0 ? bulkSelectedIds.length : 'Ninguno') + ' seleccionado(s)';

function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'\/g,"&#039;");
}
}

function ejecutarBulk(action) {
  if (bulkSelectedIds.length === 0) return;
  _bulkPendingAction = action;
  var count = bulkSelectedIds.length;
  var modal = document.getElementById('bulkConfirmModal');
  var icon = document.getElementById('bulkConfirmIcon');
  var title = document.getElementById('bulkConfirmTitle');
  var msg = document.getElementById('bulkConfirmMsg');
  var btn = document.getElementById('bulkConfirmBtn');
  var printBtn = document.getElementById('bulkPrintBtn');
  printBtn.style.display = 'none';

  if (action === 'suspender') {
    icon.innerHTML = '<i class="fas fa-pause-circle" style="color:#dc2626; font-size:2rem;"></i>';
    title.textContent = 'Suspender servicios';
    msg.innerHTML = '<div id="bulkSuspenderContent" style="text-align:center;"><i class="fas fa-spinner fa-spin"></i> Cargando servicios...</div>';
    btn.style.display = 'none';
    // Fetch services info
    fetch('/api/clientes/servicios-info', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: bulkSelectedIds })
    }).then(function(r) { return r.json(); }).then(function(resp) {
      if (!resp.success || !resp.data || resp.data.length === 0) {
        document.getElementById('bulkSuspenderContent').innerHTML = '<div style="color:#dc2626;">No se encontraron servicios activos.</div>';
        return;
      }
      var html = '<div style="max-height:350px;overflow-y:auto;text-align:left;">';
      resp.data.forEach(function(cli) {
        html += '<div style="font-weight:700;font-size:0.85rem;color:#1e293b;padding:8px 0 4px;border-top:1px solid #e2e8f0;">' + escapeHtml(cli.cliente_nombre) + '</div>';
        cli.servicios.forEach(function(svc) {
          var bg = svc.estado === 'activo' ? (svc.deuda > 0 ? '#fef2f2' : '#f0fdf4') : '#fef3c7';
          var label = svc.estado === 'activo' ? (svc.deuda > 0 ? 'RD$' + svc.deuda.toFixed(2) : 'Al día') : 'Suspendido';
          var labelColor = svc.estado === 'activo' ? (svc.deuda > 0 ? '#dc2626' : '#16a34a') : '#d97706';
          html += '<label style="display:flex;align-items:center;gap:8px;padding:6px 8px;margin:3px 0;border-radius:6px;background:' + bg + ';cursor:pointer;">';
          html += '<input type="checkbox" class="svc-suspender-check" data-cliente="' + cli.cliente_id + '" data-svc="' + svc.id + '" value="' + svc.id + '" checked style="width:16px;height:16px;">';
          html += '<span style="flex:1;font-size:0.82rem;"><b>#' + svc.id + '</b> ' + escapeHtml(svc.plan_nombre) + ' ' + (svc.direccion ? '- ' + escapeHtml(svc.direccion) : '') + '</span>';
          html += '<span style="font-size:0.72rem;font-weight:600;color:' + labelColor + ';background:#fff;padding:2px 8px;border-radius:10px;border:1px solid ' + labelColor + ';">' + label + '</span>';
          html += '</label>';
        });
      });
      html += '</div><div style="margin-top:8px;"><button class="btn btn-sm" onclick="document.querySelectorAll('.svc-suspender-check').forEach(function(c){c.checked=true})">Seleccionar todos</button>';
      html += '<button class="btn btn-sm" onclick="document.querySelectorAll('.svc-suspender-check').forEach(function(c){c.checked=false})">Deseleccionar todos</button></div>';
      document.getElementById('bulkSuspenderContent').innerHTML = html;
      btn.style.display = 'inline-flex'; btn.textContent = 'Sí, Suspender seleccionados';
      _bulkServicioIds = [];
    }).catch(function() {
      document.getElementById('bulkSuspenderContent').innerHTML = '<div style="color:#dc2626;">Error al cargar servicios.</div>';
    });
  } else if (action === 'activar') {
    icon.innerHTML = '<i class="fas fa-play-circle" style="color:#16a34a; font-size:2rem;"></i>';
    title.textContent = 'Activar clientes';
    msg.innerHTML = '<div style="text-align:center;">¿Estás seguro que deseas activar los servicios de <b>' + count + '</b> cliente(s)?</div>';
    btn.style.background = '#16a34a'; btn.textContent = 'Sí, Activar';
  } else if (action === 'retirar') {
    icon.innerHTML = '<i class="fas fa-exclamation-triangle" style="color:#ea580c; font-size:2rem;"></i>';
    title.textContent = 'Retirar titulares';
    msg.innerHTML = '<div style="background:#fff7ed; border:1px solid #fed7aa; border-radius:8px; padding:12px; color:#7c2d12;"><b>Estás retirando ' + count + ' titular(es).</b><br>Los servicios se eliminarán del MikroTik y de la OLT. ¿Seguro que deseas continuar?</div>';
    btn.style.background = '#ea580c'; btn.textContent = 'Sí, Retirar';
  } else if (action === 'eliminar') {
    icon.innerHTML = '<i class="fas fa-exclamation-triangle" style="color:#991b1b; font-size:2rem;"></i>';
    title.textContent = 'Eliminar titulares';
    msg.innerHTML = '<div style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; padding:12px; color:#7f1d1d;"><b>Estás eliminando ' + count + ' titular(es).</b><br>Esta acción es irrevocable y borrará todos los servicios del MikroTik. ¿Seguro?</div>';
    btn.style.background = '#991b1b'; btn.textContent = 'Sí, Eliminar';
  } else if (action === 'whatsapp') {
    icon.innerHTML = '<i class="fab fa-whatsapp" style="color:#25D366; font-size:2rem;"></i>';
    title.textContent = 'Enviar WhatsApp';
    msg.innerHTML = '<div style="text-align:center;">¿Enviar mensaje de bienvenida a <b>' + count + '</b> cliente(s)?<br><small style="color:#64748b;">Se enviará con 2 segundos de diferencia entre cada mensaje.</small></div>';
    btn.style.background = '#25D366'; btn.textContent = 'Sí, Enviar';
  } else if (action === 'facturar') {
    icon.innerHTML = '<i class="fas fa-file-invoice-dollar" style="color:#2563eb; font-size:2rem;"></i>';
    title.textContent = 'Generar Facturas';
    msg.innerHTML = '<div style="text-align:center;">¿Generar factura para <b>' + count + '</b> cliente(s)?<br><small style="color:#64748b;">Se creará una factura por cada servicio activo.</small></div>';
    btn.style.background = '#2563eb'; btn.textContent = 'Sí, Facturar';
  }
  abrirModal('bulkConfirmModal');
}

function confirmarBulk() {
  if (!_bulkPendingAction || bulkSelectedIds.length === 0) return;
  var action = _bulkPendingAction;
  
  if (action === 'whatsapp') {
    enviarWhatsappBulk();
    return;
  }
  
  if (action === 'facturar') {
    facturarBulk();
    return;
  }
  
  if (action === 'suspender') {
    // Obtener servicios seleccionados
    var checks = document.querySelectorAll('.svc-suspender-check:checked');
    var servicioIds = [];
    checks.forEach(function(c) { servicioIds.push(parseInt(c.value)); });
    
    if (servicioIds.length === 0) {
      showToast('Selecciona al menos un servicio para suspender', 'error');
      return;
    }
    
    fetch('/api/servicios/batch-suspender', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ servicio_ids: servicioIds })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) {
        showToast(res.message || servicioIds.length + ' servicio(s) suspendido(s)');
        cerrarModal('bulkConfirmModal');
        cargarTabla();
      } else {
        showToast('Error: ' + (res.message || 'desconocido'), 'error');
      }
    })
    .catch(function() {
      showToast('Error de conexión', 'error');
    });
    return;
  }
  
  // Acciones normales: activar, retirar, eliminar
  fetch('/modulo?pagina=Clientes&ajax=toggle_status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: action, ids: bulkSelectedIds })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Operación completada en ' + bulkSelectedIds.length + ' clientes');
      cerrarModal('bulkConfirmModal');
      cargarTabla();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
  })
  .catch(function() {
    showToast('Error de conexión', 'error');
  });
}

function enviarWhatsappBulk() {
  cerrarModal('bulkConfirmModal');
  showToast('Enviando mensajes...');
  var total = bulkSelectedIds.length;
  var enviados = 0;
  var errores = 0;
  var idx = 0;
  
  function enviarSiguiente() {
    if (idx >= total) {
      showToast('WhatsApp: ' + enviados + ' enviados, ' + errores + ' errores');
      return;
    }
    var id = bulkSelectedIds[idx];
    
    // Obtener datos del cliente y enviar mensaje
    fetch('/api/clientes/' + id + '/info')
      .then(function(r) { return r.json(); })
      .then(function(cliente) {
        if (cliente.success && cliente.data.telefono) {
          // Send welcome message
          enviarBienvenidaDirecta(cliente.data.telefono, cliente.data.nombre, function(ok) {
            if (ok) enviados++; else errores++;
            idx++;
            setTimeout(enviarSiguiente, 2000);
          });
        } else {
          errores++;
          idx++;
          setTimeout(enviarSiguiente, 500);
        }
      })
      .catch(function() {
        errores++;
        idx++;
        setTimeout(enviarSiguiente, 500);
      });
  }
  
  enviarSiguiente();
}

function enviarBienvenidaDirecta(telefono, nombre, callback) {
  if (!telefono) { if (callback) callback(false); return; }
  fetch('/api/template/get?key=bienvenida_sms')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var msg = (d.content || 'Hola {client_name}, bienvenido!')
        .replace(/{client_name}/g, nombre)
        .replace(/{company_name}/g, 'Joel Wifi Dominicana')
        .replace(/{company_phone}/g, '8092470033')
        .replace(/{current_date}/g, new Date().toLocaleDateString('es-DO'));
      
      fetch('/api/openwa/test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: telefono, message: msg })
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (callback) callback(res.success);
      })
      .catch(function() { if (callback) callback(false); });
    })
    .catch(function() { if (callback) callback(false); });
}

function facturarBulk() {
  cerrarModal('bulkConfirmModal');
  showToast('Generando facturas...');
  fetch('/api/facturar/bulk', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ clientes: bulkSelectedIds })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.success) showToast(d.message || 'Facturas generadas');
    else showToast('Error: ' + (d.message || ''), 'error');
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

function guardarCliente(e) {
  e.preventDefault();
  var fd = new FormData(document.getElementById('formCliente'));
  fetch('/modulo?pagina=Clientes&ajax=save', {
    method: 'POST',
    body: fd
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Cliente guardado correctamente');
      cerrarModal('modalNuevoCliente');
      cargarTabla();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

function guardarInformal(e) {
  e.preventDefault();
  var nombre = document.getElementById('infNombre').value.trim();
  if (!nombre) { showToast('El nombre es obligatorio', 'error'); return; }
  
  var fd = new FormData();
  fd.append('nombre', nombre);
  fd.append('cedula', document.getElementById('infCedula').value);
  fd.append('telefono', document.getElementById('infTelefono').value);
  fd.append('zona_id', document.getElementById('infZona').value);
  fd.append('apodo', document.getElementById('infApodo').value);
  fd.append('direccion', document.getElementById('infDireccion').value);
  
  fetch('/modulo?pagina=Clientes&ajax=save', {
    method: 'POST',
    body: fd
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Cliente informal creado');
      cerrarModal('modalInformal');
      cargarTabla();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

var deleteId = null;
function borrarCliente(id) { deleteId = id; abrirModal('modalConfirmDelete'); }
function confirmarEliminar() {
  if (!deleteId) return;
  var eliminarOnu = document.getElementById('chkEliminarOnuSmartolt').checked;
  var fd = new FormData();
  fd.append('id', deleteId);
  fd.append('eliminar_onu_smartolt', eliminarOnu ? '1' : '0');
  
  fetch('/modulo?pagina=Clientes&ajax=delete', {
    method: 'POST',
    body: fd
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Cliente eliminado');
      deleteId = null;
      cerrarModal('modalConfirmDelete');
      cargarTabla();
    } else {
      showToast('Error: ' + (res.message || 'desconocido'), 'error');
    }
  })
  .catch(function() { showToast('Error de conexión', 'error'); });
}

function exportarLista() {
  window.print();
}

// ===== ENVIAR BIENVENIDA WHATSAPP =====
function enviarBienvenida(clienteId, telefono, nombre) {
  if (!telefono) {
    showToast('El cliente no tiene teléfono registrado', 'error');
    return;
  }
  
  // Get welcome template from templates table
  fetch('/api/template/get?key=bienvenida_sms')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.status !== 'success' || !d.content) {
        showToast('Error al cargar plantilla', 'error');
        return;
      }
      
      var template = d.content;
      var company = 'Joel Wifi Dominicana';
      var cPhone = '8092470033';
      var cEmail = 'info@joelwifi.com';
      
      // Also get company info
      fetch('/api/config/get?keys=company_name,company_phone,company_email')
        .then(function(r2) { return r2.json(); })
        .then(function(d2) {
          if (d2.status === 'success') {
            company = d2.data.company_name || company;
            cPhone = d2.data.company_phone || cPhone;
            cEmail = d2.data.company_email || cEmail;
          }
          
          // Replace placeholders
          var msg = template
            .replace(/{client_name}/g, nombre)
            .replace(/{company_name}/g, company)
            .replace(/{company_phone}/g, cPhone)
            .replace(/{company_email}/g, cEmail)
            .replace(/{current_date}/g, new Date().toLocaleDateString('es-DO'))
            .replace(/{client_phone}/g, telefono)
            .replace(/{plan_name}/g, 'Fibra')
            .replace(/{plan_price}/g, '')
            .replace(/{service_address}/g, '')
            .replace(/{service_ip}/g, '');
          
          sendWelcome(telefono, nombre, msg);
        })
        .catch(function() {
          sendWelcome(telefono, nombre, template.replace(/{client_name}/g, nombre));
        });
    })
    .catch(function() {
      showToast('Error al cargar plantilla', 'error');
    });
}

function sendWelcome(telefono, nombre, msg) {
  if (confirm('Enviar mensaje de bienvenida a ' + nombre + ' (' + telefono + ')?\n\n' + msg)) {
    fetch('/api/openwa/test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone: telefono, message: msg })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) showToast('Mensaje enviado a ' + nombre);
      else showToast('Error: ' + (res.msg || 'desconocido'), 'error');
    })
    .catch(function() { showToast('Error de conexión', 'error'); });
  }
}

function abrirModal(id) { document.getElementById(id).style.display = 'flex'; }
function cerrarModal(id) { document.getElementById(id).style.display = 'none'; }

// ===== ACCIONES POR CLIENTE =====
function toggleAcciones(clienteId) {
  var menu = document.getElementById('acciones-menu-' + clienteId);
  if (menu.style.display === 'block') { menu.style.display = 'none'; return; }
  // Cerrar otros menus abiertos
  document.querySelectorAll('[id^="acciones-menu-"]').forEach(function(m) { m.style.display = 'none'; });
  menu.style.display = 'block';
}

// Cerrar menus al hacer clic fuera
document.addEventListener('click', function(e) {
  if (!e.target.closest('[id^="acciones-menu-"]') && !e.target.closest('button[onclick*="toggleAcciones"]')) {
    document.querySelectorAll('[id^="acciones-menu-"]').forEach(function(m) { m.style.display = 'none'; });
  }
});

function accionCliente(clienteId, accion) {
  var nombres = { 'activar':'Activar', 'suspender':'Suspender', 'retirar':'Retirar', 'tr069':'TR069', 'eliminar':'Eliminar' };
  
  if (accion === 'eliminar') {
    if (!confirm('¿Eliminar este cliente? Se borrarán todos sus datos.')) return;
    fetch('/modulo?pagina=Clientes&ajax=delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: clienteId })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.success) { showToast('Cliente eliminado'); cargarTabla(); }
      else showToast('Error: ' + (d.message || 'desconocido'), 'error');
    })
    .catch(function() { showToast('Error de conexión', 'error'); });
    return;
  }
  
  if (accion === 'tr069') {
    window.location.href = '/modulo?pagina=TR069&cliente_id=' + clienteId;
    return;
  }
  
  // Activar, Suspender, Retirar: obtener servicios del cliente
  mostrarSelectorServicios(clienteId, accion, nombres[accion]);
}

function mostrarSelectorServicios(clienteId, accion, nombreAccion) {
  fetch('/api/clientes/' + clienteId + '/servicios')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.success || !data.data || data.data.length === 0) {
        showToast('El cliente no tiene servicios', 'error');
        return;
      }
      
      var servicios = data.data;
      
      if (servicios.length === 1) {
        // Solo un servicio, ejecutar directamente
        ejecutarAccion(clienteId, servicios[0].id, accion);
        return;
      }
      
      // Mostrar modal de seleccion
      var modal = document.getElementById('modalSelectorServicios');
      document.getElementById('modalSelectorTitulo').textContent = nombreAccion + ' - Seleccionar Servicio';
      var lista = document.getElementById('modalSelectorLista');
      lista.innerHTML = '';
      servicios.forEach(function(s) {
        var div = document.createElement('div');
        div.style.cssText = 'padding:10px 14px;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:all 0.15s;';
        div.onmouseover = function() { this.style.borderColor = '#6366f1'; this.style.background = '#f5f3ff'; };
        div.onmouseout = function() { this.style.borderColor = '#e2e8f0'; this.style.background = ''; };
        div.onclick = function() { ejecutarAccion(clienteId, s.id, accion); cerrarModal('modalSelectorServicios'); };
        var estado = s.estado || 'activo';
        var color = estado === 'activo' ? '#16a34a' : (estado === 'suspendido' ? '#d97706' : '#94a3b8');
        div.innerHTML = '<div><strong>' + (s.plan_nombre || 'Servicio #' + s.id) + '</strong><br><small style="color:#64748b;">' + (s.direccion || '') + ' | IP: ' + (s.ip || '—') + '</small></div><span style="color:' + color + ';font-weight:600;font-size:0.78rem;">' + estado.toUpperCase() + '</span>';
        lista.appendChild(div);
      });
      abrirModal('modalSelectorServicios');
    })
    .catch(function() { showToast('Error al cargar servicios', 'error'); });
}

function ejecutarAccion(clienteId, servicioId, accion) {
  var url = '/api/servicios/' + servicioId + '/' + accion;
  if (accion === 'retirar') url = '/api/servicios/' + servicioId + '/eliminar';
  
  if (!confirm('¿' + accion.charAt(0).toUpperCase() + accion.slice(1) + ' servicio #' + servicioId + '?')) return;
  
  fetch(url, { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.success) {
        showToast('Servicio ' + (accion === 'retirar' ? 'retirado' : accion + 'do'));
        cargarTabla();
      } else {
        showToast('Error: ' + (d.message || 'desconocido'), 'error');
      }
    })
    .catch(function() { showToast('Error de conexión', 'error'); });
}

// Initialize on load
cargarTabla();
</script>