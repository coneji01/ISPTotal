  transform:rotate(180deg);
}

@media print {
  body { background: white; font-size: 11pt; }
  .sidebar, nav, .modal, #bulkActionsBar, .page-header button, .filter-pill, #filtroMostrar, #filtroZona, #filtroFacturas, #filtroFecha, #buscador, #selectAll, .clienteCheck, .btn-accion.eliminar, .btn-accion.suspender, .btn-accion.retirar, .btn-accion.reactivar, .expand-toggle { display: none; }
