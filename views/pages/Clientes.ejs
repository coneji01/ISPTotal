  cursor:pointer;
  font-size:0.78rem;
  transition:all 0.15s;
}
.btn-accion.ver {
  color:#6366f1;
  background:#eef2ff;
}
.btn-accion.ver:hover { background:#e0e7ff; }
.btn-accion.reactivar {
  color:#16a34a;
  background:#dcfce7;
}
.btn-accion.reactivar:hover { background:#bbf7d0; }
