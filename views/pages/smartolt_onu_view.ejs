<script>
$(document).ready(function() {
  var params = new URLSearchParams(window.location.search);
  var onuId = params.get('onu_id');
  if (onuId) {
    // En el futuro cargar datos desde API /api/olt/onu/:id
    $('#onuSn').text('ONU #' + onuId);
    $('#onuSn2').text('ONU #' + onuId);
  }
  
  // Traffic chart placeholder
  var ctx = document.getElementById('trafficChart');
  if (ctx) {
    ctx.getContext('2d').fillStyle = '#2C2C2E';
    ctx.getContext('2d').fillRect(0, 0, ctx.width, ctx.height);
    ctx.getContext('2d').fillStyle = '#5cb85c';
    ctx.getContext('2d').font = '14px Inter';
    ctx.getContext('2d').textAlign = 'center';
    ctx.getContext('2d').fillText('Traffic graph (requires Chart.js + OLT data)', ctx.width/2, ctx.height/2);
  }
});
</script>

