          <input type="text" class="form-control" id="vlanDescription" maxlength="64">
        </div>
        <div class="mb-3 form-check">
          <input type="checkbox" class="form-check-input" id="createOnOlt" disabled>
          <label class="form-check-label" for="createOnOlt">Create on OLT</label>
          <div class="form-text text-muted">Select an OLT first to enable this option.</div>
        </div>
        <div class="modal-footer border-top pt-3 mt-3">
