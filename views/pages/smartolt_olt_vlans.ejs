<script type="text/javascript">
$( document ).ready(function() {
  $.ajaxSetup({
    cache: false
  });
  
  window.jqxhrs = [];

  window.registerJqxhr = function(jqxhr) {
    jqxhrs.push(jqxhr);
  }

  window.abortJqxhr = function() {
    for (var i = jqxhrs.length - 1; i >= 0; i--) {
      if (jqxhrs[i]) {
        jqxhrs[i].abort();
      }
    }
    window.jqxhrs = [];
  }

  $(window).bind("beforeunload", function(event) {
    abortJqxhr();
  });

  function unregisterJqxhr(event, jqxhr, settings) {
    var idx = $.inArray(jqxhr, jqxhrs);
    if (idx != -1) {
      jqxhrs.splice(idx, 1);
    }
  }

  $(document).ajaxComplete(unregisterJqxhr);

  config = {
    X_TOKEN: '9C23F19BE06B4BEB93046ECFDF50FF91'
  }

  // Get OLT ID from URL query param or from data attribute
  var oltId = parseInt('<%= typeof oltId !== "undefined" ? oltId : "" %>') || getQueryParam('olt_id') || 1;

  function getQueryParam(name) {
    var urlParams = new URLSearchParams(window.location.search);
    return urlParams.get(name);
  }

  // Load VLANs from API
  function loadVlans() {
    var jqxhr = $.getJSON('/api/olts/' + oltId + '/vlans', function(data) {
      if (data.success && data.vlans) {
        renderVlansTable(data.vlans);
      } else if (data.vlans) {
        renderVlansTable(data.vlans);
      } else {
        $('#vlanTable tbody').html('<tr><td colspan="5" class="text-center text-muted">No VLANs found</td></tr>');
      }
    }).fail(function() {
      $('#vlanTable tbody').html('<tr><td colspan="5" class="text-center text-danger">Error loading VLANs</td></tr>');
    });
    registerJqxhr(jqxhr);
  }

  function renderVlansTable(vlans) {
    var tbody = $('#vlanTable tbody');
    tbody.empty();
    if (!vlans || vlans.length === 0) {
      tbody.html('<tr><td colspan="5" class="text-center text-muted">No VLANs found</td></tr>');
      return;
    }
    vlans.forEach(function(vlan) {
      var row = $('<tr>');
      row.append($('<td>').text(vlan.id || vlan.ID || ''));
      row.append($('<td>').text(vlan.vlan || vlan.VLAN || vlan.vlan_id || ''));
      row.append($('<td>').text(vlan.description || vlan.Description || ''));
      row.append($('<td>').text(vlan.created || vlan.Created || vlan.created_at || ''));
      var delBtn = $('<button class="btn btn-danger btn-sm" onclick="deleteVlan(' + (vlan.vlan || vlan.VLAN || vlan.id) + ')">Delete</button>');
      row.append($('<td>').append(delBtn));
      tbody.append(row);
    });
  }

  // Delete VLAN
  window.deleteVlan = function(vlanId) {
    if (confirm('Delete VLAN ' + vlanId + '?')) {
      $.ajax({
        url: '/api/olts/' + oltId + '/vlans/' + vlanId,
        method: 'DELETE',
        success: function(data) {
          if (data.success) {
            $.MessageBox('VLAN ' + vlanId + ' deleted successfully.');
            loadVlans();
          } else {
            $.MessageBox(data.error || 'Failed to delete VLAN.');
          }
        },
        error: function() {
          $.MessageBox('Error deleting VLAN.');
        }
      });
    }
  }

  // Add VLAN form submission
  $('#addVlanForm').on('submit', function(e) {
    e.preventDefault();
    var vlanId = $('#vlanId').val();
    var vlanDesc = $('#vlanDescription').val();
    var createOnOlt = $('#createOnOlt').is(':checked');

    if (!vlanId) {
      $.MessageBox('VLAN ID is required.');
      return;
    }

    $.ajax({
      url: '/api/olts/' + oltId + '/vlans',
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify({
        vlan: parseInt(vlanId),
        description: vlanDesc,
        create_on_olt: createOnOlt
      }),
      success: function(data) {
        if (data.success) {
          $.MessageBox('VLAN ' + vlanId + ' added successfully.');
          closeModal();
          $('#addVlanForm')[0].reset();
          loadVlans();
        } else {
          $.MessageBox(data.error || 'Failed to add VLAN.');
        }
      },
      error: function() {
        $.MessageBox('Error adding VLAN.');
      }
    });
  });

  // Initial load
  loadVlans();

  // Periodically refresh every 30s
  setInterval(loadVlans, 30000);

});

function closeModal() {
  document.getElementById('addVlanModal').style.display = 'none';
}

// Close modal when clicking outside the modal content
document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('addVlanModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
    }
  });
});
</script>

