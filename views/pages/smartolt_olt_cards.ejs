<!DOCTYPE html><html lang="en" class="smartolt-night"><head>
        <script>window.SMARTOLT_DB_THEME='night';</script>
    <script>try{var k='smartolt-night',lk='smartolt-theme-local',dbTheme=window.SMARTOLT_DB_THEME,local=null,pref,n;try{local=localStorage.getItem(lk);}catch(e){}if(local==='night'||local==='light'||local==='system'){pref=local;}else if(dbTheme==='night'||dbTheme==='light'||dbTheme==='system'){pref=dbTheme;}else{pref='system';}if(pref==='system'){n=!!(window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches);}else if(pref==='night'){n=true;}else{n=false;}try{localStorage.setItem(k,n?'1':'0');}catch(e){}if(n){document.documentElement.classList.add('smartolt-night');}else{document.documentElement.classList.remove('smartolt-night');}document.cookie=k+'='+(n?'1':'0')+'; path=/; max-age=31536000; SameSite=Lax'+(location.protocol==='https:'?'; Secure':'');}catch(e){}</script>
    <meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="/favicon.ico">
    <title>OLT Cards - ISPTotal</title>
    <link href="/public/smartolt-files/bootstrap-custom.css" rel="stylesheet">
    <link href="/public/smartolt-files/styles.css" rel="stylesheet">
    <link href="/public/smartolt-files/font-awesome.min.css" rel="stylesheet">
    <link href="/public/smartolt-files/inter-fonts.css" rel="stylesheet">
    <link href="/public/smartolt-files/dashboard-smartolt-night.css" rel="stylesheet">
    <script src="/public/smartolt-files/jquery.min.js"></script>
    <script src="/public/smartolt-files/dashboard-smartolt-night.js" defer></script>
</head>
<body class="smartolt-site">
<script>
$(document).ready(function() {
  var oltId = <%= locals.olt_id || 0 %>;
  
  function checkConnectivity() {
    $('#olt-status').html('<span class="text-muted"><i class="fa fa-spinner fa-spin"></i> Checking...</span>');
    $.getJSON('/api/core/ping?olt_id=' + oltId, function(data) {
      if (data && data.success && data.loss === '0') {
        $('#olt-status').html('<span class="label label-success"><i class="fa fa-check-circle"></i> Online</span> <small class="text-muted">(' + (data.rtt || '--') + ')</small>');
      } else {
        $('#olt-status').html('<span class="label label-danger"><i class="fa fa-times-circle"></i> Offline</span>');
      }
    }).fail(function() { $('#olt-status').html('<span class="label label-default">Unknown</span>'); });
  }
  
  $('#test-connection-btn').click(function() {
    var btn = $(this); btn.text('Testing...').prop('disabled', true);
    $('#test-result').html('<span class="text-muted"><i class="fa fa-spinner fa-spin"></i> Connecting...</span>');
    $.getJSON('/api/core/ping?olt_id=' + oltId, function(data) {
      if (data && data.success && data.loss === '0') {
        $('#test-result').html('<span class="text-success"><i class="fa fa-check-circle"></i> Connected! RTT: ' + (data.rtt || '--') + '</span>');
      } else {
        $('#test-result').html('<span class="text-danger"><i class="fa fa-times-circle"></i> ' + (data ? 'No response' : 'Failed') + '</span>');
      }
    }).fail(function() { $('#test-result').html('<span class="text-danger"><i class="fa fa-times-circle"></i> Connection failed</span>'); })
    .always(function() { btn.html('<i class="fa fa-plug"></i> Test connection').prop('disabled', false); });
  });
  
  function loadCards() {
    $('#cards-body').html('<tr><td colspan="6" class="text-center"><i class="fa fa-spinner fa-spin"></i> Loading cards...</td></tr>');
    $.getJSON('/api/olt/cards?olt_id=' + oltId, function(data) {
      if (!data || !data.success) { $('#cards-body').html('<tr><td colspan="6" class="text-danger">' + (data?.message||'Error') + '</td></tr>'); return; }
      if (!data.data || !data.data.length) { $('#cards-body').html('<tr><td colspan="6">No cards</td></tr>'); return; }
      var h = '';
      $.each(data.data, function(i, c) {
        var cls = c.status === 'INSERVICE' || c.status === 'Online' ? 'label-success' : 'label-danger';
        h += '<tr><td>' + c.slot + '</td><td>' + c.type + '</td><td>' + c.hardware + '</td><td>' + c.ports + '</td><td>' + (c.software||'-') + '</td><td><span class="label ' + cls + '">' + c.status + '</span></td></tr>';
      });
      $('#cards-body').html(h);
    }).fail(function() { $('#cards-body').html('<tr><td colspan="6" class="text-danger">Connection error</td></tr>'); });
  }
  
  checkConnectivity();
  loadCards();
  setInterval(loadCards, 30000);
});
</script>

<div class="smartolt-landing-hero-bg"></div>
<div id="content-wrapper">
  <div class="navbar navbar-default navbar-fixed-top">
    <div class="container">
      <div class="navbar-header">
        <button class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-main">
          <span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span>
        </button>
        <a class="navbar-brand" href="/modulo?pagina=GPONManager">Dashboard</a>
      </div>
      <div class="collapse navbar-collapse" id="navbar-main">
        <ul class="nav navbar-nav">
          <li><a href="/modulo?pagina=smartolt_olt">OLTs</a></li>
          <li class="active"><a href="#">OLT Cards</a></li>
        </ul>
        <ul class="nav navbar-nav navbar-right">
          <li><a id="smartolt-night-toggle" class="is-pref-night" title="Night mode"><i class="fa fa-moon-o"></i></a></li>
        </ul>
      </div>
    </div>
  </div>
  
  <div class="container">
    <h2>OLT Cards <small id="olt-status"><i class="fa fa-spinner fa-spin"></i></small></h2>
    <a href="/modulo?pagina=smartolt_olt" class="btn btn-success btn-sm">Back to OLTs list</a>
    <button id="test-connection-btn" class="btn btn-default btn-sm"><i class="fa fa-plug"></i> Test connection</button>
    <span id="test-result" style="margin-left:10px;"></span>
    <hr>
    <table class="table table-striped">
      <thead><tr><th>Slot</th><th>Type</th><th>Hardware</th><th>Ports</th><th>Software</th><th>Status</th></tr></thead>
      <tbody id="cards-body"><tr><td colspan="6" class="text-center"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr></tbody>
    </table>
  </div>
</div>
<footer><div class="text-center">ISPTotal GPON v1.0</div></footer>
<script src="/public/smartolt-files/bootstrap.min.js"></script>
</body></html>
