    <div class="container in">

<div class="container-fluid content-wrap">
	<h2>General Settings</h2>
		
	<form id="generalSettingsForm" method="POST" action="/general/save">
		
		<!-- Company Info Section -->
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title"><i class="fa fa-building"></i> Company Info</h3>
			</div>
			<div class="panel-body">
				<div class="form-horizontal">
					<div class="form-group">
						<label class="col-sm-3 control-label" for="companyName">Company Name</label>
						<div class="col-sm-6">
							<input type="text" class="form-control" id="companyName" name="companyName" value="<%= typeof companyName !== 'undefined' ? companyName : '' %>" placeholder="Enter company name">
						</div>
					</div>
					<div class="form-group">
						<label class="col-sm-3 control-label" for="companyEmail">Email</label>
						<div class="col-sm-6">
							<input type="email" class="form-control" id="companyEmail" name="companyEmail" value="<%= typeof companyEmail !== 'undefined' ? companyEmail : '' %>" placeholder="Enter email address">
						</div>
					</div>
					<div class="form-group">
						<label class="col-sm-3 control-label" for="companyPhone">Phone</label>
						<div class="col-sm-6">
							<input type="text" class="form-control" id="companyPhone" name="companyPhone" value="<%= typeof companyPhone !== 'undefined' ? companyPhone : '' %>" placeholder="Enter phone number">
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Notifications Section -->
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title"><i class="fa fa-bell"></i> Notifications</h3>
			</div>
			<div class="panel-body">
				<div class="form-horizontal">
					<div class="form-group">
						<div class="col-sm-offset-3 col-sm-9">
							<div class="checkbox">
								<label>
									<input type="checkbox" name="emailAlert" id="emailAlert" value="1" <%= typeof emailAlert !== 'undefined' && emailAlert == 1 ? 'checked' : '' %>>
									Email Alert
								</label>
							</div>
							<div class="checkbox">
								<label>
									<input type="checkbox" name="whatsappAlert" id="whatsappAlert" value="1" <%= typeof whatsappAlert !== 'undefined' && whatsappAlert == 1 ? 'checked' : '' %>>
									WhatsApp Alert
								</label>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Timezone Section -->
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title"><i class="fa fa-clock-o"></i> Timezone</h3>
			</div>
			<div class="panel-body">
				<div class="form-horizontal">
					<div class="form-group">
						<label class="col-sm-3 control-label" for="timezone">Timezone</label>
						<div class="col-sm-6">
							<select class="form-control" id="timezone" name="timezone">
								<option value="America/New_York" <%= typeof timezone !== 'undefined' && timezone === 'America/New_York' ? 'selected' : '' %>>America/New_York (EST/EDT)</option>
								<option value="America/Chicago" <%= typeof timezone !== 'undefined' && timezone === 'America/Chicago' ? 'selected' : '' %>>America/Chicago (CST/CDT)</option>
								<option value="America/Denver" <%= typeof timezone !== 'undefined' && timezone === 'America/Denver' ? 'selected' : '' %>>America/Denver (MST/MDT)</option>
								<option value="America/Los_Angeles" <%= typeof timezone !== 'undefined' && timezone === 'America/Los_Angeles' ? 'selected' : '' %>>America/Los_Angeles (PST/PDT)</option>
								<option value="America/Santo_Domingo" <%= typeof timezone !== 'undefined' && timezone === 'America/Santo_Domingo' ? 'selected' : '' %>>America/Santo_Domingo</option>
								<option value="America/Mexico_City" <%= typeof timezone !== 'undefined' && timezone === 'America/Mexico_City' ? 'selected' : '' %>>America/Mexico_City</option>
								<option value="America/Argentina/Buenos_Aires" <%= typeof timezone !== 'undefined' && timezone === 'America/Argentina/Buenos_Aires' ? 'selected' : '' %>>America/Argentina/Buenos_Aires</option>
								<option value="America/Sao_Paulo" <%= typeof timezone !== 'undefined' && timezone === 'America/Sao_Paulo' ? 'selected' : '' %>>America/Sao_Paulo</option>
								<option value="Europe/London" <%= typeof timezone !== 'undefined' && timezone === 'Europe/London' ? 'selected' : '' %>>Europe/London (GMT/BST)</option>
								<option value="Europe/Madrid" <%= typeof timezone !== 'undefined' && timezone === 'Europe/Madrid' ? 'selected' : '' %>>Europe/Madrid (CET/CEST)</option>
								<option value="Europe/Berlin" <%= typeof timezone !== 'undefined' && timezone === 'Europe/Berlin' ? 'selected' : '' %>>Europe/Berlin (CET/CEST)</option>
								<option value="Asia/Kolkata" <%= typeof timezone !== 'undefined' && timezone === 'Asia/Kolkata' ? 'selected' : '' %>>Asia/Kolkata (IST)</option>
								<option value="Asia/Shanghai" <%= typeof timezone !== 'undefined' && timezone === 'Asia/Shanghai' ? 'selected' : '' %>>Asia/Shanghai (CST)</option>
								<option value="Asia/Tokyo" <%= typeof timezone !== 'undefined' && timezone === 'Asia/Tokyo' ? 'selected' : '' %>>Asia/Tokyo (JST)</option>
								<option value="Australia/Sydney" <%= typeof timezone !== 'undefined' && timezone === 'Australia/Sydney' ? 'selected' : '' %>>Australia/Sydney (AEST/AEDT)</option>
								<option value="Pacific/Auckland" <%= typeof timezone !== 'undefined' && timezone === 'Pacific/Auckland' ? 'selected' : '' %>>Pacific/Auckland (NZST/NZDT)</option>
								<option value="UTC" <%= typeof timezone !== 'undefined' && timezone === 'UTC' ? 'selected' : '' %>>UTC</option>
							</select>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Session Timeout Section -->
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title"><i class="fa fa-hourglass-half"></i> Session Timeout</h3>
			</div>
			<div class="panel-body">
				<div class="form-horizontal">
					<div class="form-group">
						<label class="col-sm-3 control-label" for="sessionTimeout">Timeout (minutes)</label>
						<div class="col-sm-3">
							<input type="number" class="form-control" id="sessionTimeout" name="sessionTimeout" value="<%= typeof sessionTimeout !== 'undefined' ? sessionTimeout : '30' %>" min="1" max="1440">
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Save Button -->
		<div class="form-group">
			<div class="col-sm-12 text-center">
				<button type="submit" class="btn btn-primary btn-lg"><i class="fa fa-floppy-o"></i> Save Settings</button>
			</div>
		</div>

	</form>

</div>

