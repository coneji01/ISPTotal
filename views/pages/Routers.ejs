<div class="page-header">
  <h2><i class="fas fa-server"></i> Gestión de Routers</h2>
  <button class="btn btn-primary btn-sm" onclick="abrirModalCrear()"><i class="fas fa-plus"></i> Nuevo Router</button>
</div>

<div class="card">
  <div class="card-body" id="routersList">
    <div class="loading"><i class="fas fa-spinner fa-spin"></i><br>Cargando routers...</div>
  </div>
</div>

<!-- Modal Crear/Editar Router -->
<div id="modalRouter" class="modal" style="display:none">
  <div class="modal-content" style="max-width:700px;">
    <div class="modal-header">
      <h3 id="modalTitle"><i class="fas fa-plus-circle" style="color:#10b981;"></i> Nuevo Router</h3>
      <span class="modal-close" onclick="cerrarModal()">&times;</span>
    </div>
    <div class="modal-body">
      <form id="formRouter" onsubmit="guardarRouter(event)">
        <input type="hidden" name="accion" id="accionInput" value="guardar">
        <input type="hidden" name="id_router_edit" id="idRouterInput" value="">
        
        <div class="form-group">
          <label>Nombre del Router</label>
          <input type="text" name="name" id="routerName" class="form-control" placeholder="Ej: Router Cliente 001" required>
        </div>

        <!-- Selector de Tipo de Conexión -->
        <div class="form-group">
          <label>Tipo de Conexión</label>
          <div style="display:flex;gap:15px;margin-top:6px;">
            <label class="radio-card" onclick="seleccionarTipo('ip')" id="tipoIP" style="flex:1;padding:15px;border:2px solid #e2e8f0;border-radius:10px;cursor:pointer;text-align:center;transition:all .2s;background:#f0fdf4;border-color:#10b981;">
              <input type="radio" name="connection_type" value="ip" checked style="display:none;">
              <i class="fas fa-globe" style="font-size:1.5rem;color:#10b981;"></i>
              <div style="font-weight:600;margin-top:6px;">IP Pública</div>
              <div style="font-size:0.75rem;color:#64748b;">Conexión directa vía API</div>
            </label>
            <label class="radio-card" onclick="seleccionarTipo('vpn')" id="tipoVPN" style="flex:1;padding:15px;border:2px solid #e2e8f0;border-radius:10px;cursor:pointer;text-align:center;transition:all .2s;">
              <input type="radio" name="connection_type" value="vpn" style="display:none;">
              <i class="fas fa-lock" style="font-size:1.5rem;color:#6366f1;"></i>
              <div style="font-weight:600;margin-top:6px;">VPN (SSTP)</div>
              <div style="font-size:0.75rem;color:#64748b;">El router inicia el túnel</div>
            </label>
          </div>
        </div>

        <!-- Campos para IP Pública -->
        <div id="camposIP">
          <div class="row" style="display:flex;gap:10px;">
            <div class="form-group" style="flex:3;">
              <label>IP del Router</label>
              <input type="text" name="ip" id="routerIp" class="form-control" placeholder="IP pública del router">
            </div>
            <div class="form-group" style="flex:1;">
              <label>Puerto API</label>
              <input type="number" name="port" id="routerPort" class="form-control" value="8728">
            </div>
          </div>
          <div class="row" style="display:flex;gap:10px;">
            <div class="form-group" style="flex:1;">
              <label>Usuario API</label>
              <input type="text" name="user" id="routerUser" class="form-control" placeholder="admin">
            </div>
            <div class="form-group" style="flex:1;">
              <label>Password API</label>
              <input type="password" name="password" id="routerPass" class="form-control" placeholder="••••••••">
            </div>
          </div>
        </div>

        <!-- Campos para VPN -->
        <div id="camposVPN" style="display:none;">
          <div style="background:#eef2ff;border:1px solid #c7d2fe;border-radius:10px;padding:16px;margin-bottom:16px;">
            <p style="font-size:0.85rem;color:#4338ca;margin:0 0 10px 0;">
              <i class="fas fa-info-circle"></i> El router se conectará al servidor SSTP. 
              Se generará un usuario y script para copiar en el router.
            </p>
            <div class="row" style="display:flex;gap:10px;">
              <div class="form-group" style="flex:1;">
                <label>Router ID (Cliente)</label>
                <input type="text" id="vpnRouterId" class="form-control" placeholder="Ej: RTR-001" value="RTR-" style="font-family:monospace;">
              </div>
              <div class="form-group" style="flex:1;">
                <label>IP Fija VPN (opcional)</label>
                <input type="text" id="vpnFija" class="form-control" placeholder="10.50.x.x (dejar vacío = dinámica)" style="font-family:monospace;">
              </div>
            </div>
            <button type="button" class="btn btn-primary" onclick="generarScriptVPN()" id="btnGenScript" style="width:100%;margin-top:10px;">
              <i class="fas fa-file-code"></i> Generar Script
            </button>
          </div>

          <!-- Script Preview -->
          <div id="scriptPreview" style="display:none;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
              <label style="font-weight:600;font-size:0.9rem;">Script para el Router</label>
              <div>
                <button class="btn btn-sm btn-secondary" onclick="copiarScript()"><i class="fas fa-copy"></i> Copiar</button>
                <button class="btn btn-sm btn-secondary" onclick="descargarScript()"><i class="fas fa-download"></i> Descargar</button>
              </div>
            </div>
            <textarea id="scriptOutput" style="width:100%;height:350px;font-family:'Consolas','Monaco',monospace;font-size:0.78rem;background:#1e293b;color:#e2e8f0;border:none;border-radius:8px;padding:16px;resize:vertical;tab-size:2;" readonly></textarea>
            <p style="font-size:0.8rem;color:#64748b;margin-top:6px;">
              <i class="fas fa-info-circle"></i> Copia este script en la terminal del router MikroTik para conectarlo automáticamente.
            </p>
          </div>
        </div>

        <!-- Campos comunes -->
        <div style="border-top:1px solid #e2e8f0;padding-top:16px;margin-top:16px;">
          <div class="row" style="display:flex;gap:10px;">
            <div class="form-group" style="flex:1;">
              <label>OS</label>
              <select name="version" id="routerVersion" class="form-control">
                <option value="RouterOS v7">RouterOS v7</option>
                <option value="RouterOS v6">RouterOS v6</option>
              </select>
            </div>
            <div class="form-group" style="flex:1;">
              <label>Autenticación</label>
              <select name="auth_type" id="routerAuth" class="form-control">
                <option value="PPPoE">PPPoE</option>
                <option value="IP Estática">IP Estática</option>
                <option value="DHCP (IPoE)">DHCP (IPoE)</option>
              </select>
            </div>
          </div>
        </div>

        <!-- WAN Interface (solo IP) -->
        <div id="wanSection">
          <div style="display:flex;gap:10px;align-items:end;">
            <div class="form-group" style="flex:1;margin-bottom:0;">
              <label>Interfaz a monitorear (WAN)</label>
              <select name="interface_wan" id="routerWan" class="form-control">
                <option value="ether1">ether1</option>
                <option value="">-- Detectar interfaces --</option>
              </select>
            </div>
            <button type="button" class="btn btn-sm btn-secondary" onclick="detectarInterfaces()" id="btnDetectIfaces" style="margin-bottom:1px;height:fit-content;"><i class="fas fa-search"></i> Detectar</button>
          </div>
        </div>

        <div style="border-top:1px solid #e2e8f0;padding-top:16px;margin-top:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <label style="font-weight:600;font-size:0.9rem;">Rangos IP</label>
            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalPool()" id="btnAgregarRango">+ Agregar Rango</button>
          </div>
          <div id="poolList" style="font-size:0.85rem;">
            <div style="color:var(--text-gray);text-align:center;padding:10px;">Seleccione o guarde el router primero</div>
          </div>
        </div>

        <div class="form-group" style="margin-top:16px;">
          <label>DHCPv6 PD Pool</label>
          <input type="text" name="ipv6_pd" id="routerIpv6" class="form-control" placeholder="Nombre exacto del PD Pool en MikroTik">
        </div>

        <div style="border-top:1px solid #e2e8f0;padding-top:16px;margin-top:16px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
            <input type="checkbox" name="suspend_ips" id="suspendIps" value="1">
            <label for="suspendIps" style="margin:0;">¿Suspender ip's en este router?</label>
          </div>
        </div>

        <div class="btn-group" style="justify-content:flex-end;margin-top:16px;">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="button" class="btn btn-secondary" onclick="testConexion()" id="btnTestRouter" style="background:#0ea5e9;color:#fff;border:none;"><i class="fas fa-plug"></i> Probar Conexión</button>
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar Router</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Confirmar Eliminar -->
<div id="modalEliminar" class="modal" style="display:none">
  <div class="modal-content" style="max-width:400px;">
    <div class="modal-header">
      <h3><i class="fas fa-trash" style="color:#ef4444;"></i> Eliminar Router</h3>
      <span class="modal-close" onclick="cerrarModalEliminar()">&times;</span>
    </div>
    <div class="modal-body" style="text-align:center;">
      <div style="font-weight:700;font-size:1.05rem;color:#1e293b;margin-bottom:8px;">¿Eliminar router?</div>
      <div style="font-size:0.88rem;color:#64748b;margin-bottom:20px;" id="eliminarMsg"></div>
      <div class="btn-group" style="justify-content:center;">
        <button class="btn btn-secondary" onclick="cerrarModalEliminar()">Cancelar</button>
        <button class="btn btn-danger" id="btnConfirmarEliminar">Sí, eliminar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Resync -->
<div id="modalResync" class="modal" style="display:none">
  <div class="modal-content" style="max-width:420px;">
    <div class="modal-header">
      <h3><i class="fas fa-sync" style="color:#2563eb;"></i> Resincronizar MikroTik</h3>
      <span class="modal-close" onclick="cerrarModalResync()">&times;</span>
    </div>
    <div class="modal-body" style="text-align:center;">
      <div style="font-size:0.9rem;color:#64748b;margin-bottom:20px;">
        Esta acción cargará todos los datos con un delay de 1s por registro. El proceso tardará unos minutos.
      </div>
      <div class="btn-group" style="justify-content:center;">
        <button class="btn btn-secondary" onclick="cerrarModalResync()">Cancelar</button>
        <button class="btn btn-primary" id="btnConfirmarResync"><i class="fas fa-sync"></i> Sincronizar Ahora</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Pool IP -->
<div id="modalPool" class="modal" style="display:none">
  <div class="modal-content" style="max-width:500px;">
    <div class="modal-header">
      <h3><i class="fas fa-network-wired" style="color:#10b981;"></i> Nuevo Rango IP</h3>
      <span class="modal-close" onclick="cerrarModalPool()">&times;</span>
    </div>
    <div class="modal-body">
      <input type="hidden" id="poolRouterId" value="0">
      <div class="form-group">
        <label>Red (CIDR)</label>
        <input type="text" id="poolRed" class="form-control" placeholder="Ej: 10.0.0.0/24" oninput="calcularPool()">
      </div>
      <div class="form-group">
        <label>Tipo</label>
        <select id="poolTipo" class="form-control">
          <option value="privada">Privada</option>
          <option value="publica">Pública</option>
        </select>
      </div>
      <div id="poolCalculo" style="background:#f0fdf4;padding:12px;border-radius:8px;margin-bottom:10px;display:none;">
        <div style="font-size:0.85rem;"><strong>Total IPs disponibles:</strong> <span id="poolTotal">0</span></div>
        <div style="font-size:0.85rem;"><strong>Rango:</strong> <span id="poolRango">-</span></div>
      </div>
      <div id="poolError" style="color:#ef4444;font-size:0.85rem;display:none;"></div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-secondary" onclick="cerrarModalPool()">Cancelar</button>
      <button type="button" class="btn btn-primary" onclick="guardarPool()"><i class="fas fa-save"></i> Guardar Rango</button>
    </div>
  </div>
</div>

<script>
let routerActualId = 0;
let resyncId = null;
let scriptGenerado = '';

function seleccionarTipo(tipo) {
  document.getElementById('tipoIP').style.background = tipo === 'ip' ? '#f0fdf4' : '#fff';
  document.getElementById('tipoIP').style.borderColor = tipo === 'ip' ? '#10b981' : '#e2e8f0';
  document.getElementById('tipoVPN').style.background = tipo === 'vpn' ? '#eef2ff' : '#fff';
  document.getElementById('tipoVPN').style.borderColor = tipo === 'vpn' ? '#6366f1' : '#e2e8f0';
  
  document.getElementById('camposIP').style.display = tipo === 'ip' ? 'block' : 'none';
  document.getElementById('camposVPN').style.display = tipo === 'vpn' ? 'block' : 'none';
  document.getElementById('wanSection').style.display = tipo === 'ip' ? 'block' : 'none';
  
  // Ocultar boton Probar Conexion para VPN
  var btnTest = document.getElementById('btnTestRouter');
  if (btnTest) btnTest.style.display = tipo === 'ip' ? 'inline-block' : 'none';
  
  if (tipo === 'ip') {
    document.getElementById('routerIp').required = true;
  } else {
    document.getElementById('routerIp').required = false;
  }
}

function generarScriptVPN() {
  var name = document.getElementById('routerName').value.trim();
  var routerId = document.getElementById('vpnRouterId').value.trim();
  var ipFija = document.getElementById('vpnFija').value.trim();
  
  if (!name) { showToast('Primero ingrese el nombre del router', 'error'); return; }
  if (!routerId) { showToast('Ingrese un ID para el router', 'error'); return; }
  
  var btn = document.getElementById('btnGenScript');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generando...';
  
  fetch('/api/routers/generate-vpn-script', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: name, router_id: routerId, ip_fija: ipFija })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-file-code"></i> Generar Script';
    
    if (res.success) {
      document.getElementById('scriptPreview').style.display = 'block';
      document.getElementById('scriptOutput').value = res.script;
      scriptGenerado = res.script;
      
      // Auto-llenar campos ocultos
      document.getElementById('routerIp').value = res.vpn_ip || '';
      document.getElementById('routerUser').value = res.vpn_user || '';
      document.getElementById('routerPass').value = res.vpn_password || '';
      document.getElementById('vpnRouterId').value = res.vpn_user || '';
      document.getElementById('vpnFija').value = res.vpn_ip || '';
      
      // Seleccionar modo VPN
      document.querySelector('input[name="connection_type"][value="vpn"]').checked = true;
      seleccionarTipo('vpn');
      
      showToast('✅ Script generado exitosamente');
    } else {
      showToast('❌ Error: ' + (res.error || 'No se pudo generar'), 'error');
    }
  })
  .catch(function(e) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-file-code"></i> Generar Script';
    showToast('Error de conexión: ' + e.message, 'error');
  });
}

function copiarScript() {
  var textarea = document.getElementById('scriptOutput');
  textarea.select();
  
  // Intentar con clipboard API (requiere HTTPS)
  if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
    navigator.clipboard.writeText(textarea.value).then(function() {
      showToast('✅ Script copiado al portapapeles');
    }).catch(function() {
      document.execCommand('copy');
      showToast('✅ Script copiado');
    });
  } else {
    // Fallback para HTTP
    document.execCommand('copy');
    showToast('✅ Script copiado');
  }
}

function descargarScript() {
  var name = document.getElementById('routerName').value.trim() || 'router';
  var blob = new Blob([scriptGenerado], { type: 'text/plain' });
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = name.replace(/[^a-zA-Z0-9]/g, '_') + '_script.rsc';
  a.click();
  URL.revokeObjectURL(a.href);
}

function cargarRouters() {
  // Sincronizar estado de routers VPN primero
  fetch('/api/routers/sync-vpn-status', { method: 'POST' }).catch(function(){});
  
  fetch('/api/routers')
    .then(r => {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(data => {
      if (data.length === 0) {
        document.getElementById('routersList').innerHTML = '<p style="text-align:center;padding:40px;color:var(--text-gray);"><i class="fas fa-server" style="font-size:2rem;display:block;margin-bottom:10px;"></i>No hay routers registrados<br><button class="btn btn-primary btn-sm mt-20" onclick="abrirModalCrear()"><i class="fas fa-plus"></i> Nuevo Router</button></p>';
        return;
      }
      let html = '<div class="table-container"><table><thead><tr><th>#</th><th>Nombre</th><th>Tipo</th><th>IP / Puerto</th><th>Estado</th><th>Acciones</th></tr></thead><tbody>';
      data.forEach((r, i) => {
        const tipo = r.connection_type === 'vpn' ? '<span style="color:#6366f1;"><i class="fas fa-lock"></i> VPN</span>' : '<span style="color:#10b981;"><i class="fas fa-globe"></i> IP</span>';
        const status = r.connected ? '<span class="badge badge-success">Online</span>' : '<span class="badge badge-danger">Offline</span>';
        const ipInfo = r.connection_type === 'vpn' ? (r.vpn_ip || '—') : (r.ip + ':' + (r.port || 8728));
        html += '<tr><td>' + (i+1) + '</td><td><strong>' + r.name + '</strong></td><td>' + tipo + '</td><td style="font-family:monospace;font-size:0.85rem;">' + ipInfo + '</td><td>' + status + '</td><td>';
        html += '<div class="btn-group">';
        if (r.connection_type === 'vpn') {
          html += '<button class="btn btn-sm btn-primary" onclick="verScript(' + r.id + ')" title="Ver script"><i class="fas fa-file-code"></i></button>';
        }
        html += '<button class="btn btn-sm btn-primary" onclick="abrirModalResync(' + r.id + ')"><i class="fas fa-sync"></i></button>';
        html += '<button class="btn btn-sm btn-secondary" onclick="abrirModalEditar(' + r.id + ')"><i class="fas fa-edit"></i></button>';
        html += '<button class="btn btn-sm btn-danger" onclick="confirmarEliminar(' + r.id + ',\'' + r.name.replace(/'/g, "\\'") + '\')"><i class="fas fa-trash"></i></button>';
        html += '</div></td></tr>';
      });
      html += '</tbody></table></div>';
      document.getElementById('routersList').innerHTML = html;
    })
    .catch(function(e) {
      document.getElementById('routersList').innerHTML = '<p style="text-align:center;padding:30px;color:#ef4444;"><i class="fas fa-exclamation-triangle"></i> Error: ' + e.message + '</p>';
    });
}

function abrirModalCrear() {
  document.getElementById('formRouter').reset();
  document.getElementById('accionInput').value = 'guardar';
  document.getElementById('idRouterInput').value = '';
  document.getElementById('modalTitle').innerHTML = '<i class="fas fa-plus-circle" style="color:#10b981;"></i> Nuevo Router';
  document.getElementById('poolList').innerHTML = '<div style="color:var(--text-gray);text-align:center;padding:10px;">Guarde el router primero</div>';
  document.getElementById('scriptPreview').style.display = 'none';
  document.getElementById('camposIP').style.display = 'block';
  document.getElementById('camposVPN').style.display = 'none';
  document.getElementById('wanSection').style.display = 'block';
  document.getElementById('tipoIP').style.background = '#f0fdf4';
  document.getElementById('tipoIP').style.borderColor = '#10b981';
  document.getElementById('tipoVPN').style.background = '#fff';
  document.getElementById('tipoVPN').style.borderColor = '#e2e8f0';
  document.getElementById('vpnRouterId').value = 'RTR-';
  document.getElementById('vpnFija').value = '';
  document.getElementById('routerIp').required = true;
  document.getElementById('modalRouter').style.display = 'flex';
}

function abrirModalEditar(id) {
  fetch('/api/routers/' + id)
    .then(r => {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(r => {
      document.getElementById('accionInput').value = 'editar';
      document.getElementById('idRouterInput').value = r.id;
      document.getElementById('routerName').value = r.name;
      document.getElementById('routerIp').value = r.ip;
      document.getElementById('routerPort').value = r.port || 8728;
      document.getElementById('routerUser').value = r.user || '';
      document.getElementById('routerPass').value = r.password || '';
      document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit" style="color:#f59e0b;"></i> Editar Router';
      routerActualId = r.id;
      
      // Set connection type
      var tipo = r.connection_type || 'ip';
      seleccionarTipo(tipo);
      document.querySelector('input[name="connection_type"][value="' + tipo + '"]').checked = true;
      document.getElementById('vpnRouterId').value = r.vpn_user || '';
      document.getElementById('vpnFija').value = r.vpn_ip || '';
      
      try { cargarPools(r.id); } catch(e) {}
      document.getElementById('modalRouter').style.display = 'flex';
      
      // Detectar interfaces
      if (tipo === 'ip') {
        setTimeout(function() {
          var host = r.ip;
          var port = parseInt(r.port) || 8728;
          var username = r.user || '';
          var password = r.password || '';
          if (host && username) {
            fetch('/api/routers/interfaces', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ host: host, port: port, username: username, password: password })
            })
            .then(function(resp) { return resp.json(); })
            .then(function(res) {
              var sel = document.getElementById('routerWan');
              sel.innerHTML = '';
              if (res.success && res.interfaces && res.interfaces.length > 0) {
                res.interfaces.forEach(function(iface) {
                  var opt = document.createElement('option');
                  opt.value = iface.name;
                  opt.textContent = iface.name + ' (' + (iface.type || '') + ') ' + (iface.running === 'true' ? '🟢' : '🔴');
                  sel.appendChild(opt);
                });
              } else {
                sel.innerHTML = '<option value="ether1">ether1 (por defecto)</option><option value="">-- Detectar interfaces --</option>';
              }
              sel.value = r.interface_wan || 'ether1';
            })
            .catch(function() {
              var sel = document.getElementById('routerWan');
              sel.innerHTML = '<option value="ether1">ether1 (por defecto)</option><option value="">-- Detectar interfaces --</option>';
              sel.value = r.interface_wan || 'ether1';
            });
          }
        }, 100);
      }
    })
    .catch(function(e) {
      showToast('Error al cargar router: ' + e.message, 'error');
    });
}

function verScript(id) {
  fetch('/api/routers/' + id)
    .then(function(r) { return r.json(); })
    .then(function(r) {
      if (r.connection_type === 'vpn' && r.vpn_user) {
        document.getElementById('routerName').value = r.name;
        document.getElementById('vpnRouterId').value = r.vpn_user || '';
        document.getElementById('vpnFija').value = r.vpn_ip || '';
        seleccionarTipo('vpn');
        generarScriptVPN();
        document.getElementById('modalRouter').style.display = 'flex';
      } else {
        showToast('Este router no tiene script VPN', 'error');
      }
    });
}

function cerrarModal() { document.getElementById('modalRouter').style.display = 'none'; }

function testConexion() {
  var host = document.getElementById('routerIp').value.trim();
  var port = parseInt(document.getElementById('routerPort').value) || 8728;
  var username = document.getElementById('routerUser').value.trim();
  var password = document.getElementById('routerPass').value;
  
  if (!host) { showToast('Ingrese la IP del router', 'error'); return; }
  if (!username) { showToast('Ingrese el usuario', 'error'); return; }
  
  var btn = document.getElementById('btnTestRouter');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Probando...';
  
  fetch('/api/routers/test', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ host: host, port: port, username: username, password: password })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-plug"></i> Probar Conexión';
    if (res.success) {
      showToast('✅ Conexión exitosa con ' + host + ' (' + (res.info && res.info.version ? res.info.version : '') + ')');
    } else {
      showToast('❌ Error: ' + (res.error || 'No se pudo conectar'), 'error');
    }
  })
  .catch(function(e) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-plug"></i> Probar Conexión';
    showToast('Error de conexión con el servidor', 'error');
  });
}

function detectarInterfaces() {
  var host = document.getElementById('routerIp').value.trim();
  var port = parseInt(document.getElementById('routerPort').value) || 8728;
  var username = document.getElementById('routerUser').value.trim();
  var password = document.getElementById('routerPass').value;
  
  if (!host || !username) { showToast('Primero complete IP y usuario', 'error'); return; }
  
  var btn = document.getElementById('btnDetectIfaces');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
  
  fetch('/api/routers/interfaces', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ host: host, port: port, username: username, password: password })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-search"></i> Detectar';
    var sel = document.getElementById('routerWan');
    sel.innerHTML = '';
    if (res.success && res.interfaces && res.interfaces.length > 0) {
      res.interfaces.forEach(function(iface) {
        var opt = document.createElement('opt ion');
        opt.value = iface.name;
        opt.textContent = iface.name + ' (' + (iface.type || '') + ') ' + (iface.running === 'true' ? '🟢' : '🔴');
        sel.appendChild(opt);
      });
      showToast('✅ ' + res.interfaces.length + ' interfaces detectadas');
    } else {
      sel.innerHTML = '<option value="ether1">ether1 (por defecto)</option>';
      showToast('❌ No se pudieron detectar interfaces: ' + (res.error || 'sin datos'), 'error');
    }
  })
  .catch(function(e) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-search"></i> Detectar';
    showToast('Error al conectar con el router', 'error');
  });
}

function guardarRouter(e) {
  e.preventDefault();
  var tipo = document.querySelector('input[name="connection_type"]:checked').value;
  const data = {
    accion: document.getElementById('accionInput').value,
    id_router_edit: document.getElementById('idRouterInput').value,
    name: document.getElementById('routerName').value,
    connection_type: tipo,
    ip: tipo === 'vpn' ? (document.getElementById('vpnFija').value || document.getElementById('vpnRouterId').value) : document.getElementById('routerIp').value,
    port: document.getElementById('routerPort').value,
    user: document.getElementById('routerUser').value,
    password: document.getElementById('routerPass').value,
    version: document.getElementById('routerVersion').value,
    auth_type: document.getElementById('routerAuth').value,
    ip_blocks: '[]',
    ipv6_pd: document.getElementById('routerIpv6').value,
    suspend_ips: document.getElementById('suspendIps').checked ? 1 : 0,
    interface_wan: document.getElementById('routerWan').value || 'ether1',
    vpn_user: document.getElementById('vpnRouterId').value,
    vpn_password: document.getElementById('routerPass').value,
    vpn_ip: document.getElementById('vpnFija').value
  };
  fetch('/api/routers/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(r => r.json())
  .then(res => {
    if (res.success) { 
      document.getElementById('idRouterInput').value = res.id;
      routerActualId = res.id;
      showToast('Router guardado'); 
      cerrarModal(); 
      cargarRouters();
    }
    else showToast('Error: ' + (res.message || 'No se pudo guardar'), 'error');
  })
  .catch(() => showToast('Error de conexión', 'error'));
}

function confirmarEliminar(id, nombre) {
  document.getElementById('eliminarMsg').innerHTML = 'Está seguro que desea eliminar el router <b>' + nombre + '</b>? Esta acción no se puede deshacer.';
  document.getElementById('btnConfirmarEliminar').onclick = function() {
    fetch('/api/routers/' + id + '/delete', { method: 'POST' })
      .then(r => r.json()).then(res => {
        if (res.success) { showToast('Router eliminado'); cerrarModalEliminar(); cargarRouters(); }
        else showToast('Error al eliminar', 'error');
      });
  };
  document.getElementById('modalEliminar').style.display = 'flex';
}
function cerrarModalEliminar() { document.getElementById('modalEliminar').style.display = 'none'; }

function abrirModalResync(id) {
  resyncId = id;
  document.getElementById('btnConfirmarResync').onclick = function() {
    showToast('Sincronizando router...');
    fetch('/api/routers/' + resyncId + '/resync', { method: 'POST' })
      .then(r => r.json()).then(res => {
        if (res.success) showToast('Router sincronizado');
        else showToast('Error: ' + (res.error || 'desconocido'), 'error');
        cerrarModalResync();
        cargarRouters();
      });
  };
  document.getElementById('modalResync').style.display = 'flex';
}
function cerrarModalResync() { document.getElementById('modalResync').style.display = 'none'; }

function abrirModalPool() {
    var id = parseInt(document.getElementById('idRouterInput').value) || 0;
    if (!id) { showToast('Guarde el router primero', 'error'); return; }
    routerActualId = id;
    document.getElementById('poolRouterId').value = id;
    document.getElementById('poolRed').value = '';
    document.getElementById('poolTipo').value = 'privada';
    document.getElementById('poolCalculo').style.display = 'none';
    document.getElementById('poolError').style.display = 'none';
    document.getElementById('modalPool').style.display = 'flex';
}
function cerrarModalPool() { document.getElementById('modalPool').style.display = 'none'; }
function calcularPool() {
    var red = document.getElementById('poolRed').value.trim();
    if (!red || red.indexOf('/') === -1) { document.getElementById('poolCalculo').style.display = 'none'; return; }
    fetch('/api/ip-pools/calcular', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({red:red}) })
    .then(function(r){return r.json()})
    .then(function(d){
        if(d.success){
            document.getElementById('poolCalculo').style.display='block';
            document.getElementById('poolTotal').textContent=d.total;
            document.getElementById('poolRango').textContent=d.first_ip+' - '+d.last_ip;
        } else {
            document.getElementById('poolCalculo').style.display='none';
            document.getElementById('poolError').style.display='block';
            document.getElementById('poolError').textContent=d.message;
        }
    });
}
function guardarPool() {
    var rid = parseInt(document.getElementById('poolRouterId').value);
    var red = document.getElementById('poolRed').value.trim();
    var tipo = document.getElementById('poolTipo').value;
    if(!rid||!red){showToast('Complete los datos','error');return;}
    fetch('/api/ip-pools/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({router_id:rid,red:red,tipo:tipo})})
    .then(function(r){return r.json()})
    .then(function(d){
        if(d.success){showToast('Rango agregado: '+d.total+' IPs');cerrarModalPool();cargarPools(rid);}
        else showToast('Error: '+d.message,'error');
    });
}
function cargarPools(rid){
    if(!rid){document.getElementById('poolList').innerHTML='<div style="color:var(--text-gray);text-align:center;padding:10px;">Seleccione un router</div>';return;}
    document.getElementById('poolList').innerHTML='<div style="text-align:center;padding:10px;color:var(--text-gray);"><i class="fas fa-spinner fa-spin"></i> Cargando...</div>';
    fetch('/api/ip-pools/'+rid).then(function(r){return r.json()}).then(function(pools){
        if(!pools||pools.length===0){document.getElementById('poolList').innerHTML='<div style="color:var(--text-gray);text-align:center;padding:10px;">Sin rangos IP</div>';return;}
        var h='<table style="width:100%;border-collapse:collapse;font-size:0.82rem;"><tr style="background:#f8fafc;"><th style="padding:6px 8px;text-align:left;">Red</th><th style="padding:6px 8px;">Total</th><th style="padding:6px 8px;">Usadas</th><th style="padding:6px 8px;">Disp.</th><th style="padding:6px 8px;"></th></tr>';
        for(var i=0;i<pools.length;i++){
            var p=pools[i];
            h+='<tr><td style="padding:6px 8px;font-family:monospace;">'+p.red+'</td><td style="padding:6px 8px;text-align:center;">'+p.total+'</td><td style="padding:6px 8px;text-align:center;">'+(p.usadas||0)+'</td><td style="padding:6px 8px;text-align:center;font-weight:700;">'+(p.disponibles||0)+'</td><td style="padding:6px 8px;text-align:center;"><button class="btn btn-sm btn-danger" onclick="eliminarPool('+p.id+')"><i class="fas fa-trash"></i></button></td></tr>';
        }
        h+='</table>';
        document.getElementById('poolList').innerHTML=h;
    });
}
function eliminarPool(id){
    if(!confirm('Eliminar este rango?'))return;
    fetch('/api/ip-pools/'+id+'/eliminar',{method:'POST'}).then(function(r){return r.json()}).then(function(d){if(d.success){showToast('Rango eliminado');cargarPools(routerActualId);}});
}

cargarRouters();
</script>
