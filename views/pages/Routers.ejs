<div class="page-header">
  <h2><i class="fas fa-server"></i> Routers</h2>
  <button class="btn btn-primary btn-sm" onclick="abrirModalCrear()"><i class="fas fa-plus"></i> Nuevo Router</button>
</div>

<div class="card">
  <div class="card-body" id="routersList">
    <div class="loading"><i class="fas fa-spinner fa-spin"></i><br>Cargando routers...</div>
  </div>
</div>

<!-- Modal Crear/Editar Router -->
<div id="modalRouter" class="modal" style="display:none">
  <div class="modal-content" style="max-width:550px;">
    <div class="modal-header">
      <h3 id="modalTitle"><i class="fas fa-plus-circle" style="color:#10b981;"></i> Nuevo Router</h3>
      <span class="modal-close" onclick="cerrarModal()">&times;</span>
    </div>
    <div class="modal-body">
      <form id="formRouter" onsubmit="guardarRouter(event)">
        <input type="hidden" name="accion" id="accionInput" value="guardar">
        <input type="hidden" name="id_router" id="idRouterInput" value="">
        
        <div class="form-group">
          <label>Nombre del Router *</label>
          <input type="text" name="name" id="routerName" class="form-control" placeholder="Ej: MikroTik Principal" required>
        </div>
        <div class="form-group">
          <label>Dirección IP *</label>
          <input type="text" name="ip" id="routerIp" class="form-control" placeholder="Ej: 192.168.88.1" required>
        </div>
        <div class="form-group">
          <label>Puerto API</label>
          <input type="number" name="port" id="routerPort" class="form-control" placeholder="8728" value="8728">
        </div>
        <div class="form-group">
          <label>Usuario API *</label>
          <input type="text" name="user" id="routerUser" class="form-control" placeholder="admin" required>
        </div>
        <div class="form-group">
          <label>Contraseña API</label>
          <input type="password" name="password" id="routerPass" class="form-control" placeholder="Contraseña">
        </div>
        
        <div style="border-top:1px solid #e2e8f0;padding-top:16px;margin-top:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <label style="font-weight:600;font-size:0.9rem;">Bloques de IP Privadas</label>
            <button type="button" class="btn btn-secondary btn-sm" onclick="addPool('priv')">+ Agregar Bloque</button>
          </div>
          <div id="ipBlocksList"></div>
        </div>
        
        <div class="btn-group" style="justify-content:flex-end;margin-top:20px;">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Confirmar Eliminar -->
<div id="modalEliminar" class="modal" style="display:none">
  <div class="modal-content" style="max-width:400px;">
    <div class="modal-header">
      <h3><i class="fas fa-trash" style="color:#ef4444;"></i> Eliminar Router</h3>
      <span class="modal-close" onclick="cerrarModalEliminar()">&times;</span>
    </div>
    <div class="modal-body" style="text-align:center;">
      <div style="font-weight:700;font-size:1.05rem;color:#1e293b;margin-bottom:8px;">¿Eliminar router?</div>
      <div style="font-size:0.88rem;color:#64748b;margin-bottom:20px;" id="eliminarMsg"></div>
      <div class="btn-group" style="justify-content:center;">
        <button class="btn btn-secondary" onclick="cerrarModalEliminar()">Cancelar</button>
        <button class="btn btn-danger" id="btnConfirmarEliminar">Sí, eliminar</button>
      </div>
    </div>
  </div>
</div>

<script>
let ipBlocks = [];

function cargarRouters() {
  const div = document.getElementById('routersList');
  div.innerHTML = '<div class="loading"><i class="fas fa-spinner fa-spin"></i><br>Cargando routers...</div>';
  
  fetch('/api/routers')
    .then(r => r.json())
    .then(data => {
      if (data.length === 0) {
        div.innerHTML = '<p style="text-align:center;padding:40px;color:var(--text-gray);"><i class="fas fa-server" style="font-size:2rem;display:block;margin-bottom:10px;"></i>No hay routers registrados<br><button class="btn btn-primary btn-sm mt-20" onclick="abrirModalCrear()"><i class="fas fa-plus"></i> Nuevo Router</button></p>';
        return;
      }
      let html = '<div class="table-container"><table><thead><tr><th>Nombre</th><th>IP</th><th>Puerto</th><th>Estado</th><th>Última sinc.</th><th>Acciones</th></tr></thead><tbody>';
      data.forEach(r => {
        const status = r.connected ? '<span class="badge badge-success">Online</span>' : '<span class="badge badge-danger">Offline</span>';
        html += '<tr><td><strong>' + r.name + '</strong></td><td>' + r.ip + '</td><td>' + (r.port || 8728) + '</td><td>' + status + '</td><td>' + (r.last_sync || 'Nunca') + '</td><td>';
        html += '<div class="btn-group">';
        html += '<button class="btn btn-sm btn-secondary" onclick="abrirModalEditar(' + r.id + ')"><i class="fas fa-edit"></i></button>';
        html += '<button class="btn btn-sm btn-primary" onclick="resyncRouter(' + r.id + ')"><i class="fas fa-sync"></i></button>';
        html += '<button class="btn btn-sm btn-danger" onclick="confirmarEliminar(' + r.id + ',\'' + r.name.replace(/'/g, "\\'") + '\')"><i class="fas fa-trash"></i></button>';
        html += '</div></td></tr>';
      });
      html += '</tbody></table></div>';
      div.innerHTML = html;
    })
    .catch(e => {
      div.innerHTML = '<p style="text-align:center;padding:40px;color:#ef4444;">Error al cargar routers</p>';
    });
}

function abrirModalCrear() {
  document.getElementById('formRouter').reset();
  document.getElementById('accionInput').value = 'guardar';
  document.getElementById('idRouterInput').value = '';
  document.getElementById('modalTitle').innerHTML = '<i class="fas fa-plus-circle" style="color:#10b981;"></i> Nuevo Router';
  ipBlocks = [];
  document.getElementById('ipBlocksList').innerHTML = '';
  document.getElementById('modalRouter').style.display = 'flex';
}

function abrirModalEditar(id) {
  fetch('/api/routers/' + id)
    .then(r => r.json())
    .then(r => {
      document.getElementById('accionInput').value = 'editar';
      document.getElementById('idRouterInput').value = r.id;
      document.getElementById('routerName').value = r.name;
      document.getElementById('routerIp').value = r.ip;
      document.getElementById('routerPort').value = r.port || 8728;
      document.getElementById('routerUser').value = r.user || '';
      document.getElementById('routerPass').value = '';
      document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit" style="color:#f59e0b;"></i> Editar Router';
      
      ipBlocks = JSON.parse(r.ip_blocks || '[]');
      renderIpBlocks();
      document.getElementById('modalRouter').style.display = 'flex';
    });
}

function cerrarModal() {
  document.getElementById('modalRouter').style.display = 'none';
}

function guardarRouter(e) {
  e.preventDefault();
  const data = {
    accion: document.getElementById('accionInput').value,
    id_router: document.getElementById('idRouterInput').value,
    name: document.getElementById('routerName').value,
    ip: document.getElementById('routerIp').value,
    port: document.getElementById('routerPort').value,
    user: document.getElementById('routerUser').value,
    password: document.getElementById('routerPass').value,
    ip_blocks: JSON.stringify(ipBlocks)
  };
  
  fetch('/api/routers/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(r => r.json())
  .then(res => {
    if (res.success) {
      showToast('Router guardado');
      cerrarModal();
      cargarRouters();
    } else {
      showToast('Error: ' + (res.message || 'No se pudo guardar'), 'error');
    }
  })
  .catch(() => showToast('Error de conexión', 'error'));
}

function confirmarEliminar(id, nombre) {
  document.getElementById('eliminarMsg').innerHTML = 'Está seguro que desea eliminar el router <b>' + nombre + '</b>? Esta acción no se puede deshacer.';
  const btn = document.getElementById('btnConfirmarEliminar');
  btn.onclick = function() { eliminarRouter(id); };
  document.getElementById('modalEliminar').style.display = 'flex';
}

function cerrarModalEliminar() {
  document.getElementById('modalEliminar').style.display = 'none';
}

function eliminarRouter(id) {
  fetch('/api/routers/' + id + '/delete', { method: 'POST' })
    .then(r => r.json())
    .then(res => {
      if (res.success) {
        showToast('Router eliminado');
        cerrarModalEliminar();
        cargarRouters();
      } else {
        showToast('Error al eliminar', 'error');
      }
    });
}

function resyncRouter(id) {
  showToast('Sincronizando router...');
  fetch('/api/routers/' + id + '/resync', { method: 'POST' })
    .then(r => r.json())
    .then(res => {
      if (res.success) showToast('Router sincronizado');
      else showToast('Error de conexión: ' + (res.error || 'desconocido'), 'error');
    })
    .catch(() => showToast('Error al sincronizar', 'error'));
}

function addPool(type) {
  const net = prompt('Ingrese la red (Ej: 192.168.1.0/24):');
  if (net) {
    ipBlocks.push({ network: net, type: type });
    renderIpBlocks();
  }
}

function removePool(idx) {
  ipBlocks.splice(idx, 1);
  renderIpBlocks();
}

function renderIpBlocks() {
  const div = document.getElementById('ipBlocksList');
  if (ipBlocks.length === 0) {
    div.innerHTML = '<p style="color:var(--text-gray);font-size:0.85rem;">No hay bloques configurados</p>';
    return;
  }
  let html = '<div class="table-container"><table style="font-size:0.8rem;"><thead><tr><th>Red</th><th>Tipo</th><th></th></tr></thead><tbody>';
  ipBlocks.forEach((b, i) => {
    html += '<tr><td>' + b.network + '</td><td>' + (b.type === 'priv' ? 'Privada' : 'Pública') + '</td><td><button class="btn btn-sm btn-danger" onclick="removePool(' + i + ')"><i class="fas fa-times"></i></button></td></tr>';
  });
  html += '</tbody></table></div>';
  div.innerHTML = html;
}

// Load on page init
cargarRouters();
</script>
