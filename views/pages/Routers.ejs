<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
  <h2 style="margin:0;font-size:1.3rem;color:var(--text-dark);display:flex;align-items:center;gap:10px;">
    <i class="fas fa-server" style="color:var(--accent);"></i> Mis Routers
  </h2>
  <button class="btn btn-primary" onclick="abrirModalCrear()" style="padding:8px 20px;border:none;border-radius:8px;background:var(--accent);color:#fff;font-weight:600;cursor:pointer;font-size:0.85rem;">
    <i class="fas fa-plus"></i> Nuevo Router
  </button>
</div>

<div id="routersList" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:16px;">
  <div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--text-gray);">
    <i class="fas fa-spinner fa-spin" style="font-size:2rem;display:block;margin-bottom:12px;"></i>
    Cargando routers...
  </div>
</div>

<!-- Modal Crear/Editar Router -->
<div id="modalRouter" class="modal" style="display:none">
  <div class="modal-content" style="max-width:680px;max-height:90vh;overflow-y:auto;">
    <div class="modal-header" style="position:sticky;top:0;z-index:2;">
      <h3 id="modalRouterTitle"><i class="fas fa-plus-circle" style="color:var(--accent-success);"></i> Nuevo Router</h3>
      <button onclick="cerrarModal()" style="background:var(--accent-danger);color:white;border:none;border-radius:6px;padding:5px 12px;cursor:pointer;font-size:0.78rem;font-weight:600;"><i class="fas fa-times"></i> Cerrar</button>
    </div>
    <div class="modal-body">
      <form id="formRouter" onsubmit="guardarRouter(event)">
        <input type="hidden" name="accion" id="accionInput" value="guardar">
        <input type="hidden" name="id_router_edit" id="idRouterInput" value="">

        <div class="form-group">
          <label class="form-label">Nombre</label>
          <input type="text" name="name" id="routerName" class="form-control" placeholder="Nombre del router" required>
        </div>
        <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;">
          <div class="form-group">
            <label class="form-label">IP</label>
            <input type="text" name="ip" id="routerIp" class="form-control" placeholder="IP del router" required>
          </div>
          <div class="form-group">
            <label class="form-label">Puerto API</label>
            <input type="number" name="port" id="routerPort" class="form-control" value="8728">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div class="form-group">
            <label class="form-label">Usuario</label>
            <input type="text" name="user" id="routerUser" class="form-control" placeholder="admin">
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input type="password" name="password" id="routerPass" class="form-control" placeholder="••••••••">
          </div>
        </div>
        <div style="border-top:1px solid var(--border-color);padding-top:16px;margin-top:16px;">
          <label class="form-label">Interfaz WAN</label>
          <input type="text" name="interface_wan" id="routerWan" class="form-control" placeholder="ether1" value="ether1">
        </div>
        <div class="btn-group" style="justify-content:flex-end;margin-top:20px;">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary" style="padding:10px 28px;"><i class="fas fa-save"></i> Guardar Router</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Detalle Router -->
<div id="modalDetalle" class="modal" style="display:none">
  <div class="modal-content" style="max-width:800px;max-height:90vh;overflow-y:auto;">
    <div class="modal-header" style="position:sticky;top:0;z-index:2;">
      <h3 id="detalleTitle"><i class="fas fa-info-circle" style="color:var(--accent);"></i> Detalle del Router</h3>
      <button onclick="cerrarDetalle()" style="background:var(--accent-danger);color:white;border:none;border-radius:6px;padding:5px 12px;cursor:pointer;font-size:0.78rem;font-weight:600;"><i class="fas fa-times"></i> Cerrar</button>
    </div>
    <div class="modal-body">
      <!-- Tabs -->
      <div style="display:flex;gap:0;border-bottom:2px solid var(--border-color);margin-bottom:16px;">
        <button class="tab-btn active" data-tab="interfaces" onclick="switchTab('interfaces')"><i class="fas fa-network-wired"></i> Interfaces</button>
        <button class="tab-btn" data-tab="dhcp" onclick="switchTab('dhcp')"><i class="fas fa-dharmachakra"></i> DHCP Leases</button>
        <button class="tab-btn" data-tab="ppp" onclick="switchTab('ppp')"><i class="fas fa-users"></i> PPP Secrets</button>
      </div>
      <div id="tabContent" style="min-height:200px;">
        <div style="text-align:center;padding:30px;color:var(--text-gray);"><i class="fas fa-spinner fa-spin"></i> Cargando...</div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Resync Confirmación -->
<div id="modalResync" class="modal" style="display:none">
  <div class="modal-content" style="max-width:400px;text-align:center;">
    <div style="font-size:3rem;color:var(--accent);margin-bottom:12px;"><i class="fas fa-sync-alt"></i></div>
    <h3>¿Resincronizar Router?</h3>
    <p style="color:var(--text-gray);font-size:0.9rem;line-height:1.5;margin-bottom:20px;">
      Esta acción probará la conexión y actualizará el estado del router.
    </p>
    <div style="display:flex;gap:10px;justify-content:center;">
      <button class="btn btn-secondary" onclick="cerrarModalResync()">Cancelar</button>
      <button class="btn btn-primary" id="btnConfirmResync" onclick="confirmarResync()"><i class="fas fa-sync"></i> Sincronizar</button>
    </div>
  </div>
</div>

<!-- Modal Confirmar Eliminar -->
<div id="modalEliminar" class="modal" style="display:none">
  <div class="modal-content" style="max-width:400px;text-align:center;">
    <div style="font-size:2.5rem;color:#f59e0b;margin-bottom:12px;"><i class="fas fa-exclamation-triangle"></i></div>
    <h3>¿Eliminar router?</h3>
    <p style="color:var(--text-gray);font-size:0.9rem;margin-bottom:20px;" id="eliminarMsg"></p>
    <div style="display:flex;gap:10px;justify-content:center;">
      <button class="btn btn-secondary" onclick="cerrarModalEliminar()">Cancelar</button>
      <button class="btn btn-danger" id="btnConfirmEliminar"><i class="fas fa-trash"></i> Eliminar</button>
    </div>
  </div>
</div>

<style>
  .rt-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 16px;
    transition: all 0.2s ease;
    box-shadow: var(--shadow);
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .rt-card:hover {
    box-shadow: 0 4px 16px rgba(99,102,241,0.1);
    border-color: var(--accent);
  }
  .rt-card-header {
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
  }
  .rt-card-name {
    font-weight:600;
    font-size:0.95rem;
    color:var(--text-dark);
    display:flex;
    align-items:center;
    gap:6px;
  }
  .rt-card-ip {
    font-size:0.82rem;
    color:var(--text-gray);
    font-family:monospace;
  }
  .rt-badge {
    display:inline-flex;
    align-items:center;
    gap:5px;
    padding:3px 12px;
    border-radius:20px;
    font-size:0.72rem;
    font-weight:700;
    white-space:nowrap;
  }
  .rt-badge-online {
    background:#dcfce7;
    color:#166534;
  }
  .rt-badge-offline {
    background:#fef2f2;
    color:#991b1b;
  }
  .rt-badge i {
    font-size:0.4rem;
  }
  .rt-stats {
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:6px;
  }
  .rt-stat {
    display:flex;
    align-items:center;
    gap:6px;
    font-size:0.78rem;
    color:var(--text-gray);
    padding:4px 8px;
    background:var(--bg-body);
    border-radius:6px;
  }
  .rt-stat i {
    width:14px;
    text-align:center;
    color:var(--accent);
  }
  .rt-card-actions {
    display:flex;
    gap:6px;
    justify-content:flex-end;
    margin-top:4px;
    padding-top:8px;
    border-top:1px solid var(--border-color);
  }
  .rt-action-btn {
    padding:5px 10px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-size:0.78rem;
    transition:all 0.15s;
    display:flex;
    align-items:center;
    gap:4px;
  }
  .rt-action-btn:hover { opacity:0.85; transform:translateY(-1px); }
  .tab-btn {
    padding:8px 18px;
    border:none;
    background:transparent;
    color:var(--text-gray);
    font-weight:600;
    font-size:0.82rem;
    cursor:pointer;
    border-bottom:2px solid transparent;
    margin-bottom:-2px;
    transition:all 0.15s;
    display:flex;
    align-items:center;
    gap:6px;
  }
  .tab-btn.active {
    color:var(--accent);
    border-bottom-color:var(--accent);
  }
  .tab-btn:hover { color:var(--text-dark); }
  /* Modal overlay fixes */
  .modal-content {
    border-radius:12px;
    box-shadow:0 20px 60px rgba(0,0,0,0.15);
  }
  @media(max-width:768px) {
    #routersList { grid-template-columns:1fr; }
    .modal-overlay { padding:0 !important; align-items:flex-start !important; }
    .modal-content { max-width:100% !important; width:100% !important; min-height:100vh; max-height:100vh !important; overflow-y:auto !important; border-radius:0 !important; margin:0 !important; }
    .rt-stats { grid-template-columns:1fr; }
  }
</style>

<script>
let resyncId = null;
let deleteId = null;
let detailRouterId = null;

function cargarRouters() {
  fetch('/api/routers')
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(data) {
      var container = document.getElementById('routersList');
      if (!data || data.length === 0) {
        container.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--text-gray);"><i class="fas fa-server" style="font-size:3rem;display:block;margin-bottom:12px;color:var(--border-color);"></i><div style="font-size:1rem;font-weight:600;margin-bottom:8px;">No hay routers registrados</div><div style="font-size:0.85rem;margin-bottom:20px;">Agregue un router MikroTik para comenzar</div><button class="btn btn-primary" onclick="abrirModalCrear()" style="padding:8px 24px;border:none;border-radius:8px;background:var(--accent);color:#fff;font-weight:600;cursor:pointer;"><i class="fas fa-plus"></i> Nuevo Router</button></div>';
        return;
      }
      var html = '';
      data.forEach(function(r) {
        var isOnline = r.connected == 1;
        var statusBadge = isOnline
          ? '<span class="rt-badge rt-badge-online"><i class="fas fa-circle"></i> Online</span>'
          : '<span class="rt-badge rt-badge-offline"><i class="fas fa-circle"></i> Offline</span>';
        var lastSync = r.last_sync ? formatDateTime(r.last_sync) : '—';
        html += '<div class="rt-card">';
        html += '<div class="rt-card-header">';
        html += '<div>';
        html += '<div class="rt-card-name"><i class="fas fa-router" style="color:var(--accent);"></i> ' + escHtml(r.name) + '</div>';
        html += '<div class="rt-card-ip"><i class="fas fa-network-wired" style="width:14px;text-align:center;font-size:0.7rem;color:var(--text-gray);"></i> ' + escHtml(r.ip) + ' <span style="color:var(--text-gray);">:' + (r.port || 8728) + '</span></div>';
        html += '</div>';
        html += '<div>' + statusBadge + '</div>';
        html += '</div>';
        html += '<div class="rt-stats">';
        html += '<div class="rt-stat"><i class="fas fa-clock"></i> Último sync: ' + lastSync + '</div>';
        html += '<div class="rt-stat"><i class="fas fa-plug"></i> WAN: ' + escHtml(r.interface_wan || 'ether1') + '</div>';
        html += '</div>';
        html += '<div class="rt-card-actions">';
        html += '<button class="rt-action-btn" style="background:#eff6ff;color:var(--accent);" onclick="abrirDetalle(' + r.id + ')" title="Detalle"><i class="fas fa-eye"></i> Detalle</button>';
        html += '<button class="rt-action-btn" style="background:#e0f2fe;color:#0284c7;" onclick="abrirModalResync(' + r.id + ')" title="Resincronizar"><i class="fas fa-sync"></i></button>';
        html += '<button class="rt-action-btn" style="background:#fef3c7;color:#92400e;" onclick="abrirModalEditar(' + r.id + ')" title="Editar"><i class="fas fa-edit"></i></button>';
        html += '<button class="rt-action-btn" style="background:#fef2f2;color:var(--accent-danger);" onclick="confirmarEliminar(' + r.id + ",'" + escHtml(r.name).replace(/'/g, "\\'") + "')" + '" title="Eliminar"><i class="fas fa-trash"></i></button>';
        html += '</div>';
        html += '</div>';
      });
      container.innerHTML = html;
    })
    .catch(function(e) {
      document.getElementById('routersList').innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--accent-danger);"><i class="fas fa-exclamation-triangle" style="font-size:2rem;display:block;margin-bottom:10px;"></i>Error al cargar routers: ' + e.message + '</div>';
    });
}

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function formatDateTime(dt) {
  if (!dt) return '—';
  try {
    var d = new Date(String(dt).replace(' ','T'));
    if (isNaN(d.getTime())) return String(dt).substring(0,16);
    return d.toLocaleString('es-DO', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
  } catch(e) { return String(dt).substring(0,16); }
}

// ========== MODAL ROUTER ==========
function abrirModalCrear() {
  document.getElementById('formRouter').reset();
  document.getElementById('accionInput').value = 'guardar';
  document.getElementById('idRouterInput').value = '';
  document.getElementById('routerWan').value = 'ether1';
  document.getElementById('modalRouterTitle').innerHTML = '<i class="fas fa-plus-circle" style="color:var(--accent-success);"></i> Nuevo Router';
  document.getElementById('modalRouter').style.display = 'flex';
}

function abrirModalEditar(id) {
  fetch('/api/routers/' + id)
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(router) {
      document.getElementById('accionInput').value = 'editar';
      document.getElementById('idRouterInput').value = router.id;
      document.getElementById('routerName').value = router.name;
      document.getElementById('routerIp').value = router.ip;
      document.getElementById('routerPort').value = router.port || 8728;
      document.getElementById('routerUser').value = router.user || '';
      document.getElementById('routerPass').value = '';
      document.getElementById('routerWan').value = router.interface_wan || 'ether1';
      document.getElementById('modalRouterTitle').innerHTML = '<i class="fas fa-edit" style="color:#f59e0b;"></i> Editar: ' + escHtml(router.name);
      document.getElementById('modalRouter').style.display = 'flex';
    })
    .catch(function(e) { rtToast('Error al cargar router: ' + e.message, 'error'); });
}

function cerrarModal() {
  document.getElementById('modalRouter').style.display = 'none';
}

function guardarRouter(e) {
  e.preventDefault();
  var btn = e.target.querySelector('button[type="submit"]');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

  var data = {
    accion: document.getElementById('accionInput').value,
    id_router_edit: document.getElementById('idRouterInput').value,
    name: document.getElementById('routerName').value,
    ip: document.getElementById('routerIp').value,
    port: parseInt(document.getElementById('routerPort').value) || 8728,
    user: document.getElementById('routerUser').value,
    password: document.getElementById('routerPass').value,
    interface_wan: document.getElementById('routerWan').value || 'ether1'
  };

  fetch('/api/routers/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-save"></i> Guardar Router';
    if (res.success) {
      rtToast('Router guardado correctamente');
      cerrarModal();
      cargarRouters();
    } else {
      rtToast('Error: ' + (res.error || res.message || 'No se pudo guardar'), 'error');
    }
  })
  .catch(function() {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-save"></i> Guardar Router';
    rtToast('Error de conexión', 'error');
  });
}

// ========== DELETE ==========
function confirmarEliminar(id, nombre) {
  deleteId = id;
  document.getElementById('eliminarMsg').innerHTML = 'Está seguro que desea eliminar el router <b>' + escHtml(nombre) + '</b>? Esta acción no se puede deshacer.';
  document.getElementById('btnConfirmEliminar').onclick = function() {
    fetch('/api/routers/' + deleteId + '/delete', { method: 'POST' })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.success) { rtToast('Router eliminado'); cerrarModalEliminar(); cargarRouters(); }
        else rtToast('Error al eliminar', 'error');
      });
  };
  document.getElementById('modalEliminar').style.display = 'flex';
}
function cerrarModalEliminar() { document.getElementById('modalEliminar').style.display = 'none'; }

// ========== RESYNC ==========
function abrirModalResync(id) {
  resyncId = id;
  document.getElementById('modalResync').style.display = 'flex';
}
function cerrarModalResync() { document.getElementById('modalResync').style.display = 'none'; }
function confirmarResync() {
  var btn = document.getElementById('btnConfirmResync');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sincronizando...';
  fetch('/api/routers/' + resyncId + '/resync', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-sync"></i> Sincronizar';
      cerrarModalResync();
      if (res.success) {
        rtToast('Router sincronizado correctamente');
      } else {
        rtToast('Error de conexión: ' + (res.error || res.message || 'No se pudo conectar'), 'error');
      }
      cargarRouters();
    })
    .catch(function() {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-sync"></i> Sincronizar';
      cerrarModalResync();
      rtToast('Error de conexión', 'error');
    });
}

// ========== DETALLE with TABS ==========
var detalleModal = document.getElementById('modalDetalle');

function abrirDetalle(id) {
  detailRouterId = id;
  detalleModal.style.display = 'flex';
  // Load router name into title
  fetch('/api/routers/' + id)
    .then(function(r) { return r.json(); })
    .then(function(router) {
      document.getElementById('detalleTitle').innerHTML = '<i class="fas fa-info-circle" style="color:var(--accent);"></i> ' + escHtml(router.name) + ' <span style="font-size:0.8rem;font-weight:400;color:var(--text-gray);">(' + escHtml(router.ip) + ')</span>';
    })
    .catch(function() {});
  switchTab('interfaces');
}

function cerrarDetalle() { detalleModal.style.display = 'none'; }

function switchTab(tab) {
  var tabs = document.querySelectorAll('.tab-btn');
  tabs.forEach(function(t) { t.classList.remove('active'); });
  var activeTab = document.querySelector('.tab-btn[data-tab="' + tab + '"]');
  if (activeTab) activeTab.classList.add('active');

  var content = document.getElementById('tabContent');
  content.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-gray);"><i class="fas fa-spinner fa-spin"></i> Cargando ' + tab + '...</div>';

  if (!detailRouterId) return;

  if (tab === 'interfaces') {
    cargarInterfaces(content);
  } else if (tab === 'dhcp') {
    cargarDHCPLeases(content);
  } else if (tab === 'ppp') {
    cargarPPPSecrets(content);
  }
}

function cargarInterfaces(contentEl) {
  fetch('/api/routers/' + detailRouterId)
    .then(function(r) { return r.json(); })
    .then(function(router) {
      if (!router.user || !router.password) {
        contentEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-gray);"><i class="fas fa-exclamation-triangle" style="font-size:2rem;display:block;margin-bottom:10px;color:#f59e0b;"></i>Credenciales incompletas. Configure usuario y password para consultar interfaces.</div>';
        return;
      }
      fetch('/api/routers/interfaces', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ host: router.ip, port: router.port || 8728, username: router.user, password: router.password })
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.success || !res.interfaces || res.interfaces.length === 0) {
          contentEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-gray);">No se pudieron obtener interfaces: ' + (res.error || 'sin datos') + '</div>';
          return;
        }
        var h = '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:0.82rem;">';
        h += '<thead><tr style="background:var(--bg-body);"><th style="padding:8px 10px;text-align:left;">Nombre</th><th style="padding:8px 10px;text-align:left;">Tipo</th><th style="padding:8px 10px;text-align:center;">Estado</th><th style="padding:8px 10px;text-align:right;">TX (bps)</th><th style="padding:8px 10px;text-align:right;">RX (bps)</th></tr></thead><tbody>';
        res.interfaces.forEach(function(iface) {
          var disabled = iface.disabled === 'true';
          var statusClass = disabled ? 'color:#991b1b;background:#fef2f2;' : 'color:#166534;background:#dcfce7;';
          var statusText = disabled ? 'Disabled' : 'Running';
          h += '<tr style="border-bottom:1px solid var(--border-color);">';
          h += '<td style="padding:8px 10px;font-weight:600;">' + escHtml(iface.name) + '</td>';
          h += '<td style="padding:8px 10px;color:var(--text-gray);">' + escHtml(iface.type || '—') + '</td>';
          h += '<td style="padding:8px 10px;text-align:center;"><span style="display:inline-flex;align-items:center;gap:4px;padding:2px 10px;border-radius:10px;font-size:0.7rem;font-weight:600;' + statusClass + '"><i class="fas fa-circle" style="font-size:0.35rem;"></i> ' + statusText + '</span></td>';
          h += '<td style="padding:8px 10px;text-align:right;font-family:monospace;font-size:0.75rem;">' + (iface['tx-byte'] ? formatBytes(iface['tx-byte']) : '—') + '</td>';
          h += '<td style="padding:8px 10px;text-align:right;font-family:monospace;font-size:0.75rem;">' + (iface['rx-byte'] ? formatBytes(iface['rx-byte']) : '—') + '</td>';
          h += '</tr>';
        });
        h += '</tbody></table></div>';
        contentEl.innerHTML = h;
      })
      .catch(function(e) {
        contentEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--accent-danger);">Error: ' + e.message + '</div>';
      });
    });
}

function cargarDHCPLeases(contentEl) {
  fetch('/api/routers/' + detailRouterId)
    .then(function(r) { return r.json(); })
    .then(function(router) {
      if (!router.user || !router.password) {
        contentEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-gray);"><i class="fas fa-exclamation-triangle" style="font-size:2rem;display:block;margin-bottom:10px;color:#f59e0b;"></i>Credenciales incompletas.</div>';
        return;
      }
      fetch('/api/routers/dhcp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ host: router.ip, port: router.port || 8728, username: router.user, password: router.password })
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.success || !res.leases || res.leases.length === 0) {
          contentEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-gray);">' + (res.error ? 'Error: ' + res.error : 'No hay leases DHCP') + '</div>';
          return;
