      <div class="btn-group" style="justify-content:center;">
        <button class="btn btn-secondary" onclick="cerrarModalEliminar()">Cancelar</button>
        <button class="btn btn-danger" id="btnConfirmarEliminar">Sí, eliminar</button>
      </div>
    </div>
  </div>
</div>

