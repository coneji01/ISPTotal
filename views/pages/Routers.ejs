<div class="page-header">
  <h2><i class="fas fa-server"></i> Gestión de Routers</h2>
  <button class="btn btn-primary btn-sm" onclick="abrirModalCrear()"><i class="fas fa-plus"></i> Nuevo Router</button>
</div>

<div class="card">
  <div class="card-body" id="routersList">
    <div class="loading"><i class="fas fa-spinner fa-spin"></i><br>Cargando routers...</div>
  </div>
</div>

<!-- Modal Crear/Editar Router -->
<div id="modalRouter" class="modal" style="display:none">
  <div class="modal-content" style="max-width:500px;">
    <div class="modal-header">
      <h3 id="modalTitle"><i class="fas fa-plus-circle" style="color:#10b981;"></i> Nuevo Router</h3>
      <span class="modal-close" onclick="cerrarModal()">&times;</span>
    </div>
    <div class="modal-body">
      <form id="formRouter" onsubmit="guardarRouter(event)">
        <input type="hidden" name="accion" id="accionInput" value="guardar">
        <input type="hidden" name="id_router_edit" id="idRouterInput" value="">
        
        <div class="form-group">
          <label>Nombre del Router</label>
          <input type="text" name="name" id="routerName" class="form-control" placeholder="Ej: Router Cliente 001" required>
        </div>

        <!-- Selector de Tipo de Conexión -->
        <div class="form-group">
          <label>Tipo de Conexión</label>
          <div style="display:flex;gap:10px;margin-top:6px;">
            <label class="radio-card" onclick="seleccionarTipo('ip')" id="tipoIP" style="flex:1;padding:12px;border:2px solid #e2e8f0;border-radius:10px;cursor:pointer;text-align:center;transition:all .2s;background:#f0fdf4;border-color:#10b981;">
              <input type="radio" name="connection_type" value="ip" checked style="display:none;">
              <i class="fas fa-globe" style="font-size:1.2rem;color:#10b981;"></i>
              <div style="font-weight:600;margin-top:4px;font-size:0.85rem;">IP Pública</div>
              <div style="font-size:0.7rem;color:#64748b;">Conexión directa</div>
            </label>
            <label class="radio-card" onclick="seleccionarTipo('sstp')" id="tipoSSTP" style="flex:1;padding:12px;border:2px solid #e2e8f0;border-radius:10px;cursor:pointer;text-align:center;transition:all .2s;background:#f5f3ff;border-color:#8b5cf6;">
              <input type="radio" name="connection_type" value="sstp" checked style="display:none;">
              <i class="fas fa-link" style="font-size:1.2rem;color:#8b5cf6;"></i>
              <div style="font-weight:600;margin-top:4px;font-size:0.85rem;">SSTP (VPN)</div>
              <div style="font-size:0.7rem;color:#64748b;">Conexión simple</div>
            </label>
          </div>
        </div>

        <!-- Campos para IP Pública -->
        <div id="camposIP">
          <div class="row" style="display:flex;gap:10px;">
            <div class="form-group" style="flex:3;">
              <label>IP del Router</label>
              <input type="text" name="ip" id="routerIp" class="form-control" placeholder="IP pública del router">
            </div>
            <div class="form-group" style="flex:1;">
              <label>Puerto API</label>
              <input type="number" name="port" id="routerPort" class="form-control" value="8728">
            </div>
          </div>
          <div class="row" style="display:flex;gap:10px;">
            <div class="form-group" style="flex:1;">
              <label>Usuario API</label>
              <input type="text" name="user" id="routerUser" class="form-control" placeholder="admin">
            </div>
            <div class="form-group" style="flex:1;">
              <label>Password API</label>
              <input type="password" name="password" id="routerPass" class="form-control" placeholder="••••••••">
            </div>
          </div>
        </div>

        <!-- Campos para VPN (WireGuard) - Mínimos -->
        <div id="camposVPN" style="display:none;">
          <div style="background:#ecfdf5;border:1px solid #6ee7b7;border-radius:10px;padding:16px;">
            <p style="font-size:0.85rem;color:#047857;margin:0 0 6px 0;">
              <i class="fas fa-info-circle"></i> Solo necesitas el nombre. El sistema generará automáticamente la IP de túnel, puerto y script completo.
            </p>
            <div class="form-group" style="margin-bottom:0;">
              <label>IP Pública del Cliente <span style="font-weight:400;color:#94a3b8;font-size:0.75rem;">(opcional, mejora detección)</span></label>
              <input type="text" id="wgClientPublicIp" class="form-control" placeholder="Ej: 200.100.x.x" style="font-family:monospace;">
            </div>
          </div>
        </div>

        <!-- Campos para Pools de IP -->
        <div id="camposPools" style="margin-top:16px;padding-top:16px;border-top:1px solid #e2e8f0;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
            <label style="font-weight:600;font-size:0.88rem;color:#1e293b;">
              <i class="fas fa-network-wired" style="color:#2563eb;"></i> Pools de IP
            </label>
            <button type="button" class="btn btn-sm btn-success" onclick="agregarPool()" style="font-size:0.75rem;padding:4px 10px;">
              <i class="fas fa-plus"></i> Agregar Rango
            </button>
          </div>
          <div id="poolsContainer">
            <!-- Los pools se agregan dinámicamente aquí -->
          </div>
          <div style="margin-top:8px;">
            <button type="button" class="btn btn-sm btn-info" onclick="aplicarPoolsRouter()" id="btnAplicarPools" style="font-size:0.75rem;display:none;background:#0ea5e9;color:#fff;border:none;padding:4px 10px;border-radius:6px;">
              <i class="fas fa-upload"></i> Enviar pools al MikroTik
            </button>
          </div>
        </div>

        <!-- Botones del modal -->
        <div id="modalBotones" style="display:flex;gap:8px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid #e2e8f0;">
          <button type="button" class="btn btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <div id="btnGroupExtra" style="display:none;gap:8px;">
            <button type="button" class="btn btn-success" onclick="generarScriptRouterActual()" id="btnGenScript"><i class="fas fa-file-code"></i> Generar Script</button>
            <button type="button" class="btn btn-info" onclick="probarRouterActual()" id="btnProbarConexion" style="background:#0ea5e9;color:#fff;border:none;"><i class="fas fa-plug"></i> Probar Conexión</button>
          </div>
          <button type="submit" class="btn btn-primary" id="btnGuardarRouter"><i class="fas fa-save"></i> Guardar Router</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Script WireGuard -->
<div id="modalScriptWG" class="modal" style="display:none">
  <div class="modal-content" style="max-width:750px;">
    <div class="modal-header">
      <h3><i class="fas fa-shield-alt" style="color:#10b981;"></i> Script WireGuard - Listo para pegar</h3>
      <span class="modal-close" onclick="cerrarModalScriptWG()">&times;</span>
    </div>
    <div class="modal-body">
      <div style="background:#f0fdf4;border:1px solid #6ee7b7;border-radius:8px;padding:10px 14px;margin-bottom:12px;font-size:0.82rem;color:#047857;">
        <i class="fas fa-check-circle"></i> 
        <strong>Router: <span id="scriptRouterName"></span></strong> &mdash; 
        IP Túnel: <code id="scriptTunnelIp"></code> &mdash; 
        Servidor: <code id="scriptServerEndpoint"></code>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <label style="font-weight:600;font-size:0.9rem;">Copia este script en la terminal del MikroTik cliente:</label>
        <div>
          <button class="btn btn-sm btn-success" onclick="agregarPeerEnBorde()" id="btnAddPeer"><i class="fas fa-plus-circle"></i> Agregar peer en borde</button>
          <button class="btn btn-sm btn-secondary" onclick="copiarScriptWG()"><i class="fas fa-copy"></i> Copiar</button>
          <button class="btn btn-sm btn-secondary" onclick="descargarScriptWG()"><i class="fas fa-download"></i> Descargar</button>
        </div>
      </div>
      <textarea id="scriptOutputWG" style="width:100%;height:350px;font-family:'Consolas','Monaco',monospace;font-size:0.8rem;background:#1e293b;color:#e2e8f0;border:none;border-radius:8px;padding:16px;resize:vertical;tab-size:2;" readonly></textarea>
    </div>
  </div>
</div>

<!-- Modal Confirmar Eliminar -->
