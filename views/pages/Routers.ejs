        var h = '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:0.82rem;">';
        h += '<thead><tr style="background:var(--bg-body);"><th style="padding:8px 10px;text-align:left;">Dirección</th><th style="padding:8px 10px;text-align:left;">MAC</th><th style="padding:8px 10px;text-align:left;">Server</th><th style="padding:8px 10px;text-align:center;">Estado</th><th style="padding:8px 10px;text-align:left;">Comentario</th></tr></thead><tbody>';
        res.leases.forEach(function(l) {
          var isDinamic = l['dynamic'] === 'true';
          var statusClass = isDinamic ? 'color:#166534;background:#dcfce7;' : 'color:#92400e;background:#fef3c7;';
          var statusText = isDinamic ? 'Dynamic' : 'Static';
          h += '<tr style="border-bottom:1px solid var(--border-color);">';
          h += '<td style="padding:8px 10px;font-family:monospace;">' + escHtml(l.address) + '</td>';
          h += '<td style="padding:8px 10px;font-family:monospace;font-size:0.75rem;color:var(--text-gray);">' + escHtml(l['mac-address'] || '—') + '</td>';
          h += '<td style="padding:8px 10px;">' + escHtml(l.server || '—') + '</td>';
          h += '<td style="padding:8px 10px;text-align:center;"><span style="display:inline-flex;gap:4px;padding:2px 10px;border-radius:10px;font-size:0.7rem;font-weight:600;' + statusClass + '">' + statusText + '</span></td>';
          h += '<td style="padding:8px 10px;color:var(--text-gray);">' + escHtml(l.comment || '') + '</td>';
          h += '</tr>';
        });
        h += '</tbody></table></div>';
        contentEl.innerHTML = h;
      })
      .catch(function(e) {
        contentEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--accent-danger);">Error: ' + e.message + '</div>';
      });
    });
}

