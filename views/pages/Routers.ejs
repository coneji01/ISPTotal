<!-- Modal Pool IP -->
<div id="modalPool" class="modal" style="display:none">
  <div class="modal-content" style="max-width:500px;">
    <div class="modal-header">
      <h3><i class="fas fa-network-wired" style="color:#10b981;"></i> Nuevo Rango IP</h3>
      <span class="modal-close" onclick="cerrarModalPool()">&times;</span>
    </div>
    <div class="modal-body">
      <input type="hidden" id="poolRouterId" value="0">
      <div class="form-group">
