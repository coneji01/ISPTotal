<!-- Modal Script WireGuard -->
<div id="modalScriptWG" class="modal" style="display:none">
  <div class="modal-content" style="max-width:800px;">
    <div class="modal-header">
      <h3><i class="fas fa-shield-alt" style="color:#10b981;"></i> Script WireGuard</h3>
      <span class="modal-close" onclick="cerrarModalScriptWG()">&times;</span>
    </div>
    <div class="modal-body">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <label style="font-weight:600;font-size:0.9rem;">Copia este script en la terminal del MikroTik cliente (System > Scripts o directamente en CLI):</label>
        <div>
          <button class="btn btn-sm btn-secondary" onclick="copiarScriptWG()"><i class="fas fa-copy"></i> Copiar</button>
          <button class="btn btn-sm btn-secondary" onclick="descargarScriptWG()"><i class="fas fa-download"></i> Descargar</button>
        </div>
      </div>
      <textarea id="scriptOutputWG" style="width:100%;height:400px;font-family:'Consolas','Monaco',monospace;font-size:0.8rem;background:#1e293b;color:#e2e8f0;border:none;border-radius:8px;padding:16px;resize:vertical;tab-size:2;" readonly></textarea>
    </div>
  </div>
</div>

<script>
let routerActualId = 0;
let scriptGeneradoWG = '';
var _ultimoScriptData = null; // Guarda datos del último script generado (public key, IP, etc.)

// ====== AUTO-ASIGNAR IP DE TÚNEL ======
// Cada router VPN recibe automáticamente la próxima IP disponible en 10.10.10.x/24
// El servidor usa 10.10.10.1, los clientes empiezan en 10.10.10.2
var _nextTunnelIp = 2;

function obtenerSiguienteTunnelIp() {
  var id = parseInt(document.getElementById('idRouterInput').value) || 0;
  // Si es router existente, mantener su IP
  if (id > 0) {
    return '10.10.10.' + (id + 1) + '/24';
  }
  // Si es nuevo, asignar siguiente disponible
  var ip = '10.10.10.' + _nextTunnelIp + '/24';
  _nextTunnelIp++;
  return ip;
}

// ====== SELECCIONAR TIPO ======
function seleccionarTipo(tipo) {
  document.getElementById('tipoIP').style.background = tipo === 'ip' ? '#f0fdf4' : '#fff';
  document.getElementById('tipoIP').style.borderColor = tipo === 'ip' ? '#10b981' : '#e2e8f0';
  document.getElementById('tipoSSTP').style.background = tipo === 'sstp' ? '#f5f3ff' : '#fff';
  document.getElementById('tipoSSTP').style.borderColor = tipo === 'sstp' ? '#8b5cf6' : '#e2e8f0';
  
  document.getElementById('camposIP').style.display = tipo === 'ip' ? 'block' : 'none';
  document.getElementById('camposVPN').style.display = tipo === 'sstp' ? 'block' : 'none';
  
  document.getElementById('routerIp').required = tipo === 'ip';
}

// ====== GUARDAR ROUTER ======
function guardarRouter(e) {
  e.preventDefault();
  var tipo = document.querySelector('input[name="connection_type"]:checked').value;
  // SSTP se guarda como sstp en DB
  var tunnelIp = obtenerSiguienteTunnelIp();
  
  const data = {
    accion: document.getElementById('accionInput').value,
    id_router_edit: document.getElementById('idRouterInput').value,
    name: document.getElementById('routerName').value,
    connection_type: tipo,
    ip: tipo === 'vpn' ? tunnelIp.split('/')[0] : document.getElementById('routerIp').value,
    port: tipo === 'vpn' ? 13231 : document.getElementById('routerPort').value,
    user: tipo === 'ip' ? document.getElementById('routerUser').value : '',
    password: tipo === 'ip' ? document.getElementById('routerPass').value : '',
    interface_wan: 'ether1',
    vpn_user: '',
    vpn_password: '',
    vpn_ip: tipo === 'vpn' ? document.getElementById('wgClientPublicIp').value.trim() : ''
  };

  // Deshabilitar botón guardar
  var btnGuardar = document.getElementById('btnGuardarRouter');
  btnGuardar.disabled = true;
  btnGuardar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

  fetch('/api/routers/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(r => r.json())
  .then(res => {
    btnGuardar.disabled = false;
    btnGuardar.innerHTML = '<i class="fas fa-save"></i> Guardar Router';
    
    if (res.success) {
      document.getElementById('idRouterInput').value = res.id;
      routerActualId = res.id;
      
      if (tipo === 'sstp') {
          document.getElementById('idRouterInput').value = res.id;
          routerActualId = res.id;
          guardarPoolsRouter(res.id);
          cerrarModal();
          cargarRouters();
          // Generar script SSTP automaticamente
          generarScriptSSTP(res.id);
        } else {
          guardarPoolsRouter(res.id);
          showToast('Router guardado exitosamente');
          cerrarModal();
          cargarRouters();
        }
    } else {
      showToast('Error: ' + (res.message || 'No se pudo guardar'), 'error');
    }
  })
  .catch(function() {
    btnGuardar.disabled = false;
    btnGuardar.innerHTML = '<i class="fas fa-save"></i> Guardar Router';
    showToast('Error de conexión', 'error');
  });
}

// ====== GENERAR SCRIPT (desde el modal, después de guardar) ======
function generarScriptRouterActual() {
  var id = routerActualId;
  if (!id) { showToast('Primero guarda el router', 'error'); return; }
  generarScriptPorId(id);
}

function generarScriptPorId(id) {
  fetch('/api/routers/' + id)
    .then(function(r) { return r.json(); })
    .then(function(r) {
      var name = r.name;
      var tipo = r.connection_type;
      
      if (tipo === 'sstp') {
        generarScriptSSTP(id);
        return;
      }
      
      // Para IP directa... script no disponible
      showToast('Este router no tiene script disponible', 'error');
    });
}

// ====== PROBAR CONEXIÓN (desde el modal, después de guardar) ======
function probarRouterActual() {
  var id = routerActualId;
  if (!id) { showToast('Primero guarda el router', 'error'); return; }
  probarConexionRouter(id);
}

// ====== COPIAR / DESCARGAR SCRIPT ======
function copiarScriptWG() {
  var textarea = document.getElementById('scriptOutputWG');
  textarea.select();
  if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
    navigator.clipboard.writeText(textarea.value).then(function() {
      showToast('Script copiado al portapapeles');
    }).catch(function() {
      document.execCommand('copy');
      showToast('Script copiado');
    });
  } else {
    document.execCommand('copy');
    showToast('Script copiado');
  }
}

function descargarScriptWG() {
  var name = document.getElementById('scriptRouterName').textContent || 'router';
  var blob = new Blob([scriptGeneradoWG], { type: 'text/plain' });
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = name.replace(/[^a-zA-Z0-9]/g, '_') + '_wireguard.rsc';
  a.click();
  URL.revokeObjectURL(a.href);
}

function cerrarModalScriptWG() {
  document.getElementById('modalScriptWG').style.display = 'none';
}

// ====== AGREGAR PEER EN EL BORDE AUTOMÁTICAMENTE ======
function agregarPeerEnBorde() {
  if (!_ultimoScriptData || !_ultimoScriptData.client_tunnel_ip) {
    showToast('Primero genera el script WireGuard', 'error');
    return;
  }
  
  // Primero preguntar al usuario la public key del cliente
  // (aparece en el MikroTik cliente después de pegar el script)
  var pk = prompt(
    'Ingresa la Public Key del cliente (aparece al ejecutar: /interface wireguard print detail where name=wg-isptotal):',
    ''
  );
  
  if (!pk || pk.trim() === '') {
    showToast('Operación cancelada - ingresa la public key del cliente', 'error');
    return;
  }
  
  _ultimoScriptData.client_public_key = pk.trim();
  
  var btn = document.getElementById('btnAddPeer');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Agregando peer...';
  
  fetch('/api/routers/add-peer-to-border', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(_ultimoScriptData)
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-plus-circle"></i> Agregar peer en borde';
    
    if (res.success) {
      showToast('✅ Peer agregado en el borde. El túnel debe estar activo ahora.');
      // Verificar conectividad automáticamente
      if (routerActualId) {
        setTimeout(function() { probarConexionRouter(routerActualId); }, 1000);
      }
    } else {
      showToast('❌ Error: ' + (res.error || 'No se pudo agregar peer'), 'error');
    }
  })
  .catch(function(e) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-plus-circle"></i> Agregar peer en borde';
    showToast('Error de conexión: ' + e.message, 'error');
  });
}

// ====== CARGAR LISTA DE ROUTERS ======
function cargarRouters() {
  // Refrescar estado de routers VPN en background
  fetch('/api/routers/sync-vpn-status', { method: 'POST' }).catch(function(){});
  
  fetch('/api/routers')
    .then(r => {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(data => {
      if (data.length === 0) {
        document.getElementById('routersList').innerHTML = '<p style="text-align:center;padding:40px;color:var(--text-gray);"><i class="fas fa-server" style="font-size:2rem;display:block;margin-bottom:10px;"></i>No hay routers registrados<br><button class="btn btn-primary btn-sm mt-20" onclick="abrirModalCrear()"><i class="fas fa-plus"></i> Nuevo Router</button></p>';
        return;
      }
      let html = '<div class="table-container"><table><thead><tr><th>#</th><th>Nombre</th><th>Tipo</th><th>IP / Puerto</th><th>Estado</th><th>Acciones</th></tr></thead><tbody>';
      data.forEach((r, i) => {
        const tipo = r.connection_type === 'sstp' ? '<span style="color:#8b5cf6;"><i class="fas fa-link"></i> SSTP VPN</span>' : '<span style="color:#10b981;"><i class="fas fa-globe"></i> IP</span>';
        const status = r.connected ? '<span class="badge badge-success">Online</span>' : '<span class="badge badge-danger">Offline</span>';
        const ipInfo = r.connection_type === 'sstp' ? (r.vpn_ip || r.ip || '—') : (r.ip + ':' + (r.port || 8728));
        html += '<tr><td>' + (i+1) + '</td><td><strong>' + r.name + '</strong></td><td>' + tipo + '</td><td style="font-family:monospace;font-size:0.85rem;">' + ipInfo + '</td><td>' + status + '</td><td>';
        html += '<div class="btn-group">';
        if (r.connection_type === 'sstp') {
          html += '<button class="btn btn-sm btn-success" onclick="verScript(' + r.id + ')" title="Generar script"><i class="fas fa-file-code"></i></button>';
        }
        html += '<button class="btn btn-sm btn-info" onclick="probarConexionRouter(' + r.id + ')" title="Probar conexion"><i class="fas fa-plug"></i></button>';
        html += '<button class="btn btn-sm btn-secondary" onclick="abrirModalEditar(' + r.id + ')" title="Editar"><i class="fas fa-edit"></i></button>';
        html += '<button class="btn btn-sm btn-danger" onclick="confirmarEliminar(' + r.id + ',\'' + ('' + r.name).replace(/'/g, '') + '\')" title="Eliminar"><i class="fas fa-trash"></i></button>';
        html += '</div></td></tr>';
      });
      html += '</tbody></table></div>';
      document.getElementById('routersList').innerHTML = html;
    })
    .catch(function(e) {
      document.getElementById('routersList').innerHTML = '<p style="text-align:center;padding:30px;color:#ef4444;"><i class="fas fa-exclamation-triangle"></i> Error: ' + e.message + '</p>';
    });
}

// ====== ABRIR MODAL CREAR ======
function abrirModalCrear() {
  document.getElementById('formRouter').reset();
  document.getElementById('accionInput').value = 'guardar';
  document.getElementById('idRouterInput').value = '';
  routerActualId = 0;
  document.getElementById('modalTitle').innerHTML = '<i class="fas fa-plus-circle" style="color:#10b981;"></i> Nuevo Router';
  
  // Reset tipo
  document.getElementById('tipoIP').style.background = '#f0fdf4';
  document.getElementById('tipoIP').style.borderColor = '#10b981';
  document.getElementById('camposIP').style.display = 'block';
  document.getElementById('camposVPN').style.display = 'none';
  document.getElementById('routerIp').required = true;
  
  // Reset botones extra
  document.getElementById('btnGroupExtra').style.display = 'none';
  document.getElementById('btnGuardarRouter').innerHTML = '<i class="fas fa-save"></i> Guardar Router';
  document.getElementById('btnGuardarRouter').disabled = false;
  
  document.getElementById('wgClientPublicIp').value = '';
  cargarPoolsRouter(0);
  document.getElementById('btnAplicarPools').style.display = 'none';
  
  document.getElementById('modalRouter').style.display = 'flex';
}

// ====== ABRIR MODAL EDITAR ======
function abrirModalEditar(id) {
  fetch('/api/routers/' + id)
    .then(r => {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(r => {
      document.getElementById('accionInput').value = 'editar';
      document.getElementById('idRouterInput').value = r.id;
      routerActualId = r.id;
      cargarPoolsRouter(r.id);
      document.getElementById('routerName').value = r.name;
      
      var tipo = r.connection_type || 'ip';
      // Normalizar: wireguard/vpn -> sstp (ya no existe opcion vpn separada)
      if (tipo !== 'ip' && tipo !== 'sstp') tipo = 'sstp';
      seleccionarTipo(tipo);
      document.querySelector('input[name="connection_type"][value="' + tipo + '"]').checked = true;
      
      document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit" style="color:#f59e0b;"></i> Editar Router';
      
      if (tipo === 'ip') {
        document.getElementById('routerIp').value = r.ip;
        document.getElementById('routerPort').value = r.port || 8728;
        document.getElementById('routerUser').value = r.user || '';
        document.getElementById('routerPass').value = r.password || '';
      } else {
        document.getElementById('wgClientPublicIp').value = r.vpn_ip || '';
      }
      
      // Mostrar botones extra si ya está guardado
      document.getElementById('btnGroupExtra').style.display = tipo === 'sstp' ? 'flex' : 'none';
      document.getElementById('btnGuardarRouter').innerHTML = '<i class="fas fa-save"></i> Guardar Router';
      document.getElementById('btnGuardarRouter').disabled = false;
      
      document.getElementById('modalRouter').style.display = 'flex';
    })
    .catch(function(e) {
      showToast('Error al cargar router: ' + e.message, 'error');
    });
}

// ====== VER SCRIPT DESDE LA TABLA ======
function verScript(id) {
  fetch('/api/routers/' + id)
    .then(function(r) { return r.json(); })
    .then(function(r) {
      if (r.connection_type === 'sstp') {
        generarScriptSSTP(id);
      } else {
        showToast('Este router no tiene script VPN', 'error');
      }
    });
}

// ====== PROBAR CONEXIÓN DESDE LA TABLA ======
function probarConexionRouter(id) {
  fetch('/api/routers/' + id)
    .then(function(r) { return r.json(); })
    .then(function(r) {
      var btn = document.getElementById('btnProbarConexion');
      if (btn) btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Probando ping...';
      
      fetch('/api/routers/test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          host: r.connection_type === 'sstp' ? (r.vpn_ip || r.ip) : r.ip, 
          port: r.port || 8728, 
          username: r.user || '', 
          password: r.password || '',
          connection_type: r.connection_type || 'ip'
        })
      })
      .then(function(resp) { return resp.json(); })
      .then(function(res) {
        if (btn) btn.innerHTML = '<i class="fas fa-plug"></i> Probar Conexión';
        if (res.success) {
          showToast('✅ ' + r.name + ' - Online (' + r.ip + ')');
          cargarRouters(); // Recargar para actualizar estados
        } else {
          showToast('❌ ' + r.name + ' - ' + (res.error || 'Sin conexión'), 'error');
          cargarRouters();
        }
      })
      .catch(function() {
        if (btn) btn.innerHTML = '<i class="fas fa-plug"></i> Probar Conexión';
        showToast('Error de conexión con el servidor', 'error');
      });
    })
    .catch(function(e) {
      showToast('Error al cargar router: ' + e.message, 'error');
    });
}

// ====== MODALES SIMPLES ======
function cerrarModal() { document.getElementById('modalRouter').style.display = 'none'; }

function confirmarEliminar(id, nombre) {
  document.getElementById('eliminarMsg').innerHTML = 'Está seguro que desea eliminar el router <b>' + nombre + '</b>? Esta acción no se puede deshacer.';
  document.getElementById('btnConfirmarEliminar').onclick = function() {
    fetch('/api/routers/' + id + '/delete', { method: 'POST' })
      .then(r => r.json()).then(res => {
        if (res.success) { showToast('Router eliminado'); cerrarModalEliminar(); cargarRouters(); }
        else showToast('Error al eliminar', 'error');
      });
  };
  document.getElementById('modalEliminar').style.display = 'flex';
}
function cerrarModalEliminar() { document.getElementById('modalEliminar').style.display = 'none'; }

// ====== GESTION DE POOLS DE IP ======
var poolsEditando = [];

function agregarPool(cidr, desc, gw) {
  var container = document.getElementById('poolsContainer');
  var idx = poolsEditando.length;
  poolsEditando.push({ cidr: cidr || '', descripcion: desc || '', gateway: gw || '' });
  
  var div = document.createElement('div');
  div.id = 'pool-row-' + idx;
  div.style.cssText = 'display:flex;gap:6px;align-items:center;margin-bottom:6px;background:#f8fafc;padding:8px;border-radius:6px;border:1px solid #e2e8f0;';
  div.innerHTML = `
    <input type="text" class="form-control pool-cidr" value="${cidr||''}" placeholder="Ej: 172.16.100.0/22" style="flex:2;font-family:monospace;font-size:0.82rem;padding:5px 8px;" onchange="actualizarPool(${idx},'cidr',this.value)">
    <input type="text" class="form-control pool-desc" value="${desc||''}" placeholder="Descripción" style="flex:1;font-size:0.82rem;padding:5px 8px;" onchange="actualizarPool(${idx},'descripcion',this.value)">
    <input type="text" class="form-control pool-gw" value="${gw||''}" placeholder="Gateway" style="flex:1;font-family:monospace;font-size:0.82rem;padding:5px 8px;" onchange="actualizarPool(${idx},'gateway',this.value)">
    <button type="button" class="btn btn-sm btn-danger" onclick="eliminarPool(${idx})" style="padding:4px 8px;font-size:0.75rem;">×</button>
  `;
  container.appendChild(div);
}

function actualizarPool(idx, campo, valor) {
  if (poolsEditando[idx]) poolsEditando[idx][campo] = valor;
}

function eliminarPool(idx) {
  var div = document.getElementById('pool-row-' + idx);
  if (div) div.remove();
  if (poolsEditando[idx]) poolsEditando[idx] = null;
}

function cargarPoolsRouter(routerId) {
  document.getElementById('poolsContainer').innerHTML = '';
  poolsEditando = [];
  if (!routerId) return;
  
  fetch('/api/routers/' + routerId + '/pools')
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success && res.data) {
        res.data.forEach(function(p) {
          agregarPool(p.cidr, p.descripcion, p.gateway);
        });
      }
      // Mostrar boton de aplicar si hay pools
      document.getElementById('btnAplicarPools').style.display = poolsEditando.some(function(p){return p&&p.cidr;}) ? 'inline-block' : 'none';
    })
    .catch(function(){});
}

function guardarPoolsRouter(routerId) {
  var pools = poolsEditando.filter(function(p) { return p && p.cidr && p.cidr.trim(); });
  return fetch('/api/routers/save-pools', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ router_id: routerId, pools: pools })
  }).then(function(r) { return r.json(); });
}

function aplicarPoolsRouter() {
  var id = routerActualId || document.getElementById('idRouterInput').value;
  if (!id) { showToast('Primero guarda el router', 'error'); return; }
  
  var btn = document.getElementById('btnAplicarPools');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
  
  // Enviar pools directamente (ya estan en DB)
  fetch('/api/routers/apply-pools', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ router_id: id })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-upload"></i> Enviar pools al MikroTik';
      if (res.success) {
        var ok = res.data.filter(function(r){return r.success;}).length;
        var fail = res.data.filter(function(r){return !r.success;}).length;
        showToast('✅ ' + ok + ' pools enviados' + (fail ? ', ' + fail + ' fallaron' : ''));
      } else {
        showToast('Error: ' + (res.error || ''), 'error');
      }
    });
}

// ====== GENERAR SCRIPT SSTP ======
function generarScriptSSTP(id) {
  fetch('/api/routers/' + id)
    .then(function(r) { return r.json(); })
    .then(function(r) {
      var name = r.name;
      var routerId = r.router_id || '';
      
      fetch('/api/routers/generate-vpn-script', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: name,
          router_id: routerId,
          ip_fija: '10.50.' + (Math.floor(Math.random() * 255) + 1) + '.' + (Math.floor(Math.random() * 254) + 2)
        })
      })
      .then(function(rr) { return rr.json(); })
      .then(function(res) {
        if (res.success) {
          document.getElementById('scriptOutputWG').value = res.script;
          document.getElementById('scriptRouterName').textContent = name;
          document.getElementById('scriptTunnelIp').textContent = res.vpn_ip || '10.50.0.1';
          document.getElementById('scriptServerEndpoint').textContent = '38.159.230.88:443';
          scriptGeneradoWG = res.script;
          
          document.getElementById('btnAddPeer').style.display = 'none';
          document.getElementById('modalScriptWG').style.display = 'flex';
          showToast('✅ Script SSTP generado. Usuario: ' + res.sstp_user);
        } else {
          showToast('Error: ' + (res.error || ''), 'error');
        }
      });
    });
}

// ====== INICIALIZAR ======
cargarRouters();
</script>
