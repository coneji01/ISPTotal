<script type="text/javascript">
$( document ).ready(function() {
  $.ajaxSetup({
    cache: false
  });
  
  window.jqxhrs = [];

  window.registerJqxhr = function(jqxhr) {
    jqxhrs.push(jqxhr);
  }

  window.abortJqxhr = function() {
    for (var i = jqxhrs.length - 1; i >= 0; i--) {
      if (jqxhrs[i]) {
        jqxhrs[i].abort();
      }
    }
    window.jqxhrs = [];
  }

  $(window).bind("beforeunload", function(event) {
    abortJqxhr();
  });

  function unregisterJqxhr(event, jqxhr, settings) {
    var idx = $.inArray(jqxhr, jqxhrs);
    if (idx != -1) {
      jqxhrs.splice(idx, 1);
    }
  }

  $(document).ajaxComplete(unregisterJqxhr);

  config = {
    X_TOKEN: '9C23F19BE06B4BEB93046ECFDF50FF91'
  }

  // Get OLT ID from URL query params (e.g., ?olt_id=123)
  function getOltId() {
    var params = new URLSearchParams(window.location.search);
    var id = params.get('olt_id') || params.get('id');
    if (id) return id;
    // Fallback: try to extract from the path
    var m = window.location.pathname.match(/\/olts?\/(\d+)/);
    return m ? m[1] : null;
  }

  var oltId = getOltId();
  if (!oltId) {
    // Try to get from a data attribute on the page
    oltId = $('#olt-data').data('olt-id');
  }

  // Load PON port data from API
  function loadPonPorts() {
    if (!oltId) {
      $('.tab-pane tbody').html('<tr><td colspan="7" class="text-center text-muted">OLT ID not found in URL</td></tr>');
      return;
    }

    $.ajax({
      url: '/api/olts/' + oltId + '/pon-ports',
      method: 'GET',
      headers: { 'X-Token': config.X_TOKEN },
      success: function(data) {
        renderPonPorts(data);
      },
      error: function(xhr) {
        var msg = 'Failed to load PON port data';
        if (xhr.responseJSON && xhr.responseJSON.message) {
          msg = xhr.responseJSON.message;
        }
        $('.tab-pane tbody').html('<tr><td colspan="7" class="text-center text-danger">' + msg + '</td></tr>');
        $.MessageBox(msg, 'error');
      }
    });
  }

  // Render PON port data into board tabs
  function renderPonPorts(data) {
    var boards = data.boards || data;
    // boards is expected to be an object keyed by board number, e.g. { "2": [...], "3": [...], "4": [...] }
    // or an array of board objects.

    // Normalise: if it's an array, index by board number
    if (Array.isArray(boards)) {
      var indexed = {};
      boards.forEach(function(b) {
        indexed[b.board] = b.ports || b;
      });
      boards = indexed;
    }

    var boardIds = [2, 3, 4];
    boardIds.forEach(function(boardId) {
      var ports = boards[boardId];
      var tbody = $('#board-' + boardId + ' tbody');
      tbody.empty();

      if (!ports || !Array.isArray(ports) || ports.length === 0) {
        tbody.html('<tr><td colspan="7" class="text-center text-muted">No PON port data available for Board ' + boardId + '</td></tr>');
        return;
      }

      // Generate 16 port rows (fill missing ports with empty rows)
      for (var i = 1; i <= 16; i++) {
        var port = null;
        // Find port data matching this port number
        for (var j = 0; j < ports.length; j++) {
          if (ports[j].port === i || ports[j].port_number === i || ports[j].portId === i || ports[j].index === i) {
            port = ports[j];
            break;
          }
        }

        var tr = $('<tr></tr>');

        if (port) {
          var portLabel = port.port || port.port_number || port.portId || port.index || i;
          var portType = port.type || port.port_type || 'GPON';
          var status = port.status || 'Down';
          var onlineOnus = port.online_onus || port.online || port.onlineOnus || 0;
          var totalOnus = port.total_onus || port.total || port.totalOnus || 0;
          var signal = port.signal != null ? parseFloat(port.signal) : null;

          // Board/Port
          tr.append('<td>' + boardId + '/' + portLabel + '</td>');
          // Type
          tr.append('<td>' + portType + '</td>');
          // Status
          var statusLabel = status === 'Up' ? 'success' : (status === 'Down' ? 'danger' : 'warning');
          tr.append('<td><span class="label label-' + statusLabel + '">' + status + '</span></td>');
          // Online ONUs
          tr.append('<td><a href="#" class="btn btn-link no-padding-left">' + onlineOnus + '</a></td>');
          // Total ONUs
          tr.append('<td><a href="#" class="btn btn-link no-padding-left">' + totalOnus + '</a></td>');
          // Signal
          if (signal !== null) {
            var signalClass = signal < -30 ? 'signal-poor' : (signal < -28 ? 'signal-fair' : 'signal-good');
            tr.append('<td class="' + signalClass + '">' + signal.toFixed(1) + ' <i class="fa fa-signal fa-fw"></i></td>');
          } else {
            tr.append('<td class="text-muted">N/A</td>');
          }
          // Action
          tr.append('<td><a href="#" class="btn btn-xs btn-primary"><i class="glyphicon glyphicon-cog"></i> Config</a></td>');
        } else {
          // Empty port row
          tr.append('<td>' + boardId + '/' + i + '</td>');
          tr.append('<td>&mdash;</td>');
          tr.append('<td><span class="label label-default">N/A</span></td>');
          tr.append('<td>0</td>');
          tr.append('<td>0</td>');
          tr.append('<td class="text-muted">N/A</td>');
          tr.append('<td>&mdash;</td>');
        }

        tbody.append(tr);
      }
    });
  }

  // Tab switching
  $('.board-tab a').on('click', function(e) {
    e.preventDefault();
    $(this).tab('show');
  });

  // Activate first tab by default
  $('.board-tab:first a').tab('show');

  // Refresh PON ports button
  $('#refreshPonPortsBtn').on('click', function(e) {
    e.preventDefault();
    var btn = $(this);
    btn.html('<i class="fa fa-spinner fa-spin"></i> Refreshing...');
    loadPonPorts();
    setTimeout(function() {
      btn.html('<i class="glyphicon glyphicon-refresh"></i> Refresh');
      $.MessageBox('PON ports data refreshed successfully.');
    }, 1500);
  });

  // Initial load
  loadPonPorts();
});
</script>

