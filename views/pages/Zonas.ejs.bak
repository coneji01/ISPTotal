<style>
.zon-search { padding:14px 18px 10px; border-bottom:1px solid var(--border,#e2e8f0); }
.zon-search-wrap { position:relative; max-width:400px; }
.zon-search-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:0.85rem; }
.zon-search-input { width:100%; padding:9px 12px 9px 36px; border:1px solid #e2e8f0; border-radius:8px; font-size:0.88rem; box-sizing:border-box; outline:none; transition:border-color 0.15s; }
.zon-search-input:focus { border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.1); }
</style>

<div class="page-header">
    <h2 class="page-title"><i class="fas fa-map-marker-alt" style="color:#2563eb;"></i> Gesti&oacute;n de Zonas</h2>
    <button class="btn-primary" onclick="zonAbrirModal()">
        <i class="fas fa-plus"></i> Nueva Zona
    </button>
</div>

<div class="card">
    <div class="zon-search">
        <div class="zon-search-wrap">
            <i class="fas fa-search zon-search-icon"></i>
            <input type="text" class="zon-search-input" id="zonSearch" placeholder="Buscar por nombre, router, OLT o VLAN..." oninput="zonFiltrar()">
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Nombre de la Zona</th>
                <th>Router Asociado</th>
                <th>OLT</th>
                <th>Zona en OLT</th>
                <th>VLAN</th>
                <th>Activos</th>
                <th>Suspendidos</th>
                <th>Total</th>
                <th style="text-align:right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% if (zonas && zonas.length) { zonas.forEach(function(z) { %>
                <tr>
                    <td><strong style="font-size:1rem;"><%= z.nombre %></strong></td>
                    <td>
                        <% if (z.router_nombre) { %>
                            <span class="badge" style="background:#f0f9ff; color:#0369a1; border:1px solid #bae6fd;"><i class="fas fa-server"></i> <%= z.router_nombre %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (z.olt_nombre) { %>
                            <span class="badge" style="background:#f3e8ff; color:#7c3aed; border:1px solid #d8b4fe;"><i class="fas fa-cloud"></i> <%= z.olt_nombre %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (z.smartolt_zone) { %>
                            <span class="badge" style="background:#fef3c7; color:#92400e; border:1px solid #fcd34d;"><i class="fas fa-map-marker-alt"></i> <%= z.smartolt_zone %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (z.vlan_onu) { %>
                            <span class="badge" style="background:#e0f2fe; color:#0369a1;">VLAN <%= z.vlan_onu %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td><span class="badge badge-success"><%= z.activos || 0 %></span></td>
                    <td><span class="badge badge-danger"><%= z.suspendidos || 0 %></span></td>
                    <td><strong><%= z.total || 0 %></strong></td>
                    <td style="text-align:right;">
                        <button class="btn-icon" style="color:var(--accent);" onclick="zonAbrirModalEditar(<%= z.id %>,'<%= z.nombre.replace(/'/g,"\\'") %>',<%= z.vlan_onu||'null' %>,<%= z.router_id||'null' %>,<%= z.smartolt_profile_id||'null' %>,'<%= (z.smartolt_zone||'').replace(/'/g,"\\'") %>')" title="Editar"><i class="fas fa-edit"></i></button>
                        <button class="btn-icon" style="color:#dc2626;" onclick="zonConfirmarEliminar(<%= z.id %>,'<%= z.nombre.replace(/'/g,"\\'") %>',<%= z.total||0 %>)" title="Eliminar"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            <% }); } else { %>
                <tr><td colspan="9" style="text-align:center;padding:40px;color:#94a3b8;"><i class="fas fa-map-marker-alt" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.3;"></i>No hay zonas registradas.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- MODAL -->
<div class="modal" id="zonModal" style="display:none;">
    <div class="modal-content" style="width:440px;">
        <div style="display:flex;justify-content:space-between;margin-bottom:20px;border-bottom:1px solid #eee;padding-bottom:10px;">
            <h3 style="margin:0;" id="zonModalTitle">Nueva Zona</h3>
            <button onclick="document.getElementById('zonModal').style.display='none'" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        <form method="POST" id="zonForm">
            <input type="hidden" name="accion" value="guardar_zona">
            <input type="hidden" name="id_zona" id="zonIdInput" value="">
            <div class="form-group">
                <label class="form-label">Nombre del Sector / Zona <span style="color:red">*</span></label>
                <input type="text" name="nombre" id="zonNombre" class="form-control" required placeholder="Ej: Centro Ciudad">
            </div>
            <div class="form-group">
                <label class="form-label">Router Asociado (Opcional)</label>
                <select name="router_id" id="zonRouter" class="form-control">
                    <option value="">-- Ninguno --</option>
                    <% (routers || []).forEach(function(r) { %>
                    <option value="<%= r.id %>"><%= r.name %></option>
                    <% }); %>
                </select>
                <small style="color:#64748b;font-size:0.75rem;">Se cargar&aacute; autom&aacute;ticamente al crear &oacute;rdenes en esta zona.</small>
            </div>
            <div class="form-group">
                <label class="form-label">OLT (Opcional)</label>
                <select name="smartolt_profile_id" id="zonOlt" class="form-control" onchange="zonOnOltChange()">
                    <option value="">-- Ninguno --</option>
                    <% (olts || []).forEach(function(o) { %>
                    <option value="<%= o.id %>"><%= o.nombre %> (<%= o.smartolt_subdomain %>)</option>
                    <% }); %>
                </select>
            </div>
            <div class="form-group" id="zonZoneGroup" style="display:none;">
                <label class="form-label">Zona en OLT <span style="color:red;">*</span></label>
                <select name="smartolt_zone" id="zonZoneInput" class="form-control">
                    <option value="">-- Seleccione zona --</option>
                </select>
                <small style="color:#64748b;font-size:0.75rem;">Zona configurada en SmartOLT para esta &aacute;rea.</small>
                <div id="zonZoneError" style="display:none;color:#ef4444;font-size:0.78rem;margin-top:4px;"></div>
            </div>
            <div class="form-group">
                <label class="form-label">VLAN ONU <span style="color:#94a3b8;font-size:0.75rem;">(Opcional)</span></label>
                <input type="number" name="vlan_onu" id="zonVlan" class="form-control" placeholder="Ej: 100" min="1" max="4094">
            </div>
            <button type="submit" class="btn-primary" style="width:100%;margin-top:10px;" id="zonBtnGuardar">
                <i class="fas fa-save"></i> Guardar
            </button>
        </form>
    </div>
</div>

<script>
function zonFiltrar() {
    var q = document.getElementById('zonSearch').value.toLowerCase().trim();
    document.querySelectorAll('.card table tbody tr').forEach(function(row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}

var _zonSmartoltZones = null;
var _zonPendingZone = '';

function zonAbrirModal() {
    document.getElementById('zonModalTitle').innerText = 'Nueva Zona';
    document.getElementById('zonIdInput').value = '';
    document.getElementById('zonNombre').value = '';
    document.getElementById('zonVlan').value = '';
    document.getElementById('zonRouter').value = '';
    document.getElementById('zonOlt').value = '';
    document.getElementById('zonZoneGroup').style.display = 'none';
    document.getElementById('zonZoneError').style.display = 'none';
    document.getElementById('zonModal').style.display = 'flex';
}

function zonAbrirModalEditar(id, nombre, vlan, routerId, oltId, smartoltZone) {
    document.getElementById('zonModalTitle').innerText = 'Editar Zona';
    document.getElementById('zonIdInput').value = id;
    document.getElementById('zonNombre').value = nombre;
    document.getElementById('zonVlan').value = vlan || '';
    document.getElementById('zonRouter').value = routerId || '';
    document.getElementById('zonOlt').value = oltId || '';
    _zonPendingZone = smartoltZone || '';
    if (oltId) {
        document.getElementById('zonZoneGroup').style.display = 'block';
        zonLoadOltZones(function() {
            document.getElementById('zonZoneInput').value = _zonPendingZone;
        });
    } else {
        document.getElementById('zonZoneGroup').style.display = 'none';
    }
    document.getElementById('zonModal').style.display = 'flex';
}

function zonOnOltChange() {
    var oltId = document.getElementById('zonOlt').value;
    if (oltId) {
        document.getElementById('zonZoneGroup').style.display = 'block';
        _zonPendingZone = '';
        zonLoadOltZones();
    } else {
        document.getElementById('zonZoneGroup').style.display = 'none';
    }
}

function zonLoadOltZones(callback) {
    var sel = document.getElementById('zonZoneInput');
    sel.innerHTML = '<option value="">-- Cargando... --</option>';
    if (_zonSmartoltZones !== null) {
        zonRenderZones(_zonSmartoltZones);
        if (callback) callback();
        return;
    }
    fetch('/api/smartolt/config')
    .then(function(r) { return r.json(); })
    .then(function(cfg) {
        if (!cfg.subdomain || !cfg.api_key) throw new Error('SmartOLT no configurado');
        return fetch('https://' + cfg.subdomain + '.smartolt.com/api/olt/list_zones', {
            headers: { 'X-Token': cfg.api_key }
        });
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        var zones = d.zones || d.data || d.response || [];
        if (Array.isArray(zones)) {
            _zonSmartoltZones = zones;
            zonRenderZones(zones);
            if (callback) callback();
        } else {
            sel.innerHTML = '<option value="">-- Sin zonas --</option>';
        }
    })
    .catch(function(e) {
        sel.innerHTML = '<option value="">-- Error: ' + e.message + ' --</option>';
        document.getElementById('zonZoneError').style.display = 'block';
        document.getElementById('zonZoneError').textContent = 'Error: ' + e.message;
    });
}

function zonRenderZones(zones) {
    var sel = document.getElementById('zonZoneInput');
    var h = '<option value="">-- Seleccione zona --</option>';
    zones.forEach(function(z) {
        var name = z.name || z.zone_name || z;
        var val = (typeof z === 'string') ? z : (z.name || z.zone_name || '');
        if (val) h += '<option value="' + val.replace(/"/g,'&quot;') + '">' + val + '</option>';
    });
    sel.innerHTML = h;
    if (_zonPendingZone) { sel.value = _zonPendingZone; }
}

function zonConfirmarEliminar(id, nombre, totalServicios) {
    if (totalServicios > 0) {
        alert('Esta zona cuenta con ' + totalServicios + ' servicio(s) asignado(s). Primero elimine o mueva los servicios a otra zona.');
        return;
    }
    if (!confirm('¿Eliminar la zona "' + nombre + '"? Esta acción no se puede deshacer.')) return;
    var form = document.createElement('form');
    form.method = 'POST';
    form.innerHTML = '<input type="hidden" name="accion" value="eliminar_zona"><input type="hidden" name="id_zona" value="' + id + '">';
    document.body.appendChild(form);
    form.submit();
}
</script>
