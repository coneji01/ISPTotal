<div class="page-header">
    <h2 class="page-title"><i class="fas fa-user-cog" style="color:#6366f1;"></i> Mi Cuenta</h2>
</div>

<div id="mcLoading" style="text-align:center;padding:60px;color:#94a3b8;">
    <i class="fas fa-spinner fa-spin" style="font-size:2rem;"></i>
    <p style="margin-top:12px;">Cargando perfil...</p>
</div>

<div id="mcContent" style="display:none;max-width:600px;margin:0 auto;">
    <div class="card" style="background:var(--bg-card,#fff);border:1px solid var(--border-color,#e2e8f0);border-radius:12px;padding:25px;">
        <div id="mcMsg" style="display:none;padding:10px 14px;border-radius:8px;margin-bottom:16px;font-size:0.85rem;"></div>
        
        <div class="form-group">
            <label class="form-label">Usuario</label>
            <input type="text" id="mcUsername" class="form-control" disabled style="background:#f8fafc;">
        </div>
        <div class="form-group">
            <label class="form-label">Empresa</label>
            <input type="text" id="mcCompany" class="form-control" disabled style="background:#f8fafc;">
        </div>
        <div class="form-group">
            <label class="form-label">Correo Electrónico</label>
            <input type="email" id="mcEmail" class="form-control">
        </div>

        <div id="mcLicense" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:14px;margin:16px 0;">
            <h4 style="margin:0 0 8px;font-size:0.9rem;color:#166534;"><i class="fas fa-id-card"></i> Licencia</h4>
            <div id="mcLicenseInfo" style="font-size:0.85rem;color:#334155;line-height:1.7;"></div>
        </div>

        <hr style="border-color:#e2e8f0;margin:20px 0;">

        <h4 style="font-size:0.9rem;color:var(--text-main,#1e293b);margin:0 0 14px;">Cambiar Contraseña</h4>
        <div class="form-group">
            <label class="form-label">Contraseña actual</label>
            <input type="password" id="mcCurPw" class="form-control" placeholder="Requerido">
        </div>
        <div class="form-group">
            <label class="form-label">Nueva contraseña</label>
            <input type="password" id="mcNewPw" class="form-control" placeholder="Mín. 6 caracteres">
        </div>
        <div class="form-group">
            <label class="form-label">Confirmar nueva contraseña</label>
            <input type="password" id="mcNewPw2" class="form-control" placeholder="Repite la contraseña">
        </div>
        <button class="btn btn-primary" onclick="mcSave()" style="width:100%;"><i class="fas fa-save"></i> Guardar Cambios</button>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    fetch('/api/tenant/profile')
    .then(function(r) { return r.json(); })
    .then(function(d) {
        document.getElementById('mcLoading').style.display = 'none';
        if (d.status !== 'success') {
            document.getElementById('mcContent').innerHTML = '<div class="card" style="padding:30px;text-align:center;color:#dc2626;"><i class="fas fa-exclamation-circle" style="font-size:2rem;display:block;margin-bottom:10px;"></i>Error: ' + (d.msg || 'No disponible') + '</div>';
            return;
        }
        document.getElementById('mcContent').style.display = 'block';
        document.getElementById('mcUsername').value = d.username;
        document.getElementById('mcCompany').value = d.company_name;
        document.getElementById('mcEmail').value = d.email;
        document.getElementById('mcLicenseInfo').innerHTML = '<b>Estado:</b> <span style="color:' + (d.license_active ? '#16a34a' : '#dc2626') + ';">' + (d.license_active ? '✅ Activa' : '❌ Inactiva') + '</span><br><b>Clientes:</b> ' + d.client_count + ' / ' + d.max_clients + '<br><b>Registrado:</b> ' + (d.created_at || 'N/A');
    })
    .catch(function(e) {
        document.getElementById('mcLoading').innerHTML = '<div style="color:#dc2626;"><i class="fas fa-exclamation-circle"></i> Error de conexión: ' + e.message + '</div>';
    });
});

function mcSave() {
    var email = document.getElementById('mcEmail').value.trim();
    var curPw = document.getElementById('mcCurPw').value;
    var newPw = document.getElementById('mcNewPw').value;
    var newPw2 = document.getElementById('mcNewPw2').value;
    var msg = document.getElementById('mcMsg');
    
    if (!curPw) { showToast('Ingresa tu contraseña actual', 'error'); return; }
    if (!email) { showToast('El correo es obligatorio', 'error'); return; }
    if (newPw && newPw !== newPw2) { showToast('Las contraseñas no coinciden', 'error'); return; }
    if (newPw && newPw.length < 6) { showToast('Mínimo 6 caracteres', 'error'); return; }
    
    var data = { email: email, current_password: curPw };
    if (newPw) data.new_password = newPw;
    
    fetch('/api/tenant/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        msg.style.display = 'block';
        if (d.status === 'success') {
            msg.style.background = '#f0fdf4'; msg.style.color = '#166534'; msg.style.border = '1px solid #bbf7d0';
            msg.innerHTML = '<i class="fas fa-check-circle"></i> ' + d.msg;
            document.getElementById('mcCurPw').value = '';
            document.getElementById('mcNewPw').value = '';
            document.getElementById('mcNewPw2').value = '';
        } else {
            msg.style.background = '#fef2f2'; msg.style.color = '#dc2626'; msg.style.border = '1px solid #fecaca';
            msg.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + d.msg;
        }
    })
    .catch(function() { showToast('Error de conexión', 'error'); });
}
</script>