<!DOCTYPE html><html lang="en" class="smartolt-night"><head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Speed profiles - JOEL WIFI</title>
<link href="/public/smartolt-files/bootstrap-custom.css?v=3.53.0.24" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">
<link href="/public/smartolt-files/inter-fonts.css" rel="stylesheet">
<link href="/public/smartolt-files/styles.css?v=3.53.0.24" rel="stylesheet">
<script src="/public/smartolt-files/jquery.min.js"></script>
<style>
body { font-family: 'Inter', -apple-system, sans-serif; background: #1a1d23; color: #e0e0e0; }
.navbar-default { background:#1a1d23; border-color:#2a2d35; }
.navbar-default .navbar-nav>li>a { color:#999; }
.navbar-default .navbar-nav>.active>a { color:#fff !important; background:transparent !important; }
.page-header { border-bottom:1px solid #2a2d35; padding-bottom:10px; margin-bottom:20px; }
.table > thead > tr > th { background:#2a2d35 !important; border-color:#3a3d45 !important; color:#999 !important; font-weight:600; border-bottom:1px solid #3a3d45; }
.table > tbody > tr > td { border-color:#3a3d45 !important; vertical-align:middle; }
.table-hover > tbody > tr:hover { background:#2a2d35; }
.btn { border-radius:4px; }
.btn-primary { background:#007bff; border-color:#007bff; }
.btn-danger { background:#dc3545; border-color:#dc3545; }
.btn-xs { padding:2px 8px; font-size:12px; }
.modal-content { background:#2a2d35; color:#e0e0e0; border:1px solid #3a3d45; }
.modal-header { border-bottom:1px solid #3a3d45; }
.modal-footer { border-top:1px solid #3a3d45; }
.close { color:#fff; opacity:0.8; }
.form-control { background:#1a1d23; border:1px solid #3a3d45; color:#e0e0e0; }
.form-control:focus { border-color:#007bff; }
code { background:#1a1d23; color:#28a745; }
</style>
</head>
<body>
<div class="navbar navbar-default navbar-fixed-top">
  <div class="container">
    <div class="navbar-header">
      <a class="navbar-brand" href="/modulo?pagina=GPONManager" style="color:#e0e0e0;">GPON Manager</a>
    </div>
    <ul class="nav navbar-nav">
      <li><a href="/modulo?pagina=olt_configured">Configuradas</a></li>
      <li><a href="/modulo?pagina=olt_unconfigured">No configuradas</a></li>
      <li><a href="/modulo?pagina=speed_profiles">Velocidad</a></li>
      <li><a href="/modulo?pagina=smartolt_locations_full">Zonas</a></li>
      <li class="dropdown">
        <a class="dropdown-toggle" data-toggle="dropdown" href="#">Settings <span class="caret"></span></a>
        <ul class="dropdown-menu">
          <li class="active"><a href="/modulo?pagina=speed_profiles">Speed Profiles</a></li>
          <li><a href="/modulo?pagina=smartolt_olt">OLTs</a></li>
          <li><a href="/modulo?pagina=smartolt_general">General</a></li>
          <li><a href="/modulo?pagina=smartolt_billing">Billing</a></li>
          <li><a href="/modulo?pagina=smartolt_system_config">VPN &amp; TR069</a></li>
          <li><a href="/modulo?pagina=smartolt_presets_full">Presets</a></li>
          <li><a href="/modulo?pagina=smartolt_diagnostics_full">Diagnostics</a></li>
          <li><a href="/modulo?pagina=smartolt_graphs">Graphs</a></li>
        </ul>
      </li>
    </ul>
  </div>
</div>

<div class="container-fluid content-wrap" style="margin-top:60px;padding:20px;">
  <div class="page-header">
    <h2>Speed profiles</h2>
  </div>

  <div id="alert-area"></div>

  <a href="javascript:void(0)" class="btn btn-primary" onclick="showAddModal()"><i class="fa fa-plus"></i> Add speed profile</a>
  <hr>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th><a href="javascript:void(0)">Name</a></th>
          <th><a href="javascript:void(0)">For</a></th>
          <th><a href="javascript:void(0)">Speed</a></th>
          <th><a href="javascript:void(0)">OLT Profile Up</a></th>
          <th><a href="javascript:void(0)">OLT Profile Down</a></th>
          <th><a href="javascript:void(0)">Type</a></th>
          <th><a href="javascript:void(0)">ONUs</a></th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody id="profiles-tbody"></tbody>
    </table>
  </div>
</div>

<!-- Modal Add/Edit -->
<div class="modal fade" id="profileModal" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <h4 class="modal-title" id="modalTitle">Add speed profile</h4>
      </div>
      <div class="modal-body">
        <form id="profileForm">
          <input type="hidden" name="id" id="edit_id" value="">
          <div class="form-group">
            <label>Name</label>
            <input type="text" class="form-control" name="nombre" id="f_nombre" placeholder="30M, 50M, 100M" required>
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="form-group">
                <label>Download Speed</label>
                <input type="text" class="form-control" name="velocidad" id="f_velocidad" placeholder="30M" required>
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group">
                <label>Upload Speed</label>
                <input type="text" class="form-control" name="velocidad_subida" id="f_velocidad_subida" placeholder="30M" required>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="form-group">
                <label>OLT Up Profile (tcont)</label>
                <input type="text" class="form-control" name="perfil_olt_subida" id="f_perfil_olt_subida" placeholder="SMARTOLT-30M-UP">
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group">
                <label>OLT Down Profile</label>
                <input type="text" class="form-control" name="perfil_olt_descarga" id="f_perfil_olt_descarga" placeholder="SMARTOLT-30M-DOWN">
              </div>
            </div>
          </div>
          <div class="form-group">
            <label>MikroTik Profile</label>
            <input type="text" class="form-control" name="perfil_mikrotik" id="f_perfil_mikrotik" placeholder="30M_30M">
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="saveProfile()"><i class="fa fa-save"></i> Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-sm" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <h4 class="modal-title">Confirm delete</h4>
      </div>
      <div class="modal-body">
        <p>Are you sure?</p>
        <p><strong id="delete-name"></strong></p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" onclick="deleteProfile()"><i class="fa fa-trash"></i> Delete</button>
      </div>
    </div>
  </div>
</div>

<script src="/public/smartolt-files/bootstrap.min.js"></script>
<script>
var deleteId = 0;

function loadProfiles() {
  $.get('/api/smartolt/speed-profiles', function(r) {
    var tbody = document.getElementById('profiles-tbody');
    tbody.innerHTML = '';
    if (r && r.data) {
      r.data.forEach(function(p) {
        var tr = document.createElement('tr');
        var speedKbps = p.descarga ? (parseInt(p.descarga) * 1024) + ' kbps' : '-';
        tr.innerHTML = 
          '<td><a href="javascript:void(0)" onclick="showEditModal(' + p.id + ')"><strong>' + (p.nombre || '-') + '</strong></a></td>' +
          '<td>Any</td>' +
          '<td>' + speedKbps + '</td>' +
          '<td><code>' + (p.perfil_olt_subida || '-') + '</code></td>' +
          '<td><code>' + (p.perfil_olt_descarga || '-') + '</code></td>' +
          '<td>Internet</td>' +
          '<td>' + (p.total_onus || 0) + '</td>' +
          '<td style="white-space:nowrap">' +
            '<a href="javascript:void(0)" onclick="showEditModal(' + p.id + ')" class="btn btn-default btn-xs" title="Edit"><i class="fa fa-pencil"></i></a> ' +
            '<a href="javascript:void(0)" onclick="showDeleteModal(' + p.id + ',\'' + (p.nombre || '').replace(/'/g,"\\'") + '\')" class="btn btn-danger btn-xs" title="Delete"><i class="fa fa-trash"></i></a>' +
          '</td>';
        tbody.appendChild(tr);
      });
    }
  }).fail(function() { showAlert('danger', 'Error loading profiles'); });
}

function showAddModal() {
  document.getElementById('edit_id').value = '';
  document.getElementById('modalTitle').textContent = 'Add speed profile';
  ['f_nombre','f_velocidad','f_velocidad_subida','f_perfil_olt_subida','f_perfil_olt_descarga','f_perfil_mikrotik'].forEach(function(id) {
    document.getElementById(id).value = '';
  });
  $('#profileModal').modal('show');
}

function showEditModal(id) {
  $.get('/api/smartolt/speed-profiles', function(r) {
    if (r && r.data) {
      var p = r.data.find(function(x) { return x.id === id; });
      if (p) {
        document.getElementById('edit_id').value = p.id;
        document.getElementById('modalTitle').textContent = 'Edit speed profile';
        document.getElementById('f_nombre').value = p.nombre || '';
        document.getElementById('f_velocidad').value = p.descarga || '';
        document.getElementById('f_velocidad_subida').value = p.subida || '';
        document.getElementById('f_perfil_olt_subida').value = p.perfil_olt_subida || '';
        document.getElementById('f_perfil_olt_descarga').value = p.perfil_olt_descarga || '';
        document.getElementById('f_perfil_mikrotik').value = p.perfil_mikrotik || '';
        $('#profileModal').modal('show');
      }
    }
  });
}

function saveProfile() {
  var data = {
    id: document.getElementById('edit_id').value,
    nombre: document.getElementById('f_nombre').value,
    velocidad: document.getElementById('f_velocidad').value,
    velocidad_subida: document.getElementById('f_velocidad_subida').value,
    perfil_olt_subida: document.getElementById('f_perfil_olt_subida').value,
    perfil_olt_descarga: document.getElementById('f_perfil_olt_descarga').value,
    perfil_mikrotik: document.getElementById('f_perfil_mikrotik').value
  };
  if (!data.nombre || !data.velocidad) { showAlert('warning', 'Name and Speed required'); return; }
  
  $.ajax({
    url: '/api/smartolt/speed-profiles/save',
    method: 'POST',
    data: data,
    success: function(r) {
      $('#profileModal').modal('hide');
      showAlert(r.success ? 'success' : 'danger', r.message || (r.success ? 'Profile saved' : 'Error saving'));
      if (r.success) loadProfiles();
    },
    error: function() { showAlert('danger', 'Network error'); }
  });
}

function showDeleteModal(id, name) {
  deleteId = id;
  document.getElementById('delete-name').textContent = name;
  $('#deleteModal').modal('show');
}

function deleteProfile() {
  $.ajax({
    url: '/api/smartolt/speed-profiles/delete',
    method: 'POST',
    data: { id: deleteId },
    success: function(r) {
      $('#deleteModal').modal('hide');
      showAlert(r.success ? 'success' : 'danger', r.message || (r.success ? 'Profile deleted' : 'Error deleting'));
      if (r.success) loadProfiles();
    },
    error: function() { showAlert('danger', 'Network error'); }
  });
}

function showAlert(type, msg) {
  var area = document.getElementById('alert-area');
  area.innerHTML = '<div class="alert alert-' + type + ' alert-dismissible"><button type="button" class="close" onclick="this.parentElement.remove()">&times;</button>' + msg + '</div>';
  setTimeout(function() { area.innerHTML = ''; }, 5000);
}

$(document).ready(function() { loadProfiles(); });
</script>
</body>
</html>
