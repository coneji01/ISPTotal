<style>
:root {
  --fac-bg: var(--card-bg, #fff);
  --fac-border: var(--border-color, #e2e8f0);
  --fac-text: var(--text-primary, #1e293b);
  --fac-muted: var(--text-muted, #64748b);
  --fac-light: var(--bg-light, #f8fafc);
  --fac-accent: var(--accent, #6366f1);
  --fac-danger: var(--accent-danger, #ef4444);
  --fac-success: var(--accent-success, #10b981);
}
.btn-default-active {
    display:inline-flex; align-items:center; gap:4px;
    padding:4px 10px; border-radius:5px; font-size:0.78rem; font-weight:700;
    background:#fef3c7; color:#d97706; border:1px solid #fbbf24;
}
.btn-default-active i { color:#f59e0b; }
.btn-default-inactive {
    display:inline-flex; align-items:center; gap:4px;
    padding:4px 10px; border-radius:5px; font-size:0.78rem; font-weight:600;
    background:var(--fac-light); color:var(--fac-muted); border:1px solid var(--fac-border);
    cursor:pointer; transition:all 0.15s;
}
.btn-default-inactive:hover { background:#fef3c7; color:#d97706; border-color:#fbbf24; }
.btn-primary {
    display:inline-flex; align-items:center; gap:6px;
    padding:10px 18px; border-radius:8px; font-size:0.85rem; font-weight:600;
    background:#6366f1; color:#fff; border:none;
    cursor:pointer; transition:all 0.15s; white-space:nowrap;
}
.btn-primary:hover { background:#4f46e5; transform:translateY(-1px); box-shadow:0 4px 12px rgba(99,102,241,0.3); }
.btn-primary i { font-size:0.9rem; }
.btn.btn-primary {
    display:inline-flex; align-items:center; gap:6px;
    padding:8px 16px; border-radius:6px; font-size:0.83rem; font-weight:600;
    background:#6366f1; color:#fff; border:none;
    cursor:pointer; transition:all 0.15s;
}
.btn.btn-primary:hover { background:#4f46e5; }
@keyframes facSlideIn{from{transform:scale(0.9);opacity:0;}to{transform:scale(1);opacity:1;}}
</style>

<div class="page-header">
    <h2 class="page-title"><i class="fas fa-file-invoice"></i> Plantillas de Facturación</h2>
    <button class="btn-primary" onclick="abrirModal()">
        <i class="fas fa-plus-circle"></i> Nueva Plantilla
    </button>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th style="min-width:140px;">Nombre</th>
                <th style="min-width:80px;">ID</th>
                <th>Tipo</th>
                <th>Generación</th>
                <th>Suspensión</th>
                <th>Tolerancia</th>
                <th>Reconexión</th>
                <th>Fact. Susp.</th>
                <th>Primera Factura</th>
                <th>Clientes</th>
                <th style="text-align:right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% if (ciclos && ciclos.length) { %>
                <% ciclos.forEach(function(c) { %>
                    <tr>
                        <td style="font-weight:600;"><%= c.name || 'Plantilla #' + c.id %></td>
                        <td>#<%= c.id %></td>
                        <td>
                            <% if (c.billing_type === 'postpago') { %>
                                <span class="badge" style="background:#fef3c7; color:#92400e; white-space:nowrap; padding:3px 8px; border-radius:4px; font-weight:600; font-size:0.78rem;">POSTPAGO</span>
                            <% } else { %>
                                <span class="badge" style="background:#dcfce7; color:#166534; white-space:nowrap; padding:3px 8px; border-radius:4px; font-weight:600; font-size:0.78rem;">PREPAGO</span>
                            <% } %>
                        </td>
                        <td>
                            <span class="badge" style="background:#e0f2fe; color:#0369a1; white-space:nowrap;">
                                Día <%= c.invoice_day %> del mes
                            </span>
                        </td>
                        <td>
                            <span class="badge" style="background:#fee2e2; color:#991b1b; white-space:nowrap;">
                                Día <%= c.suspend_day %> del mes
                            </span>
                        </td>
                        <td>
                            <%= c.tolerance_months %> mes(es) vencido(s)<br>
                            <small style="color:#666;">
                                (<%= c.suspend_weekends ? 'Incluye Fines de Semana' : 'NO Suspende Fines de Semana' %>)
                            </small>
                        </td>
                        <td>
                            <% if (c.reconnection_fee_active) { %>
                                <strong style="color:green;">SI</strong> ($<%= parseFloat(c.reconnection_amount || 0).toFixed(2) %>)
                            <% } else { %>
                                <span style="color:#999;">NO</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (c.invoice_suspended) { %>
                                <strong style="color:green;">SI</strong>
                            <% } else { %>
                                <span style="color:#999;">NO</span>
                            <% } %>
                        </td>
                        <td style="font-size:0.82rem; line-height:1.6;">
                            <% if (c.prorate_first_invoice) { %>
                                <span style="background:#e0e7ff; color:#3730a3; padding:2px 8px; border-radius:4px; font-weight:600; white-space:nowrap;">
                                    <i class="fas fa-calculator" style="font-size:0.7rem;"></i> Prorateo
                                </span><br>
                            <% } %>
                            <% if (c.grace_days && c.grace_days > 0) { %>
                                <span style="background:#fef3c7; color:#92400e; padding:2px 8px; border-radius:4px; font-weight:600; white-space:nowrap;">
                                    <i class="fas fa-hourglass-half" style="font-size:0.7rem;"></i> <%= c.grace_days %> días gracia
                                </span>
                            <% } else { %>
                                <span style="color:#999;">-</span>
                            <% } %>
                        </td>
                        <td>
                            <i class="fas fa-users"></i> <strong><%= c.total_clientes || 0 %></strong>
                        </td>
                        <td style="text-align:right; white-space:nowrap;">
                            <% if (c.is_default) { %>
                                <span class="btn-default-active" title="Plantilla por defecto">
                                    <i class="fas fa-star"></i> Por defecto
                                </span>
                            <% } else { %>
                                <button class="btn-default-inactive" onclick="setDefault(<%= c.id %>, this)" title="Establecer como por defecto">
                                    <i class="far fa-star"></i> Por defecto
                                </button>
                            <% } %>
                            <button class="btn-icon" style="color:var(--accent);" onclick='abrirModal(<%= JSON.stringify(c) %>)'>
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-icon" style="color:var(--accent-danger);" onclick="facConfirmarEliminar(<%= c.id %>, '<%= (c.name || 'Plantilla #' + c.id).replace(/'/g, "\\'") %>')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="11" style="text-align:center; padding:40px; color:#94a3b8;">
                    <i class="fas fa-file-invoice" style="font-size:2.5rem; display:block; margin-bottom:12px; opacity:0.4;"></i>
                    No hay plantillas de facturación. Cree la primera.
                </td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalFacturacion" style="display:none;">
    <div class="modal-content" style="width:900px;max-width:95vw;max-height:90vh;overflow-y:auto;padding:30px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:15px; border-bottom:1px solid var(--fac-border); padding-bottom:10px;">
            <h3 style="margin:0; color:var(--fac-text);" id="modalTitle">Nueva Plantilla</h3>
            <button onclick="cerrarModal()" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:var(--fac-muted);">&times;</button>
        </div>

        <form method="POST" action="/modulo?pagina=Facturacion">
            <input type="hidden" name="accion" value="guardar_ciclo">
            <input type="hidden" name="id_ciclo" id="idCiclo">

            <div class="form-group">
                <label class="form-label">Nombre de la Plantilla <span style="color:red">*</span></label>
                <input type="text" name="name" id="nameCiclo" class="form-control" placeholder="Ej: POST | Gen: Dia 25 | Corte: Dia 11" style="font-weight:600;">
                <small style="color:var(--fac-muted);font-size:0.75rem;">Un nombre descriptivo para identificar esta plantilla fácilmente.</small>
            </div>

            <h4 style="margin-top:0; color:var(--fac-accent); font-size:0.95rem;">Tipo de Facturación</h4>
            <div class="form-group" style="background:#f0f9ff; padding:15px; border-radius:6px; margin-bottom:15px;">
                <div style="display:flex; gap:15px;">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:8px; padding:10px 18px; border:2px solid #d97706; border-radius:8px; flex:1; transition:all 0.2s; background:#fffbeb;" id="labelPostpago" onclick="selectBillingType('postpago')">
                        <input type="radio" name="billing_type" value="postpago" checked style="accent-color:#d97706;">
                        <div>
                            <strong style="color:#92400e;">Postpago <small style="color:#16a34a; font-weight:600;">(Recomendado)</small></strong><br>
                            <small style="color:var(--fac-muted);">Factura del mes consumido</small>
                        </div>
                    </label>
                    <label style="cursor:pointer; display:flex; align-items:center; gap:8px; padding:10px 18px; border:2px solid var(--fac-border); border-radius:8px; flex:1; transition:all 0.2s;" id="labelPrepago" onclick="selectBillingType('prepago')">
                        <input type="radio" name="billing_type" value="prepago" style="accent-color:#16a34a;">
                        <div>
                            <strong style="color:#166534;">Prepago</strong><br>
                            <small style="color:var(--fac-muted);">Factura del mes a consumir</small>
                        </div>
                    </label>
                </div>
            </div>

            <h4 style="margin-top:0; color:var(--fac-accent); font-size:0.95rem;">Ciclo de Facturación y Corte</h4>
            <div style="background:var(--fac-light); padding:20px; border-radius:6px; margin-bottom:15px;">
                <div class="form-group" style="margin-bottom:12px;">
                    <label class="form-label">Fecha para crear factura</label>
                    <select name="invoice_day" id="invoiceDay" class="form-control" required>
                        <% for (var d = 1; d <= 31; d++) { %>
                            <option value='<%= d %>' <%= d === 25 ? 'selected' : '' %>>Día <%= d %> del mes</option>
                        <% } %>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:12px;">
                    <label class="form-label">Día de pago <small style="font-weight:400; color:var(--fac-muted);">(usado para el prorrateo)</small></label>
                    <select name="payment_day" id="paymentDay" class="form-control" required>
                        <% for (var d = 1; d <= 31; d++) { %>
                            <option value='<%= d %>' <%= d === 30 ? 'selected' : '' %>>Día <%= d %> del mes</option>
                        <% } %>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:12px;">
                    <label class="form-label">Fecha de suspensión (corte)</label>
                    <select name="suspend_day" id="suspendDay" class="form-control" required>
                        <% for (var d = 1; d <= 31; d++) { %>
                            <option value='<%= d %>' <%= d === 15 ? 'selected' : '' %>>Día <%= d %> del mes</option>
                        <% } %>
                    </select>
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">¿Suspender con cuántos meses vencidos?</label>
                        <input type="number" name="tolerance_months" id="toleranceMonths" class="form-control" min="1" max="12" value="2" required>
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <label class="form-label">¿Suspender fines de semana?</label>
                        <div style="display:flex; gap:20px; margin-top:5px;">
                            <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                                <input type="radio" name="suspend_weekends" value="si" checked> SI
                            </label>
                            <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                                <input type="radio" name="suspend_weekends" value="no"> NO
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <hr style="margin: 15px 0; border:0; border-top:1px solid var(--fac-border);">
            <h4 style="margin-top:0; color:var(--fac-accent); font-size:0.95rem;">Notificaciones Automáticas</h4>
            <div style="background:#fff7ed; padding:15px; border-radius:6px; margin-bottom:15px;">
                <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:10px;">
                    <% for (var n = 1; n <= 3; n++) { %>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">Aviso <%= n %> (Día)</label>
                            <select name="notify_<%= n %>" id="notify<%= n %>" class="form-control">
                                <option value='0' selected>-- No Notificar --</option>
                                <% for (var d = 1; d <= 31; d++) { %>
                                    <option value='<%= d %>'>Día <%= d %></option>
                                <% } %>
                            </select>
                        </div>
                    <% } %>
                </div>
            </div>

            <hr style="margin: 15px 0; border:0; border-top:1px solid var(--fac-border);">
            <h4 style="margin-top:0; color:var(--fac-accent); font-size:0.95rem;">Cobro de Reconexión</h4>
            <div class="form-group" style="background:#f0fdf4; padding:15px; border-radius:6px;">
                <label class="form-label" style="display:block; margin-bottom:10px;">¿Cobrar Reconexión al suspender?</label>
                <div style="display:flex; gap:20px; margin-bottom:10px;">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="reconnection_option" value="no" checked onchange="toggleRecon(false)"> NO
                    </label>
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="reconnection_option" value="si" id="radioReconSi" onchange="toggleRecon(true)"> SI
                    </label>
                </div>
                <div id="divReconAmount" style="display:none;">
                    <label class="form-label">Monto de Reconexión</label>
                    <div style="position:relative;">
                        <span style="position:absolute; left:10px; top:50%; transform:translateY(-50%);">$</span>
                        <input type="number" step="0.01" name="reconnection_amount" id="reconAmount" class="form-control" style="padding-left:25px;">
                    </div>
                </div>
            </div>

            <hr style="margin: 15px 0; border:0; border-top:1px solid var(--fac-border);">
            <h4 style="margin-top:0; color:var(--fac-accent); font-size:0.95rem;">Facturar Suspendidos</h4>
            <div class="form-group" style="background:#fefce8; padding:15px; border-radius:6px;">
                <label style="display:block; margin-bottom:10px;">¿Generar facturas a servicios suspendidos?</label>
                <div style="display:flex; gap:20px;">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="invoice_suspended" value="no" checked> NO
                    </label>
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="invoice_suspended" value="si" id="radioInvSusp"> SI
                    </label>
                </div>
                <small style="color:#92400e; margin-top:6px; display:block;">Si está en NO, los servicios suspendidos no recibirán nuevas facturas mensuales.</small>
            </div>

            <hr style="margin: 15px 0; border:0; border-top:1px solid var(--fac-border);">
            <h4 style="margin-top:0; color:var(--fac-accent); font-size:0.95rem;">Notificar al Suspender</h4>
            <div class="form-group" style="background:#fef2f2; padding:15px; border-radius:6px;">
                <label style="display:block; margin-bottom:10px;">¿Enviar mensaje al cliente cuando se suspenda su servicio?</label>
                <div style="display:flex; gap:20px;">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="notify_on_suspend" value="no" checked> NO
                    </label>
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="notify_on_suspend" value="si" id="radioNotifSusp"> SI
                    </label>
                </div>
                <small style="color:#991b1b; margin-top:6px; display:block;">Usa la plantilla "Notificación Suspensión" de Plantillas. Se envía por el canal activo (WhatsApp/SMS).</small>
            </div>

            <div class="form-group" style="background:#f0fdf4; padding:15px; border-radius:6px; margin-top:10px;">
                <label style="display:block; margin-bottom:10px;">¿Enviar confirmación al cliente cuando registre un pago?</label>
                <div style="display:flex; gap:20px;">
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="notify_on_payment" value="no" checked> NO
                    </label>
                    <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                        <input type="radio" name="notify_on_payment" value="si" id="radioNotifPago"> SI
                    </label>
                </div>
                <small style="color:#166534; margin-top:6px; display:block;">Usa la plantilla "Confirmación de Pago" de Plantillas. Se envía por el canal activo (WhatsApp/SMS).</small>
            </div>

            <hr style="margin: 15px 0; border:0; border-top:1px solid var(--fac-border);">
            <h4 style="margin-top:0; color:var(--fac-accent); font-size:0.95rem;">
                <i class="fas fa-baby" style="font-size:0.85rem;"></i> Primera Factura de Servicio
            </h4>
            <div style="background:#eef2ff; padding:15px; border-radius:6px; margin-bottom:15px;">
                <small style="color:#4338ca; display:block; margin-bottom:12px;">
                    <i class="fas fa-info-circle"></i> Estas opciones solo aplican a la primera factura de servicio (mensualidad), sin importar si existen facturas libres creadas.
                </small>
                <div style="background:white; padding:12px 15px; border-radius:6px; margin-bottom:10px; border:1px solid #c7d2fe;">
                    <label style="display:block; margin-bottom:8px; font-weight:600; color:#475569;">
                        <i class="fas fa-calculator" style="color:#4f46e5;"></i> Prorateo de la primera factura
                    </label>
                    <div style="display:flex; gap:20px; margin-bottom:6px;">
                        <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                            <input type="radio" name="prorate_first_invoice" value="no" checked> NO
                        </label>
                        <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                            <input type="radio" name="prorate_first_invoice" value="si" id="radioProrateYes"> SI
                        </label>
                    </div>
                    <small style="color:var(--fac-muted);">Si está activo, la primera factura se calcula proporcionalmente desde el día de instalación del servicio hasta la fecha de generación, redondeando al múltiplo de $50 más cercano.</small>
                </div>
                <div style="background:white; padding:12px 15px; border-radius:6px; border:1px solid #c7d2fe;">
                    <label style="display:block; margin-bottom:8px; font-weight:600; color:#475569;">
                        <i class="fas fa-hourglass-half" style="color:#d97706;"></i> Días de gracia de la primera factura
                    </label>
                    <div style="display:flex; gap:20px;">
                        <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                            <input type="radio" name="grace_days_option" value="no" checked onchange="toggleGraceDays(false)"> NO
                        </label>
                        <label style="cursor:pointer; display:flex; align-items:center; gap:5px;">
                            <input type="radio" name="grace_days_option" value="si" id="radioGraceYes" onchange="toggleGraceDays(true)"> SI
                        </label>
                    </div>
                    <div id="divGraceDays" style="display:none; margin-top:8px;">
                        <label style="font-size:0.88rem; font-weight:600; color:#475569;">Cantidad de días</label>
                        <input type="number" name="grace_days" id="graceDays" class="form-control" min="1" max="60" value="7" style="max-width:150px;">
                    </div>
                    <small style="color:var(--fac-muted); margin-top:6px; display:block;">Si el servicio tiene menos de estos días desde su instalación, no se le generará factura.</small>
                </div>
            </div>

            <button type="submit" class="btn-primary" style="width:100%; margin-top:15px;">
                <i class="fas fa-save"></i> Guardar Plantilla
            </button>
        </form>
    </div>
</div>

<script>
function abrirModal(data) {
    document.getElementById('modalFacturacion').style.display = 'flex';
    
    if (data) {
        // EDITAR
        document.getElementById('modalTitle').innerText = 'Editar Plantilla #' + data.id;
        document.getElementById('idCiclo').value = data.id;
        document.getElementById('nameCiclo').value = data.name || '';
        selectBillingType(data.billing_type || 'postpago');
        document.getElementById('invoiceDay').value = data.invoice_day;
        document.getElementById('paymentDay').value = data.payment_day || data.invoice_day;
        document.getElementById('suspendDay').value = data.suspend_day;
        document.getElementById('toleranceMonths').value = data.tolerance_months;

        if (data.suspend_weekends == 1) {
            document.querySelector('input[name="suspend_weekends"][value="si"]').checked = true;
        } else {
            document.querySelector('input[name="suspend_weekends"][value="no"]').checked = true;
        }

        document.getElementById('notify1').value = data.notify_day_1 || 0;
        document.getElementById('notify2').value = data.notify_day_2 || 0;
        document.getElementById('notify3').value = data.notify_day_3 || 0;

        if (data.reconnection_fee_active == 1) {
            document.getElementById('radioReconSi').checked = true;
            toggleRecon(true);
            document.getElementById('reconAmount').value = data.reconnection_amount;
        } else {
            document.querySelector('input[name="reconnection_option"][value="no"]').checked = true;
            toggleRecon(false);
        }

        if (data.invoice_suspended == 1) {
            document.querySelector('input[name="invoice_suspended"][value="si"]').checked = true;
        } else {
            document.querySelector('input[name="invoice_suspended"][value="no"]').checked = true;
        }

        if (data.prorate_first_invoice == 1) {
            document.querySelector('input[name="prorate_first_invoice"][value="si"]').checked = true;
        } else {
            document.querySelector('input[name="prorate_first_invoice"][value="no"]').checked = true;
        }

        if (data.grace_days && parseInt(data.grace_days) > 0) {
            document.querySelector('input[name="grace_days_option"][value="si"]').checked = true;
            toggleGraceDays(true);
            document.getElementById('graceDays').value = data.grace_days;
        } else {
            document.querySelector('input[name="grace_days_option"][value="no"]').checked = true;
            toggleGraceDays(false);
        }

        if (data.notify_on_suspend == 1) {
            document.querySelector('input[name="notify_on_suspend"][value="si"]').checked = true;
        } else {
            document.querySelector('input[name="notify_on_suspend"][value="no"]').checked = true;
        }

        if (data.notify_on_payment == 1) {
            document.querySelector('input[name="notify_on_payment"][value="si"]').checked = true;
        } else {
            document.querySelector('input[name="notify_on_payment"][value="no"]').checked = true;
        }
    } else {
        // NUEVO
        document.getElementById('modalTitle').innerText = 'Nueva Plantilla';
        document.getElementById('idCiclo').value = '';
        document.querySelector('form').reset();
        document.getElementById('nameCiclo').value = '';
        selectBillingType('postpago');
        document.querySelector('input[name="suspend_weekends"][value="si"]').checked = true;
        toggleRecon(false);
        toggleGraceDays(false);
    }
}

function cerrarModal() {
    document.getElementById('modalFacturacion').style.display = 'none';
}

function toggleRecon(show) {
    const div = document.getElementById('divReconAmount');
    if (show) {
        div.style.display = 'block';
        document.getElementById('reconAmount').required = true;
    } else {
        div.style.display = 'none';
        document.getElementById('reconAmount').required = false;
        document.getElementById('reconAmount').value = '0.00';
    }
}

function toggleGraceDays(show) {
    const div = document.getElementById('divGraceDays');
    div.style.display = show ? 'block' : 'none';
}

function selectBillingType(type) {
    document.querySelector('input[name="billing_type"][value="' + type + '"]').checked = true;
    const pre = document.getElementById('labelPrepago');
    const post = document.getElementById('labelPostpago');
    if (type === 'postpago') {
        post.style.borderColor = '#d97706'; post.style.background = '#fffbeb';
        pre.style.borderColor = 'var(--fac-border)'; pre.style.background = 'transparent';
    } else {
        pre.style.borderColor = '#16a34a'; pre.style.background = '#f0fdf4';
        post.style.borderColor = 'var(--fac-border)'; post.style.background = 'transparent';
    }
}

function setDefault(cycleId, btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    
    fetch('/api/facturacion/set_default?cycle_id=' + cycleId)
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.status === 'success') {
            window.location.reload();
        } else {
            btn.disabled = false;
            btn.innerHTML = '<i class="far fa-star"></i> Por defecto';
        }
    })
    .catch(function() {
        btn.disabled = false;
        btn.innerHTML = '<i class="far fa-star"></i> Por defecto';
    });
}

function facConfirmarEliminar(id, nombre) {
    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:99998;display:flex;align-items:center;justify-content:center;';
    var box = document.createElement('div');
    box.style.cssText = 'background:var(--card-bg,#fff);border-radius:14px;padding:24px;max-width:420px;width:90%;box-shadow:0 10px 40px rgba(0,0,0,0.2);text-align:center;animation:facSlideIn 0.2s ease;';
    box.innerHTML = '<div style="font-size:2rem;color:#f59e0b;margin-bottom:12px;"><i class="fas fa-exclamation-triangle"></i></div>' +
        '<div style="font-weight:700;font-size:1.05rem;color:var(--text-primary,#1e293b);margin-bottom:8px;">&iquest;Eliminar plantilla?</div>' +
        '<div style="font-size:0.88rem;color:var(--text-muted,#64748b);margin-bottom:20px;">&iquest;Est&aacute; seguro que desea eliminar la plantilla <b>' + nombre + '</b>? Esta acci&oacute;n no se puede deshacer.</div>' +
        '<div style="display:flex;gap:8px;justify-content:center;">' +
        '<button onclick="this.closest(\'div[style*=fixed]\').remove()" style="padding:9px 20px;background:var(--bg-secondary,#f1f5f9);color:#475569;border:1px solid var(--border-color,#e2e8f0);border-radius:8px;font-weight:600;cursor:pointer;font-size:0.88rem;">Cancelar</button>' +
        '<button id="facDelBtn" style="padding:9px 20px;background:#ef4444;color:#fff;border:none;border-radius:8px;font-weight:600;cursor:pointer;font-size:0.88rem;"><i class="fas fa-trash"></i> Eliminar</button>' +
        '</div>';
    overlay.appendChild(box);
    document.body.appendChild(overlay);
    
    document.getElementById('facDelBtn').onclick = function() {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '/modulo?pagina=Facturacion';
        form.innerHTML = '<input type="hidden" name="accion" value="eliminar"><input type="hidden" name="id_ciclo" value="' + id + '">';
        document.body.appendChild(form);
        form.submit();
    };
}
</script>
