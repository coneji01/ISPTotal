        <h5 class="modal-title" style="font-weight:600;" id="profileModalTitle"><i class="fa fa-plus-circle"></i> Nuevo Perfil de Velocidad</h5>
      </div>
      <div class="modal-body" style="padding:16px;">
        <input type="hidden" id="editProfileId" value="">
        <div class="form-group">
          <label style="font-size:12px;font-weight:600;">Nombre del Perfil</label>
          <input type="text" class="form-control" id="pfName" placeholder="Ej: Plan 100MB">
        </div>
        <div class="row">
          <div class="col-sm-6">
            <div class="form-group">
              <label style="font-size:12px;font-weight:600;">Velocidad Descarga</label>
