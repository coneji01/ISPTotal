html.smartolt-night .form-control:focus { border-color: #60a5fa; box-shadow: 0 0 0 2px rgba(96,165,250,0.15); }
.btn-primary { background: #4c4b4b; border-color: #4c4b4b; }
.btn-primary:hover { background: #2d2d2d; border-color: #2d2d2d; }
html.smartolt-night .btn-primary { background: #3b82f6; border-color: #3b82f6; }
html.smartolt-night .btn-primary:hover { background: #2563eb; }
html.smartolt-night .btn-default { background: #334155; color: #e2e8f0; border: none; }
html.smartolt-night .btn-default:hover { background: #475569; color: #fff; }
html.smartolt-night .text-muted { color: #94a3b8 !important; }
html.smartolt-night .badge { background: rgba(255,255,255,0.1); color: #e2e8f0; }
.smartolt-landing-hero-bg { display: none; }
html.smartolt-night .smartolt-landing-hero-bg { display: block; position: fixed; z-index: -1; inset: 0; background: radial-gradient(circle at 72% 18%, rgba(29,139,255,0.24), transparent 28%), radial-gradient(circle at 18% 84%, rgba(0,108,255,0.18), transparent 28%), linear-gradient(135deg, #06162f, #071b3d 55%, #031022); pointer-events: none; }
#smartolt-night-toggle { align-items: center; display: flex; justify-content: center; }
#smartolt-night-toggle i { line-height: 1; width: 20px; text-align: center; }
#smartolt-night-toggle .smartolt-theme-icon-light, #smartolt-night-toggle .smartolt-theme-icon-night, #smartolt-night-toggle .smartolt-theme-icon-system { display: none; }
#smartolt-night-toggle.is-pref-light .smartolt-theme-icon-light, #smartolt-night-toggle.is-pref-night .smartolt-theme-icon-night, #smartolt-night-toggle.is-pref-system .smartolt-theme-icon-system { display: inline-block; }
.font-size-20 { font-size: 20px; }
.text-ellipsis { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.max-width-250 { max-width: 250px; }
.huge { font-size: 40px; }
</style>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
