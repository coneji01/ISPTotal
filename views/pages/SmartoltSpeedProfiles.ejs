</head>
<body>
<div class="smartolt-landing-hero-bg" aria-hidden="true"></div>
<div id="content-wrapper">
  <div class="navbar navbar-default navbar-fixed-top">
    <div class="container">
      <div class="navbar-header">
        <button class="navbar-toggle collapsed" type="button" data-toggle="collapse" data-target="#navbar-main">
          <span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span>
        </button>
        <a class="navbar-brand text-ellipsis max-width-250" href="/modulo?pagina=GPONManager">GPON Manager</a>
      </div>
      <div class="navbar-collapse collapse" id="navbar-main">
        <ul class="nav navbar-nav">
          <li><a href="/modulo?pagina=GPONManager">Dashboard</a></li>
          <li><a href="/modulo?pagina=SmartoltConfigured">ONUs Configuradas</a></li>
          <li><a href="/modulo?pagina=SmartoltUnconfigured">Sin Configurar</a></li>
          <li class="active"><a href="/modulo?pagina=SmartoltSpeedProfiles">Velocidad</a></li>
          <li><a href="/modulo?pagina=SmartoltOnuTypes">Tipos ONU</a></li>
          <li><a href="/modulo?pagina=SmartoltSettings">Config OLT</a></li>
        </ul>
        <ul class="nav navbar-nav navbar-right">
          <li><a href="#" id="smartolt-night-toggle" class="is-pref-night is-resolved" title="Night mode"><i class="fa fa-sun-o font-size-20 smartolt-theme-icon-light"></i><i class="fa fa-moon-o font-size-20 smartolt-theme-icon-night"></i><i class="fa fa-adjust font-size-20 smartolt-theme-icon-system"></i></a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="panel panel-default">
      <div class="panel-heading"><i class="fa fa-tachometer"></i> Perfiles de Velocidad</div>
      <div class="panel-body">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
          <span style="font-size:13px;color:#64748b;" id="profileCount">Cargando...</span>
          <button class="btn btn-primary btn-sm" onclick="showAddProfile()"><i class="fa fa-plus"></i> A&ntilde;adir Perfil</button>
        </div>
        <div class="table-responsive">
          <table class="table table-hover" id="profilesTable" style="font-size:13px;">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Velocidad (kbps)</th>
                <th>Tipo</th>
                <th>ONUs</th>
                <th style="text-align:right;">Acci&oacute;n</th>
              </tr>
            </thead>
            <tbody id="profilesBody">
              <tr><td colspan="5" class="text-center text-muted" style="padding:40px;"><i class="fa fa-spinner fa-spin fa-2x"></i><br>Cargando perfiles desde SmartOLT...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Night mode toggle
(function() {
  var STORAGE_LOCAL = 'smartolt-theme-local';
  function applyTheme(pref) {
    var isNight = pref === 'night' ? true : (pref === 'light' ? false : (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches));
    var html = document.documentElement;
    if (isNight) html.classList.add('smartolt-night'); else html.classList.remove('smartolt-night');
    try { localStorage.setItem('smartolt-night', isNight ? '1' : '0'); } catch(e) {}
    var toggle = document.getElementById('smartolt-night-toggle');
    if (toggle) { toggle.classList.remove('is-pref-light','is-pref-night','is-pref-system'); toggle.classList.add('is-pref-' + pref); }
  }
  var localPref = (function(){ try { var s = localStorage.getItem(STORAGE_LOCAL); if(s==='night'||s==='light'||s==='system') return s; }catch(e){} return 'system'; })();
  applyTheme(localPref || (window.SMARTOLT_DB_THEME || 'system'));
  document.getElementById('smartolt-night-toggle').addEventListener('click', function(e) {
    e.preventDefault();
    var isNight = document.documentElement.classList.contains('smartolt-night');
    var newPref = isNight ? 'light' : 'night';
    try { localStorage.setItem(STORAGE_LOCAL, newPref); } catch(e) {}
    applyTheme(newPref);
  });
})();

function loadProfiles() {
  $.get('/api/smartolt/speed-profiles', function(data) {
    if (data.success && data.profiles) {
      var p = data.profiles;
      $('#profileCount').text(p.length + ' perfil(es)');
      if (p.length === 0) {
        $('#profilesBody').html('<tr><td colspan="5" class="text-center text-muted" style="padding:30px;">No hay perfiles de velocidad configurados</td></tr>');
        return;
      }
      var h = '';
      p.forEach(function(prof) {
        var name = prof.name || prof.nombre || prof.speed_name || '--';
        var speed = prof.speed || prof.velocity || prof.download_speed || '0';
        var type = prof.type || prof.profile_type || 'Internet';
        var onuCount = prof.onu_count || prof.used_by || 0;
        h += '<tr>';
        h += '<td><strong>' + escapeHtml(name) + '</strong></td>';
        h += '<td>' + escapeHtml(String(speed)) + ' kbps</td>';
        h += '<td>' + escapeHtml(type) + '</td>';
        h += '<td><span class="badge">' + onuCount + '</span></td>';
        h += '<td style="text-align:right;"><button class="btn btn-xs btn-default" onclick="alert(\'Editar perfil: ' + escapeHtml(name) + '\')"><i class="fa fa-edit"></i></button> ';
        h += '<button class="btn btn-xs btn-danger" onclick="if(confirm(\'Eliminar perfil ' + escapeHtml(name) + '?\'))alert(\'Eliminar no implementado aun\')"><i class="fa fa-trash"></i></button></td>';
        h += '</tr>';
      });
      $('#profilesBody').html(h);
    } else {
      $('#profilesBody').html('<tr><td colspan="5" class="text-center text-danger">Error cargando perfiles</td></tr>');
    }
  }, 'json').fail(function() {
    // Fallback: mostrar perfiles locales de ejemplo
    $('#profilesBody').html('<tr><td colspan="5" class="text-center text-muted" style="padding:30px;">Usa la configuracion de SmartOLT para gestionar perfiles de velocidad</td></tr>');
  });
}

function showAddProfile() {
  alert('Funcionalidad de añadir perfil proximamente. Usa SmartOLT directamente para gestionar perfiles.');
}

function escapeHtml(s) { if (!s) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

$(document).ready(function() {
  loadProfiles();
});
</script>
</body>
</html>
