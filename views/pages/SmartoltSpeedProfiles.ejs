html.smartolt-night .table > tbody > tr:hover { background: rgba(255,255,255,0.04) !important; }
html.smartolt-night .table > thead > tr > th { border-color: rgba(255,255,255,0.1); }
.table > thead > tr > th { border-bottom: 2px solid #eef2f6; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; }
.table > tbody > tr > td { border-color: #f1f5f9; vertical-align: middle; }
html.smartolt-night .table > tbody > tr > td { border-color: rgba(255,255,255,0.06); }
.form-control { border: 1px solid #d1d5db; border-radius: 6px; box-shadow: none; }
.form-control:focus { border-color: #4c4b4b; box-shadow: 0 0 0 2px rgba(76,75,75,0.12); }
