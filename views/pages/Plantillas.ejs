      </div>
      <div class="tpl-tab-content active" id="tabVisual">
        <div class="wysiwyg-toolbar" id="wysiwygToolbar">
          <select onchange="execFmt('formatBlock',this.value);this.value='';" title="Formato"><option value="">Formato</option><option value="h1">Título 1</option><option value="h2">Título 2</option><option value="h3">Título 3</option><option value="h4">Título 4</option><option value="p">Párrafo</option><option value="blockquote">Cita</option><option value="pre">Código</option></select>
          <select onchange="execCmd('fontName',this.value);" title="Fuente"><option value="">Fuente</option><option style="font-family:Arial">Arial</option><option style="font-family:Helvetica">Helvetica</option><option style="font-family:Verdana">Verdana</option><option style="font-family:Tahoma">Tahoma</option><option style="font-family:'Trebuchet MS'">Trebuchet MS</option><option style="font-family:Georgia">Georgia</option><option style="font-family:'Times New Roman'">Times New Roman</option><option style="font-family:'Palatino Linotype'">Palatino</option><option style="font-family:Garamond">Garamond</option><option style="font-family:'Courier New'">Courier New</option><option style="font-family:Calibri">Calibri</option><option style="font-family:'Segoe UI'">Segoe UI</option></select>
          <select onchange="execCmd('fontSize',this.value);this.value='';" title="Tamaño"><option value="">Tamaño</option><option value="1">8px</option><option value="2">10px</option><option value="3">12px</option><option value="4">14px</option><option value="5">18px</option><option value="6">24px</option><option value="7">32px</option></select>
          <select onchange="applyLineHeight(this.value);this.value='';" title="Interlineado"><option value="">Interlineado</option><option value="1">Simple (1.0)</option><option value="1.2">Compacto (1.2)</option><option value="1.5">Normal (1.5)</option><option value="1.8">Amplio (1.8)</option><option value="2">Doble (2.0)</option><option value="2.5">Extra (2.5)</option><option value="3">Triple (3.0)</option></select>
          <select onchange="applyLetterSpacing(this.value);this.value='';" title="Espaciado letras"><option value="">Espaciado</option><option value="normal">Normal</option><option value="0.5px">Ligero</option><option value="1px">Medio</option><option value="2px">Amplio</option><option value="3px">Muy amplio</option></select>
