<style>
.tpl-layout {
  display: flex;
  gap: 20px;
  min-height: calc(100vh - 120px);
  margin-top: 20px;
}
.tpl-sidebar { width: 240px; flex-shrink: 0; background: var(--card-bg, #fff); border-radius: 12px; border: 1px solid var(--border, #e2e8f0); padding: 10px 0; }
.tpl-sidebar-title { padding: 10px 16px 6px; font-size: .72rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: .5px; }
.tpl-menu-item { display: flex; align-items: center; gap: 10px; padding: 9px 16px; cursor: pointer; border-left: 3px solid transparent; transition: all .15s; }
.tpl-menu-item:hover { background: var(--hover-bg, #f8fafc); }
.tpl-menu-item.active { background: rgba(99,102,241,.06); border-left-color: var(--primary, #6366f1); }
.tpl-menu-icon { width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: .8rem; flex-shrink: 0; }
.tpl-menu-label { font-size: .82rem; font-weight: 600; color: var(--text, #1e293b); line-height: 1.2; }
.tpl-menu-type { display: block; font-size: .7rem; font-weight: 400; color: #94a3b8; margin-top: 1px; }
.tpl-editor-area { flex: 1; display: flex; flex-direction: column; background: var(--card-bg, #fff); border-radius: 12px; border: 1px solid var(--border, #e2e8f0); overflow: hidden; }
.tpl-editor-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border, #e2e8f0); }
.tpl-editor-title { display: flex; align-items: center; gap: 8px; font-size: .95rem; font-weight: 700; color: var(--text, #1e293b); }
.tpl-editor-actions { display: flex; align-items: center; gap: 8px; }
.tpl-save-msg { display: none; align-items: center; gap: 5px; font-size: .78rem; color: #16a34a; font-weight: 600; background: #f0fdf4; padding: 4px 12px; border-radius: 20px; }
.tpl-btn { display: inline-flex; align-items: center; gap: 5px; padding: 7px 14px; border-radius: 8px; font-size: .82rem; font-weight: 600; border: none; cursor: pointer; transition: all .15s; }
.tpl-btn-save { background: var(--primary, #6366f1); color: #fff; }
.tpl-btn-save:hover { opacity: .9; }
.tpl-btn-reset { background: #fef3c7; color: #d97706; }
.tpl-btn-reset:hover { background: #fde68a; }
.tpl-editor-body { flex: 1; display: flex; flex-direction: column; }
.tpl-tabs { display: flex; border-bottom: 1px solid var(--border, #e2e8f0); background: #f8fafc; }
.tpl-tab { padding: 10px 20px; font-size: .82rem; font-weight: 600; color: #64748b; cursor: pointer; border-bottom: 2px solid transparent; transition: all .15s; }
.tpl-tab.active { color: var(--primary, #6366f1); border-bottom-color: var(--primary, #6366f1); }
.tpl-tab:hover { color: var(--text, #1e293b); }
.tpl-tab-content { display: none; flex: 1; }
.tpl-tab-content.active { display: flex; flex-direction: column; }
.wysiwyg-toolbar { display: flex; align-items: center; gap: 4px; padding: 8px 12px; border-bottom: 1px solid var(--border, #e2e8f0); background: #fff; flex-wrap: wrap; }
.wysiwyg-toolbar select { padding: 4px 6px; border: 1px solid #e2e8f0; border-radius: 4px; font-size: .75rem; background: #fff; }
.wysiwyg-toolbar button { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border: none; background: transparent; border-radius: 4px; cursor: pointer; color: #475569; font-size: .8rem; }
.wysiwyg-toolbar button:hover { background: #f1f5f9; }
.wysiwyg-toolbar input[type=color] { width: 22px; height: 22px; padding: 0; border: 1px solid #e2e8f0; border-radius: 4px; cursor: pointer; }
.tb-sep { width: 1px; height: 18px; background: #e2e8f0; margin: 0 4px; }
.wysiwyg-editor { flex: 1; padding: 16px 20px; min-height: 300px; outline: none; font-size: .85rem; line-height: 1.6; color: var(--text, #1e293b); background: #fff; }
.wysiwyg-editor:empty:before { content: attr(data-placeholder); color: #cbd5e1; }
.sms-editor-wrap { padding: 20px; flex: 1; }
.sms-counter { font-size: .78rem; color: #94a3b8; margin-bottom: 8px; }
.sms-counter.warning { color: #f59e0b; }
.sms-counter.danger { color: #dc2626; }
.sms-textarea { width: 100%; min-height: 150px; padding: 12px; border: 1px solid #e2e8f0; border-radius: 8px; font-size: .9rem; line-height: 1.5; resize: vertical; outline: none; font-family: inherit; }
.sms-textarea:focus { border-color: var(--primary, #6366f1); }
.tpl-textarea { width: 100%; flex: 1; min-height: 300px; padding: 16px 20px; border: none; font-family: 'Courier New', monospace; font-size: .82rem; line-height: 1.5; resize: vertical; outline: none; background: #1e293b; color: #e2e8f0; }
.tpl-preview { flex: 1; padding: 20px; background: #f8fafc; display: flex; justify-content: center; }
.tpl-preview-pos { width: 280px; background: #fff; padding: 10px; border-radius: 4px; font-family: monospace; font-size: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
.tpl-preview-full { width: 100%; max-width: 700px; background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
.tpl-preview-sms { max-width: 360px; background: #fff; padding: 16px; border-radius: 8px; font-size: .85rem; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
.tpl-preview-a4 { width: 720px; background: #fff; padding: 20px; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
.tpl-keys-panel { border-top: 1px solid var(--border, #e2e8f0); }
.tpl-keys-header { display: flex; align-items: center; gap: 8px; padding: 10px 16px; font-size: .8rem; font-weight: 600; color: #475569; cursor: pointer; user-select: none; }
.tpl-keys-header:hover { background: #f8fafc; }
.tpl-keys-header .chevron { transition: transform .2s; font-size: .7rem; color: #94a3b8; }
.tpl-keys-grid { padding: 6px 16px 14px; display: flex; flex-wrap: wrap; gap: 5px; }
.tpl-keys-grid.collapsed { display: none; }
.tpl-key-group-title { width: 100%; font-size: .72rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: .4px; padding: 6px 0 3px; }
.tpl-key-chip { display: inline-flex; padding: 3px 8px; background: #fef3c7; color: #92400e; border-radius: 4px; font-size: .75rem; font-family: monospace; cursor: pointer; border: 1px solid #fde68a; }
.tpl-key-chip:hover { background: #fde68a; }
.tpl-alert-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 2000; align-items: center; justify-content: center; }
.tpl-alert-box { background: #fff; border-radius: 14px; width: 380px; max-width: 90vw; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,.15); }
.tpl-alert-header { display: flex; align-items: center; gap: 10px; padding: 18px 20px 0; }
.tpl-alert-header.warning .tpl-alert-icon { background: #fef3c7; color: #d97706; }
.tpl-alert-header.error .tpl-alert-icon { background: #fef2f2; color: #dc2626; }
.tpl-alert-header.success .tpl-alert-icon { background: #f0fdf4; color: #16a34a; }
.tpl-alert-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
.tpl-alert-title { font-size: 1rem; font-weight: 700; color: #1e293b; }
.tpl-alert-body { padding: 14px 20px; font-size: .88rem; color: #475569; line-height: 1.5; }
.tpl-alert-footer { display: flex; gap: 8px; justify-content: flex-end; padding: 12px 20px 18px; }
.tpl-alert-btn { padding: 8px 20px; border-radius: 8px; font-size: .85rem; font-weight: 600; border: none; cursor: pointer; background: var(--primary, #6366f1); color: #fff; }
.tpl-alert-btn-cancel { background: #f1f5f9; color: #475569; }
/* Fix for sidebar */
.tpl-logo-preview-box { text-align:center; margin-bottom:10px; min-height:40px; }
.tpl-logo-placeholder { border:2px dashed #cbd5e1; border-radius:8px; padding:20px; color:#94a3b8; font-size:.82rem; }
.tpl-logo-placeholder i { font-size:1.5rem; display:block; margin-bottom:4px; }
</style>

