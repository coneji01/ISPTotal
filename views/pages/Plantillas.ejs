    <div class="tpl-menu-item" onclick="selectTemplate('bienvenida_sms',this)"><div class="tpl-menu-icon" style="background:#d1fae5;color:#059669;"><i class="fas fa-comment-dots"></i></div><div class="tpl-menu-label">Bienvenida - Pago<span class="tpl-menu-type">WhatsApp</span></div></div>
