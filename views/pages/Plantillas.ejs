function execCmd(c,v){document.getElementById('wysiwygEditor').focus();document.execCommand(c,false,v||null);}
function execFmt(c,v){if(!v)return;document.getElementById('wysiwygEditor').focus();document.execCommand(c,false,v);}
function doInsertLink(){const u=prompt('Ingrese la URL:','https://');if(u)execCmd('createLink',u);}
function applyLineHeight(v){
  if(!v)return;var sel=window.getSelection();if(!sel.rangeCount)return;
  var ed=document.getElementById('wysiwygEditor');ed.focus();
  var range=sel.getRangeAt(0);var node=range.commonAncestorContainer;
  if(node.nodeType===3)node=node.parentNode;
  var block=node.closest('div,p,h1,h2,h3,h4,li,blockquote,td,pre');
  if(block&&ed.contains(block)){block.style.lineHeight=v;}
  else{var wrapper=document.createElement('div');wrapper.style.lineHeight=v;range.surroundContents(wrapper);}
}
function applyLetterSpacing(v){
  if(!v)return;var sel=window.getSelection();if(!sel.rangeCount)return;
  var ed=document.getElementById('wysiwygEditor');ed.focus();
  var range=sel.getRangeAt(0);var node=range.commonAncestorContainer;
  if(node.nodeType===3)node=node.parentNode;
  var block=node.closest('div,p,h1,h2,h3,h4,li,blockquote,td,span,pre');
  if(block&&ed.contains(block)){block.style.letterSpacing=v;}
  else{var span=document.createElement('span');span.style.letterSpacing=v;range.surroundContents(span);}
}
function insertHR(){document.getElementById('wysiwygEditor').focus();document.execCommand('insertHTML',false,'<hr style="border:none;border-top:1px solid #ccc;margin:10px 0;">');}
function doInsertTable(){
  var c=prompt('Columnas:','3');var r=prompt('Filas:','3');
  if(!c||!r)return;c=parseInt(c);r=parseInt(r);if(isNaN(c)||isNaN(r)||c<1||r<1)return;
  var h='<table style="width:100%;border-collapse:collapse;margin:10px 0;">';
  for(var i=0;i<r;i++){h+='<tr>';for(var j=0;j<c;j++){var tag=i===0?'th':'td';var st='border:1px solid #cbd5e1;padding:6px 10px;'+(i===0?'background:#f1f5f9;font-weight:bold;':'');h+='<'+tag+' style="'+st+'">'+(i===0?'Col '+(j+1):'&nbsp;')+'</'+tag+'>';}h+='</tr>';}
  h+='</table><p><br></p>';document.getElementById('wysiwygEditor').focus();document.execCommand('insertHTML',false,h);
}

function getCurrentContent(){
  const m=tplMeta[currentKey];
  if(m.type==='sms') return document.getElementById('smsTextarea').value;
  if(activeTab==='code') return document.getElementById('tplTextarea').value;
  return document.getElementById('wysiwygEditor').innerHTML;
}
function setAllEditors(content){
  const m=tplMeta[currentKey];
  if(m.type==='sms'){document.getElementById('smsTextarea').value=content;}
  else{document.getElementById('wysiwygEditor').innerHTML=content;document.getElementById('tplTextarea').value=content;}
}
function syncV2C(){document.getElementById('tplTextarea').value=document.getElementById('wysiwygEditor').innerHTML;}
function syncC2V(){document.getElementById('wysiwygEditor').innerHTML=document.getElementById('tplTextarea').value;}

function switchTab(tab,el){
  const m=tplMeta[currentKey],prev=activeTab;
  if(m.type==='html'){if(prev==='visual'&&(tab==='code'||tab==='preview'))syncV2C();if(prev==='code'&&tab==='visual')syncC2V();}
  activeTab=tab;
  document.querySelectorAll('.tpl-tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');
  ['tabVisual','tabCode','tabPreview'].forEach(id=>document.getElementById(id).classList.remove('active'));
  if(tab==='visual'){document.getElementById('tabVisual').classList.add('active');}
  else if(tab==='code'){document.getElementById('tabCode').classList.add('active');}
  else if(tab==='preview'){document.getElementById('tabPreview').classList.add('active');updatePreview();}
}

function selectTemplate(key,el){
  if(tplMeta[currentKey]&&tplMeta[currentKey].type==='html'&&activeTab==='visual')syncV2C();
  currentKey=key;const m=tplMeta[key];
  document.querySelectorAll('.tpl-menu-item').forEach(i=>i.classList.remove('active'));el.classList.add('active');
  document.getElementById('editorIcon').className='fas '+m.icon;document.getElementById('editorIcon').style.color=m.color;document.getElementById('editorTitle').innerText=m.title;
  const content=templatesData[key]?templatesData[key].content:'';setAllEditors(content);renderKeys(key);
  // Mostrar/ocultar editores según el tipo
  var isSms=m.type==='sms';
  var smsTa=document.getElementById('smsTextarea');
  var wysiwyg=document.getElementById('wysiwygEditor');
  var htmlTa=document.getElementById('tplTextarea');
  if(smsTa) smsTa.style.display=isSms?'block':'none';
  if(wysiwyg) wysiwyg.style.display=isSms?'none':'block';
  if(htmlTa) htmlTa.style.display=isSms?'none':'block';
  // Ocultar botón Visual para SMS, mostrar para HTML
  document.querySelectorAll('.tpl-tab').forEach(function(t){
    if(t.getAttribute('data-tab')==='visual') t.style.display=isSms?'none':'inline-block';
  });
  switchTab('visual',document.querySelector('.tpl-tab[data-tab="visual"]'));
}

function renderKeys(key){
  const grid=document.getElementById('keysGrid'),groups=templateKeysMap[key]||{};
  const labels={empresa:'Empresa',cliente:'Cliente',servicio:'Servicio',plan:'Plan',impuestos:'Impuestos',factura:'Factura',pago:'Pago',libre:'Factura Libre',ecf:'Facturación Electrónica',orden:'Orden',personal:'Personal Asignado',asignacion:'Datos de Orden'};
  let h='';
  Object.keys(groups).forEach(gk=>{
    h+='<div class="tpl-key-group-title">'+(labels[gk]||gk)+'</div>';
    const ks=groups[gk];
    Object.keys(ks).forEach(k=>{
      h+='<span class="tpl-key-chip" data-desc="'+ks[k]+'" onclick="insertKey(\''+k+'\')">'+k+'</span>';
    });
  });
  grid.innerHTML=h;
}

function insertKey(key){
  const m=tplMeta[currentKey];
  if(activeTab==='code'){const ta=document.getElementById('tplTextarea');if(ta.readOnly)return;const s=ta.selectionStart,e=ta.selectionEnd;ta.value=ta.value.substring(0,s)+key+ta.value.substring(e);ta.selectionStart=ta.selectionEnd=s+key.length;ta.focus();return;}
  const ed=document.getElementById('wysiwygEditor');if(ed.getAttribute('contenteditable')!=='true')return;ed.focus();document.execCommand('insertText',false,key);
}

function updatePreview(){
  const m=tplMeta[currentKey];
  let content=m.type==='sms'?'':(document.getElementById('tplTextarea').value||document.getElementById('wysiwygEditor').innerHTML);
  let preview=content;Object.keys(sampleData).forEach(k=>{preview=preview.split(k).join(sampleData[k]);});
  const c=document.getElementById('previewContainer');c.className=m.previewType==='pos'?'tpl-preview-pos':(m.previewType==='sms'?'tpl-preview-sms':(m.previewType==='a4'?'tpl-preview-a4':'tpl-preview-full'));c.innerHTML=preview;
}

function toggleKeysPanel(){keysCollapsed=!keysCollapsed;document.querySelector('.tpl-keys-header').classList.toggle('collapsed',keysCollapsed);document.getElementById('keysGrid').classList.toggle('collapsed',keysCollapsed);}

function saveTemplate(){
  const m=tplMeta[currentKey];if(m.type==='html'&&activeTab==='visual')syncV2C();
  const content=getCurrentContent(),fd=new FormData();fd.append('template_key',currentKey);fd.append('content',content);
  fetch('/modulo?pagina=Plantillas&ajax=save_template',{method:'POST',body:fd}).then(r=>r.json()).then(d=>{
    if(d.status==='success'){if(templatesData[currentKey])templatesData[currentKey].content=content;const msg=document.getElementById('saveMsg');msg.style.display='inline-flex';setTimeout(()=>{msg.style.display='none';},3000);}
    else showAlert('error','Error',d.msg);
  }).catch(e=>showAlert('error','Error',e.message));
}
function resetTemplate(){document.getElementById('modalConfirmReset').style.display='flex';}
function confirmReset(){
  document.getElementById('modalConfirmReset').style.display='none';const fd=new FormData();fd.append('template_key',currentKey);
  fetch('/modulo?pagina=Plantillas&ajax=reset_template',{method:'POST',body:fd}).then(r=>r.json()).then(d=>{
    if(d.status==='success'){setAllEditors(d.content);document.getElementById('tplTextarea').value=d.content;if(templatesData[currentKey])templatesData[currentKey].content=d.content;showAlert('success','Restaurado','Plantilla restaurada al contenido original.');}
    else showAlert('error','Error',d.msg);
  }).catch(e=>showAlert('error','Error',e.message));
}
function showAlert(type,title,msg){document.getElementById('alertHeader').className='tpl-alert-header '+type;const icons={success:'fa-check',error:'fa-times',warning:'fa-exclamation-triangle'};document.getElementById('alertIconBox').innerHTML='<i class="fas '+(icons[type]||'fa-info')+'"></i>';document.getElementById('alertTitle').innerText=title;document.getElementById('alertBody').innerHTML=msg;document.getElementById('modalAlert').style.display='flex';}

// ============ LOGO MANAGER ============
function toggleLogoPanel(){
  logoCollapsed=!logoCollapsed;
  document.getElementById('logoContent').style.display=logoCollapsed?'none':'block';
  document.getElementById('logoChevron').style.transform=logoCollapsed?'rotate(-90deg)':'';
}

function onLogoFileSelected(input){
  if(!input.files||!input.files[0])return;
  const file=input.files[0];
  const reader=new FileReader();
  reader.onload=function(e){
    const b64=e.target.result;
    const img=new Image();
    img.onload=function(){
      logoOrigRatio=img.width/img.height;
      const w=Math.min(120,img.width);
      const h=Math.round(w/logoOrigRatio);
      document.getElementById('logoWidth').value=w;
      document.getElementById('logoHeight').value=h;
      
      // Send as base64 data URL directly
      fetch('/modulo?pagina=Plantillas&ajax=upload_logo',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          logo:b64,
          logo_width:document.getElementById('logoWidth').value,
          logo_height:document.getElementById('logoHeight').value
        })
      }).then(r=>r.json()).then(d=>{
        if(d.status==='success'){
          showLogoPreview(d.logo,d.width,d.height);
          showAlert('success','Logo','Logo subido correctamente.');
        }else{
          showAlert('error','Error',d.msg);
        }
      }).catch(e=>showAlert('error','Error',e.message));
    };
    img.src=b64;
  };
  reader.readAsDataURL(file);
  input.value='';
}

function showLogoPreview(src,w,h){
  const img=document.getElementById('logoPreviewImg');
  const ph=document.getElementById('logoPlaceholder');
  if(src){
    img.src=src;img.style.display='block';img.style.width=w+'px';img.style.height=h+'px';
    ph.style.display='none';
    document.getElementById('logoSizeControls').style.display='block';
    document.getElementById('btnDeleteLogo').style.display='block';
    document.getElementById('logoWidth').value=w;
    document.getElementById('logoHeight').value=h;
    if(w>0&&h>0)logoOrigRatio=w/h;
  }else{
    img.style.display='none';img.src='';
    ph.style.display='block';
    document.getElementById('logoSizeControls').style.display='none';
    document.getElementById('btnDeleteLogo').style.display='none';
  }
}

function onLogoSizeChange(){
  const locked=document.getElementById('logoLockRatio').checked;
  const w=parseInt(document.getElementById('logoWidth').value)||120;
  const h=parseInt(document.getElementById('logoHeight').value)||60;
  if(locked){
    const img=document.getElementById('logoPreviewImg');
    const oldW=parseInt(img.style.width)||120;
    if(w!==oldW){document.getElementById('logoHeight').value=Math.round(w/logoOrigRatio);}
    else{document.getElementById('logoWidth').value=Math.round(h*logoOrigRatio);}
  }
  const finalW=parseInt(document.getElementById('logoWidth').value);
  const finalH=parseInt(document.getElementById('logoHeight').value);
  const img=document.getElementById('logoPreviewImg');
  img.style.width=finalW+'px';img.style.height=finalH+'px';
}

function saveLogoSize(){
  const fd=new FormData();
  fd.append('logo_width',document.getElementById('logoWidth').value);
  fd.append('logo_height',document.getElementById('logoHeight').value);
  fetch('/modulo?pagina=Plantillas&ajax=save_logo_size',{method:'POST',body:fd}).then(r=>r.json()).then(d=>{
    if(d.status==='success'){
      const msg=document.getElementById('logoSizeMsg');
      msg.style.display='block';
      setTimeout(()=>{msg.style.display='none';},2000);
    }
  });
}

function deleteLogo(){
  if(!confirm('¿Eliminar el logo?'))return;
  fetch('/modulo?pagina=Plantillas&ajax=delete_logo',{method:'POST'}).then(r=>r.json()).then(d=>{
    if(d.status==='success'){showLogoPreview(null);showAlert('success','Logo','Logo eliminado.');}
  });
}

function loadLogo(){
  fetch('/modulo?pagina=Plantillas&ajax=get_logo').then(r=>r.json()).then(d=>{
    if(d.status==='success'&&d.logo){showLogoPreview(d.logo,d.width,d.height);}
  }).catch(()=>{});
}

// INIT
loadLogo();
// Initialize the first template on page load
(function() {
  var firstKey = 'recibo_pos';
  var firstEl = document.querySelector('.tpl-menu-item[onclick*="' + firstKey + '"]');
  if (firstEl) {
    selectTemplate(firstKey, firstEl);
  } else {
    renderKeys(firstKey);
  }
})();
</script>
