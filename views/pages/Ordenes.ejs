// GPS (abre Google Maps con la orden)
function gpsOrden(orderId, coord) {
  if (coord && coord.trim()) {
    window.open('https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(coord.trim()), '_blank');
    return;
  }
  // No coordinates - show modal
  if (!document.getElementById('modalGpsAdd')) {
    var div = document.createElement('div');
    // Build GPS modal without inline onclick (use JS event later)
    div.innerHTML = '<div class="modal-overlay" id="modalGpsAdd" style="display:none;">' +
      '<div class="modal-content" style="width:400px;text-align:center;padding:0;">' +
      '<div class="modal-header"><h3><i class="fas fa-map-marker-alt" style="color:#0369a1;"></i> Sin Coordenada GPS</h3>' +
      '<button class="btn-modal-close" id="btnGpsClose"><i class="fas fa-times"></i> Cerrar</button></div>' +
      '<div style="padding:20px;">' +
      '<p style="color:#64748b;margin-bottom:16px;">Esta orden no tiene coordenadas GPS registradas.</p>' +
      '<div class="form-group"><input type="text" id="gpsCoordInput" class="form-control" placeholder="Ej: 18.472, -69.931"></div>' +
      '<button class="btn btn-primary" id="btnGpsSave" style="width:100%;">Guardar y Abrir GPS</button>' +
      '</div></div></div>';
    // Add event listeners after DOM insertion
    setTimeout(function() {
      document.getElementById('btnGpsClose').onclick = function() { closeModal('modalGpsAdd'); };
      document.getElementById('btnGpsSave').onclick = function() {
        var coord = document.getElementById('gpsCoordInput').value.trim();
        if (!coord) { alert('Ingrese las coordenadas'); return; }
        closeModal('modalGpsAdd');
        window.open('https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(coord), '_blank');
      };
    }, 50);
    document.body.appendChild(div);
  }
  document.getElementById('modalGpsAdd').style.display = 'flex';
}

