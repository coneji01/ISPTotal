<style>
.modal-overlay-tr { display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(15,23,42,0.5); backdrop-filter:blur(4px); z-index:9999; justify-content:center; align-items:center; padding:12px; }
.modal-content-tr { background:white; width:90%; max-width:820px; border-radius:12px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.2); }
.modal-header-tr { padding:16px 20px; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center; position:sticky; top:0; background:white; border-radius:12px 12px 0 0; }
.modal-body-tr { padding:20px; }
.badge { padding:3px 10px; border-radius:5px; font-size:0.72rem; font-weight:700; }
.tr-grid-2col { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
@media(max-width:768px){ .tr-grid-2col { grid-template-columns:1fr; } }
</style>

<div class="page-header">
    <h2 class="page-title"><i class="fas fa-clipboard-list" style="color:#7c3aed;"></i> Órdenes de Servicio</h2>
    <button class="btn btn-primary" onclick="showAlert('info','Nueva Orden','Función próximamente')"><i class="fas fa-plus-circle"></i> Nueva Orden</button>
</div>

<div class="tabs-container" style="display:flex; gap:0; margin-bottom:16px; border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;">
    <button class="tab-btn active" onclick="openTab('tabPendientes', this)" style="flex:1; padding:10px 16px; border:none; background:var(--tab-bg,#f1f5f9); cursor:pointer; font-weight:700; font-size:0.88rem; color:#64748b;" id="tabBtnPendientes">Pendientes (<%= (ordenesPendientes || []).length %>)</button>
    <button class="tab-btn" onclick="openTab('tabCerradas', this)" style="flex:1; padding:10px 16px; border:none; background:var(--tab-bg,#f1f5f9); cursor:pointer; font-weight:700; font-size:0.88rem; color:#64748b;" id="tabBtnCerradas">Cerradas (<%= (ordenesCerradas || []).length %>)</button>
</div>

<div id="tabPendientes" class="tab-content" style="display:block;">
    <div class="filters-row" style="display:flex; gap:10px; margin-bottom:15px;">
        <input type="text" id="buscarPendiente" onkeyup="filtrarPendientes()" class="form-control" placeholder="Buscar cliente, NIC, dirección..." style="flex:2;">
        <input type="text" id="filtroZonaP" list="dlZonas" class="form-control" oninput="filtrarPendientes()" placeholder="Todas las Zonas" style="flex:1;">
        <datalist id="dlZonas">
            <% (zonas || []).forEach(function(z) { %><option value='<%= z.nombre %>'><% }); %>
        </datalist>
    </div>
    <div class="card" style="overflow-x:auto;">
        <table id="tablaPendientes" class="table" style="width:100%; border-collapse:collapse;">
            <thead>
                <tr>
                    <th style="padding:10px 8px; text-align:left; border-bottom:2px solid #e2e8f0;">#</th>
                    <th style="padding:10px 8px; text-align:left; border-bottom:2px solid #e2e8f0;">Tipo</th>
                    <th style="padding:10px 8px; text-align:left; border-bottom:2px solid #e2e8f0;">Cliente</th>
                    <th style="padding:10px 8px; text-align:left; border-bottom:2px solid #e2e8f0;">Detalles</th>
                    <th style="padding:10px 8px; text-align:left; border-bottom:2px solid #e2e8f0;">Zona</th>
                    <th style="padding:10px 8px; text-align:left; border-bottom:2px solid #e2e8f0;">Fecha</th>
                    <th style="padding:10px 8px; text-align:right; border-bottom:2px solid #e2e8f0;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% (ordenesPendientes || []).forEach(function(o) { %>
                <tr data-tecnico="<%= o.tecnico_nombre || '' %>">
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;"><%= o.id %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;">
                        <% var tipo = (o.tipo || 'trash').toLowerCase(); %>
                        <span class="badge" style="background:<%= tipo==='traslado'?'#ede9fe':'#dcfce7' %>; color:<%= tipo==='traslado'?'#6b21a8':'#166534' %>;">
                            <%= o.tipo %>
                        </span>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;">
                        <a href="/ver-cliente/<%= o.cliente_id %>" style="font-weight:600; color:#2563eb; text-decoration:none;"><%= o.cliente_nombre || '—' %></a>
                        <% if (o.tecnico_nombre) { %><div style="font-size:0.75rem; margin-top:4px;"><span style="background:#ede9fe; color:#6b21a8; padding:2px 7px; border-radius:10px;"><i class="fas fa-user-check"></i> <%= o.tecnico_nombre %></span></div><% } %>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9; font-size:0.82rem; color:#64748b; max-width:200px; overflow:hidden; text-overflow:ellipsis;"><%= o.detalle || '' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;"><%= o.zona_nombre || '—' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9; font-size:0.82rem; white-space:nowrap;"><%= (o.created_at || '').substring(0,16).replace('T',' ') %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9; text-align:right; white-space:nowrap;">
                        <button class="btn btn-sm btn-info" onclick="abrirDetalle('<%= o.id %>')" title="Ver Detalle"><i class="fas fa-eye"></i></button>
                        <button class="btn btn-sm btn-primary" onclick="abrirAsignar('<%= o.id %>')" title="Asignar"><i class="fas fa-user-tag"></i></button>
                        <% if (o.tipo && o.tipo.toLowerCase() === 'traslado') { %>
                        <button class="btn btn-sm" style="background:#7c3aed;color:#fff;" onclick="abrirCompletarTraslado(<%= o.id %>, '<%= o.tipo %>')" title="Completar Traslado"><i class="fas fa-truck-moving"></i> Completar</button>
                        <% } else { %>
                        <button class="btn btn-sm btn-success" onclick="showAlert('info','Completar','Función próximamente')"><i class="fas fa-check-circle"></i></button>
                        <% } %>
                        <button class="btn btn-sm btn-danger" onclick="showAlert('info','Cancelar','Función próximamente')"><i class="fas fa-ban"></i></button>
                    </td>
                </tr>
                <% }); %>
                <% if (!ordenesPendientes || ordenesPendientes.length === 0) { %>
                <tr><td colspan="7" style="text-align:center; padding:30px; color:#94a3b8;"><i class="fas fa-inbox"></i> No hay órdenes pendientes</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<div id="tabCerradas" class="tab-content" style="display:none;">
    <div class="filters-row" style="display:flex; gap:10px; margin-bottom:15px;">
        <input type="text" id="buscarCerrada" onkeyup="filtrarCerradas()" class="form-control" placeholder="Buscar cliente, técnico..." style="flex:2;">
        <input type="text" id="filtroZonaC" list="dlZonas" class="form-control" oninput="filtrarCerradas()" placeholder="Todas las Zonas" style="flex:1;">
    </div>
    <div class="card" style="overflow-x:auto;">
        <table id="tablaCerradas" class="table" style="width:100%; border-collapse:collapse;">
            <thead>
                <tr>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">#</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">Tipo</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">Cliente</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">Estado</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">Zona</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">Técnico</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">Fechas</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;">Cerrado Por</th>
                    <th style="padding:10px 8px; border-bottom:2px solid #e2e8f0;"></th>
                </tr>
            </thead>
            <tbody>
                <% (ordenesCerradas || []).forEach(function(o) { %>
                <tr>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;"><%= o.id %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;">
                        <span class="badge" style="background:#dcfce7; color:#166534;"><%= o.tipo %></span>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;">
                        <a href="/ver-cliente/<%= o.cliente_id %>" style="font-weight:600; color:#2563eb; text-decoration:none;"><%= o.cliente_nombre || '—' %></a>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;">
                        <span class="badge" style="background:#16a34a; color:#fff;">Completada</span>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;"><%= o.zona_nombre || '—' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;"><%= o.tecnico_nombre || '—' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9; font-size:0.8rem;">
                        <small>Creada: <%= (o.created_at || '').substring(0,10) %></small>
                        <% if (o.fecha_completada) { %><br><small>Completada: <%= (o.fecha_completada || '').substring(0,10) %></small><% } %>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9;"><%= o.cerrado_por || '—' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid #f1f5f9; text-align:right;">
                        <button class="btn btn-sm btn-info" onclick="abrirDetalle('<%= o.id %>')"><i class="fas fa-eye"></i></button>
                    </td>
                </tr>
                <% }); %>
                <% if (!ordenesCerradas || ordenesCerradas.length === 0) { %>
                <tr><td colspan="9" style="text-align:center; padding:30px; color:#94a3b8;"><i class="fas fa-check-double"></i> No hay órdenes cerradas</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: Asignar Técnico -->
<div class="modal-overlay-tr" id="modalAsignar">
    <div class="modal-content-tr" style="max-width:420px;">
        <div class="modal-header-tr">
            <h3 style="margin:0;"><i class="fas fa-user-tag" style="color:#8b5cf6;"></i> Asignar Técnico</h3>
            <button class="btn-modal-close" onclick="closeModalAsig()" style="background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;">&times;</button>
        </div>
        <div class="modal-body-tr" style="text-align:center;">
            <input type="hidden" id="asignarOrdenId">
            <div style="margin-bottom:16px;">
                <label style="font-weight:600;color:#475569;display:block;margin-bottom:6px;">Seleccionar técnico</label>
                <select id="asignarTecnico" class="form-control" style="width:100%;">
                    <option value="">-- Sin asignar --</option>
                    <% (empleados || []).forEach(function(e) { %>
                    <option value="<%= e.id %>"><%= e.nombre %></option>
                    <% }); %>
                </select>
            </div>
            <button class="btn btn-primary" onclick="asignarOrden()" style="width:100%;">Asignar</button>
        </div>
    </div>
</div>

<!-- Modal: Completar Traslado -->
<div class="modal-overlay-tr" id="modalCompletarTraslado">
    <div class="modal-content-tr">
        <div class="modal-header-tr">
            <h3 style="margin:0;"><i class="fas fa-truck-moving" style="color:#7c3aed;"></i> Completar Traslado</h3>
            <button class="btn-modal-close" onclick="closeModal('modalCompletarTraslado')" style="background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;">&times;</button>
        </div>
        <div class="modal-body-tr">
            <form id="formCompletarTraslado" onsubmit="procesarCompletarTraslado(event)">
                <input type="hidden" name="orden_id" id="ct_orden_id">
                <input type="hidden" name="accion" value="finalizar_traslado">

                <div style="margin-bottom:14px; padding:12px 16px; background:#f5f3ff; border:1px solid #d8b4fe; border-radius:8px;">
                    <label style="font-weight:600; color:#6b21a8; font-size:0.88rem; display:block; margin-bottom:6px;">
                        <i class="fas fa-user-cog"></i> Técnico asignado
                    </label>
                    <select name="tecnico_id" id="ct_tecnico" class="form-control" required>
                        <option value="">-- Seleccionar técnico --</option>
                        <% (empleados || []).forEach(function(e) { %>
                        <option value="<%= e.id %>"><%= e.nombre %></option>
                        <% }); %>
                    </select>
                </div>

                <div class="tr-grid-2col">
                    <div>
                        <h4 style="color:#475569; margin-bottom:12px;">Configuración de Red</h4>
                        <div class="form-group">
                            <label class="form-label">Zona Nueva</label>
                            <select name="sector_id" id="ct_zona" class="form-control" required>
                                <option value="">-- Seleccionar --</option>
                                <% (zonas || []).forEach(function(z) { %>
                                <option value="<%= z.id %>"><%= z.nombre %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Dirección Nueva</label>
                            <input type="text" name="direccion" id="ct_direccion" class="form-control" placeholder="Dirección del traslado">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Observaciones</label>
                            <input type="text" name="observaciones" id="ct_observaciones" class="form-control" placeholder="Resultado del traslado...">
                        </div>
                    </div>
                    <div>
                        <h4 style="color:#475569; margin-bottom:12px;">Información de Servicio</h4>
                        <div id="ct_svc_info" style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:14px; font-size:0.85rem; color:#334155; line-height:1.9;">
                            <i class="fas fa-spinner fa-spin"></i> Cargando...
                        </div>
                    </div>
                </div>

                <div style="margin-top:20px; text-align:right;">
                    <button type="button" onclick="closeModal('modalCompletarTraslado')" class="btn btn-secondary">Cancelar</button>
                    <button type="submit" class="btn btn-primary" style="background:#7c3aed;" id="btnFinTraslado">
                        <i class="fas fa-truck-moving"></i> COMPLETAR TRASLADO
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Simple alert/toast
function showAlert(type, title, text) {
    var bg = type === 'error' ? '#ef4444' : type === 'success' ? '#16a34a' : '#3b82f6';
    var icon = type === 'error' ? 'times-circle' : type === 'success' ? 'check-circle' : 'info-circle';
    var t = document.createElement('div');
    t.style.cssText = 'position:fixed;top:20px;right:20px;z-index:99999;padding:12px 20px;border-radius:8px;font-size:0.88rem;font-weight:600;color:#fff;box-shadow:0 4px 15px rgba(0,0,0,0.15);background:' + bg + ';';
    t.innerHTML = '<i class="fas fa-' + icon + '"></i> ' + text;
    document.body.appendChild(t);
    setTimeout(function() { t.style.opacity='0'; t.style.transition='opacity 0.3s'; setTimeout(function() { t.remove(); }, 300); }, 3000);
}

function openTab(tabId, btn) {
    document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.style.background = '#f1f5f9'; b.style.color = '#64748b'; });
    document.getElementById(tabId).style.display = 'block';
    btn.style.background = '#7c3aed20';
    btn.style.color = '#7c3aed';
}

function filtrarPendientes() {
    var q = (document.getElementById('buscarPendiente').value || '').toLowerCase();
    var z = (document.getElementById('filtroZonaP').value || '').toLowerCase();
    document.querySelectorAll('#tablaPendientes tbody tr').forEach(function(r) {
        var text = r.textContent.toLowerCase();
        var zona = (r.cells[4] || {}).textContent || '';
        r.style.display = (!q || text.includes(q)) && (!z || zona.toLowerCase().includes(z)) ? '' : 'none';
    });
}

function filtrarCerradas() {
    var q = (document.getElementById('buscarCerrada').value || '').toLowerCase();
    var z = (document.getElementById('filtroZonaC').value || '').toLowerCase();
    document.querySelectorAll('#tablaCerradas tbody tr').forEach(function(r) {
        var text = r.textContent.toLowerCase();
        var zona = (r.cells[4] || {}).textContent || '';
        r.style.display = (!q || text.includes(q)) && (!z || zona.toLowerCase().includes(z)) ? '' : 'none';
    });
}

function abrirDetalle(id) {
    fetch('/api/ordenes/detalle/' + id)
    .then(r => r.json()).then(function(d) {
        if (d.status !== 'success') { showAlert('error', 'Error', d.msg); return; }
        var o = d.data;
        var html = '<div style="text-align:left;">';
        html += '<p><b># Orden:</b> ' + o.id + '</p>';
        html += '<p><b>Tipo:</b> ' + o.tipo + '</p>';
        html += '<p><b>Cliente:</b> ' + (o.cliente_nombre || '—') + '</p>';
        html += '<p><b>Detalle:</b> ' + (o.detalle || '—') + '</p>';
        html += '<p><b>Dirección:</b> ' + (o.direccion || '—') + '</p>';
        html += '<p><b>Zona:</b> ' + (o.zona_nombre || '—') + '</p>';
        html += '<p><b>Técnico:</b> ' + (o.tecnico_nombre || '—') + '</p>';
        html += '<p><b>Estado:</b> ' + o.estado + '</p>';
        html += '<p><b>Creada:</b> ' + (o.created_at || '—') + '</p>';
        if (o.fecha_completada) html += '<p><b>Completada:</b> ' + o.fecha_completada + '</p>';
        html += '</div>';
        showAlert('info', 'Detalle de Orden #' + o.id, html);
    }).catch(function() { showAlert('error', 'Error', 'No se pudo cargar el detalle'); });
}

function abrirAsignar(ordenId) {
    document.getElementById('asignarOrdenId').value = ordenId;
    document.getElementById('modalAsignar').style.display = 'flex';
}

function closeModalAsig() {
    document.getElementById('modalAsignar').style.display = 'none';
}

function asignarOrden() {
    var id = document.getElementById('asignarOrdenId').value;
    var tec = document.getElementById('asignarTecnico').value;
    fetch('/api/ordenes/asignar', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orden_id: id, tecnico_id: tec })
    })
    .then(r => r.json()).then(function(d) {
        if (d.success) { showAlert('success', 'Asignado', 'Técnico asignado correctamente'); closeModalAsig(); window.location.reload(); }
        else showAlert('error', 'Error', d.message || 'No se pudo asignar');
    });
}

// ---- Completar Traslado ----
var _ctOrdenData = null;

function abrirCompletarTraslado(ordenId, tipo) {
    fetch('/api/ordenes/detalle/' + ordenId)
    .then(r => r.json())
    .then(function(resp) {
        if (resp.status !== 'success') { showAlert('error', 'Error', resp.msg); return; }
        var o = resp.data;
        _ctOrdenData = o;
        document.getElementById('ct_orden_id').value = o.id;
        document.getElementById('ct_direccion').value = o.direccion || '';
        document.getElementById('ct_observaciones').value = '';

        if (o.zona_id) document.getElementById('ct_zona').value = o.zona_id;
        else document.getElementById('ct_zona').value = '';

        document.getElementById('ct_svc_info').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Cargando...';
        fetch('/api/ordenes/servicio-info/' + o.servicio_id)
        .then(r => r.json()).then(function(d) {
            if (d.status === 'success' && d.data) {
                var svc = d.data;
                var info = '';
                if (svc.plan_name) info += '<b>Plan:</b> ' + svc.plan_name + '<br>';
                if (svc.pppoe_user) info += '<b>Usuario PPPoE:</b> <span style="font-family:monospace;">' + svc.pppoe_user + '</span><br>';
                if (svc.ip) info += '<b>IP:</b> <span style="font-family:monospace;">' + svc.ip + '</span><br>';
                if (svc.onu_sn) info += '<b>SN ONU:</b> <span style="font-family:monospace;">' + svc.onu_sn + '</span><br>';
                info += '<b>Zona actual:</b> ' + (o.zona_nombre || '—') + '<br>';
                info += '<b>Dirección actual:</b> ' + (o.direccion || '—') + '<br>';
                document.getElementById('ct_svc_info').innerHTML = info || 'Sin datos disponibles';
            } else {
                document.getElementById('ct_svc_info').innerHTML = '<span style="color:#ef4444;">No se pudo cargar información del servicio</span>';
            }
        }).catch(function() {
            document.getElementById('ct_svc_info').innerHTML = '<span style="color:#ef4444;">Error al cargar</span>';
        });

        document.getElementById('modalCompletarTraslado').style.display = 'flex';
    })
    .catch(function() {
        showAlert('error', 'Error', 'No se pudo cargar la orden');
    });
}

function closeModal(id) { document.getElementById(id).style.display = 'none'; }

function procesarCompletarTraslado(e) {
    e.preventDefault();
    var btn = document.getElementById('btnFinTraslado');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

    fetch('/api/ordenes/completar-traslado', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            orden_id: parseInt(document.getElementById('ct_orden_id').value),
            tecnico_id: parseInt(document.getElementById('ct_tecnico').value) || null,
            sector_id: parseInt(document.getElementById('ct_zona').value) || null,
            direccion: document.getElementById('ct_direccion').value.trim(),
            observaciones: document.getElementById('ct_observaciones').value.trim()
        })
    })
    .then(r => r.json()).then(function(d) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-truck-moving"></i> COMPLETAR TRASLADO';
        if (d.status === 'success') {
            closeModal('modalCompletarTraslado');
            showAlert('success', 'Traslado Completado', 'El servicio ha sido trasladado correctamente.');
            setTimeout(function() { window.location.reload(); }, 2000);
        } else {
            showAlert('error', 'Error en Traslado', d.msg || 'Error desconocido');
        }
    }).catch(function(err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-truck-moving"></i> COMPLETAR TRASLADO';
        showAlert('error', 'Error', 'Error de red: ' + err.message);
    });
}

// Close modals on overlay click
document.addEventListener('click', function(e) {
    if (e.target.classList.contains('modal-overlay-tr')) e.target.style.display = 'none';
});
</script>
