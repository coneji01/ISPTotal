function crearOrden(e) {
  e.preventDefault();
  const tipo = document.getElementById('noTipo').value;
  const clienteId = document.getElementById('noClienteId').value;
  const detalle = document.getElementById('noDetalle').value.trim();
  const zona = document.getElementById('noZona').value;
  const coord = document.getElementById('noCoordenadas').value.trim();
  const servicioRadio = document.querySelector('input[name="noServicio"]:checked');
  const servicioId = servicioRadio ? servicioRadio.value : null;

  if (!tipo) { alert('Seleccione el tipo de orden'); return; }
  if (!clienteId) { alert('Seleccione un cliente'); return; }

  const btn = document.getElementById('btnCrearOrden');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creando...';

  var detalles = tipo.toUpperCase() + (detalle ? ' - ' + detalle : '');
  if (coord) detalles += ' | Coord: ' + coord;

  fetch('/api/ordenes', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ tipo: tipo, cliente_id: parseInt(clienteId), servicio_id: servicioId ? parseInt(servicioId) : null, detalle: detalles, zona_id: zona ? parseInt(zona) : null })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-plus"></i> Crear Orden';
    if (d.status === 'success') {
      document.getElementById('modalNuevaOrden').classList.remove('active');
      location.reload();
    } else { alert(d.msg || 'Error al crear orden'); }
  })
  .catch(function(e) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-plus"></i> Crear Orden'; alert('Error: ' + e.message); });
  return false;
}

// TECNICO SEARCH (DomISP style)
var _tecnicos = [<% (empleados || []).forEach(function(e) { %>{ id:<%= e.id %>, name:'<%= e.nombre.replace(/'/g,"\\'") %>', role:'tecnico' },<% }); %>];
var _todosUsuarios = _tecnicos; // For now use tecnicos as all users
var _cerrarDept = 'tecnico';
var _asignarDept = 'tecnico';

function tecSearchShow(prefix) {
  tecSearchFilter(prefix);
  document.getElementById(prefix + '_tec_list').style.display = 'block';
}

function tecSearchFilter(prefix) {
  var q = document.getElementById(prefix + '_tec_search').value.toLowerCase();
  var list = document.getElementById(prefix + '_tec_list');
  var dept = "tecnico";
  if (prefix === "cerrar" || prefix === "co") dept = _cerrarDept || "tecnico";
  else if (prefix === "asignar") dept = _asignarDept || "tecnico";
  
  var showRole = (dept === "administrativo");
  var source = showRole ? _todosUsuarios.filter(function(u) { return u.role && u.role.toLowerCase() !== "tecnico"; }) : _tecnicos;
  var h = "";
  source.forEach(function(t) {
    var name = t.name || "";
    var role = t.role || "";
    if (q && name.toLowerCase().indexOf(q) === -1) return;
    var label = name + (showRole ? " (" + role + ")" : "");
    var data = JSON.stringify({prefix: prefix, id: t.id, name: name});
    h += '<div class="tec-result-item" data-info="' + data.replace(/"/g,'&quot;').replace(/'/g,"&apos;") + '" style="padding:10px 12px;cursor:pointer;border-bottom:1px solid #f1f5f9;font-size:0.85rem;">';
    h += '<i class="fas fa-user" style="color:#8b5cf6;margin-right:6px;"></i>' + label + '</div>';
  });
  if (!h) h = '<div style="padding:12px;text-align:center;color:#94a3b8;font-size:0.82rem;">Sin resultados</div>';
  list.innerHTML = h;
  
  // Add event listeners via delegation (no inline handlers)
  list.querySelectorAll(".tec-result-item").forEach(function(el) {
    var info = JSON.parse(el.getAttribute("data-info"));
    el.addEventListener("mouseover", function() { this.style.background = "#f0f9ff"; });
    el.addEventListener("mouseout", function() { this.style.background = "white"; });
    el.addEventListener("click", function() {
      tecSearchSelect(info.prefix, info.id, info.name);
    });
  });
}

function tecSearchSelect(prefix, id, name) {
  document.getElementById(prefix + '_tecnico').value = id;
  document.getElementById(prefix + '_tec_search').value = name;
  document.getElementById(prefix + '_tec_list').style.display = 'none';
}

// CERRAR ORDEN (DomISP exacto)
function abrirCerrar(id, dept) {
  _cerrarDept = dept || 'tecnico';
  document.getElementById('idCerrar').value = id;
  document.getElementById('cerrar_tecnico').value = '';
  document.getElementById('cerrar_tec_search').value = '';
  document.getElementById('idCerrarTipo').value = '';
  document.getElementById('idCerrarServicioId').value = '0';
  document.getElementById('cerrarTipoLabel').textContent = '';
  document.getElementById('cerrarTrasladoSection').style.display = 'none';
  document.getElementById('cerrarOnuVieja').innerHTML = '';
  document.getElementById('cerrarOltSelect').innerHTML = '<option value="">Seleccionar OLT...</option>';
  document.getElementById('cerrarOnuActions').style.display = 'none';
  document.getElementById('cerrarScanResults').style.display = 'none';
  document.getElementById('cerrarNewOnuSn').value = '';
  document.getElementById('cerrarNewOnuSelected').style.display = 'none';
  document.getElementById('modalCerrar').style.display = 'flex';
  
  // Fetch order details to check tipo
  fetch('/api/ordenes/detalle/' + id)
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.status !== 'success' || !d.data) return;
    var o = d.data;
    document.getElementById('idCerrarTipo').value = o.tipo;
    document.getElementById('cerrarTipoLabel').textContent = '(' + o.tipo + ')';
    document.getElementById('idCerrarServicioId').value = o.servicio_id || 0;
    
    // If traslado, show ONU section
    if (o.tipo === 'traslado') {
      document.getElementById('cerrarTrasladoSection').style.display = 'block';
      
      // Show old ONU info
      if (o.servicio_id) {
        fetch('/api/ordenes/servicio-info/' + o.servicio_id)
        .then(function(r2) { return r2.json(); })
        .then(function(svc) {
          if (svc.status === 'success' && svc.data) {
            var html = '<div style="background:#f8fafc;border-radius:6px;padding:8px;font-size:0.8rem;">' +
              '<b style="color:#64748b;">ONU Actual:</b> ' + (svc.data.onu_sn || 'Sin ONU') +
              ' | IP: ' + (svc.data.ip || '—') + 
              '</div>';
            document.getElementById('cerrarOnuVieja').innerHTML = html;
          }
        })
        .catch(function(e){});
      }
      
      // Cargar lista de OLTs
      fetch('/api/olts')
      .then(function(r3) { return r3.json(); })
      .then(function(olts) {
        if (olts && olts.length) {
          var sel = '<option value="">Seleccionar OLT...</option>';
          olts.forEach(function(ol) { sel += '<option value="' + ol.id + '">' + ol.nombre + '</option>'; });
          document.getElementById('cerrarOltSelect').innerHTML = sel;
        }
      })
      .catch(function(e){});
    }
  })
  .catch(function(e){});
}

function onCerrarOltChange() {
  var oltId = document.getElementById('cerrarOltSelect').value;
  document.getElementById('cerrarOnuActions').style.display = oltId ? 'block' : 'none';
  document.getElementById('cerrarScanResults').style.display = 'none';
  document.getElementById('cerrarNewOnuSn').value = '';
  document.getElementById('cerrarNewOnuSelected').style.display = 'none';
}

function scanearOnusCerrar() {
  var oltId = document.getElementById('cerrarOltSelect').value;
  if (!oltId) { alert('Seleccione una OLT primero'); return; }
  var resultsBox = document.getElementById('cerrarScanResults');
  resultsBox.innerHTML = '<div style="padding:12px;text-align:center;color:#64748b;"><i class="fas fa-spinner fa-spin"></i> Escaneando...</div>';
  resultsBox.style.display = 'block';
  
  fetch('/api/cambio-onu/scan-onus?olt_id=' + oltId + '&mode=smartolt')
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (!d.success || !d.onus || !d.onus.length) {
      resultsBox.innerHTML = '<div style="padding:12px;text-align:center;color:#ef4444;">No se encontraron ONUs disponibles</div>';
      return;
    }
    var html = '';
    d.onus.forEach(function(onu) {
      html += '<div class="onu-result-item" data-sn="' + (onu.sn || '') + '" data-model="' + (onu.model || '') + '" data-port="' + (onu.interface || '') + '" style="padding:8px 10px;cursor:pointer;border-bottom:1px solid #f1f5f9;font-size:0.8rem;" onclick="seleccionarOnuCerrar(this)" onmouseover="this.style.background=\'#eff6ff\'" onmouseout="this.style.background=\'white\'">' +
        '<div><b>SN:</b> ' + (onu.sn || '—') + ' <span style="color:#64748b;">(' + (onu.model || 'desconocido') + ')</span></div>' +
        '<div style="color:#64748b;font-size:0.75rem;">Interface: ' + (onu.interface || '—') + '</div></div>';
    });
    if (!html) html = '<div style="padding:12px;text-align:center;color:#ef4444;">No se encontraron ONUs disponibles</div>';
    resultsBox.innerHTML = html;
  })
  .catch(function(e) {
    resultsBox.innerHTML = '<div style="padding:12px;text-align:center;color:#ef4444;">Error: ' + e.message + '</div>';
  });
}

function seleccionarOnuCerrar(el) {
  var sn = el.getAttribute('data-sn');
  var model = el.getAttribute('data-model');
  document.getElementById('cerrarNewOnuSn').value = sn;
  document.getElementById('cerrarNewOnuModel').value = model;
  document.getElementById('cerrarNewOnuSelected').innerHTML = 
    '<i class="fas fa-check-circle" style="color:#16a34a;"></i> ONU seleccionada: <b>' + sn + '</b> (' + model + ')';
  document.getElementById('cerrarNewOnuSelected').style.display = 'block';
  // Highlight selected
  document.querySelectorAll('#cerrarScanResults .onu-result-item').forEach(function(i) { i.style.background = 'white'; });
  el.style.background = '#dcfce7';
}

function confirmarCerrar(e) {
  e.preventDefault();
  var id = document.getElementById('idCerrar').value;
  var tipo = document.getElementById('idCerrarTipo').value;
  var obs = document.getElementById('cerrarObs').value.trim();
  if (!obs) { alert('Las observaciones son obligatorias'); return; }
  
  var btn = document.querySelector('#modalCerrar .btn-primary');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
  
  var body = { observaciones: obs };
  
  // If traslado with ONU swap
  if (tipo === 'traslado') {
    var newOnuSn = document.getElementById('cerrarNewOnuSn').value;
    var servicioId = parseInt(document.getElementById('idCerrarServicioId').value);
    var oltId = parseInt(document.getElementById('cerrarOltSelect').value) || 0;
    
    body.servicio_id = servicioId;
    body.olt_id = oltId;
    body.new_onu_sn = newOnuSn;
    
    // Only send swap data if an ONU was selected
    if (newOnuSn) {
      var clientId = 0;
      // Get client id from the row's data attributes stored on open
      body.desvincular_onu_vieja = true;
      body.vincular_onu_nueva = true;
    }
  }
  
  fetch('/api/ordenes/' + id + '/completar', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify(body)
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    btn.disabled = false; btn.innerHTML = 'Confirmar';
    if (d.status === 'success') { closeModal('modalCerrar'); location.reload(); }
    else { alert(d.msg || 'Error'); }
  })
  .catch(function(e) { btn.disabled = false; btn.innerHTML = 'Confirmar'; alert('Error: ' + e.message); });
  return false;
}

