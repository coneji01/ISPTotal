				if ((p.status || '').indexOf('1G-FullD') >= 0 || (p.status || '').indexOf('FullD') >= 0) statusIcon = 'fa fa-arrow-up text-success';
				var adminIcon = (p.admin || 'Enabled') === 'Enabled' ? 'fa fa-check-circle text-success' : 'fa fa-times-circle text-danger';
