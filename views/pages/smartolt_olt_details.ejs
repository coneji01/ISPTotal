		'<button class="btn btn-info btn-sm" onclick="showAddMultipleVlans()"><i class="fa fa-plus"></i> Add multiple VLANs</button> ' +
		'<button class="btn btn-danger btn-sm" onclick="deleteSelectedVlans()"><i class="fa fa-minus"></i> Delete multiple VLANs</button>' +
