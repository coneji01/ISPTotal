				'<button type="button" class="btn btn-primary" id="uplink-save-btn" onclick="saveUplinkConfig()"><i class="fa fa-save"></i> Save VLANs</button></div>' +
				'</div></div></div>';
			
			contentDiv.innerHTML = html;
		})
		.catch(function(err) {
			contentDiv.innerHTML = '<p class="text-danger">Error loading uplink ports: ' + err.message + '</p>';
		});
}

var _currentUplinkPort = '';
var _currentUplinkVlans = [];

function configureUplink(portName) {
	_currentUplinkPort = portName;
	var modal = document.getElementById('uplink-config-modal');
	if (!modal) return;
	
	var body = document.getElementById('uplink-config-body');
	body.innerHTML = '<p><i class="fa fa-spinner fa-spin"></i> Loading VLANs...</p>';
	
	modal.style.display = 'block';
	modal.style.backgroundColor = 'rgba(0,0,0,0.5)';
	modal.style.position = 'fixed';
	modal.style.top = '0';
	modal.style.left = '0';
	modal.style.width = '100%';
	modal.style.height = '100%';
	modal.style.zIndex = '9999';
	
	// Cargar VLANs disponibles y las del puerto actual
	var oltId = getOltIdFromUrl();
	
	Promise.all([
		fetch('/api/olts/' + oltId + '/vlans', { credentials: 'same-origin' }).then(function(r) { return r.json(); }),
		fetch('/api/olts/' + oltId + '/uplink-ports', { credentials: 'same-origin' }).then(function(r) { return r.json(); })
	])
	.then(function(results) {
		var vlanData = results[0];
		var uplinkData = results[1];
		var allVlans = vlanData.vlans || [];
		
		// Encontrar las VLANs actuales del puerto
		var currentPort = null;
		if (uplinkData.ports) {
			uplinkData.ports.forEach(function(p) {
				if ((p.name || p.port) === portName) currentPort = p;
			});
		}
		
		var currentVlanStr = currentPort ? (currentPort.vlans || '') : '';
		var currentVlans = [];
		// Parsear "Trunk: 1, 69, 200, 600"
		var vlanMatch = currentVlanStr.match(/Trunk:\s*([\d,\s]+)/);
		if (vlanMatch) {
			vlanMatch[1].split(',').forEach(function(v) {
				var vid = parseInt(v.trim());
				if (vid > 0) currentVlans.push(vid);
			});
		}
		_currentUplinkVlans = currentVlans;
		
		var html = '<div class="row"><div class="col-md-6">' +
			'<h5>Port: <code>' + portName + '</code></h5>' +
			'<p>Current VLANs: <strong>' + currentVlans.join(', ') + '</strong></p>' +
			'<hr><h5>Available VLANs</h5>' +
			'<div style="max-height:300px;overflow-y:auto;">';
		
		allVlans.forEach(function(v) {
			var vid = v.vlan || v.id || 0;
			if (vid < 2) return;
			var checked = currentVlans.indexOf(vid) >= 0 ? 'checked' : '';
			html += '<div class="checkbox"><label><input type="checkbox" class="uplink-vlan-cb" value="' + vid + '" ' + checked + '> ' +
				'<span class="label label-primary">' + vid + '</span> ' + (v.name || '') + '</label></div>';
		});
		
		html += '</div></div><div class="col-md-6">' +
			'<h5>Add VLAN to port</h5>' +
			'<div class="input-group"><input type="number" class="form-control" id="uplink-add-vlan-input" min="2" max="4094" placeholder="VLAN ID">' +
			'<span class="input-group-btn"><button class="btn btn-success" onclick="addVlanToUplink()"><i class="fa fa-plus"></i> Add</button></span></div>' +
			'<hr><h5>Actions</h5>' +
			'<button class="btn btn-warning btn-block" onclick="setUplinkPvid()"><i class="fa fa-tag"></i> Set as PVID untag</button>' +
			'</div></div>';
		
		body.innerHTML = html;
	})
	.catch(function(err) {
		body.innerHTML = '<p class="text-danger">Error: ' + err.message + '</p>';
	});
}

function addVlanToUplink() {
	var input = document.getElementById('uplink-add-vlan-input');
	var vid = parseInt(input.value);
	if (!vid || vid < 2 || vid > 4094) { alert('Enter a valid VLAN ID (2-4094)'); return; }
	
	if (_currentUplinkVlans.indexOf(vid) >= 0) {
		alert('VLAN ' + vid + ' already added');
		return;
	}
	
	// Check the checkbox if exists
	var cb = document.querySelector('.uplink-vlan-cb[value="' + vid + '"]');
	if (cb) {
		cb.checked = true;
	} else {
		// Add a new checkbox
		var container = document.querySelector('.uplink-vlan-cb')?.closest('.col-md-6')?.querySelector('div[style*="overflow"]');
		if (container) {
			var div = document.createElement('div');
			div.className = 'checkbox';
			div.innerHTML = '<label><input type="checkbox" class="uplink-vlan-cb" value="' + vid + '" checked> ' +
				'<span class="label label-primary">' + vid + '</span></label>';
			container.appendChild(div);
		}
	}
	_currentUplinkVlans.push(vid);
	input.value = '';
}

function saveUplinkConfig() {
	var oltId = getOltIdFromUrl();
	var portName = _currentUplinkPort;
	
	// Obtener VLANs seleccionadas
	var selectedVlans = [];
	document.querySelectorAll('.uplink-vlan-cb:checked').forEach(function(cb) {
		selectedVlans.push(parseInt(cb.value));
	});
	
	if (selectedVlans.length === 0) {
		if (!confirm('No VLANs selected. This will remove all VLANs from ' + portName + '. Continue?')) return;
	}
	
	var saveBtn = document.getElementById('uplink-save-btn');
	saveBtn.disabled = true;
	saveBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Saving...';
	
	fetch('/api/olts/' + oltId + '/uplink/configure', {
		method: 'POST',
		credentials: 'same-origin',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({
			port: portName,
			vlans: selectedVlans,
			pvid: '' // no cambiar pvid por ahora
		})
	})
	.then(function(r) { return r.json(); })
	.then(function(data) {
		if (data.success) {
			alert('VLANs configured successfully on ' + portName);
			closeUplinkModal();
			loadUplinkPorts(); // refrescar tabla
		} else {
			alert('Error: ' + (data.error || 'Unknown error'));
		}
		saveBtn.disabled = false;
		saveBtn.innerHTML = '<i class="fa fa-save"></i> Save VLANs';
	})
	.catch(function(err) {
		alert('Error: ' + err.message);
		saveBtn.disabled = false;
		saveBtn.innerHTML = '<i class="fa fa-save"></i> Save VLANs';
	});
}

function closeUplinkModal() {
	var modal = document.getElementById('uplink-config-modal');
	if (modal) modal.style.display = 'none';
}

function setUplinkPvid() {
	var vid = prompt('Enter VLAN ID to set as PVID (untag) on ' + _currentUplinkPort + ':');
	if (!vid) return;
	
	var oltId = getOltIdFromUrl();
	fetch('/api/olts/' + oltId + '/uplink/configure', {
		method: 'POST',
		credentials: 'same-origin',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({ port: _currentUplinkPort, vlans: _currentUplinkVlans, pvid: parseInt(vid) })
	})
	.then(function(r) { return r.json(); })
	.then(function(data) {
		if (data.success) {
			alert('PVID set to ' + vid + ' on ' + _currentUplinkPort);
			closeUplinkModal();
			loadUplinkPorts();
		} else {
			alert('Error: ' + (data.error || 'Unknown error'));
		}
	})
	.catch(function(err) {
		alert('Error: ' + err.message);
	});
}

function loadVlans() {
	var oltId = getOltIdFromUrl();
	var container = document.getElementById('vlans');
	if (!container) return;
	var contentDiv = container.querySelector('.col-xs-12') || container;
	
