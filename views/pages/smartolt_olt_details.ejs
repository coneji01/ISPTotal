<script type="text/javascript">
function getOltId() {
	var params = new URLSearchParams(window.location.search);
	var oid = params.get('olt_id');
	if (oid) {
		return oid;
	}
	/* fallback: try to extract from the URL path */
	var parts = window.location.pathname.split('/');
	for (var i = 0; i < parts.length; i++) {
		if (parts[i] === 'olt_details' && (i + 1) < parts.length) {
			return parts[i + 1];
		}
	}
	return '3';
}

function formatUptime(val) {
	if (!val && val !== 0) {
		return '-';
	}
	/* If it's already a formatted string like "15d 4h 32m", use it directly */
	if (typeof val === 'string' && /^\d+d/.test(val)) {
		return val;
	}
	/* Otherwise treat as seconds */
	var seconds = Number(val);
	if (isNaN(seconds)) {
		return val || '-';
	}
	var days = Math.floor(seconds / 86400);
	var hours = Math.floor((seconds % 86400) / 3600);
	var mins = Math.floor((seconds % 3600) / 60);
	return days + ' days, ' + hours + ':' + (mins < 10 ? '0' : '') + mins;
}

function loadOltData() {
	var oltId = getOltId();
	var loadingEl = document.getElementById('olt-loading');
	var tableEl = document.getElementById('olt-details-table');

	if (loadingEl) {
		loadingEl.style.display = 'block';
	}
	if (tableEl) {
		tableEl.style.display = 'none';
	}

	/* Also update the Edit and CLI button links with the correct ID */
	var editBtn = document.getElementById('btn-edit-olt-settings');
	if (editBtn) {
		editBtn.href = '/olt/edit/' + oltId;
	}

	fetch('/api/olts/' + oltId + '/status')
		.then(function(response) {
			if (!response.ok) {
				throw new Error('HTTP ' + response.status);
			}
			return response.json();
		})
		.then(function(data) {
			if (loadingEl) {
				loadingEl.style.display = 'none';
			}
			if (tableEl) {
				tableEl.style.display = '';
			}

			/* ---- OLT info table ---- */
			var setText = function(id, val) {
				var el = document.getElementById(id);
				if (el) {
					el.textContent = val || '-';
				}
			};

			setText('olt-name', data.name);
			setText('olt-model', data.model);
			setText('olt-ip', data.ip);
			setText('olt-version', data.version);

			var uptimeStr = formatUptime(data.uptime);
			setText('olt-uptime', uptimeStr);
			setText('olt-up-time-sidebar', uptimeStr);

			/* ---- KPIs ---- */
			var online = (data.online !== undefined ? data.online : '-');
			var total = (data.total !== undefined ? data.total : '-');
			var offline = (data.offline !== undefined ? data.offline : '-');
			var waitingAuth = (data.waiting_auth !== undefined ? data.waiting_auth : '-');
			var lowSignals = (data.low_signals !== undefined ? data.low_signals : '-');

			setText('kpi-online', online + ' / ' + total);
			setText('kpi-offline', offline);
			setText('kpi-waiting', waitingAuth);
			setText('kpi-low-signal', lowSignals);

			/* ---- OLT image ---- */
			var imgEl = document.getElementById('olt-image');
			if (imgEl && data.model) {
				imgEl.src = '/content/img/' + encodeURIComponent(data.model) + '.png';
				imgEl.onerror = function() {
					this.src = '/content/img/OLT-generic.png';
				};
			}
		})
		.catch(function(err) {
			if (loadingEl) {
				loadingEl.style.display = 'none';
			}
			if (tableEl) {
				tableEl.style.display = '';
			}
			var setText = function(id, val) {
				var el = document.getElementById(id);
				if (el) {
					el.textContent = val;
				}
			};
			setText('olt-name', 'Error loading');
			setText('olt-model', err.message);
			setText('olt-ip', '-');
			setText('olt-version', '-');
			setText('olt-uptime', '-');
			setText('olt-up-time-sidebar', '-');
			setText('kpi-online', '-');
			setText('kpi-offline', '-');
			setText('kpi-waiting', '-');
			setText('kpi-low-signal', '-');
		});
}

$(document).ready(function() {
	loadOltData();

	$('#btn-refresh-olt').on('click', function(e) {
		e.preventDefault();
		loadOltData();
	});

	/* Tab clicks manuales (Bootstrap JS no disponible en esta pagina) */
	$('.nav-tabs a').on('click', function(e) {
		e.preventDefault();
		var tabId = $(this).attr('href');
		$('.nav-tabs li').removeClass('active');
		$(this).parent().addClass('active');
		$('.tab-pane').removeClass('active');
		$(tabId).addClass('active');
		loadTabData(tabId);
	});

	/* Load initial tab based on URL hash */
	var initialTab = window.location.hash || '#details';
	if (initialTab !== '#details') {
		// Bootstrap tabs no estan disponibles en esta pagina, activar manualmente
		$('.nav-tabs li').removeClass('active');
		$('.nav-tabs a[href="' + initialTab + '"]').parent().addClass('active');
		$('.tab-pane').removeClass('active');
		$(initialTab).addClass('active');
	}
	loadTabData(initialTab);

	/* Refresh buttons for each tab */
	$('.get-boards').on('click', function(e) {
		e.preventDefault();
		loadBoards();
	});
	$('.get-pon-ports').on('click', function(e) {
		e.preventDefault();
		loadPonPorts();
	});
});

function getOltIdFromUrl() {
	var params = new URLSearchParams(window.location.search);
	return params.get('olt_id') || '5';
}

function loadTabData(tabId) {
	if (tabId === '#cards') {
		loadBoards();
	} else if (tabId === '#pon_ports') {
		loadPonPorts();
	} else if (tabId === '#uplink_ports') {
		loadUplinkPorts();
	} else if (tabId === '#vlans') {
		loadVlans();
	} else if (tabId === '#ip_pools') {
		loadIpPools();
	}
}

function loadBoards() {
	var oltId = getOltIdFromUrl();
	var container = document.getElementById('general_boards_info');
	if (!container) return;
	container.innerHTML = '<p><i class="fa fa-spinner fa-spin"></i> Loading cards...</p>';
	
	fetch('/api/olts/' + oltId + '/boards', { credentials: 'same-origin' })
		.then(function(r) { return r.json(); })
		.then(function(data) {
			if (!data.success || !data.boards || data.boards.length === 0) {
				container.innerHTML = '<p class="text-muted">No cards data available.</p>';
				return;
			}
			var html = '<div class="table-responsive"><table class="table table-striped"><thead><tr><th>Slot</th><th>Cfg Type</th><th>Real Type</th><th>Ports</th><th>SW Version</th><th>Status</th><th>Role</th></tr></thead><tbody>';
			data.boards.forEach(function(b) {
				var statusClass = b.status === 'Online' || b.status === 'INSERVICE' ? 'label label-success' : (b.status === 'Standby' || b.status === 'STANDBY' ? 'label label-warning' : 'label label-default');
				html += '<tr><td>' + (b.slot || '-') + '</td><td>' + (b.type || '-') + '</td><td>' + (b.real_type || '-') + '</td><td>' + (b.ports || '-') + '</td><td>' + (b.sw || '-') + '</td><td><span class="' + statusClass + '">' + (b.status || '-') + '</span></td><td>' + (b.role || '-') + '</td></tr>';
			});
			html += '</tbody></table></div>';
			container.innerHTML = html;
		})
		.catch(function(err) {
			container.innerHTML = '<p class="text-danger">Error loading cards: ' + err.message + '</p>';
		});
}

function loadPonPorts() {
	var oltId = getOltIdFromUrl();
	var container = document.getElementById('general_pon_ports_info');
	if (!container) return;
	container.innerHTML = '<p><i class="fa fa-spinner fa-spin"></i> Loading PON ports...</p>';
	
	fetch('/api/olts/' + oltId + '/pon-ports', { credentials: 'same-origin' })
		.then(function(r) { return r.json(); })
		.then(function(data) {
			if (!data.success || !data.ports || data.ports.length === 0) {
				container.innerHTML = '<p class="text-muted">No PON ports data available.</p>';
				return;
			}
			/* Agrupar por board */
			var byBoard = {};
			data.ports.forEach(function(p) {
				var board = p.board || Math.floor((p.port || 0) / 100) || 1;
				if (!byBoard[board]) byBoard[board] = [];
				byBoard[board].push(p);
			});
			
			var html = '';
			for (var b in byBoard) {
				html += '<h4>OLT slot ' + b + ', board type: ' + (byBoard[b][0].type || 'GPON') + '</h4>';
				html += '<div class="table-responsive"><table class="table table-striped table-condensed"><thead><tr>' +
					'<th>Port</th><th>Type</th><th>Admin state</th><th>Status</th>' +
					'<th>ONUs</th><th>Load</th><th>Average signal</th><th>Range</th><th>Tx power</th>' +
				'</tr></thead><tbody>';
				byBoard[b].forEach(function(p) {
					var statusIcon = p.status === 'Up' ? 'fa fa-arrow-up text-success' : 'fa fa-arrow-down text-danger';
					var adminIcon = p.admin_state === 'Enabled' ? 'fa fa-check-circle text-success' : 'fa fa-times-circle text-danger';
					var loadPct = p.load_pct || Math.round((p.onus_total || 0) / 128 * 100);
					var loadColor = loadPct > 80 ? 'text-danger' : (loadPct > 60 ? 'text-warning' : 'text-success');
					var signalVal = p.signal ? (typeof p.signal === 'string' ? p.signal.replace(' dBm','') : p.signal) : '-';
					html += '<tr>' +
						'<td><strong>' + (p.port || '-') + '</strong></td>' +
						'<td>' + (p.type || 'GPON') + '</td>' +
						'<td><i class="' + adminIcon + '"></i> ' + (p.admin_state || 'Enabled') + '</td>' +
						'<td><i class="' + statusIcon + '"></i> ' + (p.status || '-') + '</td>' +
						'<td><a href="/modulo?pagina=smartolt_configured_full&board=' + b + '&port=' + (p.port || '') + '" class="text-info">Online: ' + (p.onus_online || p.online || 0) + '</a> / Total: ' + (p.onus_total || p.total || 0) + '</td>' +
						'<td class="' + loadColor + '">' + (p.onus_total || 0) + ' / 128 (' + loadPct + '%)</td>' +
						'<td>' + signalVal + '</td>' +
						'<td>' + (p.range_min || 0) + ' - ' + (p.range_max || 20000) + ' m</td>' +
						'<td>' + (p.tx_power || '-') + '</td>' +
					'</tr>';
				});
				html += '</tbody></table></div>';
			}
			container.innerHTML = html;
		})
		.catch(function(err) {
			container.innerHTML = '<p class="text-danger">Error loading PON ports: ' + err.message + '</p>';
		});
}

