					'<td>' + (v.mgmt_voip ? '<i class="fa fa-check text-success"></i>' : '<i class="fa fa-times text-muted"></i>') + '</td>' +
					'<td>' + (v.dhcp_snooping ? '<i class="fa fa-check text-success"></i>' : '<i class="fa fa-times text-muted"></i>') + '</td>' +
					'<td>' + (v.lan_to_lan ? '<i class="fa fa-check text-success"></i>' : '<i class="fa fa-times text-muted"></i>') + '</td>' +
					'<td>' + (v.onus_count || 0) + '</td>' +
					'<td><button class="btn btn-danger btn-xs" onclick="deleteVlan(\'' + vid + '\')"><i class="fa fa-trash"></i> Delete</button></td>' +
				'</tr>';
			});
			html += '</tbody></table></div>';
			area.innerHTML = html;
		})
		.catch(function(err) {
			area.innerHTML = '<p class="text-danger">Error loading VLANs: ' + err.message + '</p>';
		});
}

function showAddVlanForm() {
	var area = document.getElementById('vlan-form-area');
	if (!area) return;
	
	// Generar opciones de puertos PON (board 2-4, ports 1-16)
	var portOptions = '';
	for (var b = 2; b <= 4; b++) {
		portOptions += '<optgroup label="Board ' + b + '">';
		for (var p = 1; p <= 16; p++) {
			portOptions += '<option value="' + b + '/' + p + '">Board ' + b + ' - Port ' + p + '</option>';
		}
		portOptions += '</optgroup>';
	}
	
	area.innerHTML = '<div class="panel panel-default"><div class="panel-heading"><strong>Add VLAN</strong></div><div class="panel-body">' +
		'<div class="form-group"><label>VLAN-ID</label><input type="number" class="form-control" id="vlan-id-input" min="2" max="4094" placeholder="e.g. 100"></div>' +
		'<div class="form-group"><label>Description</label><input type="text" class="form-control" id="vlan-desc-input" placeholder="Optional description"></div>' +
		'<div class="form-group"><label>Default for PON ports</label><select class="form-control" id="vlan-ports-select" multiple size="5">' + portOptions + '</select></div>' +
		'<button class="btn btn-primary" onclick="saveVlan()"><i class="fa fa-save"></i> Save</button> ' +
		'<button class="btn btn-default" onclick="cancelVlanForm()">Cancel</button>' +
	'</div></div>';
}

function cancelVlanForm() {
	document.getElementById('vlan-form-area').innerHTML = '';
}

function saveVlan() {
	var oltId = getOltIdFromUrl();
	var vlanId = document.getElementById('vlan-id-input').value;
	var desc = document.getElementById('vlan-desc-input').value;
	var select = document.getElementById('vlan-ports-select');
	var ports = [];
	for (var i = 0; i < select.options.length; i++) {
		if (select.options[i].selected) ports.push(select.options[i].value);
	}
	
	if (!vlanId || vlanId < 2 || vlanId > 4094) {
		alert('VLAN-ID must be between 2 and 4094');
		return;
	}
	
	var area = document.getElementById('vlan-form-area');
	area.innerHTML = '<p><i class="fa fa-spinner fa-spin"></i> Creating VLAN ' + vlanId + '...</p>';
	
	fetch('/api/olts/' + oltId + '/vlans', {
		method: 'POST',
		credentials: 'same-origin',
		headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
		body: 'vlan_id=' + vlanId + '&description=' + encodeURIComponent(desc) + '&default_ports=' + ports.join(',')
	})
	.then(function(r) { return r.json(); })
	.then(function(data) {
		if (data.success) {
			cancelVlanForm();
			loadVlanTable(oltId);
			// Refrescar cache
			setTimeout(function() { location.reload(); }, 2000);
		} else {
			alert('Error: ' + (data.error || 'Unknown error'));
			cancelVlanForm();
		}
	})
	.catch(function(err) {
		alert('Error: ' + err.message);
		cancelVlanForm();
	});
}

function deleteVlan(vlanId) {
	if (!confirm('Delete VLAN ' + vlanId + '? This will remove it from the OLT.')) return;
	
	var oltId = getOltIdFromUrl();
	fetch('/api/olts/' + oltId + '/vlans/' + vlanId, {
		method: 'DELETE',
		credentials: 'same-origin'
	})
	.then(function(r) { return r.json(); })
	.then(function(data) {
		if (data.success) {
			loadVlanTable(oltId);
		} else {
			alert('Error: ' + (data.error || 'Unknown error'));
		}
	})
	.catch(function(err) {
		alert('Error: ' + err.message);
	});
}

function toggleAllVlans() {
	var checked = document.getElementById('vlan-select-all').checked;
	document.querySelectorAll('.vlan-checkbox').forEach(function(cb) { cb.checked = checked; });
}

function deleteSelectedVlans() {
	var oltId = getOltIdFromUrl();
	var selected = [];
	document.querySelectorAll('.vlan-checkbox:checked').forEach(function(cb) {
		selected.push(cb.value);
	});
	if (selected.length === 0) { alert('Select VLANs to delete'); return; }
	if (!confirm('Delete ' + selected.length + ' VLAN(s)? This will remove them from the OLT.')) return;
	
	var count = selected.length;
	var done = 0;
	selected.forEach(function(vlanId) {
		fetch('/api/olts/' + oltId + '/vlans/' + vlanId, {
			method: 'DELETE',
			credentials: 'same-origin'
		})
		.then(function(r) { return r.json(); })
		.then(function(data) {
			done++;
			if (done >= count) {
				loadVlanTable(oltId);
			}
		})
		.catch(function() { done++; });
	});
}

function showAddMultipleVlans() {
	alert('Add multiple VLANs: Enter VLAN IDs separated by commas (e.g. 100,101,102)');
	var range = prompt('VLAN IDs (comma separated or range like 100-110):');
	if (!range) return;
	
	var oltId = getOltIdFromUrl();
	var ids = [];
	range.split(',').forEach(function(part) {
		part = part.trim();
		var rangeMatch = part.match(/^(\d+)-(\d+)$/);
		if (rangeMatch) {
			for (var i = parseInt(rangeMatch[1]); i <= parseInt(rangeMatch[2]); i++) ids.push(i);
		} else if (parseInt(part) > 1) {
			ids.push(parseInt(part));
		}
	});
	
	if (ids.length === 0) return;
	var area = document.getElementById('vlan-form-area');
	area.innerHTML = '<p><i class="fa fa-spinner fa-spin"></i> Creating ' + ids.length + ' VLANs...</p>';
	
	var done = 0;
	ids.forEach(function(vlanId) {
		fetch('/api/olts/' + oltId + '/vlans', {
			method: 'POST',
			credentials: 'same-origin',
			headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
			body: 'vlan_id=' + vlanId + '&description='
		})
		.then(function(r) { return r.json(); })
		.then(function() {
			done++;
			if (done >= ids.length) {
				area.innerHTML = '';
				loadVlanTable(oltId);
			}
		})
		.catch(function() { done++; });
	});
}
</script>

