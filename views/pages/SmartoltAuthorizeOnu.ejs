<script type="text/javascript">

// Loading-overlay helpers are defined at parse time, NOT inside the ready
// wrapper below: page scripts render before the footer, so their ready
// handlers run first and may call showLoadingOverlay during initial load
// (e.g. API stats).
	var waitingForOLT   = $("<div>", {
