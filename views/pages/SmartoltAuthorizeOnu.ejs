	var currentPresetId = null;
	var presetsData = {};

	function loadPresetsForAuthorization() {
		var oltId = '1';
		var ponType = 'gpon';
		var board = '3';
		var port = '3';
		var sn = 'HWTC4ACADA1C';
		var onuTypeId = '55';

		if (!oltId || !ponType) {
			$('#presets-loading').hide();
			return;
		}

		$.ajax({
			url: '/onu_authorization_presets/get_presets_for_apply',
			type: 'GET',
			data: {
				olt_id: oltId,
				pon_type: ponType,
				board: board,
				port: port,
				sn: sn,
				onu_type_id: onuTypeId
			},
			success: function(response) {
				$('#presets-loading').hide();
				if (response.presets && response.presets.length > 0) {
					populatePresetDropdown(response.presets);
				}
			},
			error: function() {
				$('#presets-loading').hide();
			}
		});
	}

	function populatePresetDropdown(presets) {
		var $select = $('#preset_selector');

		presets.forEach(function(preset) {
			presetsData[preset.id] = preset;
			var isDefault = preset.is_default == 1 || preset.is_default === '1' || preset.is_default === true;
			var isCurrentPreset = currentPresetId && currentPresetId == preset.id;

			var label = preset.name;
			if (isDefault) {
				label += ' [' + (typeof lang_default !== 'undefined' ? lang_default : 'Default') + ']';
			}

			var $option = $('<option></option>')
				.val(preset.id)
				.text(label);

			if (isCurrentPreset) {
				$option.prop('selected', true);
			}

			$select.append($option);
		});

		// Rebuild multiselect to reflect new options
		$select.multiselect('rebuild');

		// Re-apply disabled state if checkbox is not checked
		if (!$('#use_preset').is(':checked')) {
			$select.multiselect('disable');
		}

		// Show details for the currently selected preset
		if (currentPresetId && presetsData[currentPresetId]) {
			showPresetDetails(presetsData[currentPresetId]);
		}
	}

	function showPresetDetails(preset) {
		if (!preset) {
			$('#preset-details').hide();
			return;
		}

		var summary = buildPresetSummary(preset);
		$('#preset-details-content').text(summary);
		$('#preset-details').show();
	}

	// Handle preset selection change
	$('#preset_selector').on('change', function() {
		var presetId = $(this).val();

		// Show/hide details based on selection
		if (presetId && presetsData[presetId]) {
			showPresetDetails(presetsData[presetId]);
			applyPresetToForm(presetsData[presetId]);
		} else {
			$('#preset-details').hide();
			resetFormToDefaults();
		}

		// Update current preset ID and hidden field
		currentPresetId = presetId;
		if (presetId) {
			// Add or update hidden preset_id field
			if ($('input[name="preset_id"]').length) {
				$('input[name="preset_id"]').val(presetId);
			} else {
				$('#authorized_form').prepend('<input type="hidden" name="preset_id" value="' + presetId + '"/>');
			}
		} else {
			// Remove preset_id hidden field
			$('input[name="preset_id"]').remove();
		}

		// Update URL without page reload (for bookmarking/sharing)
		var currentUrl = new URL(window.location.href);
		if (presetId) {
			currentUrl.searchParams.set('preset_id', presetId);
			currentUrl.searchParams.delete('no_preset');
		} else {
			currentUrl.searchParams.delete('preset_id');
			currentUrl.searchParams.set('no_preset', '1');
		}
		window.history.replaceState({}, '', currentUrl.toString());
	});

	// Apply preset values to form without page reload
	function applyPresetToForm(preset) {
		// ONU Type - check if detected type exists, otherwise use preset type or fallback
		var detectedOnuTypeId = '55';
		var detectedTypeExists = false;
		if (detectedOnuTypeId) {
			// Check if the detected type exists in the onu_types array
			for (var i = 0; i < onu_types.length; i++) {
				if (onu_types[i].id == detectedOnuTypeId) {
					detectedTypeExists = true;
					break;
				}
			}
		}
		if (!detectedTypeExists) {
			if (preset.onu_type_id) {
				$('#onu_type_id').val(preset.onu_type_id).multiselect('refresh');
			} else if (preset.fallback_onu_type_id) {
				$('#onu_type_id').val(preset.fallback_onu_type_id).multiselect('refresh');
			}
		}

		// Mode
		if (preset.mode) {
			$('input[name=mode]').prop('checked', false);
			$('input[name=mode][value="' + preset.mode + '"]').prop('checked', true);
		}

		// VLAN
		if (preset.vlan_id) {
			$('#vlan').val(preset.vlan_id).multiselect('refresh');
		}

		// SVLAN
		if (preset.use_svlan && preset.use_svlan !== '0' && preset.use_svlan !== 0) {
			$('#use_svlan').prop('checked', true).trigger('change');
			if (preset.svlan_id) {
				$('#svlan').val(preset.svlan_id).multiselect('refresh');
			}
			if (preset.tag_transform_mode) {
				$('#tag_transform_mode').val(preset.tag_transform_mode);
			}
			if (preset.use_other_all_tls_vlan && preset.use_other_all_tls_vlan !== '0' && preset.use_other_all_tls_vlan !== 0) {
				$('#use_other_all_tls_vlan').prop('checked', true);
			} else {
				$('#use_other_all_tls_vlan').prop('checked', false);
			}
		} else {
			$('#use_svlan').prop('checked', false).trigger('change');
		}

		// CVLAN
		if (preset.use_cvlan && preset.use_cvlan !== '0' && preset.use_cvlan !== 0) {
			$('#use_cvlan').prop('checked', true).trigger('change');
			if (preset.cvlan_id) {
				$('#cvlan').val(preset.cvlan_id).multiselect('refresh');
			}
		} else {
			$('#use_cvlan').prop('checked', false).trigger('change');
		}

		// Zone/Location
		if (preset.location_id) {
			$('#location').val(preset.location_id).multiselect('refresh').trigger('change');
		}

		// Speed profiles
		if (preset.upload_speed_id) {
			$('#upload_speed').val(preset.upload_speed_id).multiselect('refresh');
		}
		if (preset.download_speed_id) {
			$('#download_speed').val(preset.download_speed_id).multiselect('refresh');
		}

		// Custom profile
		if (preset.custom_profile && preset.custom_profile !== '0' && preset.custom_profile !== 0 && preset.custom_template_id) {
			$('.custom_templates_wrapper').show();
			$('#custom_profile').prop('checked', true);
			$('#custom_template').val(preset.custom_template_id).show();
		} else {
			$('#custom_profile').prop('checked', false);
			$('#custom_template').hide();
		}

		// Name pattern (with variable substitution) - clear if not set
		if (preset.location_name) {
			var name = substitutePatternVariables(preset.location_name);
			$('#location_name').val(name);
		} else {
			$('#location_name').val('');
		}

		// Description pattern (with variable substitution) - clear if not set
		if (preset.description_pattern) {
			var desc = substitutePatternVariables(preset.description_pattern);
			$('#description').val(desc);
		} else {
			$('#description').val('');
		}

		// ODB - set or clear
		if (preset.odb_id) {
			$('#odb').val(preset.odb_id).multiselect('refresh').trigger('change');
		} else {
			$('#odb').val('').multiselect('refresh').trigger('change');
		}
	}

	// Reset form to defaults when "None" is selected
	function resetFormToDefaults() {
		// Reset ONU type to detected type
		var detectedOnuTypeId = '55';
		if (detectedOnuTypeId) {
			$('#onu_type_id').val(detectedOnuTypeId).multiselect('refresh');
		}

		// Reset mode to Routing
		$('input[name=mode]').prop('checked', false);
		$('input[name=mode][value="Routing"]').prop('checked', true);

		// Reset VLAN to first option (default)
		$('#vlan option:first').prop('selected', true);
		$('#vlan').multiselect('refresh');

		// Reset SVLAN/CVLAN
		$('#use_svlan').prop('checked', false).trigger('change');
		$('#use_cvlan').prop('checked', false).trigger('change');
		$('#use_other_all_tls_vlan').prop('checked', false);

		// Reset Zone to default
		var defaultLocationId = '';
		if (defaultLocationId) {
			$('#location').val(defaultLocationId).multiselect('refresh').trigger('change');
		} else {
			$('#location option:first').prop('selected', true);
			$('#location').multiselect('refresh').trigger('change');
		}

		// Reset ODB
		$('#odb').val('').multiselect('refresh').trigger('change');

		// Reset speed profiles to defaults
		var defaultUploadSpeed = '23';
		var defaultDownloadSpeed = '4';
		if (defaultUploadSpeed) {
			$('#upload_speed').val(defaultUploadSpeed).multiselect('refresh');
		} else {
			$('#upload_speed option:first').prop('selected', true);
			$('#upload_speed').multiselect('refresh');
		}
		if (defaultDownloadSpeed) {
			$('#download_speed').val(defaultDownloadSpeed).multiselect('refresh');
		} else {
			$('#download_speed option:first').prop('selected', true);
			$('#download_speed').multiselect('refresh');
		}

		// Reset custom profile
		$('#custom_profile').prop('checked', false);
		$('#custom_template').hide();

		// Clear name and description
		$('#location_name').val('');
		$('#description').val('');
	}

	// Substitute pattern variables like {olt}, {board}, {port}, {sn}, etc.
	function substitutePatternVariables(pattern) {
		if (!pattern) return '';
		var oltName = 'JOEL WIFI';
		var board = '3';
		var port = '3';
		var sn = 'HWTC4ACADA1C';
		var zoneName = $('#location option:selected').text() || '';
		var odbName = $('#odb option:selected').text() || '';
		var onuTypeName = $('#onu_type_id option:selected').text() || '';

		return pattern
			.replace(/\{olt\}/g, oltName)
			.replace(/\{board\}/g, board)
			.replace(/\{port\}/g, port)
			.replace(/\{sn\}/g, sn)
			.replace(/\{zone\}/g, zoneName)
			.replace(/\{odb\}/g, odbName)
			.replace(/\{onu_type\}/g, onuTypeName);
	}

	// Reload presets when returning to page (e.g., after creating a preset in another tab)
	document.addEventListener('visibilitychange', function() {
		if (document.visibilityState === 'visible') {
			var $select = $('#preset_selector');
			var currentSelection = $select.val();
			$select.find('option:not(:first)').remove();
			presetsData = {};
			$('#presets-loading').show();
			$('#preset-details').hide();
			loadPresetsForAuthorization();
		}
	});

	// Handle "Use Preset" checkbox
	$('#use_preset').on('change', function() {
		if ($(this).is(':checked')) {
			$('#preset_selector').prop('disabled', false).multiselect('enable');
			// Auto-select default preset if available and nothing currently selected
			if (!$('#preset_selector').val()) {
				var defaultPresetId = null;
				for (var id in presetsData) {
					var preset = presetsData[id];
					if (preset.is_default == 1 || preset.is_default === '1' || preset.is_default === true) {
						defaultPresetId = id;
						break;
					}
				}
				if (defaultPresetId) {
					$('#preset_selector').val(defaultPresetId).multiselect('refresh').trigger('change');
				}
			}
		} else {
			$('#preset_selector').prop('disabled', true).multiselect('disable');
			$('#preset-details').hide();
			// Reset to "None" and clear form preset values
			$('#preset_selector').val('').multiselect('refresh').trigger('change');
		}
	});

	// Load presets on page load
	loadPresetsForAuthorization();
	});

</script>


