	// --- Per-attempt ONU ID range override (XG/XGS/10GEPON only) ---
	function isHighRangeChannelSelected() {
		var gt = $('input[name="gpon_type"]:checked').val();
		var et = $('input[name="epon_type"]:checked').val();
		var pt = $('input[name="pon_type"]:checked').val() || $('input[name="pon_type"][type="hidden"]').val();
		if (pt === 'gpon') { return gt === 'xgpon' || gt === 'xgspon'; }
		if (pt === 'epon') { return et === '10gepon'; }
		return false;
	}

	function refreshDetectedMaxOnuIdOverride() {
		if (!isHighRangeChannelSelected()) {
			$('.detected_max_onu_id_override_wrapper').hide();
			return;
		}
		var oltId = $('#olt_id').val();
		var board = $('#board').val();
		if (!oltId || board === '' || board == null) {
			$('.detected_max_onu_id_override_wrapper').hide();
			return;
		}
		$.ajax({
			url: '/api/olt/get_board_detected_limit',
			type: 'POST',
			dataType: 'json',
			beforeSend: function(request) {
				request.setRequestHeader("X-Token", config.X_TOKEN);
			},
			data: { olt_id: oltId, board: board },
			success: function(resp) {
				var vendor = resp && resp.vendor ? resp.vendor : 'huawei';
				var detected = resp && resp.detected_max_onu_id ? parseInt(resp.detected_max_onu_id, 10) : null;
				// Vendor-specific range boundaries
				var lowLabel  = (vendor === 'zte') ? '1 – 128'  : '0 – 127';
				var highLabel = (vendor === 'zte') ? '129 – 256' : '128 – 255';
				var highRangeStart = (vendor === 'zte') ? 129 : 128;
				$('#detected_max_onu_id_override_low_label').text(lowLabel);
				$('#detected_max_onu_id_override_high_label').text(highLabel);
				// Honor posted override mode once (error re-render), then clear so later
				// board changes fall back to detection-based preselect.
				var preselect;
				if (postedDetectedMaxOnuIdOverrideMode) {
					preselect = postedDetectedMaxOnuIdOverrideMode;
					postedDetectedMaxOnuIdOverrideMode = '';
				} else {
					// Pre-select based on detected limit: if the board has learned a low limit, default to low
					preselect = (detected !== null && detected < highRangeStart) ? 'low' : 'high';
				}
				$('input[name="detected_max_onu_id_override_mode"][value="' + preselect + '"]').prop('checked', true);
				$('.detected_max_onu_id_override_wrapper').show();
			}
		});
	}

	$(document).on('change', 'input[name="gpon_type"], input[name="epon_type"], input[name="pon_type"]', refreshDetectedMaxOnuIdOverride);
