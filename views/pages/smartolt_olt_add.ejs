  <link href="/public/smartolt-files/inter-fonts.css?v=3.53.0.1" rel="stylesheet">
  <link href="/public/smartolt-files/dashboard-smartolt-night.css?v=3.53.0.314" rel="stylesheet">
  <script src="/public/smartolt-files/jquery.min.js"></script>
  <script src="/public/smartolt-files/toast.js"></script>
  <style>
    .form-group { margin-bottom: 15px; }
    label { display: block; margin-bottom: 4px; color: #64748b; font-size: 13px; font-weight: 500; }
    input, select { width: 100%; padding: 8px 12px; border: 1px solid rgba(255,255,255,0.12); border-radius: 6px; background: rgba(255,255,255,0.06); color: #e2e8f0; font-size: 14px; }
    input:focus, select:focus { border-color: #8cc8ff; outline: none; }
    .btn { padding: 8px 16px; border-radius: 6px; border: none; cursor: pointer; font-size: 14px; }
    .btn-primary { background: rgba(29,139,255,0.18); color: #8cc8ff; }
    .btn-success { background: rgba(52,211,153,0.15); color: #86efac; }
    .btn-default { background: rgba(255,255,255,0.08); color: #e2e8f0; }
    .btn-default:hover { background: rgba(255,255,255,0.12); }
    .help-text { font-size: 12px; color: #64748b; margin-top: 2px; }
  </style>
</head>
<body class="smartolt-site">
<script>$(document).ready(function() {
  $('#test-connection').click(function() {
    var ip = $('#olt-ip').val();
    var port = $('#olt-port').val() || 23;
    var user = $('#olt-user').val() || 'zte';
    var pass = $('#olt-pass').val() || 'zte';
    var btn = $(this);
    btn.text('Testing...').prop('disabled', true);
    $('#test-result').removeClass('text-success text-danger').addClass('text-muted').html('<i class="fa fa-spinner fa-spin"></i> Connecting via Telnet...');
    $.post('/api/olt/test-connection', { ip: ip, port: port, username: user, password: pass })
      .done(function(r) {
        if (r.success) {
          $('#test-result').removeClass('text-muted text-danger').addClass('text-success').html('<i class="fa fa-check-circle"></i> ' + (r.message || 'Connected!'));
          if (r.output) $('#test-result').append('<br><small class="text-muted" style="font-size:11px;">' + r.output.replace(/</g,'&lt;').substring(0,200) + '</small>');
        } else {
          $('#test-result').removeClass('text-muted text-success').addClass('text-danger').html('<i class="fa fa-times-circle"></i> ' + (r.message || 'Connection failed'));
        }
      })
      .fail(function() { $('#test-result').removeClass('text-muted text-success').addClass('text-danger').html('<i class="fa fa-times-circle"></i> Connection error'); })
      .always(function() { btn.html('<i class="fa fa-plug"></i> Test connection').prop('disabled', false); });
  });
  $('#save-olt').click(function() {
    var data = {
      nombre: $('#olt-name').val(), olt_ip: $('#olt-ip').val(), olt_port: parseInt($('#olt-port').val()) || 23,
      olt_username: $('#olt-user').val() || 'zte', olt_password: $('#olt-pass').val() || 'zte',
      modelo: $('#olt-model').val(), snmp_community: 'public', snmp_port: parseInt($('#snmp-port').val()) || 161,
      socks_host: '10.50.255.245', socks_port: 1080
    };
    if (!data.nombre || !data.olt_ip) { toast('❌ Name and IP required'); return; }
    $.post('/api/olt/save', data).done(function(r) {
      if (r.success) { toast('✅ OLT saved!'); setTimeout(function() { window.location.href = '/modulo?pagina=smartolt_olt'; }, 1000); }
      else toast('❌ ' + (r.message || 'Error'));
    }).fail(function() { toast('❌ Save failed'); });
  });
});</script>

<div class="smartolt-landing-hero-bg" aria-hidden="true"></div>
<div id="content-wrapper">
  <div class="navbar navbar-default navbar-fixed-top default-menu">
    <div class="container">
