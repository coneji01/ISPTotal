  </div>

  <div class="container">
    <h2>Add OLT</h2>
    <a href="/modulo?pagina=smartolt_olt" class="btn btn-success margin-bottom">Back to OLTs list</a>
    
    <div class="row">
      <div class="col-md-6">
        <div class="form-group">
          <label>Name</label>
          <input id="olt-name" placeholder="e.g. C300 Produccion">
        </div>
        <div class="form-group">
          <label>OLT IP or FQDN</label>
          <input id="olt-ip" placeholder="192.168.20.80">
        </div>
        <div class="form-group">
          <label>Telnet TCP port</label>
          <input id="olt-port" value="23">
        </div>
        <div class="form-group">
          <label>OLT telnet username</label>
          <input id="olt-user" placeholder="e.g. zte">
        </div>
        <div class="form-group">
          <label>OLT telnet password</label>
          <input id="olt-pass" type="password" placeholder="e.g. zte">
        </div>
      </div>
      <div class="col-md-6">
        <div class="form-group">
          <label>OLT hardware version</label>
          <select id="olt-model">
            <option value="ZTE-C300">ZTE-C300</option>
            <option value="ZTE-C320">ZTE-C320</option>
            <option value="ZTE-C600">ZTE-C600</option>
            <option value="Huawei-MA5600T">Huawei-MA5600T</option>
            <option value="Huawei-MA5800-X2">Huawei-MA5800-X2</option>
            <option value="Huawei-EA5800-X15">Huawei-EA5800-X15</option>
          </select>
        </div>
        <div class="form-group">
          <label>SNMP UDP port</label>
          <input id="snmp-port" value="161">
        </div>
        <div class="form-group">
          <label>SNMP community</label>
          <input id="snmp-community" value="public">
          <span class="help-text">Will be automatically created on the OLT</span>
        </div>
        <div class="form-group">
          <label>Supported PON types</label>
          <select>
            <option>GPON (GPON, XGPON, XGSPON)</option>
            <option>EPON (EPON, 10G-EPON)</option>
            <option>GPON+EPON</option>
          </select>
        </div>
        <div class="form-group" style="margin-top: 25px;">
          <button id="save-olt" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
          <a href="/modulo?pagina=smartolt_olt" class="btn btn-default">Cancel</a>
          <button id="test-connection" class="btn btn-default"><i class="fa fa-plug"></i> Test connection</button>
          <div id="test-result" style="margin-top:10px; font-size:13px;"></div>
        </div>
      </div>
    </div>
  </div>
</div>
<footer><div class="text-center">ISPTotal GPON v1.0</div></footer>
