                                    <br>Loading ONUs...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination bottom -->
                <div class="row">
                    <ul class="pagination" id="pagination-bottom"></ul>
                </div>
            </div>
        </div>

        <!-- Import Modal -->
        <div class="modal fade" id="importOnusDetailsModal" tabindex="-1" role="dialog">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <h3>Import ONUs location details</h3>
                    </div>
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="onusCsvFile">ONUs details file</label>
                            <input type="file" name="onusCsvFile" id="onusCsvFile">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-link" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary import-onus-details-button">Import</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Confirm Modal -->
        <div class="modal fade" id="confirmModal" tabindex="-1" role="dialog">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <h4 class="modal-title">Confirm Action</h4>
                    </div>
                    <div class="modal-body" id="confirm-modal-body">
                        Are you sure you want to proceed?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="confirm-action-btn">Confirm</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <div class="text-center">ISPTotal &copy; 2026</div>
    </footer>

    <!-- Bootstrap Core JS -->
    <script src="/js/bootstrap.min.js"></script>
    <script src="/js/bootstrap-multiselect.js"></script>
    
    <!-- Loading overlay -->
    <script src="/js/loadingoverlay.custom.js"></script>
    
    <!-- Message box -->
    <script src="/js/messagebox.min.js"></script>

    <script>
    $(document).ready(function() {
        $.ajaxSetup({ cache: false });
        
        // Config
        var config = { X_TOKEN: '<%= token || "" %>' };
        
        // Form data
        var form_data = {
            page: 1,
            free_text: "",
            olt_id: "",
            zone_id: "",
            odb_id: "",
            status: "",
            signal: "",
            onu_type_id: "",
            speed_profile_id: "",
            pon_type: "",
            onu_mode: "",
            router_mode: "",
            sort_by: "id",
            sort_order: "desc"
        };
        
        var update_needed = {};
        var totalPages = 1;
        var currentPage = 1;
        var perPage = 100;
        var batchOnuSelection = {
            enabled: false,
            allMatching: true,
            selectedIds: {},
            excludedIds: {}
        };
        
        // Toast function
        function toast(message, type) {
            type = type || 'success';
            var $toast = $('<div class="toast toast-' + type + '">' + message + '</div>');
            $('body').append($toast);
            setTimeout(function() { $toast.fadeOut(function() { $(this).remove(); }); }, 3000);
        }
        
        // Loading overlay
        function showLoadingOverlay(text) {
            text = text || 'Working...';
            $('#waitingOLT').text(text);
            $('.loadingoverlay').css('display', 'flex');
        }
        
        function hideLoadingOverlay() {
            $('.loadingoverlay').css('display', 'none');
        }
        
        // Night mode toggle
        $('#smartolt-night-toggle').click(function(e) {
            e.preventDefault();
            var $html = $('html');
            var isNight = $html.hasClass('smartolt-night');
            var $toggle = $(this);
            
            if ($toggle.hasClass('is-pref-system')) {
                // system -> night
                $html.addClass('smartolt-night');
                $toggle.removeClass('is-pref-system').addClass('is-pref-night');
                try { localStorage.setItem('smartolt-theme-local', 'night'); } catch(e) {}
            } else if ($toggle.hasClass('is-pref-night')) {
                // night -> light
                $html.removeClass('smartolt-night');
                $toggle.removeClass('is-pref-night').addClass('is-pref-light');
                try { localStorage.setItem('smartolt-theme-local', 'light'); } catch(e) {}
            } else {
                // light -> system
                var prefersDark = !!(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
                if (prefersDark) { $html.addClass('smartolt-night'); } else { $html.removeClass('smartolt-night'); }
                $toggle.removeClass('is-pref-light').addClass('is-pref-system');
                try { localStorage.setItem('smartolt-theme-local', 'system'); } catch(e) {}
            }
            try { localStorage.setItem('smartolt-night', $html.hasClass('smartolt-night') ? '1' : '0'); } catch(e) {}
        });
        
        // Fetch ONU data from API
        function fetchOnus(callback) {
            showLoadingOverlay('Loading ONUs...');
            
            var params = $.extend({}, form_data, {
                page: currentPage,
                per_page: perPage
            });
            
            // Clean empty params
            Object.keys(params).forEach(function(k) {
                if (params[k] === '' || params[k] === null || typeof params[k] === 'undefined') {
                    delete params[k];
                }
            });
            
            $.ajax({
                type: 'GET',
                url: '/api/gpon/onus',
                data: params,
                dataType: 'json',
                beforeSend: function(request) {
                    if (config.X_TOKEN) request.setRequestHeader("X-Token", config.X_TOKEN);
                },
                success: function(data) {
                    hideLoadingOverlay();
                    if (callback) callback(data);
                },
                error: function(jqXHR) {
                    hideLoadingOverlay();
                    var msg = 'Error loading ONUs';
                    if (jqXHR.responseJSON && jqXHR.responseJSON.error) msg = jqXHR.responseJSON.error;
                    toast(msg, 'error');
                    if (callback) callback({ state: [], unconfigured: [], db_onus: [] });
                }
            });
        }
        
        // Render ONU table
        function renderOnuTable(data) {
            var state = data.state || [];
            var db_onus = data.db_onus || [];
            
            // Build lookup maps
            var dbMap = {};
            db_onus.forEach(function(db) {
                dbMap[db.sn] = db;
            });
            
            // Build combined rows
            var rows = [];
            var seenSN = {};
            
            // From OLT state
            state.forEach(function(s) {
                var sn = s.sn || '';
                var onuId = s.onuId || '';
                var key = sn || onuId || Math.random().toString();
                if (seenSN[key]) return;
                seenSN[key] = true;
                
                var db = sn ? (dbMap[sn] || {}) : {};
                rows.push({
                    sn: sn,
                    name: db.nombre || db.name || s.name || (onuId || 'ONU ' + (rows.length + 1)),
                    cliente_id: db.cliente_id || '',
                    location: db.location || s.zone || 'default',
                    odb: db.odb || 'None',
                    speed_profile: db.speed_profile || db['Speed Profile'] || '',
                    model: db.model || db['Model'] || '',
                    auth_date: db.created_at || s.authDate || '',
                    status: s.state || 'offline',
                    port: s.port || '',
                    onuId: onuId,
                    db_id: db.id || null
                });
            });
            
            // From DB only (not on OLT state)
            db_onus.forEach(function(db) {
                var sn = db.sn || '';
                if (seenSN[sn]) return;
                seenSN[sn] = true;
                rows.push({
                    sn: sn,
                    name: db.nombre || db.name || sn,
                    cliente_id: db.cliente_id || '',
                    location: db.location || 'default',
                    odb: db.odb || 'None',
                    speed_profile: db.speed_profile || '',
                    model: db.model || '',
                    auth_date: db.created_at || '',
                    status: 'offline',
                    port: '',
                    onuId: '',
                    db_id: db.id || null
                });
            });
            
            // Apply search filter
            if (form_data.free_text) {
                var ft = form_data.free_text.toLowerCase();
                rows = rows.filter(function(r) {
                    return (r.sn && r.sn.toLowerCase().indexOf(ft) !== -1) ||
                           (r.name && r.name.toLowerCase().indexOf(ft) !== -1) ||
                           (r.location && r.location.toLowerCase().indexOf(ft) !== -1);
                });
            }
            
            // Apply status filter
            if (form_data.status) {
                rows = rows.filter(function(r) { return r.status === form_data.status; });
            }
            
            totalPages = Math.max(1, Math.ceil(rows.length / perPage));
            if (currentPage > totalPages) currentPage = totalPages;
            
            var start = (currentPage - 1) * perPage;
            var pageRows = rows.slice(start, start + perPage);
            
            var $tbody = $('#onu-table-body');
            $tbody.empty();
            
            if (pageRows.length === 0) {
                $tbody.append('<tr><td colspan="9" class="text-center text-muted">No ONUs found</td></tr>');
            } else {
                pageRows.forEach(function(r) {
                    var statusIcon = getStatusIcon(r.status);
                    var statusClass = getStatusClass(r.status);
                    var dbId = r.db_id || '';
                    var tr = '<tr class="valign-center">';
                    tr += '<td class="batch-onu-select-col text-center"><input type="checkbox" class="batch-onu-checkbox" value="' + r.sn + '"></td>';
                    tr += '<td class="text-center"><span class="' + statusClass + '">' + statusIcon + '</span></td>';
                    tr += '<td>' + escapeHtml(r.name) + '</td>';
                    tr += '<td><code>' + escapeHtml(r.sn) + '</code></td>';
                    tr += '<td>' + escapeHtml(r.location) + '</td>';
                    tr += '<td>' + escapeHtml(r.odb) + '</td>';
                    tr += '<td>' + (r.speed_profile ? '<span class="speed-badge">' + escapeHtml(r.speed_profile) + '</span>' : '<span class="text-muted">-</span>') + '</td>';
                    tr += '<td>' + (r.model ? escapeHtml(r.model) : '<span class="text-muted">-</span>') + '</td>';
                    tr += '<td class="auth-date">' + (r.auth_date ? formatDate(r.auth_date) : '-') + '</td>';
                    tr += '</tr>';
                    $tbody.append(tr);
                });
            }
            
            // Update count
            $('#display-count').text(rows.length + ' ONUs displayed');
            $('#total-onus-count').val(rows.length);
            
            // Render pagination
            renderPagination();
            
            // Update batch count
            updateBatchCount();
        }
        
        function getStatusIcon(status) {
            switch(status) {
                case 'online': return '<i class="fa fa-globe text-green"></i>';
                case 'pwrfail': return '<i class="fa fa-plug text-grey"></i>';
                case 'los': return '<i class="fa fa-chain-broken text-red"></i>';
                case 'offline': return '<i class="fa fa-globe text-grey"></i>';
                case 'disabled': return '<i class="fa fa-ban text-grey"></i>';
                default: return '<i class="fa fa-question-circle text-grey"></i>';
            }
        }
        
        function getStatusClass(status) {
            switch(status) {
                case 'online': return 'status-online';
                case 'pwrfail': return 'status-pwrfail';
                case 'los': return 'status-los';
                case 'offline': return 'status-offline';
                case 'disabled': return 'status-disabled';
                default: return 'status-unknown';
            }
        }
        
        function escapeHtml(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }
        
        function formatDate(dateStr) {
            if (!dateStr) return '-';
            try {
                var d = new Date(dateStr);
                if (isNaN(d.getTime())) return dateStr;
                var day = ('0' + d.getDate()).slice(-2);
                var month = ('0' + (d.getMonth() + 1)).slice(-2);
                var year = d.getFullYear();
                return day + '-' + month + '-' + year;
            } catch(e) { return dateStr; }
        }
        
        function renderPagination() {
            var html = '';
            if (currentPage > 1) {
                html += '<li><a href="#" data-page="1">&laquo;</a></li>';
                html += '<li><a href="#" data-page="' + (currentPage - 1) + '">&lsaquo;</a></li>';
            }
            for (var i = 1; i <= totalPages; i++) {
                if (i === currentPage) {
                    html += '<li class="active"><a href="#">' + i + '</a></li>';
                } else if (i <= 3 || i > totalPages - 3 || Math.abs(i - currentPage) <= 1) {
                    html += '<li><a href="#" data-page="' + i + '">' + i + '</a></li>';
                } else if (i === 4 && currentPage > 5) {
                    html += '<li><a href="#">...</a></li>';
                } else if (i === totalPages - 3 && currentPage < totalPages - 4) {
                    html += '<li><a href="#">...</a></li>';
                }
            }
            if (currentPage < totalPages) {
                html += '<li><a href="#" data-page="' + (currentPage + 1) + '">&rsaquo;</a></li>';
                html += '<li><a href="#" data-page="' + totalPages + '">&raquo;</a></li>';
            }
            $('#pagination-top').html(html);
            $('#pagination-bottom').html(html);
        }
        
        // Refresh configured data
        function refreshConfiguredData() {
            fetchOnus(function(data) {
                renderOnuTable(data);
            });
        }
        
        // Load dynamic select options
        function dynamicSelectLoad(selectName, hasValue, onChangeFunc) {
            var $select = $('#' + selectName);
            if (!$select.length) return;
            
            var apiMap = {
                'olt': '/api/gpon/olts',
                'location': '/api/gpon/locations',
                'odb': '/api/gpon/odbs',
                'onuType': '/api/gpon/onu_types',
                'speedProfile': '/api/gpon/speed_profiles',
                'ponType': '/api/gpon/pon_types'
            };
            
            var url = apiMap[selectName];
            if (!url) return;
            
            $.ajax({
                type: 'GET',
                url: url,
                dataType: 'json',
                beforeSend: function(request) {
                    if (config.X_TOKEN) request.setRequestHeader("X-Token", config.X_TOKEN);
                },
                success: function(data) {
                    var options = data.response || data.data || data || [];
                    $select.empty();
                    
                    // For multiselect, we need to handle differently vs single select
                    if ($select.attr('multiple')) {
                        $.each(options, function(k, v) {
                            var id = v.id || v.option_id || k;
                            var name = v.name || v.label || v.option_name || v;
                            $select.append($('<option>').val(id).text(name));
                        });
                        
                        try {
                            $select.multiselect('rebuild');
                            if (hasValue) $select.multiselect('refresh');
                        } catch(e) {
                            // bootstrap-multiselect not loaded
                        }
                    } else {
                        $select.append('<option value="">Any</option>');
                        $.each(options, function(k, v) {
                            var id = v.id || v.option_id || k;
                            var name = v.name || v.label || v.option_name || v;
                            $select.append($('<option>').val(id).text(name));
                        });
                    }
                    
                    update_needed[selectName] = false;
                }
            });
        }
        
        // Initialize multiselects
        function initMultiselects() {
            var multiselectOptions = {
                buttonClass: '',
                inheritClass: true,
                enableCaseInsensitiveFiltering: true,
                buttonContainer: '<div class="btn-group full-width"/>',
                nonSelectedText: 'Any',
                filterPlaceholder: 'Search',
                includeSelectAllOption: false,
                maxHeight: 500,
                templates: {
                    button: '<div class="multiselect dropdown-toggle" data-toggle="dropdown" style="padding-right: 18px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><span class="multiselect-selected-text"></span> <span class="caret" style="position: absolute; right: 6px; top: 50%; margin-top: -2px;" aria-hidden="true"></span></div>',
                    li: '<li><a href="#" tabindex="0"><label></label></a></li>',
                }
            };
            
            try {
                $('#olt').multiselect(multiselectOptions);
                $('#location').multiselect(multiselectOptions);
                $('#odb').multiselect(multiselectOptions);
                $('#onuType').multiselect(multiselectOptions);
                $('#speedProfile').multiselect(multiselectOptions);
                $('#ponType').multiselect(multiselectOptions);
            } catch(e) {
                console.log('Multiselect init error (may not be loaded):', e);
            }
        }
        
        // Status filter click
        $(document).on('click', '.status-filter, .signal-filter', function() {
            var $li = $(this);
            var type = $li.hasClass('status-filter') ? 'status' : 'signal';
            $li.toggleClass('active');
            
            var selected = [];
            $('.' + type + '-filter.active').each(function() {
                selected.push($(this).attr('value'));
            });
            
            form_data[type] = selected.join(',');
            form_data.page = 1;
            refreshConfiguredData();
        });
        
        // ONU mode filter
        $(document).on('click', '.onu_mode-filter', function() {
            var $li = $(this);
            $li.toggleClass('active');
            
            var selected = [];
            $('.onu_mode-filter.active').each(function() {
                selected.push($(this).attr('value'));
            });
            
            form_data.onu_mode = selected.join(',');
            form_data.page = 1;
            refreshConfiguredData();
        });
        
        // Search input
        var searchTimer;
        $('#free_text').on('input', function() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function() {
                form_data.free_text = $('#free_text').val();
                form_data.page = 1;
                refreshConfiguredData();
            }, 500);
        });
        
        // Pagination click
        $(document).on('click', '#pagination-top a, #pagination-bottom a', function(e) {
            e.preventDefault();
            var page = parseInt($(this).data('page'));
            if (page && page !== currentPage) {
                currentPage = page;
                refreshConfiguredData();
            }
        });
        
        // More filters toggle
        $('#more-filters-toggle').click(function(e) {
            e.preventDefault();
            var $section = $('#more-filters-section');
            var isVisible = $section.is(':visible');
            $section.toggle();
            $(this).html(isVisible ? '<i class="fa fa-chevron-down"></i> More filters' : '<i class="fa fa-chevron-up"></i> Less filters');
        });
        
        // Batch actions toggle
        $('#batch-actions-toggle').click(function() {
            $('#batch-actions-container').toggle();
        });
        
        // Select all checkbox
        $(document).on('change', '#batch-select-all-onus', function() {
            var checked = $(this).is(':checked');
            $('.batch-onu-checkbox').prop('checked', checked);
            
            if (checked) {
                batchOnuSelection.allMatching = true;
                batchOnuSelection.selectedIds = {};
                batchOnuSelection.excludedIds = {};
            } else {
                batchOnuSelection.allMatching = false;
                batchOnuSelection.selectedIds = {};
                batchOnuSelection.excludedIds = {};
            }
            updateBatchCount();
        });
        
        // Individual checkbox
        $(document).on('change', '.batch-onu-checkbox', function() {
            var sn = $(this).val();
            if ($(this).is(':checked')) {
                batchOnuSelection.selectedIds[sn] = true;
                delete batchOnuSelection.excludedIds[sn];
            } else {
                delete batchOnuSelection.selectedIds[sn];
                batchOnuSelection.excludedIds[sn] = true;
                batchOnuSelection.allMatching = false;
            }
            updateBatchCount();
        });
        
        function updateBatchCount() {
            var count = Object.keys(batchOnuSelection.selectedIds).length;
            if (count === 0 && batchOnuSelection.allMatching) {
                count = parseInt($('#total-onus-count').val() || 0);
            }
            $('#batch-actions-count').text(count + ' ONU(s)');
        }
        
        // Action buttons
        function executeAction(action) {
            var selectedOnus = [];
            $('.batch-onu-checkbox:checked').each(function() {
                selectedOnus.push($(this).val());
            });
            
            if (selectedOnus.length === 0) {
                toast('Please select at least one ONU', 'error');
                return;
            }
            
            showLoadingOverlay('Executing ' + action + '...');
            
            $.ajax({
                type: 'POST',
                url: '/api/gpon/onus/action',
                data: {
                    action: action,
                    onus: selectedOnus
                },
                dataType: 'json',
                beforeSend: function(request) {
                    if (config.X_TOKEN) request.setRequestHeader("X-Token", config.X_TOKEN);
                },
                success: function(data) {
                    hideLoadingOverlay();
                    if (data.success) {
                        toast(data.message || action + ' completed successfully');
                        refreshConfiguredData();
                    } else {
                        toast(data.error || 'Action failed', 'error');
                    }
                },
                error: function() {
                    hideLoadingOverlay();
                    toast('Error executing action', 'error');
                }
            });
        }
        
        // Action button handlers
        $('#move-selected-btn').click(function() { executeAction('move'); });
        $('#admin-reboot-btn').click(function() { executeAction('reboot'); });
        $('#factory-reset-btn').click(function() { executeAction('factory_reset'); });
        $('#resync-btn').click(function() { executeAction('resync'); });
        $('#diagnostics-btn').click(function() { executeAction('diagnostics'); });
        $('#delete-btn').click(function() { executeAction('delete'); });
        
        // Batch action links
        $(document).on('click', '.batch-action-btn', function(e) {
            e.preventDefault();
            var action = $(this).data('action');
            // Trigger the corresponding button
            switch(action) {
                case 'move': $('#move-selected-btn').click(); break;
                case 'reboot': $('#admin-reboot-btn').click(); break;
                case 'factory_reset': $('#factory-reset-btn').click(); break;
                case 'resync': $('#resync-btn').click(); break;
                case 'diagnostics': $('#diagnostics-btn').click(); break;
                case 'delete': $('#delete-btn').click(); break;
            }
        });
        
        // Filter multiselect change handling
        $(document).on('change', '#olt', function() {
            var val = $(this).val() || [];
            form_data.olt_id = Array.isArray(val) ? val.join(',') : val;
            form_data.page = 1;
            refreshConfiguredData();
        });
        
        $(document).on('change', '#location', function() {
            var val = $(this).val() || [];
            form_data.zone_id = Array.isArray(val) ? val.join(',') : val;
            form_data.page = 1;
            refreshConfiguredData();
        });
        
        $(document).on('change', '#odb', function() {
            var val = $(this).val() || [];
            form_data.odb_id = Array.isArray(val) ? val.join(',') : val;
            form_data.page = 1;
            refreshConfiguredData();
        });
        
        $(document).on('change', '#routerMode', function() {
            form_data.router_mode = $(this).val();
            form_data.page = 1;
            refreshConfiguredData();
        });
        
        // Initialize
        function init() {
            initMultiselects();
            
            // Load dynamic selects
            setTimeout(function() {
                dynamicSelectLoad('olt', false, 'refreshConfiguredData');
                dynamicSelectLoad('location', false, 'refreshConfiguredData');
                dynamicSelectLoad('odb', false, 'refreshConfiguredData');
                dynamicSelectLoad('onuType', false, 'refreshConfiguredData');
                dynamicSelectLoad('speedProfile', false, 'refreshConfiguredData');
            }, 100);
            
            // Initial data load
            refreshConfiguredData();
        }
        
        init();
    });
    </script>

    <!-- Loading overlay -->
    <div class="loadingoverlay">
        <div class="loadingoverlay_fontawesome fa fa-spinner fa-spin"></div>
        <div id="waitingOLT" style="font-size: 50px; white-space: nowrap;">Loading ONUs...</div>
    </div>
</body>
</html>