                    </span>
                </div>

                <!-- Table -->
                <div class="table-responsive-wrap">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th class="batch-onu-select-col text-center">
                                    <input type="checkbox" id="batch-select-all-onus" title="Select All">
                                </th>
                                <th class="text-center">Status</th>
                                <th>Name</th>
                                <th>SN</th>
                                <th>Location</th>
                                <th>ODB</th>
                                <th>Speed Profile</th>
                                <th>Model</th>
                                <th>Auth Date</th>
                            </tr>
                        </thead>
                        <tbody id="onu-table-body">
                            <tr>
                                <td colspan="9" class="text-center text-muted">
