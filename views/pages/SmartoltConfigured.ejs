    <!-- Page Content -->
    <div class="container" style="padding-top: 70px;">
        <div class="content-wrap">
            <h2><i class="fa fa-check-circle text-success"></i> Configured ONUs</h2>
            
            <!-- Filters Form -->
            <form class="form-inline configured" onsubmit="return false;">
                <div class="filters-row margin-bottom">
                    <div class="form-group">
                        <label class="control-label" for="free_text">Search</label>
                        <input type="text" class="form-control input-190 input-search" id="free_text" name="free_text" placeholder="SN, name, address..." title="Search by SN, name, address">
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="olt">OLT</label>
                        <select name="olt_id" id="olt" class="form-control input-150 select-search" multiple="multiple"></select>
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="location">Location</label>
                        <select name="zone_id" id="location" class="form-control input-120 select-search" multiple="multiple"></select>
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="odb">ODB</label>
                        <select name="odb_id" id="odb" class="form-control input-120 select-search" multiple="multiple"></select>
                    </div>
                    <div class="form-group pon-type-filter">
                        <label class="control-label">Status</label>
                        <ul class="pagination">
                            <li class="status-filter" value="online" title="Online"><span><i class="fa fa-globe text-green"></i></span></li>
                            <li class="status-filter" value="pwrfail" title="Power Fail"><span><i class="fa fa-plug text-grey"></i></span></li>
                            <li class="status-filter" value="los" title="Loss of Signal"><span><i class="fa fa-chain-broken text-red"></i></span></li>
                            <li class="status-filter" value="offline" title="Offline"><span><i class="fa fa-globe text-grey"></i></span></li>
                            <li class="status-filter" value="disabled" title="Admin Disabled"><span><i class="fa fa-ban text-grey"></i></span></li>
                        </ul>
                    </div>
                    <div class="form-group">
                        <a href="#" id="batch-actions-toggle" class="text-success" title="Batch actions" style="font-size: 24px; line-height: 34px;">
                            <i class="fa fa-tasks"></i>
                        </a>
                    </div>
                </div>

                <!-- More Filters Toggle -->
                <div class="more-filters-toggle-row">
                    <a href="#" id="more-filters-toggle"><i class="fa fa-chevron-down"></i> More filters</a>
                </div>

                <div id="more-filters-section" class="filters-row more-filters-panel" style="display: none;">
                    <div class="form-group">
                        <label class="control-label" for="onuType">ONU type</label>
                        <select name="onu_type_id" id="onuType" class="form-control input-120 select-search" multiple="multiple"></select>
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="speedProfile">Speed Profile</label>
                        <select name="speed_profile_id" id="speedProfile" class="form-control input-120 select-search" multiple="multiple"></select>
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="ponType">PON type</label>
                        <select name="pon_type" id="ponType" class="form-control input-90 select-search" multiple="multiple"></select>
                    </div>
                    <div class="form-group pon-type-filter">
                        <label class="control-label">Signal</label>
                        <ul class="pagination">
                            <li class="signal-filter" value="good" title="Good"><span><i class="fa fa-signal text-green"></i></span></li>
                            <li class="signal-filter" value="warning" title="Warning"><span><i class="fa fa-signal" style="color:darkorange;"></i></span></li>
                            <li class="signal-filter" value="critical" title="Critical"><span><i class="fa fa-signal" style="color:red;"></i></span></li>
                        </ul>
                    </div>
                    <div class="form-group pon-type-filter">
                        <ul class="pagination">
                            <li class="onu_mode-filter" value="bridging" title="Bridging"><span>B</span></li>
                            <li class="onu_mode-filter" value="routing" title="Routing"><span>R</span></li>
                        </ul>
                    </div>
                    <div class="form-group">
                        <label class="control-label" for="routerMode">WAN mode</label>
                        <select name="router_mode" id="routerMode" class="form-control input-120 select-search">
                            <option value="">Any</option>
                            <option value="DHCP">DHCP</option>
                            <option value="Static">Static</option>
                            <option value="PPPoE">PPPoE</option>
                        </select>
                    </div>
                </div>
            </form>

            <!-- Batch Actions Panel -->
            <div id="batch-actions-container" style="display: none;">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <strong>
                                <a class="accordion-toggle" data-toggle="collapse" href="#batchActionsList">
                                    <i class="fa fa-tasks text-success"></i> Batch Actions
                                </a>
                            </strong>
                        </h4>
                    </div>
                    <div id="batchActionsList" class="panel-collapse collapse in">
                        <div class="panel-body">
                            <p class="margin-bottom">
                                <span>
                                    <i class="fa fa-info-circle"></i>
                                    Select ONUs using the filters above, then choose an action.
                                    <span id="batch-actions-count" class="badge badge-primary">0 ONU(s)</span>
                                </span>
                            </p>
                            
                            <!-- Action: Move Selected -->
                            <div class="batch-action-row">
                                <a href="#" class="batch-action-link batch-action-btn" data-action="move">
                                    <i class="fa fa-arrows text-success"></i> Move Selected
                                </a>
                            </div>
                            
                            <!-- Action: Admin Reboot -->
                            <div class="batch-action-row">
                                <a href="#" class="batch-action-link batch-action-btn" data-action="reboot">
                                    <i class="fa fa-power-off text-success"></i> Admin Reboot
                                </a>
                            </div>
                            
                            <!-- Action: Factory Reset -->
                            <div class="batch-action-row">
                                <a href="#" class="batch-action-link batch-action-btn" data-action="factory_reset">
                                    <i class="fa fa-undo text-warning"></i> Factory Reset
                                </a>
                            </div>
                            
                            <!-- Action: Resync -->
                            <div class="batch-action-row">
                                <a href="#" class="batch-action-link batch-action-btn" data-action="resync">
                                    <i class="fa fa-refresh text-success"></i> Resync
                                </a>
                            </div>
                            
                            <!-- Action: Diagnostics -->
                            <div class="batch-action-row">
                                <a href="#" class="batch-action-link batch-action-btn" data-action="diagnostics">
                                    <i class="fa fa-stethoscope text-success"></i> Diagnostics
                                </a>
                            </div>
                            
