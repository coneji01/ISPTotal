<!DOCTYPE html>
<html lang="en" class="">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<script>window.SMARTOLT_DB_THEME='system';</script>
<script>try{var k='smartolt-night',lk='smartolt-theme-local',dbTheme=window.SMARTOLT_DB_THEME,local=null,pref,n;try{local=localStorage.getItem(lk);}catch(e){}if(local==='night'||local==='light'||local==='system'){pref=local;}else if(dbTheme==='night'||dbTheme==='light'||dbTheme==='system'){pref=dbTheme;}else{pref='system';}if(pref==='system'){n=!!(window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches);}else if(pref==='night'){n=true;}else{n=false;}try{localStorage.setItem(k,n?'1':'0');}catch(e){}if(n){document.documentElement.classList.add('smartolt-night');}else{document.documentElement.classList.remove('smartolt-night');}document.cookie=k+'='+(n?'1':'0')+'; path=/; max-age=31536000; SameSite=Lax'+(location.protocol==='https:'?'; Secure':'');}catch(e){}</script>
<meta http-equiv="content-type" content="text/html; utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ONUs Configuradas | GPON Manager</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css">
<style>
body { font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif; -webkit-font-smoothing: antialiased; background: #fafbfd; }
html.smartolt-night body { background: #06162f; color: #e2e8f0; }
.navbar-default { background: #fff !important; border-bottom: 1px solid #eef2f6 !important; }
html.smartolt-night .navbar-default { background: rgba(6,22,47,0.82) !important; border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
html.smartolt-night .navbar-default .navbar-brand, html.smartolt-night .navbar-default .nav > li > a { color: rgba(255,255,255,0.9) !important; }
html.smartolt-night .navbar-default .nav > li > a:hover { background: rgba(255,255,255,0.08) !important; color: #fff !important; }
.navbar-brand { font-weight: 700; }
.container { padding-top: 70px; padding-bottom: 40px; }
.panel { background: #fff; border: 1px solid #eef2f6; border-radius: 10px; box-shadow: 0 1px 2px rgba(15,23,42,0.03), 0 4px 14px rgba(15,23,42,0.04); }
html.smartolt-night .panel { background: rgba(15,26,46,0.92); border: 1px solid rgba(255,255,255,0.1); color: #e2e8f0; }
.panel-heading { background: #4c4b4b !important; color: #fff !important; border-radius: 10px 10px 0 0 !important; border: none !important; font-weight: 600; }
html.smartolt-night .panel-heading { background: rgba(255,255,255,0.08) !important; }
.panel-body { padding: 16px 20px; }
html.smartolt-night .panel-body, html.smartolt-night .table, html.smartolt-night .table > tbody > tr > td, html.smartolt-night .table > thead > tr > th { background: transparent !important; color: #e2e8f0; }
html.smartolt-night .table > tbody > tr:hover { background: rgba(255,255,255,0.04) !important; }
html.smartolt-night .table > thead > tr > th { border-color: rgba(255,255,255,0.1); }
.table { font-size: 12px; margin-bottom: 0; }
.table > thead > tr > th { border-bottom: 2px solid #eef2f6; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; padding: 10px 8px; }
.table > tbody > tr > td { border-color: #f1f5f9; vertical-align: middle; padding: 10px 8px; }
html.smartolt-night .table > tbody > tr > td { border-color: rgba(255,255,255,0.06); }
html.smartolt-night .text-muted { color: #94a3b8 !important; }
.form-control { border: 1px solid #d1d5db; border-radius: 6px; box-shadow: none; }
html.smartolt-night .form-control { background: #0f172a; border-color: #475569; color: #e2e8f0; }
.smartolt-landing-hero-bg { display: none; }
html.smartolt-night .smartolt-landing-hero-bg { display: block; position: fixed; z-index: -1; inset: 0; background: radial-gradient(circle at 72% 18%, rgba(29,139,255,0.24), transparent 28%), radial-gradient(circle at 18% 84%, rgba(0,108,255,0.18), transparent 28%), linear-gradient(135deg, #06162f, #071b3d 55%, #031022); pointer-events: none; }
#smartolt-night-toggle { align-items: center; display: flex; justify-content: center; }
#smartolt-night-toggle i { line-height: 1; width: 20px; text-align: center; }
#smartolt-night-toggle .smartolt-theme-icon-light, #smartolt-night-toggle .smartolt-theme-icon-night, #smartolt-night-toggle .smartolt-theme-icon-system { display: none; }
#smartolt-night-toggle.is-pref-light .smartolt-theme-icon-light, #smartolt-night-toggle.is-pref-night .smartolt-theme-icon-night, #smartolt-night-toggle.is-pref-system .smartolt-theme-icon-system { display: inline-block; }
.font-size-20 { font-size: 20px; }
.text-ellipsis { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.max-width-250 { max-width: 250px; }
.label { font-size: 10px; }
.btn-xs { padding: 2px 8px; font-size: 11px; }
html.smartolt-night .btn-default { background: #334155; color: #e2e8f0; border: none; }
html.smartolt-night .btn-default:hover { background: #475569; color: #fff; }
.filter-section { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.filter-section select, .filter-section input { width: auto; min-width: 120px; }
.pagination-info { font-size: 12px; color: #64748b; padding: 8px 0; }
</style>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>
</head>
<body>
<div class="smartolt-landing-hero-bg" aria-hidden="true"></div>
<div id="content-wrapper">
  <div class="navbar navbar-default navbar-fixed-top">
    <div class="container">
      <div class="navbar-header">
        <button class="navbar-toggle collapsed" type="button" data-toggle="collapse" data-target="#navbar-main">
          <span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span>
        </button>
        <a class="navbar-brand text-ellipsis max-width-250" href="/modulo?pagina=GPONManager">GPON Manager</a>
      </div>
      <div class="navbar-collapse collapse" id="navbar-main">
        <ul class="nav navbar-nav">
          <li><a href="/modulo?pagina=GPONManager">Dashboard</a></li>
          <li class="active"><a href="/modulo?pagina=SmartoltConfigured">ONUs Configuradas</a></li>
          <li><a href="/modulo?pagina=SmartoltUnconfigured">Sin Configurar</a></li>
          <li><a href="/modulo?pagina=SmartoltSpeedProfiles">Velocidad</a></li>
          <li><a href="/modulo?pagina=SmartoltOnuTypes">Tipos ONU</a></li>
          <li><a href="/modulo?pagina=SmartoltSettings">Config OLT</a></li>
        </ul>
        <ul class="nav navbar-nav navbar-right">
          <li><a href="#" id="smartolt-night-toggle" class="is-pref-night is-resolved" title="Night mode"><i class="fa fa-sun-o font-size-20 smartolt-theme-icon-light"></i><i class="fa fa-moon-o font-size-20 smartolt-theme-icon-night"></i><i class="fa fa-adjust font-size-20 smartolt-theme-icon-system"></i></a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="panel panel-default">
      <div class="panel-heading"><i class="fa fa-check-circle"></i> ONUs Configuradas</div>
      <div class="panel-body">
        <div class="filter-section">
          <input type="text" class="form-control" id="searchOnu" placeholder="Buscar nombre o SN..." style="min-width:200px;" onkeyup="filterOnus()">
          <select class="form-control" id="filterStatus" onchange="filterOnus()">
            <option value="">Todos los estados</option>
            <option value="online">Online</option>
            <option value="offline">Offline</option>
            <option value="pwrfail">Power Fail</option>
            <option value="los">Loss of Signal</option>
          </select>
          <select class="form-control" id="filterVlan" onchange="filterOnus()">
            <option value="">VLAN: Todas</option>
          </select>
          <button class="btn btn-primary btn-sm" onclick="syncOnus()"><i class="fa fa-refresh"></i> Sincronizar</button>
        </div>
        <div class="pagination-info" id="onuCount">Cargando...</div>
        <div class="table-responsive" style="max-height:calc(100vh - 280px);overflow-y:auto;">
          <table class="table table-hover" id="onuTable">
            <thead>
              <tr>
                <th style="width:40px;">Status</th>
                <th>Nombre / SN</th>
                <th>ONU</th>
                <th>Zona</th>
                <th>Se&ntilde;al</th>
                <th>Modo</th>
                <th>VLAN</th>
                <th>Tipo</th>
                <th style="width:80px;">Acci&oacute;n</th>
              </tr>
            </thead>
            <tbody id="onuBody">
              <tr><td colspan="9" class="text-center text-muted" style="padding:50px;"><i class="fa fa-spinner fa-spin fa-2x"></i><br>Cargando ONUs desde SmartOLT...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
var allOnus = [];

// Night mode toggle
(function() {
  var STORAGE_LOCAL = 'smartolt-theme-local';
  function applyTheme(pref) {
    var isNight = pref === 'night' ? true : (pref === 'light' ? false : (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches));
    var html = document.documentElement;
    if (isNight) html.classList.add('smartolt-night'); else html.classList.remove('smartolt-night');
    try { localStorage.setItem('smartolt-night', isNight ? '1' : '0'); } catch(e) {}
    var toggle = document.getElementById('smartolt-night-toggle');
    if (toggle) { toggle.classList.remove('is-pref-light','is-pref-night','is-pref-system'); toggle.classList.add('is-pref-' + pref); }
  }
  var localPref = (function(){ try { var s = localStorage.getItem(STORAGE_LOCAL); if(s==='night'||s==='light'||s==='system') return s; }catch(e){} return 'system'; })();
  applyTheme(localPref || (window.SMARTOLT_DB_THEME || 'system'));
  document.getElementById('smartolt-night-toggle').addEventListener('click', function(e) {
    e.preventDefault();
    var isNight = document.documentElement.classList.contains('smartolt-night');
    var newPref = isNight ? 'light' : 'night';
    try { localStorage.setItem(STORAGE_LOCAL, newPref); } catch(e) {}
    applyTheme(newPref);
  });
})();

function loadOnus() {
  $.get('/api/smartolt/onus', function(data) {
    if (data.success && data.onus) {
      allOnus = data.onus;
      // Collect VLANs for filter
      var vlans = {};
      allOnus.forEach(function(o) { if (o.vlan) vlans[o.vlan] = true; });
      var vlanSelect = $('#filterVlan');
      vlanSelect.html('<option value="">VLAN: Todas</option>');
      Object.keys(vlans).sort().forEach(function(v) { vlanSelect.append('<option value="' + v + '">' + v + '</option>'); });
      filterOnus();
    } else {
      $('#onuBody').html('<tr><td colspan="9" class="text-center text-danger">Error: ' + (data.msg || 'No data') + '</td></tr>');
      $('#onuCount').text('Error cargando ONUs');
    }
  }, 'json').fail(function() {
    // Fallback: mostrar datos mock para desarrollo
    showMockData();
  });
}

function showMockData() {
  var mockOnus = [];
  for (var i = 1; i <= 20; i++) {
    mockOnus.push({
      sn: 'HWTC' + (0xBEEF00 + i).toString(16).toUpperCase(),
      name: 'Cliente ' + i,
      description: '1 - JOEL WIFI gpon-onu_1/2/' + (i % 16 + 1) + ':' + i,
      zone_name: 'Zona ' + ((i % 3) + 1),
      signal: -(20 + (i % 10)),
      vlan: i % 2 === 0 ? '200' : '100',
      mode: i % 2 === 0 ? 'R: PPPoE' : 'Router',
      onu_type_name: ['F673AV9','EG8021V5','HS8545M5','GPON_ONUV7.1','HG8145X6-10'][i % 5],
      state: i % 3 === 0 ? 'pwrfail' : (i % 7 === 0 ? 'los' : 'working'),
      auth_date: '0' + (i % 28 + 1) + '-06-2026'
    });
  }
  allOnus = mockOnus;
  filterOnus();
}

function filterOnus() {
  var q = $('#searchOnu').val().toLowerCase().trim();
  var status = $('#filterStatus').val();
  var vlan = $('#filterVlan').val();
  
  var filtered = allOnus.filter(function(o) {
    if (q && !(o.name || '').toLowerCase().includes(q) && !(o.sn || '').toLowerCase().includes(q)) return false;
    if (status) {
      if (status === 'online' && o.state !== 'working' && o.state !== 'online') return false;
      if (status === 'offline' && (o.state === 'working' || o.state === 'online')) return false;
      if (status === 'pwrfail' && o.state !== 'pwrfail') return false;
      if (status === 'los' && o.state !== 'los') return false;
    }
    if (vlan && String(o.vlan) !== vlan) return false;
    return true;
  });
  
  $('#onuCount').text(filtered.length + ' ONUs de ' + allOnus.length + ' mostradas');
  
  if (filtered.length === 0) {
    $('#onuBody').html('<tr><td colspan="9" class="text-center text-muted" style="padding:30px;">No se encontraron ONUs con esos filtros</td></tr>');
    return;
  }
  
  var h = '';
  filtered.forEach(function(o) {
    var isOnline = o.state === 'working' || o.state === 'online';
    var isPwrfail = o.state === 'pwrfail';
    var isLos = o.state === 'los';
    var stateIcon, stateLabel, stateClass;
    if (isOnline) { stateIcon = 'fa-circle text-success'; stateLabel = 'Online'; stateClass = 'label-success'; }
    else if (isPwrfail) { stateIcon = 'fa-plug text-danger'; stateLabel = 'PwrFail'; stateClass = 'label-danger'; }
    else if (isLos) { stateIcon = 'fa-chain-broken text-warning'; stateLabel = 'LoS'; stateClass = 'label-warning'; }
    else { stateIcon = 'fa-circle text-muted'; stateLabel = 'Offline'; stateClass = 'label-default'; }
    
    var signalVal = parseFloat(o.signal);
    var signalClass = 'text-muted';
    if (signalVal < -25) signalClass = 'text-danger';
    else if (signalVal < -22) signalClass = 'text-warning';
    else signalClass = 'text-success';
    
    h += '<tr>';
    h += '<td><i class="fa ' + stateIcon + '" style="font-size:10px;" title="' + stateLabel + '"></i></td>';
    h += '<td><strong>' + escapeHtml(o.name || '--') + '</strong><br><small class="text-muted">' + escapeHtml(o.sn || '--') + '</small></td>';
    h += '<td><small>' + escapeHtml(o.description || '--') + '</small></td>';
    h += '<td><small>' + escapeHtml(o.zone_name || '-') + '</small></td>';
    h += '<td><span class="' + signalClass + '">' + (o.signal ? o.signal + ' dBm' : '--') + '</span></td>';
    h += '<td><small>' + escapeHtml(o.mode || o.wan_mode || '--') + '</small></td>';
    h += '<td><span class="label label-info">' + escapeHtml(o.vlan || '--') + '</span></td>';
    h += '<td><small>' + escapeHtml(o.onu_type_name || '--') + '</small></td>';
    h += '<td><button class="btn btn-xs btn-default" onclick="viewOnu(\'' + escapeHtml(o.sn || '') + '\')" title="Ver detalles"><i class="fa fa-eye"></i></button></td>';
    h += '</tr>';
  });
  $('#onuBody').html(h);
}

function viewOnu(sn) {
  if (!sn) return;
  window.location.href = '/modulo?pagina=GPONManager&action=onu&sn=' + encodeURIComponent(sn);
}

function syncOnus() {
  var btn = $(this);
  $('#onuBody').html('<tr><td colspan="9" class="text-center text-muted" style="padding:30px;"><i class="fa fa-spinner fa-spin"></i> Sincronizando con SmartOLT...</td></tr>');
  $.post('/api/smartolt/sync', function(data) {
    if (data.success) {
      loadOnus();
    } else {
      $('#onuBody').html('<tr><td colspan="9" class="text-center text-danger">Error: ' + (data.msg || 'Sync failed') + '</td></tr>');
    }
  }, 'json').fail(function() {
    // Si falla, cargar datos mock
    showMockData();
  });
}

function escapeHtml(s) { if (!s) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

$(document).ready(function() {
  loadOnus();
});
</script>
</body>
</html>
