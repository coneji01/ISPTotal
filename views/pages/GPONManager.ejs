  window.abortJqxhr = function() {
    for (var i = jqxhrs.length - 1; i >= 0; i--) { if (jqxhrs[i]) jqxhrs[i].abort(); }
    window.jqxhrs = [];
  };
  $(window).bind("beforeunload", function(event) { abortJqxhr(); });
  function unregisterJqxhr(event, jqxhr, settings) {
    var idx = $.inArray(jqxhr, jqxhrs);
    if (idx != -1) jqxhrs.splice(idx, 1);
  }
  $(document).ajaxComplete(unregisterJqxhr);
});
</script>

