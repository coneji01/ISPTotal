<script type="text/javascript">
// ===== NIGHT MODE TOGGLE (SmartOLT-style) =====
(function() {
  var STORAGE_KEY = 'smartolt-night';
  var STORAGE_LOCAL = 'smartolt-theme-local';
  var VALID = ['light', 'night', 'system'];

  function normalizePref(p) { return VALID.indexOf(p) !== -1 ? p : 'system'; }

  function getLocalOverride() {
    try {
      var stored = localStorage.getItem(STORAGE_LOCAL);
      if (stored === 'night' || stored === 'light' || stored === 'system') return stored;
    } catch(e) {}
    return null;
  }

  function setLocalOverride(pref) {
    pref = normalizePref(pref);
    try { localStorage.setItem(STORAGE_LOCAL, pref); } catch(e) {}
    applyTheme(pref);
  }

  function getDbTheme() {
    try { return window.SMARTOLT_DB_THEME || 'system'; } catch(e) { return 'system'; }
  }

  function applyTheme(pref) {
    var isNight;
    if (pref === 'night') isNight = true;
    else if (pref === 'light') isNight = false;
    else isNight = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;

    var html = document.documentElement;
    if (isNight) html.classList.add('smartolt-night');
    else html.classList.remove('smartolt-night');

    try { localStorage.setItem(STORAGE_KEY, isNight ? '1' : '0'); } catch(e) {}

    // Update toggle icon
    var toggle = document.getElementById('smartolt-night-toggle');
    if (toggle) {
      toggle.classList.remove('is-pref-light', 'is-pref-night', 'is-pref-system');
      toggle.classList.add('is-pref-' + pref);
    }
  }

  // Init
  var localPref = getLocalOverride();
  if (localPref) {
    applyTheme(localPref);
  } else {
    applyTheme(getDbTheme());
  }

  // Toggle handler
  document.getElementById('smartolt-night-toggle').addEventListener('click', function(e) {
    e.preventDefault();
    var html = document.documentElement;
    var isNight = html.classList.contains('smartolt-night');
    var newPref = isNight ? 'light' : 'night';
    setLocalOverride(newPref);
  });
})();

// ===== DATA LOADING =====
function loadGPONData() {
  var $status = $('#onus-status-list');
  var $online = $('.online');
  var $offline = $('.total-offline');
  var $totalOnus = $('.total-onus');
  var $totalAuth = $('.total-auth');
  var $lowSignal = $('.total-signal-low');
  var $pending = $('.auth-waiting-auth');
  var $pendingBadge = $('.disabled-waiting-auth');
  var $updatedDate = $('.updated-date');
  var $powerFail = $('.power-fail');
  var $los = $('.los');
  var $offlineNa = $('.offline');
  var $signalWarn = $('.signal-warning');
  var $signalCrit = $('.signal-critical');
  var $onlineBar = $('.online-bar');
  var $offlineBar = $('.offline-bar');
  var $pendingBar = $('.pending-bar');
  var $oltStatus = $('#olt-status');
  var $oltUpTime = $('#olt-up-time');
  var $oltOnuCount = $('#olt-onu-count');
  var $infoList = $('#info-list');
  var $moveWaitingAuth = $('.move-waiting-auth');

  $.ajax({
    type: 'GET',
    url: '/api/gpon/onus',
    timeout: 30000,
    dataType: 'json',
    success: function(data) {
      var state = data.state || [];
      var unconfigured = data.unconfigured || [];
      var db_onus = data.db_onus || [];
      var low_signal = data.low_signal || 0;

      // KPIs
      var total = state.length;
      var online = state.filter(function(s) { return s.state === 'working' || s.state === 'online'; }).length;
      var offline = total - online;
      var pending = unconfigured.length;
      
      // ONUs en OLT pero no en DB local = "sin emparejar"
      var unpaired = 0;
      if (state.length > 0 && db_onus.length > 0) {
        var db_sns = db_onus.map(function(d) { return d.sn; }).filter(function(s) { return s && s.length >= 8; });
        unpaired = total; // fallback: total si no podemos cotejar por SN
      }

      // Blue box: pendientes por autorizar (no configuradas en OLT)
      $totalOnus.text(pending);
      $online.text(online);
      $offline.text(offline);
      $totalAuth.text('Total authorized: ' + total);
      $pending.text('Sin config: ' + pending);
      $pendingBadge.text('En DB: ' + db_onus.length);
      $moveWaitingAuth.text('Sin emparejar: ' + unpaired);

      // Low signal
      $lowSignal.text(low_signal);
      $signalWarn.text('Low: ' + low_signal);
      $signalCrit.text('Critical: 0');

      // Offline breakdown
      $powerFail.text('PwrFail: ' + offline);
      $los.text('LoS: 0');
      $offlineNa.text('N/A: 0');

      // State bars
      $onlineBar.text(online);
      $offlineBar.text(offline);
      $pendingBar.text(pending);

      // OLT info
      $oltOnuCount.text(db_onus.length || total);
      $oltStatus.html('<span class="text-success"><i class="fa fa-circle"></i> Connected</span>');
      $oltUpTime.text(db_onus.length + ' ONUs cached');

      // Info list
      var infoHtml = '';
      var now = new Date();
      if (state.length > 0) {
        var workingCount = online;
        var offlineCount = offline;
        if (infoHtml === '') {
          infoHtml += '<a href="/modulo?pagina=GPONManager&action=onu" class="list-group-item">';
          infoHtml += '<i class="fa fa-wifi fa-fw"></i> ' + workingCount + ' ONUs online';
          infoHtml += ' <span class="pull-right small"><em>Now</em></span></a>';
        }
        if (offlineCount > 0) {
          infoHtml += '<a href="/modulo?pagina=GPONManager&action=onu&state=offline" class="list-group-item">';
          infoHtml += '<i class="fa fa-exclamation-triangle fa-fw"></i> ' + offlineCount + ' ONUs offline';
          infoHtml += ' <span class="pull-right small"><em>Now</em></span></a>';
        }
        if (pending > 0) {
          infoHtml += '<a href="/modulo?pagina=GPONManager&action=onu&state=pending" class="list-group-item">';
          infoHtml += '<i class="fa fa-clock-o fa-fw"></i> ' + pending + ' ONUs pending authorization';
          infoHtml += ' <span class="pull-right small"><em>Now</em></span></a>';
        }
        if (low_signal > 0) {
          infoHtml += '<a href="/modulo?pagina=GPONManager&action=diagnostics&signal=low" class="list-group-item">';
          infoHtml += '<i class="fa fa-exclamation-circle fa-fw"></i> ' + low_signal + ' ONUs with low signal';
          infoHtml += ' <span class="pull-right small"><em>Now</em></span></a>';
        }
      }
      if (infoHtml === '') {
        infoHtml = '<span class="list-group-item text-muted" style="border:none;">No recent events</span>';
      }
      $infoList.html(infoHtml);

      // Chart.js: donut chart con online / offline / pending
      var chartCanvas = document.getElementById('onus-statuses-chart');
      if (chartCanvas && typeof Chart !== 'undefined') {
        if (window._onuChart) window._onuChart.destroy();
        var ctx = chartCanvas.getContext('2d');
        var isNight = document.documentElement.classList.contains('smartolt-night');
        var textColor = isNight ? '#e2e8f0' : '#334155';
        window._onuChart = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: ['Online (' + online + ')', 'Offline (' + offline + ')', 'Pendientes (' + pending + ')'],
            datasets: [{
              data: [online, offline, pending],
              backgroundColor: ['#4db14b', '#4c4b4b', '#f7a127'],
              borderColor: isNight ? '#1e293b' : '#ffffff',
              borderWidth: 2
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: {
              legend: {
                position: 'bottom',
                labels: { color: textColor, padding: 16, font: { size: 12 } }
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    var label = context.label || '';
                    var value = context.parsed || 0;
                    var totalAll = online + offline + pending;
                    var pct = totalAll > 0 ? ((value / totalAll) * 100).toFixed(1) : 0;
                    return label + ' (' + pct + '%)';
                  }
                }
              }
            }
          }
        });
      }

      // Timestamp
      var ts = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit' });
      $updatedDate.text('Information valid at ' + ts);
    },
    error: function() {
      $status.html('<div class="text-danger text-center" style="padding:40px;font-size:13px;">Error connecting to OLT. Verify the connection.</div>');
      $oltStatus.html('<span class="text-danger"><i class="fa fa-circle"></i> Disconnected</span>');
      $updatedDate.text('Connection error');
    }
  });
}

// ===== SYNC ONUs FROM SMARTOLT =====
function syncOnusFromSmartOLT() {
  var $btn = $('#btn-sync-onus');
  var $status = $('#sync-status');
  if ($btn.prop('disabled')) return;
  
  $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Syncing...');
  $status.text('Connecting to SmartOLT...').css('color','');
  
  $.ajax({
    type: 'POST',
    url: '/api/gpon/sync',
    timeout: 60000,
    success: function(data) {
      if (data.success) {
        $status.text(data.msg).css('color','#4db14b');
        // Refrescar datos del dashboard
        if (typeof loadGPONData === 'function') loadGPONData();
      } else {
        $status.text(data.msg || 'Sync failed').css('color','#dc3545');
      }
    },
    error: function() {
      $status.text('Connection error').css('color','#dc3545');
    },
    complete: function() {
      $btn.prop('disabled', false).html('<i class="fa fa-refresh"></i> Sync ONUs from SmartOLT');
    }
  });
}

// ===== ONU DETAIL MODAL =====
var _currentOnuSn = '';

function openOnuDetail(sn) {
  if (!sn) return;
  _currentOnuSn = sn;
  
  $('#onuDetailSn').text('SN: ' + sn);
  $('#onuDetailBody').html('<div class="text-center text-muted" style="padding:40px;"><i class="fa fa-spinner fa-spin fa-3x" style="color:#4c4b4b;"></i><p style="margin-top:12px;font-size:14px;">Loading ONU details...</p></div>');
  $('#onuDetailModal').modal('show');
  
  $.ajax({
    type: 'GET',
    url: '/api/gpon/onu/detail/' + encodeURIComponent(sn),
    timeout: 30000,
    dataType: 'json',
    success: function(data) {
      if (!data.success || !data.data) {
        $('#onuDetailBody').html('<div class="text-center text-danger" style="padding:40px;"><i class="fa fa-exclamation-circle fa-3x" style="color:#e74c3c;"></i><p style="margin-top:12px;">Error loading ONU details</p></div>');
        return;
      }
      
      var d = data.data;
      var smartolt = d.smartolt || {};
      var local = d.local || {};
      var signal = d.signal || {};
      var detailedKey = signal && signal["ONU details"] ? signal["ONU details"] : {};
      
      var html = '';
      
      // === Section 1: Basic Information ===
      html += '<div class="onu-detail-section">';
      html += '<h5>Basic Information</h5>';
      html += '<div class="onu-detail-grid">';
      html += '<div class="field"><span class="label">Serial Number</span><div class="value"><strong>' + escapeHtml(d.sn || sn || '--') + '</strong></div></div>';
      html += '<div class="field"><span class="label">ONU ID</span><div class="value"><code>' + escapeHtml(smartolt.description || d.onuId || '--') + '</code></div></div>';
      html += '<div class="field"><span class="label">Name</span><div class="value"><input type="text" id="edit-nombre" value="' + escapeHtml(smartolt.name || local.nombre || '') + '" placeholder="Client name"/></div></div>';
      html += '<div class="field"><span class="label">Client</span><div class="value">' + escapeHtml(local.cliente_nombre || smartolt.name || '--') + '</div></div>';
      html += '<div class="field"><span class="label">ONU Type</span><div class="value"><input type="text" id="edit-onu-type" value="' + escapeHtml(smartolt.onu_type_name || local.onu_type || '') + '" placeholder="e.g. F679LV9.1"/></div></div>';
      html += '<div class="field"><span class="label">Board / Port</span><div class="value">' + escapeHtml((smartolt.board || '') + '/' + (smartolt.port || '') + ':' + (smartolt.onu || '--')) + '</div></div>';
      html += '<div class="field"><span class="label">Zone</span><div class="value"><input type="text" id="edit-zona" value="' + escapeHtml(smartolt.zone_name || local.zona || '') + '" placeholder="Zone name"/></div></div>';
      html += '<div class="field"><span class="label">VLAN</span><div class="value"><input type="text" id="edit-vlan" value="' + escapeHtml(smartolt.vlan || local.vlan || '') + '" placeholder="e.g. 200"/></div></div>';
      html += '<div class="field"><span class="label">Mode</span><div class="value">' + escapeHtml(smartolt.mode || '--') + '</div></div>';
      html += '<div class="field"><span class="label">WAN Mode</span><div class="value">' + escapeHtml(smartolt.wan_mode || '--') + '</div></div>';
      html += '</div></div>';
      
      // === Section 2: Status ===
      html += '<div class="onu-detail-section">';
      html += '<h5>Status</h5>';
      html += '<div class="onu-detail-grid">';
      html += '<div class="field"><span class="label">Phase State</span><div class="value"><span class="' + ((detailedKey["Phase state"] === 'working') ? 'signal-ok' : 'signal-bad') + '">' + escapeHtml(detailedKey["Phase state"] || '--') + '</span></div></div>';
      html += '<div class="field"><span class="label">Admin State</span><div class="value">' + escapeHtml(detailedKey["Admin state"] || '--') + '</div></div>';
      html += '<div class="field"><span class="label">Online Duration</span><div class="value">' + escapeHtml(detailedKey["Online Duration"] || '--') + '</div></div>';
      html += '<div class="field"><span class="label">ONU Distance</span><div class="value">' + escapeHtml(detailedKey["ONU Distance"] || '--') + '</div></div>';
      html += '<div class="field"><span class="label">HW Version</span><div class="value">' + escapeHtml(detailedKey["HW Version"] || '--') + '</div></div>';
      html += '<div class="field"><span class="label">Vendor</span><div class="value">' + escapeHtml(detailedKey["Vendor ID"] || '--') + '</div></div>';
      html += '</div></div>';
      
      // === Section 3: Optical Signal ===
      html += '<div class="onu-detail-section">';
      html += '<h5>Optical Signal</h5>';
      if (signal && signal["Optical status"]) {
        var opt = signal["Optical status"];
        html += '<div class="onu-detail-grid">';
        html += '<div class="field"><span class="label">OLT Rx (1310nm)</span><div class="value">' + escapeHtml(opt["OLT Rx"] || 'N/A') + '</div></div>';
        html += '<div class="field"><span class="label">ONU Tx (1310nm)</span><div class="value">' + escapeHtml(opt["ONU Tx"] || 'N/A') + '</div></div>';
        html += '<div class="field"><span class="label">OLT Tx (1490nm)</span><div class="value">' + escapeHtml(opt["OLT Tx"] || 'N/A') + '</div></div>';
        html += '<div class="field"><span class="label">ONU Rx (1490nm)</span><div class="value">' + escapeHtml(opt["ONU Rx"] || 'N/A') + '</div></div>';
        html += '<div class="field"><span class="label">Attenuation 1310nm</span><div class="value">' + escapeHtml(opt["1310nm Attenuation"] || 'N/A') + '</div></div>';
        html += '<div class="field"><span class="label">Attenuation 1490nm</span><div class="value">' + escapeHtml(opt["1490nm Attenuation"] || 'N/A') + '</div></div>';
        html += '</div>';
      } else {
        html += '<p style="color:#94a3b8;font-size:13px;margin:4px 0 12px;">Signal data not available for this ONU</p>';
      }
      html += '</div>';
      
      $('#onuDetailBody').html(html);
    },
    error: function() {
      $('#onuDetailBody').html('<div class="text-center text-danger" style="padding:40px;"><i class="fa fa-exclamation-triangle fa-3x" style="color:#e74c3c;"></i><p style="margin-top:12px;">Connection error</p></div>');
    }
  });
}

function saveOnuDetail() {
  var sn = _currentOnuSn;
  if (!sn) return;
  
  var nombre = $('#edit-nombre').val() || "";
  var zona = $('#edit-zona').val() || "";
  var vlan = $('#edit-vlan').val() || "";
  var onuType = $('#edit-onu-type').val() || "";
  
  var $btn = $('#btnSaveOnu');
  $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Saving...');
  
  $.ajax({
    type: 'POST',
    url: '/api/gpon/onu/save',
    contentType: 'application/json',
    data: JSON.stringify({ sn: sn, nombre: nombre, zona: zona, vlan: vlan, onu_type: onuType }),
    timeout: 15000,
    dataType: 'json',
    success: function(data) {
      if (data.success) {
        $('#btnSaveOnu').html('<i class="fa fa-check"></i> Saved!');
        setTimeout(function() {
          $('#btnSaveOnu').prop('disabled', false).html('<i class="fa fa-save"></i> Save Changes');
        }, 1500);
      } else {
        alert('Error: ' + (data.msg || 'Unknown'));
        $('#btnSaveOnu').prop('disabled', false).html('<i class="fa fa-save"></i> Save Changes');
      }
    },
    error: function() {
      alert('Connection error saving ONU');
      $('#btnSaveOnu').prop('disabled', false).html('<i class="fa fa-save"></i> Save Changes');
    }
  });
}

// ===== URL PARAMETER HANDLING =====
function getUrlParam(name) {
  var match = location.search.match(new RegExp('[?&]' + name + '=([^&]*)'));
  return match ? decodeURIComponent(match[1]) : null;
}

// ===== ONU LIST VIEW (action=onu) =====
function loadOnuListView(filterState) {
  var $content = $('#content-wrapper .content-wrap');
  
  // Back button
  var html = '<style>.onu-list-table,.onu-list-table>tbody>tr,.onu-list-table>tbody>tr>td,.onu-list-table>thead>tr>th{background:transparent!important;}.onu-list-table>tbody>tr:hover{background:rgba(76,75,75,0.06)!important;}html.smartolt-night .onu-list-table>tbody>tr:hover{background:rgba(255,255,255,0.06)!important;}</style>';
  html += '<div style="margin-bottom:16px;">';
  html += '<a href="/modulo?pagina=GPONManager" class="btn btn-default btn-sm"><i class="fa fa-arrow-left"></i> Back to Dashboard</a>';
  html += '<span style="margin-left:12px;font-weight:600;font-size:18px;">';
  if (filterState === 'online') html += '<i class="fa fa-wifi text-success"></i> ONUs Online';
  else if (filterState === 'offline') html += '<i class="fa fa-exclamation-triangle text-danger"></i> ONUs Offline';
  else if (filterState === 'pending') html += '<i class="fa fa-clock-o text-warning"></i> ONUs Pendientes';
  else html += 'All ONUs';
  html += '</span></div>';
  
  // Table
  html += '<div class="table-responsive"><table class="onu-list-table table table-hover" style="font-size:12px;background:transparent;">';
  html += '<thead><tr>';
  html += '<th>Status</th><th>Name / SN / MAC</th><th>ONU</th><th>Zone</th><th>Type</th><th>Mode</th><th>VLAN</th><th>Estado</th>';
  html += '</tr></thead><tbody id="onu-list-tbody">';
  html += '<tr><td colspan="8" class="text-center text-muted">Loading ONU data from SmartOLT...</td></tr>';
  html += '</tbody></table></div>';
  
  $content.html(html);
  
  // Fetch detailed data from SmartOLT API
  $.ajax({
    type: 'GET',
    url: '/api/gpon/onus/detailed',
    timeout: 30000,
    dataType: 'json',
    success: function(data) {
      if (!data.success || !data.onus || data.onus.length === 0) {
        $('#onu-list-tbody').html('<tr><td colspan="6" class="text-center text-danger">No data available from SmartOLT</td></tr>');
        return;
      }
      
      var onus = data.onus;
      
      // Filtrar por estado si se especificó
      if (filterState === 'online') {
        onus = onus.filter(function(o) { return o.state === 'working' || o.state === 'online'; });
      } else if (filterState === 'offline') {
        onus = onus.filter(function(o) { return o.state !== 'working' && o.state !== 'online' && o.state !== 'unknown' && o.state !== 'pending'; });
      } else if (filterState === 'pending') {
        onus = onus.filter(function(o) { return o.state === 'pending' || o.type === 'unconfigured'; });
      }
      
      if (onus.length === 0) {
        $('#onu-list-tbody').html('<tr><td colspan="8" class="text-center text-muted">No ONUs match this filter</td></tr>');
        return;
      }
      
      var rows = '';
      onus.forEach(function(o) {
        var isOnline = o.state === 'working' || o.state === 'online';
        var isPending = o.state === 'pending' || o.type === 'unconfigured';
        var stateIcon = isOnline ? '<i class="fa fa-circle text-success" style="font-size:10px;"></i>' : (isPending ? '<i class="fa fa-clock-o text-warning" style="font-size:10px;"></i>' : '<i class="fa fa-circle text-muted" style="font-size:10px;"></i>');
        var stateLabel = isOnline ? 'Online' : (isPending ? 'Pending' : (o.state === 'unknown' ? 'Unknown' : 'Offline'));
        var stateBadge = isOnline ? 'success' : (isPending ? 'warning' : (o.state === 'unknown' ? 'warning' : 'default'));
        
        var dataSn = (o.sn || o.onuId || "");
        rows += '<tr style="cursor:pointer;" data-sn="' + escapeHtml(dataSn) + '" onclick="openOnuDetail(this.dataset.sn)">';
        rows += '<td>' + stateIcon + '</td>';
        rows += '<td><strong>' + escapeHtml(o.name || '--') + '</strong><br><small class="text-muted">' + escapeHtml(o.sn || '--') + '</small></td>';
        rows += '<td><small>' + escapeHtml(o.description || '--') + '</small></td>';
        rows += '<td><small>' + escapeHtml(o.zone_name || '--') + '</small></td>';
        rows += '<td><small>' + escapeHtml(o.onu_type_name || '--') + '</small></td>';
        rows += '<td><small>' + escapeHtml(o.wan_mode || o.mode || '--') + '</small></td>';
        rows += '<td><small>' + escapeHtml(o.vlan || '--') + '</small></td>';
        rows += '<td><span class="label label-' + stateBadge + '">' + stateLabel + '</span></td>';
        rows += '</tr>';
      });
      
      $('#onu-list-tbody').html(rows);
    },
    error: function() {
      $('#onu-list-tbody').html('<tr><td colspan="8" class="text-center text-danger">Error fetching ONU data from SmartOLT</td></tr>');
    }
  });
}

// Escapado HTML para seguridad
function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ===== INIT: Check URL params =====
$(document).ready(function() {
  var action = getUrlParam('action');
  var stateFilter = getUrlParam('state');
  
  if (action === 'onu') {
    // Mostrar lista detallada de ONUs
    loadOnuListView(stateFilter);
  } else if (action === 'config') {
    // Mostrar configuración (placeholder)
    $('#content-wrapper .content-wrap').html('<div class="text-center text-muted" style="padding:60px;"><i class="fa fa-cog fa-4x"></i><h3>Configuración</h3><p>Página de configuración próximamente.</p><a href="/modulo?pagina=GPONManager" class="btn btn-default">Volver</a></div>');
  } else if (action === 'diagnostics') {
    // Mostrar diagnóstico (placeholder)
    $('#content-wrapper .content-wrap').html('<div class="text-center text-muted" style="padding:60px;"><i class="fa fa-stethoscope fa-4x"></i><h3>Diagnostics</h3><p>Página de diagnóstico próximamente.</p><a href="/modulo?pagina=GPONManager" class="btn btn-default">Volver</a></div>');
  } else {
    // Dashboard - iniciar auto-refresh
    loadGPONData();
    setInterval(loadGPONData, 30000);
  }
});
</script>
