     MODAL: Confirmar Eliminaci&oacute;n
---------------------------------------------------------- -->
<div class="pa-overlay" id="paModalDeleteConfirm">
    <div class="pa-modal pa-modal-sm" style="max-width:400px;">
        <div class="pa-modal-head">
            <div class="pa-modal-title"><i class="fas fa-trash-alt" style="color:#ef4444;"></i> Eliminar Pago</div>
            <button class="pa-modal-x" onclick="paClose('paModalDeleteConfirm')"><i class="fas fa-times"></i></button>
        </div>
