            <div style="width:56px;height:56px;border-radius:50%;background:var(--pa-red-bg);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
                <i class="fas fa-exclamation-triangle" style="color:#ef4444;font-size:1.4rem;"></i>
