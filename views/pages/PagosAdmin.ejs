<!-- Toast Notification -->
<div id="paToast" style="position:fixed;top:20px;right:20px;z-index:9999;display:none;max-width:380px;width:90%;animation:paSlide .2s ease;">
    <div id="paToastInner" style="padding:14px 18px;border-radius:10px;box-shadow:0 8px 25px rgba(0,0,0,0.15);display:flex;align-items:center;gap:10px;">
        <i id="paToastIcon" style="font-size:1.1rem;flex-shrink:0;"></i>
        <div id="paToastMsg" style="font-size:0.88rem;font-weight:600;flex:1;"></div>
        <button onclick="document.getElementById('paToast').style.display='none'" style="background:none;border:none;font-size:1rem;cursor:pointer;opacity:0.5;color:inherit;">&times;</button>
    </div>
</div>

<script>
(function(){
// ==========================================================================
// Utilidades
// ==========================================================================
function fmt(n){ return 'RD$ '+parseFloat(n||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtDate(s){ if(!s) return ''; var p=s.substring(0,10).split('-'); return p[2]+'/'+p[1]+'/'+p[0]; }
function isOverdue(d){ return d && new Date(d+'T00:00:00') < new Date(); }
function esc(s){ var d=document.createElement('div'); d.textContent=String(s||''); return d.innerHTML; }

var BASE_URL = '/modulo?pagina=PagosAdmin';
function api(url){ return fetch(url).then(function(r){return r.json();}); }
function apiPost(url,fd){ return fetch(url,{method:'POST',body:fd}).then(function(r){return r.json();}); }
function setBtn(id,on,html){ var b=document.getElementById(id); b.disabled=!on; if(html) b.innerHTML=html; }

window.paClose = function(id){ document.getElementById(id).classList.remove('open'); };
window.paOpen  = function(id){ document.getElementById(id).classList.add('open'); };

// --------------------------------------------------------------------------
// Toast notification (reemplaza alert)
// --------------------------------------------------------------------------
window.paToast = function(msg, type) {
    var toast = document.getElementById('paToast');
    var inner = document.getElementById('paToastInner');
    var icon = document.getElementById('paToastIcon');
    var text = document.getElementById('paToastMsg');
    text.textContent = msg;
    if (type === 'success') {
        inner.style.background = '#f0fdf4'; inner.style.color = '#166534'; inner.style.border = '1px solid #bbf7d0';
        icon.className = 'fas fa-check-circle'; icon.style.color = '#16a34a';
    } else if (type === 'error') {
        inner.style.background = '#fef2f2'; inner.style.color = '#991b1b'; inner.style.border = '1px solid #fecaca';
        icon.className = 'fas fa-times-circle'; icon.style.color = '#ef4444';
    } else {
        inner.style.background = '#eff6ff'; inner.style.color = '#1e40af'; inner.style.border = '1px solid #bfdbfe';
        icon.className = 'fas fa-info-circle'; icon.style.color = '#3b82f6';
    }
    toast.style.display = 'block';
    clearTimeout(window._paToastTimer);
    window._paToastTimer = setTimeout(function(){ toast.style.display = 'none'; }, 4000);
};

// --------------------------------------------------------------------------
// Confirmaci&oacute;n de eliminaci&oacute;n (reemplaza confirm)
// --------------------------------------------------------------------------
window._paDeleteCallback = null;
window.paDeleteConfirm = function(msg, callback) {
    document.getElementById('paDeleteConfirmText').innerHTML = msg;
    window._paDeleteCallback = callback;
    paOpen('paModalDeleteConfirm');
};
window.paDeleteConfirmExec = function() {
    paClose('paModalDeleteConfirm');
    if (window._paDeleteCallback) window._paDeleteCallback();
};

// ==========================================================================
// Dropdown "Nuevo Pago"
// ==========================================================================
window.paToggleDropdown = function(){
    document.getElementById('paDrop').classList.toggle('open');
};
document.addEventListener('click', function(e){
    var wrap = document.getElementById('paNuevoWrap');
    if(wrap && !wrap.contains(e.target)) document.getElementById('paDrop').classList.remove('open');
});

window.paOpenType = function(type){
    document.getElementById('paDrop').classList.remove('open');
    if(type==='proveedor'){ paLoadSuppliers(); paOpen('paModalSup'); }
    else if(type==='empleado'){ paLoadEmployees(); paOpen('paModalEmp'); }
    else if(type==='otro'){ paResetOtro(); paOpen('paModalOtro'); }
};

// ==========================================================================
// Cerrar con ESC o clic fondo
// ==========================================================================
var overlays=['paModalSup','paModalInv','paModalPayInv','paModalEmp','paModalPayEmp','paModalOtro','paModalLoanConfirm','paModalDeleteConfirm','paModalEditOtro'];
overlays.forEach(function(id){
    var el = document.getElementById(id);
    if (el) el.addEventListener('click',function(e){ if(e.target===this) paClose(id); });
});
document.addEventListener('keydown',function(e){ if(e.key==='Escape') overlays.forEach(function(id){ paClose(id); }); });

// ==========================================================================
// PROVEEDORES
// ==========================================================================
var _supCurrentId = 0;
var _supCurrentName = '';

window.paLoadSuppliers = function(){
    var search = document.getElementById('paSupSearch').value;
    var list = document.getElementById('paSupList');
    list.innerHTML='<li class="pa-loading"><i class="fas fa-spinner fa-spin"></i></li>';
    api(BASE_URL+'&ajax=pa_suppliers&search='+encodeURIComponent(search))
    .then(function(d){
        if(d.status!=='success'||!d.data.length){
            list.innerHTML='<li class="pa-empty"><i class="fas fa-search"></i>Sin proveedores encontrados</li>'; return;
        }
        var supMap = {};
        list.innerHTML = d.data.map(function(s){
            supMap[s.id] = s.name;
            var debt = parseFloat(s.pending_debt);
            var badge = debt > 0
                ? '<span class="pa-badge pa-badge-red">'+fmt(debt)+'</span>'
                : '<span class="pa-badge pa-badge-green"><i class="fas fa-check"></i> Al d&iacute;a</span>';
            return '<li class="pa-row" data-sup-id="'+s.id+'">'
                +'<div><div class="pa-row-name">'+esc(s.name)+'</div>'
                +'<div class="pa-row-sub">'+(s.rnc?'RNC: '+esc(s.rnc)+' &middot; ':'')+s.pending_count+' factura(s) pendiente(s)</div></div>'
                +badge+'</li>';
        }).join('');
        // Attach click after render
        list.querySelectorAll('[data-sup-id]').forEach(function(li){
            li.addEventListener('click', function(){ paOpenInvoices(this.dataset.supId, supMap[this.dataset.supId]); });
        });
    });
};

window.paOpenInvoices = function(supId, supName){
    _supCurrentId = supId;
    _supCurrentName = supName;
    document.getElementById('paInvTitle').textContent = supName;
    var body = document.getElementById('paInvBody');
    body.innerHTML='<div class="pa-loading"><i class="fas fa-spinner fa-spin"></i></div>';
    paClose('paModalSup');
    paOpen('paModalInv');
    paRefreshInvoices();
};

function paRefreshInvoices(){
    var body = document.getElementById('paInvBody');
    api(BASE_URL+'&ajax=pa_invoices&supplier_id='+_supCurrentId)
    .then(function(d){
        if(d.status!=='success'){
            body.innerHTML='<div class="pa-empty">Error al cargar facturas</div>'; return;
        }
        if(!d.data.length){
            body.innerHTML='<div class="pa-empty"><i class="fas fa-check-circle" style="color:#16a34a;font-size:2rem;"></i><br>Este proveedor no tiene facturas pendientes.<br>&iexcl;Est&aacute; al d&iacute;a!</div>';
            return;
        }
        body.innerHTML = d.data.map(function(inv){
            var rem = parseFloat(inv.remaining);
            var over = isOverdue(inv.due_date);
            var dueTxt = inv.due_date
                ? ' &middot; Vence: <span class="'+(over?'pa-overdue':'')+'">'+fmtDate(inv.due_date)+(over?' &#9200;':'')+'</span>'
                : '';
            var stBadge = inv.status==='partial'
                ? '<span class="pa-badge pa-badge-yellow">Abono</span>'
                : '<span class="pa-badge pa-badge-red">Pendiente</span>';
            return '<div class="pa-inv-row">'
                +'<div style="flex:1;min-width:0;">'
                +'<div class="pa-inv-concept">'+(inv.invoice_number?'#'+esc(inv.invoice_number)+' - ':'')+esc(inv.concept)+'</div>'
                +'<div class="pa-inv-meta">Total: <b>'+fmt(inv.total)+'</b> &middot; Pagado: <b style="color:#16a34a;">'+fmt(inv.paid_amount)+'</b> &middot; <b style="color:#dc2626;">Resta: '+fmt(rem)+'</b>'+dueTxt+'</div>'
                +'</div>'
                +'<div style="display:flex;gap:6px;align-items:center;flex-shrink:0;">'+stBadge
                +'<button class="pa-btn pa-btn-green pa-btn-sm pa-pay-inv-btn"'
                +' data-id="'+inv.id+'"'
                +' data-total="'+parseFloat(inv.total).toFixed(2)+'"'
                +' data-paid="'+parseFloat(inv.paid_amount).toFixed(2)+'"'
                +' data-concept="'+esc(inv.concept).replace(/"/g,'&quot;')+'">'
                +'<i class="fas fa-coins"></i> Pagar</button>'
                +'</div></div>';
        }).join('');

        // Attach click handlers after render
        body.querySelectorAll('.pa-pay-inv-btn').forEach(function(btn){
            btn.addEventListener('click', function(){
                paOpenPayInv(
                    this.dataset.id,
                    parseFloat(this.dataset.total),
                    parseFloat(this.dataset.paid),
                    this.dataset.concept
                );
            });
        });
    });
}

var _invData = {};
window.paOpenPayInv = function(invId, total, paid, concept){
    _invData = {id:invId, total:parseFloat(total), paid:parseFloat(paid)};
    var rem = Math.round((total - paid)*100)/100;
    document.getElementById('paPayInvId').value = invId;
    document.getElementById('paSumConcept').textContent = concept;
    document.getElementById('paSumTotal').textContent = fmt(total);
    document.getElementById('paSumPaid').textContent = fmt(paid);
    document.getElementById('paSumRemaining').textContent = fmt(rem);
    document.getElementById('paPayInvAmt').value = rem.toFixed(2);
    document.getElementById('paPayInvAmt').max = rem;
    document.getElementById('paPayInvMethod').value = 'Efectivo';
    document.getElementById('paPayInvRef').value = '';
    document.getElementById('paPayInvNotes').value = '';
    setBtn('paBtnPayInv', true, '<i class="fas fa-check-circle"></i> Confirmar Pago');
    paOpen('paModalPayInv');
};

window.paSubmitPayInv = function(){
    var amount = parseFloat(document.getElementById('paPayInvAmt').value);
    if(!amount || amount <= 0){ paToast('Ingrese un monto v&aacute;lido', 'error'); return; }
    var maxRem = _invData.total - _invData.paid;
    if(amount > maxRem + 0.009){ paToast('El monto supera el saldo pendiente ('+fmt(maxRem)+')', 'error'); return; }
    setBtn('paBtnPayInv', false, '<i class="fas fa-spinner fa-spin"></i> Procesando...');
    var fd = new FormData();
    fd.append('invoice_id', _invData.id);
    fd.append('amount', amount);
    fd.append('method', document.getElementById('paPayInvMethod').value);
    fd.append('reference', document.getElementById('paPayInvRef').value.trim());
    fd.append('notes', document.getElementById('paPayInvNotes').value.trim());
    apiPost(BASE_URL+'&ajax=pa_pay_invoice', fd)
    .then(function(d){
        if(d.status==='success'){
            paClose('paModalPayInv');
            paRefreshInvoices();
            paLoadRecent();
        } else { paToast('Error: '+(d.msg||'Desconocido'), 'error'); }
    })
    .catch(function(){ paToast('Error de conexi&oacute;n', 'error'); })
    .finally(function(){ setBtn('paBtnPayInv', true, '<i class="fas fa-check-circle"></i> Confirmar Pago'); });
};

// ==========================================================================
// EMPLEADOS
// ==========================================================================
window.paLoadEmployees = function(){
    var search = document.getElementById('paEmpSearch').value;
    var list = document.getElementById('paEmpList');
    list.innerHTML='<li class="pa-loading"><i class="fas fa-spinner fa-spin"></i></li>';
    api(BASE_URL+'&ajax=pa_employees&search='+encodeURIComponent(search))
    .then(function(d){
        if(d.status!=='success'||!d.data.length){
            list.innerHTML='<li class="pa-empty"><i class="fas fa-search"></i>Sin empleados encontrados</li>'; return;
        }
        list.innerHTML = d.data.map(function(e){
            var loanBadge = parseFloat(e.loan_balance)>0
                ? ' <span class="pa-badge pa-badge-yellow"><i class="fas fa-exclamation-triangle"></i> Pr&eacute;stamo: '+fmt(e.loan_balance)+'</span>'
                : '';
            var tipo = e.employee_type==='Otro'?(e.employee_type_other||'Otro'):e.employee_type;
            return '<li class="pa-row" onclick="paOpenEmpPay('+e.id+')">'
                +'<div><div class="pa-row-name">'+esc(e.name)+'</div>'
                +'<div class="pa-row-sub">'+esc(tipo)+' &middot; '+fmt(e.salary)+' '+esc(e.salary_period)+'</div></div>'
                +'<div style="display:flex;gap:6px;align-items:center;flex-shrink:0;">'+loanBadge
                +'<span class="pa-badge pa-badge-blue"><i class="fas fa-money-bill"></i> Pagar</span>'
                +'</div></li>';
        }).join('');
    });
};

window.paOpenEmpPay = function(empId){
    document.getElementById('paEmpPayId').value = empId;
    document.getElementById('paEmpPayName').textContent = '...';
    document.getElementById('paEmpLoanWarn').style.display = 'none';
    document.getElementById('paEmpSalaryBox').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Cargando...';
    document.getElementById('paEmpPayAmt').value = '';
    document.getElementById('paEmpPayPeriod').value = '';
    document.getElementById('paEmpPayMethod').value = 'Efectivo';
    document.getElementById('paEmpPayRef').value = '';
    document.getElementById('paEmpPayNotes').value = '';
    document.getElementById('paEmpHistWrap').style.display = 'none';
    setBtn('paBtnPayEmp', true, '<i class="fas fa-check-circle"></i> Confirmar Pago');
    paClose('paModalEmp');
    paOpen('paModalPayEmp');

    api(BASE_URL+'&ajax=pa_employee_detail&id='+empId)
    .then(function(d){
        if(d.status!=='success'){ paToast('Error: '+d.msg, 'error'); paClose('paModalPayEmp'); return; }
        var e = d.data;
        document.getElementById('paEmpPayName').textContent = e.name;

        // Advertencia de pr&eacute;stamos
        window._paCurrentEmp = e;
        if(parseFloat(e.loan_balance) > 0){
            document.getElementById('paEmpLoanWarn').style.display = 'flex';
            document.getElementById('paEmpLoanText').innerHTML =
                e.active_loans+' pr&eacute;stamo(s) activo(s). Saldo pendiente: '+fmt(e.loan_balance)+'. Considere coordinar el descuento.';
        }

        // Info salario
        var period = e.salary_period==='quincenal'?'Quincenal':'Mensual';
        var days = 'D&iacute;a de pago: '+e.pay_day_1+(e.pay_day_2?' y '+e.pay_day_2:'');
        document.getElementById('paEmpSalaryBox').innerHTML =
            'Salario establecido: <b>'+fmt(e.salary)+'</b> &middot; '+period+' &middot; '+days+' <span style="color:#3b82f6;cursor:pointer;font-weight:600;" onclick="document.getElementById(\'paEmpPayAmt\').value=\''+parseFloat(e.salary).toFixed(2)+'\'">&#8594; Usar monto</span>';
        document.getElementById('paEmpPayAmt').value = parseFloat(e.salary).toFixed(2);

        // Historial
        if(d.history && d.history.length){
            document.getElementById('paEmpHistWrap').style.display = 'block';
            document.getElementById('paEmpHistList').innerHTML = d.history.map(function(h){
                return '<div style="display:flex;justify-content:space-between;align-items:center;padding:7px 10px;border-bottom:1px solid var(--pa-border-light);font-size:0.82rem;">'
                    +'<div><b>'+fmt(h.amount)+'</b>'+(h.period_label?' <span style="color:var(--pa-text-muted);">'+esc(h.period_label)+'</span>':'')+'</div>'
                    +'<span style="color:#94a3b8;">'+fmtDate(h.payment_date)+' &middot; '+esc(h.payment_method)+'</span></div>';
            }).join('');
        }
    });
};

window.paSubmitPayEmp = function(){
    var empId  = document.getElementById('paEmpPayId').value;
    var amount = parseFloat(document.getElementById('paEmpPayAmt').value);
    if(!amount || amount <= 0){ paToast('Ingrese un monto v&aacute;lido', 'error'); return; }

    var e = window._paCurrentEmp;
    var salary = e ? parseFloat(e.salary) : 0;
    var loanBalance = e ? parseFloat(e.loan_balance) : 0;

    // Si tiene pr&eacute;stamo y el monto es inferior al salario, ofrecer abono
    if(loanBalance > 0 && salary > 0 && amount < salary){
        var diferencia = Math.min(salary - amount, loanBalance);
        window._paLoanDeduction = diferencia;
        document.getElementById('paLoanConfirmText').innerHTML =
            'El pago de <b>'+fmt(amount)+'</b> es inferior al salario de <b>'+fmt(salary)+'</b>.<br>&iquest;Desea abonar la diferencia al pr&eacute;stamo?';
        document.getElementById('paLoanConfirmAmount').textContent = fmt(diferencia);
        paOpen('paModalLoanConfirm');
        return;
    }

    paExecutePayEmp(empId, amount, 0);
};

window.paLoanConfirmResolve = function(accepted){
    paClose('paModalLoanConfirm');
    var empId  = document.getElementById('paEmpPayId').value;
    var amount = parseFloat(document.getElementById('paEmpPayAmt').value);
    var deduction = accepted ? (window._paLoanDeduction || 0) : 0;
    paExecutePayEmp(empId, amount, deduction);
};

function paExecutePayEmp(empId, amount, loanDeduction){
    setBtn('paBtnPayEmp', false, '<i class="fas fa-spinner fa-spin"></i> Procesando...');
    var fd = new FormData();
    fd.append('employee_id', empId);
    fd.append('amount', amount);
    fd.append('period_label', document.getElementById('paEmpPayPeriod').value.trim());
    fd.append('method', document.getElementById('paEmpPayMethod').value);
    fd.append('reference', document.getElementById('paEmpPayRef').value.trim());
    fd.append('notes', document.getElementById('paEmpPayNotes').value.trim());
    fd.append('loan_deduction', loanDeduction);
    apiPost(BASE_URL+'&ajax=pa_pay_employee', fd)
    .then(function(d){
        if(d.status==='success'){
            paClose('paModalPayEmp');
            paLoadRecent();
            if(d.loan_msg) paToast(d.loan_msg, 'success');
        } else { paToast('Error: '+(d.msg||'Desconocido'), 'error'); }
    })
    .catch(function(){ paToast('Error de conexi&oacute;n', 'error'); })
    .finally(function(){ setBtn('paBtnPayEmp', true, '<i class="fas fa-check-circle"></i> Confirmar Pago'); });
}

// ==========================================================================
// OTRO PAGO
// ==========================================================================
function selectGastoType(type){
    var emp = document.getElementById('labelGastoEmpresa');
    var per = document.getElementById('labelGastoPersonal');
    if(type==='empresa'){
        emp.style.borderColor='#2563eb'; emp.style.background='#eff6ff';
        per.style.borderColor='var(--pa-border)'; per.style.background='transparent';
    } else {
        per.style.borderColor='#d97706'; per.style.background='#fffbeb';
        emp.style.borderColor='var(--pa-border)'; emp.style.background='transparent';
    }
}

function selectEditGastoType(type){
    var emp = document.getElementById('labelEditEmpresa');
    var per = document.getElementById('labelEditPersonal');
    if(type==='empresa'){
        if(emp){emp.style.borderColor='#2563eb'; emp.style.background='#eff6ff';}
        if(per){per.style.borderColor='var(--pa-border)'; per.style.background='transparent';}
    } else {
        if(per){per.style.borderColor='#d97706'; per.style.background='#fffbeb';}
        if(emp){emp.style.borderColor='var(--pa-border)'; emp.style.background='transparent';}
    }
}

window.paOpenEditOtro = function(idx){
    var p = _paRecentRows[idx];
    if(!p) return;
    document.getElementById('paEditOtroId').value = p.id;
    document.getElementById('paEditConcept').value = p.descripcion;
    document.getElementById('paEditAmt').value = p.amount;
    document.getElementById('paEditMethod').value = p.payment_method || 'Efectivo';
    document.getElementById('paEditRef').value = p.reference || '';
    document.getElementById('paEditNotes').value = p.notes || '';
    document.getElementById('paEditFecha').value = p.payment_date || '';
    var cat = (p.categoria || 'empresa').toLowerCase();
    selectEditGastoType(cat === 'personal' ? 'personal' : 'empresa');
    var radioBtn = document.querySelector('input[name="edit_gasto_tipo"][value="' + (cat === 'personal' ? 'personal' : 'empresa') + '"]');
    if (radioBtn) radioBtn.checked = true;
    paOpen('paModalEditOtro');
};

window.paSubmitEditOtro = function(){
    var id = document.getElementById('paEditOtroId').value;
    var concept = document.getElementById('paEditConcept').value.trim();
    var amount = parseFloat(document.getElementById('paEditAmt').value);
    if(!concept || !amount || amount<=0){ paToast('Datos inv&aacute;lidos', 'error'); return; }
    var catEl = document.querySelector('input[name="edit_gasto_tipo"]:checked');
    var categoria = catEl ? catEl.value : 'empresa';
    setBtn('paBtnEditOtro', false, '<i class="fas fa-spinner fa-spin"></i> Guardando...');
    var fd = new FormData();
    fd.append('id', id);
    fd.append('concept', concept);
    fd.append('amount', amount);
    fd.append('method', document.getElementById('paEditMethod').value);
    fd.append('reference', document.getElementById('paEditRef').value.trim());
    fd.append('notes', document.getElementById('paEditNotes').value.trim());
    fd.append('categoria', categoria);
    fd.append('payment_date', document.getElementById('paEditFecha').value);
    apiPost(BASE_URL+'&ajax=pa_edit_other', fd)
    .then(function(d){
        if(d.status==='success'){
            paClose('paModalEditOtro');
            paLoadRecent();
        } else { paToast('Error: '+(d.msg||'Desconocido'), 'error'); }
    })
    .catch(function(){ paToast('Error de conexi&oacute;n', 'error'); })
    .finally(function(){ setBtn('paBtnEditOtro', true, '<i class="fas fa-save"></i> Guardar Cambios'); });
};

function paResetOtro() {
    ['paOtroConcept','paOtroAmt','paOtroRef','paOtroNotes'].forEach(function(id){ document.getElementById(id).value=''; });
    document.getElementById('paOtroMethod').value = 'Efectivo';
    document.getElementById('paOtroFecha').value = new Date().toISOString().split('T')[0];
    selectGastoType('empresa');
    var radioBtn = document.querySelector('input[name="gasto_tipo"][value="empresa"]');
    if (radioBtn) radioBtn.checked = true;
    setBtn('paBtnOtro', true, '<i class="fas fa-save"></i> Guardar Pago');
}

window.paSubmitOtro = function(){
    var concept = document.getElementById('paOtroConcept').value.trim();
    var amount  = parseFloat(document.getElementById('paOtroAmt').value);
    if(!concept){ paToast('El concepto es requerido', 'error'); return; }
    if(!amount || amount <= 0){ paToast('Ingrese un monto v&aacute;lido', 'error'); return; }
    var gastoTipo = document.querySelector('input[name="gasto_tipo"]:checked');
    var categoria = gastoTipo ? gastoTipo.value : 'empresa';
    setBtn('paBtnOtro', false, '<i class="fas fa-spinner fa-spin"></i> Guardando...');
    var fd = new FormData();
    fd.append('concept', concept);
    fd.append('amount', amount);
    fd.append('method', document.getElementById('paOtroMethod').value);
    fd.append('reference', document.getElementById('paOtroRef').value.trim());
    fd.append('notes', document.getElementById('paOtroNotes').value.trim());
    fd.append('categoria', categoria);
    fd.append('payment_date', document.getElementById('paOtroFecha').value);
    apiPost(BASE_URL+'&ajax=pa_pay_other', fd)
    .then(function(d){
        if(d.status==='success'){
            paClose('paModalOtro');
            paLoadRecent();
        } else { paToast('Error: '+(d.msg||'Desconocido'), 'error'); }
    })
    .catch(function(){ paToast('Error de conexi&oacute;n', 'error'); })
    .finally(function(){ setBtn('paBtnOtro', true, '<i class="fas fa-save"></i> Guardar Pago'); });
};

// ==========================================================================
// HISTORIAL RECIENTE
// ==========================================================================
var paIconMap = {
    proveedor: {icon:'fa-truck', color:'#7c3aed', bg:'#f3e8ff'},
    empleado:  {icon:'fa-user-tie', color:'#0891b2', bg:'#e0f2fe'},
    otro:      {icon:'fa-receipt', color:'#d97706', bg:'#fef3c7'}
};
var paLabelMap = {proveedor:'Proveedor', empleado:'Empleado', otro:'Otro'};

var _paRecentRows = [];
window.paLoadRecent = function(){
    var body = document.getElementById('paRecentBody');
    body.innerHTML='<div class="pa-loading"><i class="fas fa-spinner fa-spin"></i></div>';
    api(BASE_URL+'&ajax=pa_recent')
    .then(function(d){
        if(d.status!=='success'||!d.data.length){
            body.innerHTML='<div class="pa-empty"><i class="fas fa-inbox"></i><br>Sin pagos registrados a&uacute;n</div>'; return;
        }
        _paRecentRows = d.data;
        var rows = _paRecentRows;
        body.innerHTML = rows.map(function(p, idx){
            var info = paIconMap[p.tipo] || paIconMap.otro;
            return '<div class="pa-hist-row" data-idx="'+idx+'">'
                +'<div class="pa-hist-icon" style="background:'+info.bg+';color:'+info.color+';">'
                +'<i class="fas '+info.icon+'"></i></div>'
                +'<div class="pa-hist-desc">'
                +'<div class="pa-hist-name">'+esc(p.descripcion)+'</div>'
                +'<div class="pa-hist-meta">'+paLabelMap[p.tipo]+' &middot; '+esc(p.payment_method)+' &middot; '+fmtDate(p.payment_date)+'</div>'
                +'</div>'
                +'<div style="display:flex;align-items:center;gap:4px;">'
                +'<div class="pa-hist-amt" style="color:'+info.color+';">'+fmt(p.amount)+'</div>'
                +((p.tipo==='otro')?'<button class="pa-btn pa-btn-gray pa-btn-sm" onclick="paOpenEditOtro('+idx+')" title="Editar" style="padding:4px 8px;color:#2563eb;"><i class="fas fa-pencil-alt"></i></button>':'')
                +'<button class="pa-btn pa-btn-gray pa-btn-sm pa-del-btn" data-idx="'+idx+'" title="Eliminar" style="padding:4px 8px;color:#dc2626;border-color:#fecaca;">'
                +'<i class="fas fa-trash-alt"></i></button>'
                +'</div></div>';
        }).join('');
        body.querySelectorAll('.pa-del-btn').forEach(function(btn){
            btn.addEventListener('click', function(e){
                e.stopPropagation();
                var p = rows[parseInt(this.dataset.idx)];
                var self = this;
                paDeleteConfirm('&iquest;Eliminar este pago de <b>'+fmt(p.amount)+'</b>?', function(){
                    self.disabled = true;
                    var fd = new FormData();
                    fd.append('tipo', p.tipo);
                    fd.append('id', p.id);
                    apiPost(BASE_URL+'&ajax=pa_delete_payment', fd)
                    .then(function(d){ if(d.status==='success'){ paToast('Pago eliminado', 'success'); paLoadRecent(); } else { paToast('Error: '+(d.msg||'No se pudo eliminar'), 'error'); } })
                    .catch(function(){ paToast('Error de conexi&oacute;n', 'error'); });
                });
            });
        });
    });
};

// ==========================================================================
// Init
// ==========================================================================
paLoadRecent();

})();
</script>