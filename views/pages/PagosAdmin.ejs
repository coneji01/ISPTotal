<style>
/* ==========================================================================
   PagosAdmin - DomISP replication for ispTotal
   Uses CSS custom properties for theme support
   ========================================================================== */

:root {
  --pa-bg: #ffffff;
  --pa-bg-alt: #f8fafc;
  --pa-bg-hover: #f1f5f9;
  --pa-text: #1e293b;
  --pa-text-muted: #64748b;
  --pa-text-light: #94a3b8;
  --pa-border: #e2e8f0;
  --pa-border-light: #f1f5f9;
  --pa-primary: #2563eb;
  --pa-primary-hover: #1d4ed8;
  --pa-primary-bg: #dbeafe;
  --pa-green: #16a34a;
  --pa-green-hover: #15803d;
  --pa-green-bg: #dcfce7;
  --pa-amber: #d97706;
  --pa-amber-hover: #b45309;
  --pa-amber-bg: #fef3c7;
  --pa-red: #dc2626;
  --pa-red-bg: #fee2e2;
  --pa-gray: #475569;
  --pa-gray-bg: #f1f5f9;
  --pa-purple: #7c3aed;
  --pa-purple-bg: #f3e8ff;
  --pa-cyan: #0891b2;
  --pa-cyan-bg: #e0f2fe;
  --pa-orange: #c2410c;
  --pa-orange-bg: #ffedd5;
  --pa-overlay: rgba(0,0,0,0.44);
  --pa-shadow: 0 1px 4px rgba(0,0,0,0.07);
  --pa-shadow-lg: 0 8px 28px rgba(0,0,0,0.13);
  --pa-shadow-modal: 0 20px 60px rgba(0,0,0,0.18);
  --pa-radius: 13px;
  --pa-radius-sm: 9px;
  --pa-radius-xs: 8px;
  --pa-font-sm: 0.74rem;
  --pa-font: 0.87rem;
  --pa-font-md: 0.9rem;
  --pa-font-lg: 1rem;
  --pa-font-xl: 1.3rem;
}

/* -- Layout -- */
.pa-wrap{max-width:920px;margin:0 auto}
.pa-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:20px}
.pa-title{font-size:var(--pa-font-xl);font-weight:700;color:var(--pa-text);display:flex;align-items:center;gap:9px}
.pa-title i{color:var(--pa-primary)}

/* -- Botones -- */
.pa-btn{padding:9px 18px;border:none;border-radius:var(--pa-radius-sm);font-size:var(--pa-font);font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .15s;white-space:nowrap}
.pa-btn:disabled{opacity:.5;cursor:not-allowed}
.pa-btn-primary{background:var(--pa-primary);color:#fff}.pa-btn-primary:hover:not(:disabled){background:var(--pa-primary-hover)}
.pa-btn-green{background:var(--pa-green);color:#fff}.pa-btn-green:hover:not(:disabled){background:var(--pa-green-hover)}
.pa-btn-gray{background:var(--pa-gray-bg);color:var(--pa-gray);border:1px solid var(--pa-border)}.pa-btn-gray:hover:not(:disabled){background:var(--pa-border)}
.pa-btn-amber{background:var(--pa-amber);color:#fff}.pa-btn-amber:hover:not(:disabled){background:var(--pa-amber-hover)}
.pa-btn-sm{padding:5px 11px;font-size:0.8rem;border-radius:7px}

/* -- Card / tabla -- */
.pa-card{background:var(--pa-bg);border-radius:var(--pa-radius);box-shadow:var(--pa-shadow);border:1px solid var(--pa-border);overflow:hidden}
.pa-card-head{padding:13px 18px;border-bottom:1px solid var(--pa-border);display:flex;justify-content:space-between;align-items:center;gap:10px;background:var(--pa-bg-alt);flex-wrap:wrap}
.pa-card-title{font-size:var(--pa-font-md);font-weight:700;color:var(--pa-text);display:flex;align-items:center;gap:7px}
.pa-search{padding:7px 13px;border:1px solid var(--pa-border);border-radius:var(--pa-radius-xs);font-size:0.86rem;outline:none;min-width:180px}
.pa-search:focus{border-color:var(--pa-primary);box-shadow:0 0 0 3px rgba(37,99,235,.1)}

/* -- Filas lista -- */
.pa-list{margin:0;padding:0;list-style:none}
.pa-row{display:flex;justify-content:space-between;align-items:center;padding:12px 18px;border-bottom:1px solid var(--pa-border-light);gap:10px;cursor:pointer;transition:background .1s}
.pa-row:last-child{border-bottom:none}
.pa-row:hover{background:var(--pa-bg-alt)}
.pa-row-name{font-weight:600;color:var(--pa-text);font-size:var(--pa-font-md)}
.pa-row-sub{font-size:0.77rem;color:var(--pa-text-muted);margin-top:2px}
.pa-empty{text-align:center;padding:32px 20px;color:var(--pa-text-light);font-size:0.88rem}
.pa-empty i{font-size:1.8rem;display:block;margin-bottom:7px}
.pa-loading{text-align:center;padding:28px;color:var(--pa-text-light)}

/* -- Badges -- */
.pa-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:var(--pa-font-sm);font-weight:600;white-space:nowrap}
.pa-badge-red{background:var(--pa-red-bg);color:var(--pa-red)}
.pa-badge-green{background:var(--pa-green-bg);color:var(--pa-green)}
.pa-badge-yellow{background:var(--pa-amber-bg);color:var(--pa-amber-hover)}
.pa-badge-blue{background:var(--pa-primary-bg);color:var(--pa-primary)}
.pa-badge-orange{background:var(--pa-orange-bg);color:var(--pa-orange)}

/* -- Dropdown "Nuevo Pago" -- */
.pa-dropdown-wrap{position:relative;display:inline-block}
.pa-dropdown-menu{position:absolute;top:calc(100% + 6px);right:0;background:var(--pa-bg);border:1px solid var(--pa-border);border-radius:11px;box-shadow:var(--pa-shadow-lg);min-width:200px;z-index:999;overflow:hidden;display:none;animation:paFadeIn .14s ease}
.pa-dropdown-menu.open{display:block}
@keyframes paFadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.pa-dropdown-item{display:flex;align-items:center;gap:10px;padding:11px 16px;font-size:0.88rem;font-weight:600;color:var(--pa-text);cursor:pointer;transition:background .1s;border:none;background:none;width:100%;text-align:left}
.pa-dropdown-item:hover{background:var(--pa-gray-bg)}
.pa-dropdown-item i{width:18px;text-align:center;font-size:1rem}

/* -- Modales -- */
.pa-overlay{position:fixed;inset:0;background:var(--pa-overlay);z-index:9000;display:none;align-items:center;justify-content:center;padding:16px}
.pa-overlay.open{display:flex}
.pa-modal{background:var(--pa-bg);border-radius:16px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;box-shadow:var(--pa-shadow-modal);animation:paSlide .18s ease}
@keyframes paSlide{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
.pa-modal-sm{max-width:440px}
.pa-modal-head{padding:17px 20px 13px;border-bottom:1px solid var(--pa-border);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--pa-bg);z-index:2}
.pa-modal-title{font-size:var(--pa-font-lg);font-weight:700;color:var(--pa-text);display:flex;align-items:center;gap:8px}
.pa-modal-x{background:none;border:none;font-size:1.15rem;color:var(--pa-text-light);cursor:pointer;padding:4px 6px;border-radius:6px;line-height:1}
.pa-modal-x:hover{background:var(--pa-gray-bg);color:var(--pa-gray)}
.pa-modal-body{padding:18px 20px}
.pa-modal-foot{padding:13px 20px;border-top:1px solid var(--pa-border);display:flex;justify-content:flex-end;gap:8px}

/* -- Formulario -- */
.pa-field{margin-bottom:14px}
.pa-label{display:block;font-size:0.81rem;font-weight:600;color:var(--pa-gray);margin-bottom:5px}
.pa-input,.pa-select,.pa-textarea{width:100%;padding:9px 12px;border:1px solid var(--pa-border);border-radius:var(--pa-radius-xs);font-size:var(--pa-font);outline:none;box-sizing:border-box;font-family:inherit;color:var(--pa-text)}
.pa-input:focus,.pa-select:focus,.pa-textarea:focus{border-color:var(--pa-primary);box-shadow:0 0 0 3px rgba(37,99,235,.08)}
.pa-textarea{resize:vertical;min-height:68px}
.pa-grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:460px){.pa-grid2{grid-template-columns:1fr}}

/* -- Resumen factura -- */
.pa-summary{background:var(--pa-bg-alt);border:1px solid var(--pa-border);border-radius:var(--pa-radius-sm);padding:12px 14px;margin-bottom:16px;font-size:0.84rem}
.pa-summary-row{display:flex;justify-content:space-between;margin-bottom:3px}
.pa-summary-row:last-child{border-top:1px solid var(--pa-border);padding-top:6px;margin-top:4px;margin-bottom:0;font-weight:700}

/* -- Advertencia préstamo -- */
.pa-warn{background:var(--pa-amber-bg);border:1px solid #fcd34d;border-radius:var(--pa-radius-sm);padding:11px 13px;margin-bottom:14px;display:flex;gap:9px}
.pa-warn i{color:var(--pa-amber);margin-top:1px;flex-shrink:0}
.pa-warn-text{font-size:0.83rem;color:#78350f}
.pa-warn-text b{display:block;margin-bottom:2px}

/* -- Info salario -- */
.pa-salary-box{background:#eff6ff;border:1px solid #bfdbfe;border-radius:var(--pa-radius-sm);padding:11px 13px;margin-bottom:14px;font-size:0.84rem;color:#1e40af}

/* -- Historial reciente -- */
.pa-hist-row{display:flex;align-items:center;gap:10px;padding:11px 18px;border-bottom:1px solid var(--pa-border-light)}
.pa-hist-row:last-child{border-bottom:none}
.pa-hist-icon{width:30px;height:30px;border-radius:var(--pa-radius-xs);display:flex;align-items:center;justify-content:center;font-size:0.9rem;flex-shrink:0}
.pa-hist-desc{flex:1;min-width:0}
.pa-hist-name{font-size:var(--pa-font);font-weight:600;color:var(--pa-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pa-hist-meta{font-size:0.75rem;color:var(--pa-text-light);margin-top:1px}
.pa-hist-amt{font-weight:700;font-size:var(--pa-font-md);white-space:nowrap}

/* -- Facturas -- */
.pa-inv-row{display:flex;justify-content:space-between;align-items:center;padding:13px 18px;border-bottom:1px solid var(--pa-border-light);gap:10px}
.pa-inv-row:last-child{border-bottom:none}
.pa-inv-concept{font-weight:600;color:var(--pa-text);font-size:0.88rem}
.pa-inv-meta{font-size:0.76rem;color:var(--pa-text-muted);margin-top:3px}
.pa-overdue{color:var(--pa-red)!important;font-weight:600}
</style>

<div class="pa-wrap">

    <!-- Header -->
    <div class="pa-header">
        <div class="pa-title"><i class="fas fa-money-bill-wave"></i> Pagos</div>
        <div class="pa-dropdown-wrap" id="paNuevoWrap">
            <button class="pa-btn pa-btn-primary" onclick="paToggleDropdown()">
                <i class="fas fa-plus"></i> Nuevo Pago <i class="fas fa-chevron-down" style="font-size:.75rem;"></i>
            </button>
            <div class="pa-dropdown-menu" id="paDrop">
                <button class="pa-dropdown-item" onclick="paOpenType('proveedor')">
                    <i class="fas fa-truck" style="color:#7c3aed;"></i> Pago a Proveedor
                </button>
                <button class="pa-dropdown-item" onclick="paOpenType('empleado')">
                    <i class="fas fa-user-tie" style="color:#0891b2;"></i> Pago a Empleado
                </button>
                <button class="pa-dropdown-item" onclick="paOpenType('otro')">
                    <i class="fas fa-receipt" style="color:#d97706;"></i> Otro Pago
                </button>
            </div>
        </div>
    </div>

    <!-- Historial reciente -->
    <div class="pa-card">
        <div class="pa-card-head">
            <div class="pa-card-title"><i class="fas fa-clock" style="color:var(--pa-primary);"></i> Pagos Recientes</div>
        </div>
        <div id="paRecentBody">
            <div class="pa-loading"><i class="fas fa-spinner fa-spin"></i></div>
        </div>
    </div>

</div>

<!-- ----------------------------------------------------------
     MODAL: Seleccionar Proveedor
---------------------------------------------------------- -->
<div class="pa-overlay" id="paModalSup">
    <div class="pa-modal">
        <div class="pa-modal-head">
            <div class="pa-modal-title"><i class="fas fa-truck" style="color:#7c3aed;"></i> Seleccionar Proveedor</div>
            <button class="pa-modal-x" onclick="paClose('paModalSup')"><i class="fas fa-times"></i></button>
        </div>
        <div class="pa-modal-body" style="padding:14px 18px">
            <input type="text" class="pa-search pa-input" id="paSupSearch" placeholder="Buscar proveedor..." oninput="paLoadSuppliers()" style="width:100%;margin-bottom:12px;">
            <div class="pa-card" style="box-shadow:none;border-radius:9px;">
                <ul class="pa-list" id="paSupList">
                    <li class="pa-loading"><i class="fas fa-spinner fa-spin"></i></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- ----------------------------------------------------------
     MODAL: Facturas pendientes del proveedor
---------------------------------------------------------- -->
<div class="pa-overlay" id="paModalInv">
    <div class="pa-modal">
        <div class="pa-modal-head">
            <div class="pa-modal-title"><i class="fas fa-file-invoice-dollar" style="color:#7c3aed;"></i> <span id="paInvTitle">Facturas pendientes</span></div>
            <button class="pa-modal-x" onclick="paClose('paModalInv')"><i class="fas fa-times"></i></button>
        </div>
        <div class="pa-modal-body" style="padding:0">
            <div id="paInvBody"></div>
        </div>
        <div class="pa-modal-foot">
            <button class="pa-btn pa-btn-gray" onclick="paClose('paModalInv')">Cerrar</button>
        </div>
    </div>
</div>

<!-- ----------------------------------------------------------
     MODAL: Pagar / Abonar factura
---------------------------------------------------------- -->
<div class="pa-overlay" id="paModalPayInv">
    <div class="pa-modal pa-modal-sm">
        <div class="pa-modal-head">
            <div class="pa-modal-title"><i class="fas fa-coins" style="color:#16a34a;"></i> Registrar Pago</div>
            <button class="pa-modal-x" onclick="paClose('paModalPayInv')"><i class="fas fa-times"></i></button>
        </div>
        <div class="pa-modal-body">
            <input type="hidden" id="paPayInvId">
            <div class="pa-summary">
                <div class="pa-summary-row"><span style="color:#64748b;">Concepto</span><span id="paSumConcept" style="font-weight:600;max-width:240px;text-align:right;"></span></div>
                <div class="pa-summary-row"><span style="color:#64748b;">Total factura</span><span id="paSumTotal"></span></div>
                <div class="pa-summary-row"><span style="color:#64748b;">Ya pagado</span><span id="paSumPaid" style="color:var(--pa-green);"></span></div>
                <div class="pa-summary-row"><span>Pendiente</span><span id="paSumRemaining" style="color:var(--pa-red);font-size:1rem;"></span></div>
            </div>
            <div class="pa-field">
                <label class="pa-label">Monto a pagar *</label>
                <input type="number" class="pa-input" id="paPayInvAmt" min="0.01" step="0.01" placeholder="0.00">
            </div>
            <div class="pa-grid2">
                <div class="pa-field">
                    <label class="pa-label">M&eacute;todo de pago</label>
                    <select class="pa-select" id="paPayInvMethod">
                        <option>Efectivo</option><option>Transferencia</option><option>Cheque</option><option>Tarjeta</option><option>Otro</option>
                    </select>
                </div>
                <div class="pa-field">
                    <label class="pa-label">N&uacute;m. Transacci&oacute;n <small style="color:#94a3b8;">(opcional)</small></label>
                    <input type="text" class="pa-input" id="paPayInvRef" placeholder="# cheque, transferencia...">
                </div>
            </div>
            <div class="pa-field">
                <label class="pa-label">Notas</label>
                <textarea class="pa-textarea" id="paPayInvNotes" placeholder="Opcional..."></textarea>
            </div>
        </div>
        <div class="pa-modal-foot">
            <button class="pa-btn pa-btn-gray" onclick="paClose('paModalPayInv')">Cancelar</button>
            <button class="pa-btn pa-btn-green" id="paBtnPayInv" onclick="paSubmitPayInv()"><i class="fas fa-check-circle"></i> Confirmar Pago</button>
        </div>
    </div>
</div>

<!-- ----------------------------------------------------------
     MODAL: Seleccionar Empleado
---------------------------------------------------------- -->
<div class="pa-overlay" id="paModalEmp">
    <div class="pa-modal">
        <div class="pa-modal-head">
            <div class="pa-modal-title"><i class="fas fa-user-tie" style="color:#0891b2;"></i> Seleccionar Empleado</div>
            <button class="pa-modal-x" onclick="paClose('paModalEmp')"><i class="fas fa-times"></i></button>
        </div>
        <div class="pa-modal-body" style="padding:14px 18px">
            <input type="text" class="pa-search pa-input" id="paEmpSearch" placeholder="Buscar empleado..." oninput="paLoadEmployees()" style="width:100%;margin-bottom:12px;">
            <div class="pa-card" style="box-shadow:none;border-radius:9px;">
                <ul class="pa-list" id="paEmpList">
                    <li class="pa-loading"><i class="fas fa-spinner fa-spin"></i></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- ----------------------------------------------------------
     MODAL: Pagar a Empleado
---------------------------------------------------------- -->
<div class="pa-overlay" id="paModalPayEmp">
    <div class="pa-modal pa-modal-sm">
        <div class="pa-modal-head">
            <div class="pa-modal-title"><i class="fas fa-user-tie" style="color:#0891b2;"></i> Pagar a <span id="paEmpPayName">--</span></div>
            <button class="pa-modal-x" onclick="paClose('paModalPayEmp')"><i class="fas fa-times"></i></button>
        </div>
        <div class="pa-modal-body">
            <input type="hidden" id="paEmpPayId">
            <div class="pa-warn" id="paEmpLoanWarn" style="display:none">
                <i class="fas fa-exclamation-triangle"></i>
                <div class="pa-warn-text">
                    <b>Empleado con pr&eacute;stamos activos</b>
                    <span id="paEmpLoanText"></span>
                </div>
            </div>
            <div class="pa-salary-box" id="paEmpSalaryBox"></div>
            <div class="pa-field">
                <label class="pa-label">Monto a pagar *</label>
                <input type="number" class="pa-input" id="paEmpPayAmt" min="0.01" step="0.01" placeholder="0.00">
            </div>
            <div class="pa-field">
                <label class="pa-label">Periodo / Descripci&oacute;n</label>
                <input type="text" class="pa-input" id="paEmpPayPeriod" placeholder="Ej: Quincena 1 - Marzo 2025">
            </div>
            <div class="pa-grid2">
                <div class="pa-field">
                    <label class="pa-label">M&eacute;todo de pago</label>
                    <select class="pa-select" id="paEmpPayMethod">
                        <option>Efectivo</option><option>Transferencia</option><option>Cheque</option><option>Tarjeta</option><option>Otro</option>
                    </select>
                </div>
                <div class="pa-field">
                    <label class="pa-label">Referencia</label>
                    <input type="text" class="pa-input" id="paEmpPayRef" placeholder="Opcional...">
                </div>
            </div>
            <div class="pa-field">
                <label class="pa-label">Notas</label>
                <textarea class="pa-textarea" id="paEmpPayNotes" placeholder="Opcional..."></textarea>
            </div>
            <div id="paEmpHistWrap" style="display:none">
                <div style="font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;">&Uacute;ltimos pagos registrados</div>
                <div id="paEmpHistList" style="border:1px solid var(--pa-border);border-radius:8px;overflow:hidden;"></div>
            </div>
        </div>
        <div class="pa-modal-foot">
            <button class="pa-btn pa-btn-gray" onclick="paClose('paModalPayEmp')">Cancelar</button>
            <button class="pa-btn pa-btn-primary" id="paBtnPayEmp" onclick="paSubmitPayEmp()"><i class="fas fa-check-circle"></i> Confirmar Pago</button>
        </div>
    </div>
</div>

<!-- ----------------------------------------------------------
     MODAL: Otro Pago
---------------------------------------------------------- -->
<div class="pa-overlay" id="paModalOtro">
    <div class="pa-modal pa-modal-sm">
        <div class="pa-modal-head">
            <div class="pa-modal-title"><i class="fas fa-receipt" style="color:#d97706;"></i> Otro Pago</div>
            <button class="pa-modal-x" onclick="paClose('paModalOtro')"><i class="fas fa-times"></i></button>
        </div>
        <div class="pa-modal-body">
            <div class="pa-field">
                <label class="pa-label">Concepto *</label>
                <input type="text" class="pa-input" id="paOtroConcept" placeholder="Ej: Renta, luz, internet...">
            </div>
            <div class="pa-field">
                <label class="pa-label">Monto *</label>
                <input type="number" class="pa-input" id="paOtroAmt" min="0.01" step="0.01" placeholder="0.00">
            </div>
            <div class="pa-field">
                <label class="pa-label">Tipo de Gasto *</label>
                <div style="display:flex;gap:16px;margin-top:4px;">
                    <label style="cursor:pointer;display:flex;align-items:center;gap:6px;font-weight:600;padding:8px 14px;border:2px solid var(--pa-border);border-radius:8px;flex:1;transition:all 0.2s;" id="labelGastoEmpresa" onclick="selectGastoType('empresa')">
                        <input type="radio" name="gasto_tipo" value="empresa" checked style="accent-color:var(--pa-primary);">
                        <span>&#127975; Empresa</span>
                    </label>
                    <label style="cursor:pointer;display:flex;align-items:center;gap:6px;font-weight:600;padding:8px 14px;border:2px solid var(--pa-border);border-radius:8px;flex:1;transition:all 0.2s;" id="labelGastoPersonal" onclick="selectGastoType('personal')">
                        <input type="radio" name="gasto_tipo" value="personal" style="accent-color:#d97706;">
                        <span>&#128100; Personal</span>
                    </label>
                </div>
            </div>
            <div class="pa-grid2">
                <div class="pa-field">
                    <label class="pa-label">M&eacute;todo de pago</label>
                    <select class="pa-select" id="paOtroMethod">
                        <option>Efectivo</option><option>Transferencia</option><option>Cheque</option><option>Tarjeta</option><option>Otro</option>
                    </select>
                </div>
                <div class="pa-field">
                    <label class="pa-label">Referencia</label>
                    <input type="text" class="pa-input" id="paOtroRef" placeholder="Opcional...">
                </div>
            </div>
            <div class="pa-field">
                <label class="pa-label">Notas</label>
                <textarea class="pa-textarea" id="paOtroNotes" placeholder="Opcional..."></textarea>
            </div>
            <div class="pa-field">
                <label class="pa-label">Fecha del Gasto</label>
                <input type="date" class="pa-input" id="paOtroFecha">
            </div>
