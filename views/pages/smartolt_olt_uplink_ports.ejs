<!-- Configure Uplink Port Modal -->
<div id="configureModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="configureModalLabel">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="configureModalLabel">Configure Uplink Port</h4>
      </div>
      <form id="configureForm">
        <div class="modal-body">
          <h4 id="configurePortLabel">Port: <span id="modalPortName"></span></h4>
          <input type="hidden" id="modalPortNameInput" name="portName">

          <div class="form-group">
            <label for="vlanSelect">Select VLANs</label>
            <select multiple class="form-control vlan-select" id="vlanSelect" name="vlans">
              <option value="10">VLAN 10</option>
              <option value="20">VLAN 20</option>
              <option value="50">VLAN 50</option>
              <option value="100">VLAN 100</option>
              <option value="200">VLAN 200</option>
              <option value="300">VLAN 300</option>
              <option value="400">VLAN 400</option>
              <option value="500">VLAN 500</option>
            </select>
            <p class="help-block">Hold Ctrl (or Cmd on Mac) to select multiple VLANs.</p>
          </div>

          <div class="checkbox">
            <label>
              <input type="checkbox" id="enablePortCheckbox" name="enabled" value="true" checked>
              Enable Port
            </label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Configuration</button>
        </div>
      </form>
    </div>
  </div>
