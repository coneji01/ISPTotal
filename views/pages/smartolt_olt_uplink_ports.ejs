<script type="text/javascript">
$( document ).ready(function() {
  $.ajaxSetup({
    cache: false
  });

  // --- Helper: get OLT ID from URL ---
  function getOltId() {
    var params = new URLSearchParams(window.location.search);
    var oid = params.get('olt_id');
    if (oid) {
      return oid;
    }
    /* fallback: try to extract from the URL path */
    var parts = window.location.pathname.split('/');
    for (var i = 0; i < parts.length; i++) {
      if (parts[i] === 'uplink_ports' && (i + 1) < parts.length) {
        return parts[i + 1];
      }
    }
    return '1';
  }

  // --- Helper: escape HTML ---
  function esc(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  // --- Load uplink ports from API ---
  function loadUplinkPorts() {
    var oltId = getOltId();
    var loadingEl = document.getElementById('uplink-loading');
    var tableContainer = document.getElementById('uplink-table-container');
    var errorEl = document.getElementById('uplink-error');
    var refreshBtn = document.getElementById('refreshUplinkBtn');

    if (loadingEl) loadingEl.style.display = 'block';
    if (tableContainer) tableContainer.style.display = 'none';
    if (errorEl) errorEl.style.display = 'none';
    if (refreshBtn) refreshBtn.disabled = true;

    fetch('/api/olts/' + oltId + '/uplink-ports')
      .then(function(response) {
        if (!response.ok) {
          throw new Error('HTTP ' + response.status);
        }
        return response.json();
      })
      .then(function(data) {
        if (loadingEl) loadingEl.style.display = 'none';
        if (refreshBtn) refreshBtn.disabled = false;

        if (!data || !data.success) {
          if (errorEl) {
            errorEl.innerHTML = '<div class="alert alert-danger">' +
              esc(data && data.error ? data.error : 'Unknown error') +
              '</div>';
            errorEl.style.display = 'block';
          }
          return;
        }

        var ports = data.ports || data.data || [];
        if (!Array.isArray(ports)) {
          ports = [];
        }

        var tbody = document.getElementById('uplink-ports-tbody');
        if (!tbody) return;

        if (ports.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No uplink ports found.</td></tr>';
        } else {
          var html = '';
          ports.forEach(function(p) {
            var portName = esc(p.port || p.name || '-');
            var portType = esc(p.type || p.port_type || '-');
            var speed = esc(p.speed || '-');
            var status = p.status || p.state || 'unknown';
            var statusLower = status.toLowerCase();
            var isOnline = (statusLower === 'up' || statusLower === 'online' || statusLower === 'enabled');
            var statusClass = isOnline ? 'status-online' : 'status-offline';
            var statusLabel = isOnline ? 'Online' : 'Offline';
            var vlans = p.vlans || p.vlan || [];
            var vlansStr = '';
            if (Array.isArray(vlans)) {
              vlansStr = vlans.join(', ');
            } else if (typeof vlans === 'string') {
              vlansStr = vlans;
            } else {
              vlansStr = '—';
            }
            var enabled = isOnline;

            html += '<tr>' +
              '<td><strong>' + portName + '</strong></td>' +
              '<td class="port-type">' + portType + '</td>' +
              '<td>' + speed + '</td>' +
              '<td class="' + statusClass + '">' + statusLabel + '</td>' +
              '<td>' + esc(vlansStr || '—') + '</td>' +
              '<td>' +
                '<button class="btn btn-primary btn-sm configure-uplink-btn" ' +
                  'data-port="' + esc(portName) + '" ' +
                  'data-vlans="' + esc(vlansStr) + '" ' +
                  'data-enabled="' + (enabled ? 'true' : 'false') + '">' +
                  '<i class="glyphicon glyphicon-cog"></i> Configure' +
                '</button>' +
              '</td>' +
            '</tr>';
          });
          tbody.innerHTML = html;
        }

        if (tableContainer) tableContainer.style.display = 'block';
      })
      .catch(function(err) {
        if (loadingEl) loadingEl.style.display = 'none';
        if (refreshBtn) refreshBtn.disabled = false;
        if (errorEl) {
          errorEl.innerHTML = '<div class="alert alert-danger">Error loading uplink ports: ' + esc(err.message) + '</div>';
          errorEl.style.display = 'block';
        }
      });
  }

  // --- Configure button handler (opens modal) ---
  $(document).on('click', '.configure-uplink-btn', function() {
    var portName = $(this).data('port');
    var vlansStr = $(this).data('vlans');
    var enabled = $(this).data('enabled');

    $('#modalPortName').text(portName);
    $('#modalPortNameInput').val(portName);

    // Clear and set selected VLANs
    $('#vlanSelect option').prop('selected', false);
    if (vlansStr && vlansStr !== '—') {
      var vlans = vlansStr.split(',').map(function(v) { return v.trim(); });
      $('#vlanSelect option').each(function() {
        if (vlans.indexOf($(this).val()) !== -1) {
          $(this).prop('selected', true);
        }
      });
    }

    // Set enable checkbox
    $('#enablePortCheckbox').prop('checked', enabled);

    $('#configureModal').modal('show');
  });

  // --- Form submit handler ---
  $('#configureForm').on('submit', function(e) {
    e.preventDefault();
    var portName = $('#modalPortNameInput').val();
    var selectedVlans = $('#vlanSelect').val() || [];
    var enabled = $('#enablePortCheckbox').is(':checked');

    var msg = 'Port "' + portName + '" configured.\n';
    msg += 'VLANs: ' + (selectedVlans.length > 0 ? selectedVlans.join(', ') : '(none)') + '\n';
    msg += 'Status: ' + (enabled ? 'Enabled' : 'Disabled');

    alert(msg);
    $('#configureModal').modal('hide');
  });

  // --- Refresh button ---
  $('#refreshUplinkBtn').on('click', function(e) {
    e.preventDefault();
    var btn = $(this);
    btn.html('<i class="fa fa-spinner fa-spin"></i> Refreshing...');
    loadUplinkPorts();
    setTimeout(function() {
      btn.html('<i class="glyphicon glyphicon-refresh"></i> Refresh');
      $.MessageBox('Uplink ports refreshed successfully.');
    }, 500);
  });

  // --- Initial load ---
  loadUplinkPorts();

});
</script>

