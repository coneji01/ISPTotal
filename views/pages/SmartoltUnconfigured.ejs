html.smartolt-night .label-info { background: #3b82f6; }
html.smartolt-night .label-danger { background: #ef4444; }
.form-control, .input-sm { border: 1px solid #d1d5db; border-radius: 6px; font-size: 12px; }
html.smartolt-night .form-control, html.smartolt-night .input-sm { background: #0f172a; border-color: #475569; color: #e2e8f0; }
.search-box { max-width: 280px; }
.badge-pulse { animation: pulse 2s infinite; }
@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
