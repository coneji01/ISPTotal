<script>
// ====== ISPTotal: Unconfigured ONUs ======
$(document).ready(function() {
  window.form_data = { olt_id: [1], pon: '' };
  
  function cargarUnconfigured() {
    $('#onuTable tbody').html('<tr><td colspan="7" class="text-center"><i class="fa fa-spinner fa-spin"></i> Scanning...</td></tr>');
    
    $.ajax({
      url: '/api/olt/unconfigured-onus',
      method: 'GET',
      timeout: 15000,
      success: function(r) {
        if (!r.success || !r.data || !r.data.length) {
          $('#onuTable tbody').html('<tr><td colspan="7" class="text-center text-muted">No unconfigured ONUs found</td></tr>');
          $('#lastScan').text('Just now');
          return;
        }
        
        // Apply PON filter
        var ponFilter = $('#pon').val().trim().toLowerCase();
        var filtered = r.data;
        if (ponFilter !== '') {
          filtered = r.data.filter(function(o) {
            var boardPort = String(o.board) + '/' + String(o.port);
            return boardPort.indexOf(ponFilter) !== -1;
          });
        }
        
        if (!filtered.length) {
          $('#onuTable tbody').html('<tr><td colspan="7" class="text-center text-muted">No unconfigured ONUs match the filter</td></tr>');
          $('#lastScan').text('Just now');
          return;
        }
        
        var html = '';
        filtered.forEach(function(o) {
          var ponDesc = (o.board || '') + '/' + (o.port || '');
          var sn = o.sn || '';
          html += '<tr class="valign-center">' +
            '<td>GPON</td>' +
            '<td>' + o.board + '</td>' +
            '<td>' + o.port + '</td>' +
            '<td>' + ponDesc + '</td>' +
            '<td>' + (sn || 'N/A') + '</td>' +
            '<td class="text-nowrap">Auto-detect</td>' +
            '<td class="text-center">' +
            '<a href="/modulo?pagina=SmartoltAuthorizeOnu&board=' + o.board + '&port=' + o.port + '&sn=' + encodeURIComponent(sn) + '" class="btn btn-sm btn-primary"><i class="fa fa-check"></i> Authorize</a>' +
            '</td></tr>';
        });
        
        $('#onuTable tbody').html(html);
        $('#lastScan').text('Just now');
      },
      error: function() {
        $('#onuTable tbody').html('<tr><td colspan="7" class="text-center text-danger"><i class="fa fa-exclamation-triangle"></i> Error connecting to OLT</td></tr>');
      }
    });
  }
  
  // Cargar inicial
  cargarUnconfigured();
  
  // Auto-refresh cada 30s
  setInterval(cargarUnconfigured, 30000);
  
  // Boton refresh manual
  $('#btnRefresh, .refresh-single-olt').on('click', cargarUnconfigured);
  
  // PON filter on input change
  $('#pon').on('input', cargarUnconfigured);
});
</script>

