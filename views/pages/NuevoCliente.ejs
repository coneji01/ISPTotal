<div class="page-header">
    <h2><i class="fas fa-user-plus"></i> Nuevo Cliente</h2>
    <a href="/modulo?pagina=Clientes" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Volver
    </a>
</div>

<div class="card" style="max-width:860px;margin:0 auto;">
    <form id="formNuevoCliente" method="POST">
        <input type="hidden" name="accion" value="guardar">

        <!-- Identificación del Cliente -->
        <h4 style="color:var(--accent);border-bottom:1px solid #eee;padding-bottom:10px;margin-bottom:20px;">
            <i class="fas fa-id-card"></i> Identificación del Cliente
        </h4>

        <div class="form-group">
            <label class="form-label">Documento de Identidad <span style="color:red">*</span></label>
            <div class="doc-row" style="display:flex;gap:10px;flex-wrap:wrap;">
                <select name="tipo_doc" id="tipoDoc" class="form-control" style="width:140px;flex-shrink:0;">
                    <option value="cedula">Cédula</option>
                    <option value="pasaporte">Pasaporte</option>
                    <option value="rnc">RNC</option>
                </select>
                <input type="text" name="cedula" id="inputCedula" class="form-control" required
                       placeholder="Número sin guiones" autocomplete="off"
                       style="flex:1;min-width:200px;"
                       oninput="this.value=this.value.replace(/[^0-9]/g,'')">
                <button type="button" class="btn btn-success" id="btnConfirmarDoc" onclick="validarDocumento()" style="flex-shrink:0;">
                    <i class="fas fa-check"></i> Confirmar
                </button>
            </div>
            <small style="color:var(--text-gray);font-size:0.75rem;margin-top:5px;display:block;">
                Seleccione el tipo y escriba el número sin guiones.
            </small>
            <div id="docResult" style="margin-top:8px;display:none;"></div>
        </div>

        <fieldset id="restoFormulario" disabled style="border:none;padding:0;margin:0;opacity:0.6;transition:opacity 0.3s;">

            <!-- Datos Personales -->
            <div class="form-grid" style="margin-top:20px;">
                <div class="form-group">
                    <label class="form-label">Nombre Completo <span style="color:red">*</span></label>
                    <input type="text" name="name" id="inputName" class="form-control" required
                           placeholder="Ej: JUAN PEREZ"
                           oninput="this.value=this.value.replace(/[^a-zA-Z0-9\s]/g,'').toUpperCase()"
                           style="text-transform:uppercase;">
                </div>
                <div class="form-group">
                    <label class="form-label">Apodo</label>
                    <input type="text" name="alias" id="inputAlias" class="form-control" placeholder="Ej: El Rubio">
                </div>
                <div class="form-group">
                    <label class="form-label">Teléfono / Celular <span style="color:red">*</span></label>
                    <input type="text" name="phone" id="inputPhone" class="form-control" required
                           placeholder="8090000000" minlength="10"
                           oninput="this.value=this.value.replace(/[^0-9]/g,'')">
                </div>
                <div class="form-group">
                    <label class="form-label">Teléfono 2 <small style="color:var(--text-gray);">(opcional)</small></label>
                    <input type="text" name="phone2" id="inputPhone2" class="form-control"
                           placeholder="Segundo teléfono"
                           oninput="this.value=this.value.replace(/[^0-9]/g,'')">
                </div>
                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label">Dirección del Servicio <span style="color:red">*</span></label>
                    <input type="text" name="address" class="form-control" required
                           placeholder="Calle, Número, Referencia...">
                </div>
                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label" id="lblObs">Observaciones</label>
                    <input type="text" name="observations" id="inputObs" class="form-control"
                           placeholder="Detalles de ubicación, referencias extra...">
                </div>
            </div>

            <!-- Zona y Servicio -->
            <h4 style="color:var(--accent);border-bottom:1px solid #eee;padding-bottom:10px;margin:30px 0 20px 0;">
                <i class="fas fa-map-marker-alt"></i> Zona y Servicio
            </h4>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Zona / Sector <span style="color:red">*</span></label>
                    <select name="sector_id" id="sectorSelect" class="form-control" required onchange="mostrarPlanes()">
                        <option value="">-- Seleccione zona para ver planes --</option>
                        <% (zonas || []).forEach(function(z) { %>
                        <option value="<%= z.id %>"><%= z.nombre %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group" id="divPlan" style="display:none;">
                    <label class="form-label">Plan de Internet <span style="color:red">*</span></label>
                    <select name="plan_id" id="planSelect" class="form-control">
                        <option value="">-- Seleccione Plan --</option>
                    </select>
                </div>
            </div>

            <!-- Facturación -->
            <h4 style="color:var(--accent);border-bottom:1px solid #eee;padding-bottom:10px;margin:30px 0 20px 0;">
                <i class="fas fa-file-invoice-dollar"></i> Facturación
            </h4>

            <div class="form-grid">
                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label">Plantilla de Facturación <span style="color:red">*</span></label>
                    <select name="ciclo_id" id="cicloSelect" class="form-control" required onchange="onCicloChange()">
                        <option value="">-- Seleccione una plantilla --</option>
                        <option value="custom"><i class="fas fa-cog"></i> Personalizada (definir fechas manualmente)</option>
                        <% if (typeof ciclos !== 'undefined' && ciclos) { ciclos.forEach(function(c) { %>
                        <option value="<%= c.id %>"
                            data-type="<%= c.billing_type %>"
                            data-invoice="<%= c.invoice_day %>"
                            data-suspend="<%= c.suspend_day %>"
                            data-tolerance="<%= c.tolerance_months %>"
                            data-grace="<%= c.grace_days %>">
                            <%= c.name || (c.billing_type.toUpperCase() + ' | Gen: Día ' + c.invoice_day + ' | Corte: Día ' + c.suspend_day) %>
                        </option>
                        <% }); } %>
                    </select>
                    <small style="color:var(--text-gray);font-size:0.75rem;margin-top:4px;display:block;">
                        Seleccione una plantilla o elija "Personalizada" para definir fechas manualmente.
                    </small>
                </div>
                <div id="divCicloPreset" style="display:none;grid-column:span 2;">
                    <div id="resumenCiclo" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;padding:12px 16px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
                        <span id="badgeTipo" style="padding:4px 12px;border-radius:5px;font-size:0.82rem;font-weight:700;"></span>
                        <span id="badgeGen" style="padding:4px 12px;border-radius:5px;font-size:0.82rem;font-weight:600;background:#e0f2fe;color:#0369a1;">
                            <i class="fas fa-file-invoice"></i> Gen: Día <span id="txtGen"></span>
                        </span>
                        <span id="badgeCorte" style="padding:4px 12px;border-radius:5px;font-size:0.82rem;font-weight:600;background:#fee2e2;color:#991b1b;">
                            <i class="fas fa-ban"></i> Corte: Día <span id="txtCorte"></span>
                        </span>
                        <span id="badgeTol" style="padding:4px 12px;border-radius:5px;font-size:0.78rem;font-weight:600;background:#fef3c7;color:#92400e;">
                            <i class="fas fa-clock"></i> <span id="txtTol"></span> mes(es) tolerancia
                        </span>
                        <span id="badgeGrace" style="display:none;padding:4px 12px;border-radius:5px;font-size:0.78rem;font-weight:600;background:#e0e7ff;color:#3730a3;">
                            <i class="fas fa-hourglass-half"></i> <span id="txtGrace"></span> días gracia
                        </span>
                    </div>
                </div>
                <div id="divCicloCustom" style="display:none;grid-column:span 2;background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:16px;">
                    <div class="form-grid" style="margin:0;">
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">Tipo <span style="color:red">*</span></label>
                            <select name="billing_type" id="billingTypeSelect" class="form-control" onchange="mostrarInfoCiclo()">
                                <option value="">-- Seleccione --</option>
                                <option value="postpago">POSTPAGO</option>
                                <option value="prepago">PREPAGO</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">Día de Generación (factura) <span style="color:red">*</span></label>
                            <select name="dia_generacion" id="diaGeneracion" class="form-control">
                                <% for(var d=1; d<=31; d++) { %>
                                <option value="<%= d %>" <%= d===25?'selected':'' %>>Día <%= d %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">Día de Corte (suspensión) <span style="color:red">*</span></label>
                            <select name="dia_corte" id="diaCorte" class="form-control">
                                <% for(var d=1; d<=31; d++) { %>
                                <option value="<%= d %>" <%= d===11?'selected':'' %>>Día <%= d %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label class="form-label">Tolerancia (meses vencidos)</label>
                            <input type="number" name="tolerance_months" id="toleranceMonths" class="form-control" min="1" max="12" value="1">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Costo de Instalación -->
            <h4 style="color:var(--accent);border-bottom:1px solid #eee;padding-bottom:10px;margin:30px 0 20px 0;">
                <i class="fas fa-tools"></i> Instalación
            </h4>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Costo de Instalación (RD$)</label>
                    <input type="number" name="precio_instalacion" id="inputPrecioInst" class="form-control"
                           value="0" min="0" step="0.01"
                           onchange="actualizarInstalacion()">
                </div>
                <div class="form-group" style="display:flex;align-items:flex-end;gap:10px;padding-bottom:8px;">
                    <label class="checkbox-label" style="display:flex;align-items:center;gap:6px;cursor:pointer;">
                        <input type="checkbox" name="crear_factura_instalacion" id="chkFacturaInst" value="1"
                               onchange="actualizarInstalacion()">
                        Crear factura de instalación
                    </label>
                    <label class="checkbox-label" style="display:flex;align-items:center;gap:6px;cursor:pointer;">
                        <input type="checkbox" name="instalacion_pagada" id="chkInstPagada" value="1"
                               onchange="actualizarInstalacion()">
                        Instalación pagada
                    </label>
                </div>
            </div>

            <!-- Crea Orden -->
            <div style="margin-top:30px;text-align:right;border-top:1px solid #eee;padding-top:20px;">
                <button type="submit" class="btn btn-primary" style="padding:12px 30px;font-size:1rem;">
                    <i class="fas fa-clipboard-list"></i> Crear Orden
                </button>
            </div>
        </fieldset>
    </form>
</div>

<!-- Modal Resultado -->
<div id="modalResultado" class="modal" style="display:none;">
    <div class="modal-content" style="max-width:420px;">
        <div class="modal-header">
            <h3 id="modalResultadoTitle"><i class="fas fa-check-circle"></i> Cliente Creado</h3>
            <span class="modal-close" onclick="cerrarResultado()">&times;</span>
        </div>
        <div class="modal-body">
            <p id="modalResultadoMsg" style="text-align:center;padding:10px 0;"></p>
            <div class="btn-group" style="justify-content:center;margin-top:16px;">
                <button class="btn btn-secondary" onclick="cerrarResultado()">Cerrar</button>
                <button class="btn btn-primary" onclick="irAClientes()">Ir a Clientes</button>
            </div>
        </div>
    </div>
</div>

<style>
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    @media (max-width:768px) {
        .form-grid { grid-template-columns:1fr; }
        .form-group[style*="span 2"] { grid-column:span 1 !important; }
        .doc-row { flex-wrap:wrap !important; }
        .doc-row select, .doc-row input, .doc-row button { width:100% !important; min-width:0 !important; flex-shrink:1 !important; }
    }
    .checkbox-label { font-size:0.85rem; color:var(--text-color); }
</style>

<script>
var clienteConfirmado = null;
var planesCache = {};

function onCicloChange() {
    var sel = document.getElementById('cicloSelect');
    var val = sel.value;
    var pres = document.getElementById('divCicloPreset');
    var cust = document.getElementById('divCicloCustom');
    if (val === 'custom') {
        pres.style.display = 'none';
        cust.style.display = 'block';
    } else if (val && val !== '') {
        cust.style.display = 'none';
        pres.style.display = 'block';
        var opt = sel.options[sel.selectedIndex];
        var tipo = opt.getAttribute('data-type');
        var inv = opt.getAttribute('data-invoice');
        var susp = opt.getAttribute('data-suspend');
        var tol = opt.getAttribute('data-tolerance');
        var grace = opt.getAttribute('data-grace');
        document.getElementById('badgeTipo').textContent = tipo.toUpperCase();
        document.getElementById('badgeTipo').style.background = tipo === 'postpago' ? '#fef3c7' : '#dcfce7';
        document.getElementById('badgeTipo').style.color = tipo === 'postpago' ? '#92400e' : '#166534';
        document.getElementById('txtGen').textContent = inv;
        document.getElementById('txtCorte').textContent = susp;
        document.getElementById('txtTol').textContent = tol;
        var graceBadge = document.getElementById('badgeGrace');
        if (grace && parseInt(grace) > 0) {
            document.getElementById('txtGrace').textContent = grace;
            graceBadge.style.display = 'inline-flex';
        } else {
            graceBadge.style.display = 'none';
        }
    } else {
        pres.style.display = 'none';
        cust.style.display = 'none';
    }
}

// Cargar todos los planes disponibles
<% (planes || []).forEach(function(p) { %>
if (!planesCache['todas']) planesCache['todas'] = [];
planesCache['todas'].push({ id: <%= p.id %>, nombre: '<%= (p.nombre || "").replace(/'/g, "\\'") %>', velocidad: '<%= (p.velocidad || "").replace(/'/g, "\\'") %>', precio: <%= p.precio || 0 %> });
<% }); %>

function limpiarInput(el) { el.value = el.value.replace(/[^0-9]/g,''); }

function validarDocumento() {
    var tipo = document.getElementById('tipoDoc').value;
    var num = document.getElementById('inputCedula').value.trim();
    var docResult = document.getElementById('docResult');

    if (!num) { docResult.style.display = 'block'; docResult.innerHTML = '<span style="color:red;">Debe escribir un número de documento.</span>'; return; }

    docResult.style.display = 'block';
    docResult.innerHTML = '<span style="color:var(--text-gray);"><i class="fas fa-spinner fa-spin"></i> Verificando...</span>';

    fetch('/api/nuevo-cliente/verificar-documento', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tipo: tipo, numero: num })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.existe) {
            docResult.innerHTML = '<span style="color:#d97706;"><i class="fas fa-exclamation-triangle"></i> Este documento ya está registrado: <strong>' + d.cliente.nombre + '</strong></span>';
            clienteConfirmado = d.cliente;
            document.getElementById('btnConfirmarDoc').disabled = true;
            return;
        }
        docResult.innerHTML = '<span style="color:#16a34a;"><i class="fas fa-check-circle"></i> Documento válido. Complete los datos.</span>';
        clienteConfirmado = null;
        document.getElementById('restoFormulario').disabled = false;
        document.getElementById('restoFormulario').style.opacity = '1';
        document.getElementById('inputName').focus();
    })
    .catch(function(e) {
        docResult.innerHTML = '<span style="color:red;">Error de conexión. Intente de nuevo.</span>';
    });
}

function mostrarPlanes() {
    var sectorId = document.getElementById('sectorSelect').value;
    var divPlan = document.getElementById('divPlan');
    var planSelect = document.getElementById('planSelect');

    if (!sectorId) { divPlan.style.display = 'none'; return; }

    divPlan.style.display = 'block';
    planSelect.innerHTML = '<option value="">-- Seleccione Plan --</option>';

    var planes = planesCache['todas'] || [];

    planes.forEach(function(p) {
        var opt = document.createElement('option');
        opt.value = p.id;
        opt.textContent = p.nombre + (p.velocidad ? ' (' + p.velocidad + ')' : '') + ' - RD$' + (p.precio || 0);
        planSelect.appendChild(opt);
    });
}

function mostrarInfoCiclo() {
    var tipo = document.getElementById('billingTypeSelect').value;
    var divInfo = document.getElementById('divInfoCiclo');
    var badgeTipo = document.getElementById('badgeTipo');
    var badgeGen = document.getElementById('badgeGen');
    var badgeCorte = document.getElementById('badgeCorte');
    var txtGen = document.getElementById('txtGen');
    var txtCorte = document.getElementById('txtCorte');
    var diaGen = document.getElementById('diaGeneracion').value;
    var diaCorte = document.getElementById('diaCorte').value;

    if (!tipo) { divInfo.style.display = 'none'; return; }

    divInfo.style.display = 'block';
    badgeTipo.textContent = tipo.toUpperCase();
    badgeTipo.style.background = tipo === 'postpago' ? '#dbeafe' : '#fef3c7';
    badgeTipo.style.color = tipo === 'postpago' ? '#1e40af' : '#92400e';

    if (tipo) {
        badgeGen.style.display = 'inline-flex';
        badgeCorte.style.display = 'inline-flex';
        txtGen.textContent = diaGen;
        txtCorte.textContent = diaCorte;
    }
}

function actualizarInstalacion() {
    var precio = parseFloat(document.getElementById('inputPrecioInst').value) || 0;
    var chkFactura = document.getElementById('chkFacturaInst');
    var chkPagada = document.getElementById('chkInstPagada');

    if (precio <= 0) {
        chkFactura.checked = false;
        chkPagada.checked = false;
        chkFactura.disabled = true;
        chkPagada.disabled = true;
    } else {
        chkFactura.disabled = false;
        chkPagada.disabled = false;
    }
}

// Submit
document.getElementById('formNuevoCliente').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = this;
    var btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

    var fd = new FormData(form);
    var data = {};
    fd.forEach(function(v, k) { data[k] = v; });

    fetch('/api/nuevo-cliente/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Crear Orden';
        if (d.success) {
            window.location.href = '/modulo?pagina=Ordenes';
        } else {
            document.getElementById('modalResultadoTitle').innerHTML = '<i class="fas fa-times-circle" style="color:#dc2626;"></i> Error';
            document.getElementById('modalResultadoMsg').innerHTML = d.message || 'Error al guardar. Intente de nuevo.';
            document.getElementById('modalResultado').style.display = 'flex';
        }
    })
    .catch(function(e) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Crear Orden';
        document.getElementById('modalResultadoTitle').innerHTML = '<i class="fas fa-times-circle" style="color:#dc2626;"></i> Error';
        document.getElementById('modalResultadoMsg').innerHTML = 'Error de conexión. Intente de nuevo.';
        document.getElementById('modalResultado').style.display = 'flex';
    });
});

function cerrarResultado() { document.getElementById('modalResultado').style.display = 'none'; }
function irAClientes() { window.location.href = '/modulo?pagina=Clientes'; }

// Init
document.getElementById('restoFormulario').disabled = true;
document.getElementById('restoFormulario').style.opacity = '0.6';
document.getElementById('chkFacturaInst').disabled = true;
document.getElementById('chkInstPagada').disabled = true;
</script>
