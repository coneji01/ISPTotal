  html += '<div class="co-param-item"><span class="co-param-label">PPPoE Contraseña</span><span class="co-param-value">' + (coState.pppoePass ? '••••••••' : 'N/A') + '</span></div>';
  
  // WiFi params
  var wifiHtml = '<div class="co-card"><div class="co-card-title"><i class="fas fa-wifi"></i> Configuración WiFi</div>';
  wifiHtml += '<label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">SSID 2.4GHz</label>';
  wifiHtml += '<input type="text" class="form-control" id="coWifiSsid24" value="' + (coState.wifiSsid24 || '') + '" placeholder="Ej: ISPTotal-WiFi" style="margin-bottom:8px;">';
  wifiHtml += '<label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">Contraseña 2.4GHz</label>';
  wifiHtml += '<input type="text" class="form-control" id="coWifiPass24" value="' + (coState.wifiPass24 || '') + '" placeholder="Ej: Clave1234" style="margin-bottom:8px;">';
  wifiHtml += '<label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">SSID 5GHz</label>';
  wifiHtml += '<input type="text" class="form-control" id="coWifiSsid5" value="' + (coState.wifiSsid5 || '') + '" placeholder="Opcional" style="margin-bottom:8px;">';
  wifiHtml += '<label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">Contraseña 5GHz</label>';
  wifiHtml += '<input type="text" class="form-control" id="coWifiPass5" value="' + (coState.wifiPass5 || '') + '" placeholder="Opcional" style="margin-bottom:4px;">';
  wifiHtml += '</div>';
  
  // VLAN
  var vlanHtml = '<div class="co-card"><div class="co-card-title"><i class="fas fa-tag"></i> VLAN</div>';
