  html += '<div class="co-param-item"><span class="co-param-label">ONU Vieja (SN)</span><span class="co-param-value">' + coState.oldOnuSn + '</span></div>';
  html += '<div class="co-param-item"><span class="co-param-label">OLT Vieja</span><span class="co-param-value">' + coState.oldOltName + '</span></div>';
  html += '<div class="co-param-item"><span class="co-param-label">ONU Nueva (SN)</span><span class="co-param-value">' + coState.newOnuSn + '</span></div>';
  html += '<div class="co-param-item"><span class="co-param-label">OLT Nueva</span><span class="co-param-value">' + coState.newOltName + '</span></div>';
