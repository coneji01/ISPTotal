function abrirModalRazon() {
  // Save WiFi/VLAN values
  if (document.getElementById('coWifiSsid24')) coState.wifiSsid24 = document.getElementById('coWifiSsid24').value;
  if (document.getElementById('coWifiPass24')) coState.wifiPass24 = document.getElementById('coWifiPass24').value;
  if (document.getElementById('coWifiSsid5')) coState.wifiSsid5 = document.getElementById('coWifiSsid5').value;
  if (document.getElementById('coWifiPass5')) coState.wifiPass5 = document.getElementById('coWifiPass5').value;
  if (document.getElementById('coVlan')) coState.vlan = document.getElementById('coVlan').value;
  
  document.getElementById('coRazonCambio').value = '';
  openModal('coReasonModal');
}

function confirmarCambio() {
  var razon = document.getElementById('coRazonCambio').value.trim();
  if (!razon) { alert('Debe ingresar el motivo del cambio.'); return; }
  coState.changeReason = razon;
  closeModal('coReasonModal');
  
  // Show confirm modal
  var paramsHtml = '';
  var items = [
    ['Cliente', coState.cliente ? coState.cliente.nombre : ''],
    ['Servicio', '#SVC-' + (coState.servicio ? coState.servicio.id : '')],
    ['ONU Vieja', coState.oldOnuSn],
    ['OLT Vieja', coState.oldOltName],
    ['ONU Nueva', coState.newOnuSn],
    ['OLT Nueva', coState.newOltName],
    ['PPPoE', coState.pppoeUser || 'DHCP'],
    ['WiFi 2.4', coState.wifiSsid24 || 'No'],
    ['WiFi 5', coState.wifiSsid5 || 'No'],
    ['VLAN', coState.vlan || 'Default OLT']
  ];
  items.forEach(function(item) {
    paramsHtml += '<div class="co-confirm-label">' + item[0] + '</div><div class="co-confirm-value">' + item[1] + '</div>';
  });
  document.getElementById('coConfirmParams').innerHTML = paramsHtml;
  document.getElementById('coConfirmRazon').textContent = razon;
  openModal('coConfirmModal');
}

function ejecutarCambio() {
  closeModal('coConfirmModal');
  var overlay = document.getElementById('coLoadingOverlay');
  overlay.classList.add('active');
  
  // Reset loading steps
  document.querySelectorAll('.co-loading-step').forEach(function(el) {
    el.className = 'co-loading-step pending';
    el.querySelector('i').className = 'fas fa-circle';
  });
  
  // ===== NUEVO FLUJO: Primero autorizar, luego eliminar =====
  
  // STEP 1: Authorize new ONU first
  document.getElementById('coLoadingStatus').textContent = 'Autorizando nueva ONU...';
  var step1 = document.querySelector('.co-loading-step[data-step="authorize"]');
  step1.className = 'co-loading-step active';
  step1.querySelector('i').className = 'fas fa-spinner fa-spin';
  
  fetch('/api/cambio-onu/autorizar-nueva-onu', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      olt_id: coState.newOnuOltId,
      serial: coState.newOnuSn,
      onu_type: coState.onuType || 'Generic',
      cliente_nombre: coState.cliente ? coState.cliente.nombre : '',
      servicio_id: coState.servicio.id,
      vlan: coState.vlan || '',
      board: coState.newOnuBoard || '',
      port: coState.newOnuPort || '',
      pppoe_user: coState.pppoeUser || '',
      pppoe_pass: coState.pppoePass || '',
      onu_mode: coState.pppoeUser ? 'bridge' : 'bridge'
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(authResult) {
    if (!authResult.success) {
      throw new Error(authResult.message || 'Error al autorizar nueva ONU');
    }
    step1.className = 'co-loading-step done';
    step1.querySelector('i').className = 'fas fa-check-circle';
    
    // STEP 2: Verify ONU was added in SmartOLT
    document.getElementById('coLoadingStatus').textContent = 'Verificando ONU en SmartOLT...';
    return new Promise(function(resolve, reject) {
      var attempts = 0;
      var maxAttempts = 6;
      function checkOnu() {
        attempts++;
        fetch('/api/cambio-onu/verificar-onu', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ olt_id: coState.newOnuOltId, serial: coState.newOnuSn })
        })
        .then(function(r) { return r.json(); })
        .then(function(checkResult) {
          if (checkResult.found) {
            resolve(checkResult);
          } else if (attempts >= maxAttempts) {
            reject(new Error('La ONU no se registró en SmartOLT después de varios intentos'));
          } else {
            setTimeout(checkOnu, 5000);
          }
        })
        .catch(function() {
          if (attempts >= maxAttempts) reject(new Error('Error verificando ONU'));
          else setTimeout(checkOnu, 5000);
        });
      }
      setTimeout(checkOnu, 3000);
    });
  })
  .then(function(verifyResult) {
    // STEP 3: Delete old ONU (only if new one is verified)
    document.getElementById('coLoadingStatus').textContent = 'Eliminando ONU vieja...';
    var step3 = document.querySelector('.co-loading-step[data-step="delete"]');
    step3.className = 'co-loading-step active';
    step3.querySelector('i').className = 'fas fa-spinner fa-spin';
    
    return fetch('/api/cambio-onu/eliminar-onu-vieja', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sn: coState.oldOnuSn, olt_id: coState.oldOnuOltId, servicio_id: coState.servicio.id })
    });
  })
  .then(function(r) { return r.json(); })
  .then(function(deleteResult) {
    var step3 = document.querySelector('.co-loading-step[data-step="delete"]');
    step3.className = 'co-loading-step done';
    step3.querySelector('i').className = 'fas fa-check-circle';
    
    // STEP 4: Create swap record
    document.getElementById('coLoadingStatus').textContent = 'Registrando cambio en base de datos...';
    var step4 = document.querySelector('.co-loading-step[data-step="register"]');
    step4.className = 'co-loading-step active';
    step4.querySelector('i').className = 'fas fa-spinner fa-spin';
    
    return fetch('/api/cambio-onu/crear-swap', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        cliente_id: coState.cliente ? coState.cliente.id : null,
        servicio_id: coState.servicio ? coState.servicio.id : null,
        old_sn: coState.oldOnuSn,
        new_sn: coState.newOnuSn,
        old_olt_id: coState.oldOnuOltId,
        new_olt_id: coState.newOnuOltId,
        pppoe_user: coState.pppoeUser,
        pppoe_pass: coState.pppoePass,
        wifi_ssid_24: coState.wifiSsid24,
        wifi_pass_24: coState.wifiPass24,
        wifi_ssid_5: coState.wifiSsid5,
        wifi_pass_5: coState.wifiPass5,
        vlan: coState.vlan,
        onu_type: coState.onuType,
        change_reason: coState.changeReason
      })
    });
  })
  .then(function(r) { return r.json(); })
  .then(function(swapResult) {
    var step4 = document.querySelector('.co-loading-step[data-step="register"]');
    if (swapResult.success) {
      step4.className = 'co-loading-step done';
      step4.querySelector('i').className = 'fas fa-check-circle';
      coState.swapId = swapResult.id;
    } else {
      step4.className = 'co-loading-step failed';
      step4.querySelector('i').className = 'fas fa-times-circle';
    }
    
    if (coState.swapId && coState.changeReason) {
      fetch('/api/cambio-onu/actualizar-razon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: coState.swapId, change_reason: coState.changeReason })
      }).catch(function() {});
    }
    
    document.getElementById('coLoadingStatus').textContent = 'Cambio completado';
    overlay.classList.remove('active');
    mostrarResultado();
  })
  .catch(function(err) {
    document.getElementById('coLoadingStatus').textContent = 'Error: ' + err.message;
    document.querySelector('.co-loading-step[data-step="delete"]').className = 'co-loading-step failed';
    document.querySelector('.co-loading-step[data-step="delete"] i').className = 'fas fa-times-circle';
    setTimeout(function() {
      overlay.classList.remove('active');
      alert('Error durante el cambio: ' + err.message);
    }, 1500);
  });
}

function mostrarResultado() {
  document.getElementById('coResultCard').style.display = 'block';
  var html = '';
  
  html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">ONU vieja (SN: ' + coState.oldOnuSn + ') eliminada de SmartOLT y desvinculada del servicio.</div></div>';
  
  html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">Nueva ONU (SN: ' + coState.newOnuSn + ') autorizada y configurada en ' + coState.newOltName + '.</div></div>';
  
  if (coState.pppoeUser) {
    html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">WAN configurada en modo PPPoE con usuario: ' + coState.pppoeUser + '</div></div>';
  } else {
    html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">WAN configurada en modo DHCP</div></div>';
  }
  
  if (coState.wifiSsid24) {
    html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">WiFi 2.4GHz configurado: SSID=' + coState.wifiSsid24 + '</div></div>';
  }
  if (coState.wifiSsid5) {
    html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">WiFi 5GHz configurado: SSID=' + coState.wifiSsid5 + '</div></div>';
  }
  
  html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">TR-069 habilitado en la nueva ONU para gestión remota.</div></div>';
  
  if (coState.vlan) {
    html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">VLAN ' + coState.vlan + ' configurada en servicio y ONU.</div></div>';
  }
  
  html += '<div class="co-result-step done"><i class="fas fa-check-circle"></i><div class="co-result-text">Swap registrado (ID: ' + coState.swapId + ') con motivo: ' + coState.changeReason + '</div></div>';
  
  html += '<div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border-color);text-align:center;">';
  html += '<button class="btn btn-primary" onclick="resetWizard()"><i class="fas fa-redo"></i> Realizar Otro Cambio</button>';
  html += '</div>';
  
  document.getElementById('coResultSteps').innerHTML = html;
}

// ===== HISTORY =====
var historyVisible = false;
function toggleHistory() {
  var panel = document.getElementById('coHistoryPanel');
  historyVisible = !historyVisible;
  panel.classList.toggle('active');
  if (historyVisible) cargarHistorial(1);
}

function cargarHistorial(page) {
  page = page || 1;
  var search = document.getElementById('coHistorySearch') ? document.getElementById('coHistorySearch').value.trim() : '';
  
  var url = '/api/cambio-onu/historial?page=' + page + '&limit=20';
  if (search) url += '&search=' + encodeURIComponent(search);
  
  fetch(url)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.success) { document.getElementById('coHistoryBody').innerHTML = '<tr><td colspan="9" style="text-align:center;padding:20px;color:var(--danger);">' + data.message + '</td></tr>'; return; }
      
      var html = '';
      if (data.data.length === 0) {
        html = '<tr><td colspan="9" style="text-align:center;padding:20px;color:var(--text-gray);">No se encontraron registros</td></tr>';
      } else {
        data.data.forEach(function(r) {
          html += '<tr>';
          html += '<td>' + r.id + '</td>';
          html += '<td><strong>' + (r.cliente_nombre || 'N/A') + '</strong></td>';
          html += '<td style="font-family:monospace;font-size:11px;">' + (r.old_sn || '') + '</td>';
          html += '<td style="font-family:monospace;font-size:11px;">' + (r.new_sn || '') + '</td>';
          html += '<td>' + (r.old_olt_nombre || '') + '</td>';
          html += '<td>' + (r.new_olt_nombre || '') + '</td>';
          html += '<td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + (r.change_reason || '') + '">' + (r.change_reason || '') + '</td>';
          html += '<td style="font-size:11px;">' + (r.completed_at || '') + '</td>';
          html += '<td style="font-size:11px;">' + (r.creado_por || '') + '</td>';
          html += '</tr>';
        });
      }
      document.getElementById('coHistoryBody').innerHTML = html;
      document.getElementById('coHistoryInfo').textContent = 'Página ' + data.page + ' de ' + data.pages + ' (' + data.total + ' registros)';
      
      // Pagination
      var pagesHtml = '';
      for (var i = 1; i <= data.pages; i++) {
        pagesHtml += '<button class="btn btn-sm ' + (i === data.page ? 'btn-primary' : 'btn-secondary') + '" onclick="cargarHistorial(' + i + ')">' + i + '</button>';
      }
      document.getElementById('coHistoryPages').innerHTML = pagesHtml;
    })
    .catch(function(err) {
      document.getElementById('coHistoryBody').innerHTML = '<tr><td colspan="9" style="text-align:center;padding:20px;color:var(--danger);">Error: ' + err.message + '</td></tr>';
    });
}

// ===== INIT =====
document.addEventListener('DOMContentLoaded', function() {
  // Preload zone/olt info if available
  var autoOlt = '<%= JSON.stringify(typeof zonas !== 'undefined' ? zonas : []) %>';
  goToStep(1);
});
</script>
