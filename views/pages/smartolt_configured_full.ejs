<!DOCTYPE html><html lang="en"><head>
<script>window.SMARTOLT_DB_THEME='night';</script>
<script>try{var k='smartolt-night',lk='smartolt-theme-local',dbTheme=window.SMARTOLT_DB_THEME,local=null,pref,n;try{local=localStorage.getItem(lk);}catch(e){}if(local==='night'||local==='light'||local==='system'){pref=local;}else if(dbTheme==='night'||dbTheme==='light'||dbTheme==='system'){pref=dbTheme;}else{pref='system';}if(pref==='system'){n=!!(window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches);}else if(pref==='night'){n=true;}else{n=false;}try{localStorage.setItem(k,n?'1':'0');}catch(e){}if(n){document.documentElement.classList.add('smartolt-night');}else{document.documentElement.classList.remove('smartolt-night');}document.cookie=k+'='+(n?'1':'0')+'; path=/; max-age=31536000; SameSite=Lax'+(location.protocol==='https:'?'; Secure':'');}catch(e){}</script>
<meta http-equiv="content-type" content="text/html; utf-8">
<meta charset="utf-8">
<meta http-equiv="Content-Language" content="en">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Configured ONUs - JOEL WIFI</title>
<link rel="stylesheet" type="text/css" href="/public/smartolt-files/bootstrap.min.css">
<link rel="stylesheet" type="text/css" href="/public/smartolt-files/font-awesome/css/font-awesome.min.css">
<link rel="stylesheet" type="text/css" href="/public/smartolt-files/dashboard-smartolt-night.css">
<style>
body.smartolt-site { background: #0f1a2e; color: #e0e0e0; font-family: Inter, system-ui, sans-serif; }
.container-fluid.content-wrap { padding: 15px 30px; }
h2 { font-size: 24px; font-weight: 600; margin-top: 10px; }
table.table { background: rgba(15,26,46,0.92); border-radius: 8px; }
table.table thead th { background: rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.1); color: #98989D; font-weight: 500; font-size: 12px; padding: 8px 6px; }
table.table tbody td { padding: 6px; vertical-align: middle; border-top: 1px solid rgba(255,255,255,0.05); font-size: 12px; }
.valign-center td { vertical-align: middle !important; }
.onu-copy-cell { cursor: copy; border-radius: 4px; padding: 1px 3px; display: inline-block; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.onu-copy-cell:hover { background: rgba(255,255,255,0.1); }
.pagination>li>a { background: transparent; border-color: rgba(255,255,255,0.1); color: #e0e0e0; }
.pagination>li.active>a { background: #3498db; border-color: #3498db; }
.pagination>li>a:hover { background: rgba(255,255,255,0.1); }
.text-green { color: #4db14b; }
.text-warning { color: #f0ad4e; }
.text-red { color: #e06600; }
.text-grey { color: #6c757d; }
.loading-wrap { text-align: center; padding: 60px 0; color: #98989D; }
.loading-wrap .fa { font-size: 36px; margin-bottom: 10px; }
</style>
</head>
<body class="smartolt-site smartolt-dashboard">
<nav class="navbar navbar-inverse navbar-static-top" role="navigation" style="margin-bottom:0">
  <div class="navbar-header"><a class="navbar-brand" href="/modulo?pagina=GPONManager">JOEL WIFI</a></div>
</nav>
<div class="container-fluid content-wrap">
  <h2>Configured ONUs</h2>
  <div id="onu_configured_list" class="h-75">
    <div class="loading-wrap"><i class="fa fa-spinner fa-spin"></i><br>Loading ONUs...</div>
  </div>
</div>
<script src="/public/smartolt-files/jquery.min.js"></script>
<script src="/public/smartolt-files/bootstrap.min.js"></script>
<script>
window.getOnuStatus = window.getOnuStatus || function(){ return {done:function(fn){fn({});return this;},fail:function(){}}; };
window.refreshConfigured = window.refreshConfigured || function(){};
window.renderConfigured = window.renderConfigured || function(){};
window.getConfigured = window.getConfigured || function(){};
window.getConfiguredSelectedOltIds = function(){ return []; };

function cargarConfigured(pag) {
  pag = pag || 1;
  var h = '<div class="loading-wrap"><i class="fa fa-spinner fa-spin"></i><br>Loading...</div>';
  $('#onu_configured_list').html(h);
  $.ajax({ url: '/api/onu/configured-list?page=' + pag + '&per_page=100&_=' + Date.now(), method: 'GET', dataType: 'json',
    success: function(r) {
      if (!r.success || !r.data) return;
      h = '<div class="table-responsive"><table class="table table-striped table-bordered"><thead><tr><th></th><th>Status</th><th>View</th><th>Name</th><th>SN / MAC</th><th>ONU</th><th>Zone</th><th>ODB</th><th>Signal</th><th>B/R</th><th>VLAN</th><th>VoIP</th><th>TV</th><th>Type</th><th>Auth date</th></tr></thead><tbody>';
      r.data.forEach(function(o) {
        var ic = 'fa-globe text-green';
        if (o.state === 'pwrfail') ic = 'fa-exclamation-triangle text-warning';
        else if (o.state === 'los') ic = 'fa-times-circle text-red';
        else if (o.state === 'offline') ic = 'fa-circle text-grey';
        h += '<tr class="valign-center"><td></td><td class="text-center"><i class="fa ' + ic + '" style="font-size:16px"></i></td>';
        h += '<td class="text-center"><a href="/onu/view/' + o.id + '" class="btn btn-success btn-xs">View</a></td>';
        h += '<td><span class="onu-copy-cell" data-copy="' + $('<div>').text(o.name||'').html() + '">' + $('<div>').text(o.name||'').html() + '</span></td>';
        h += '<td><span class="onu-copy-cell" data-copy="' + (o.sn||'') + '">' + (o.sn||'') + '</span></td>';
        h += '<td style="font-size:12px">' + (o.description||'') + '</td>';
        h += '<td>' + (o.zone_name||'') + '</td><td>' + (o.odb||'') + '</td>';
        h += '<td style="white-space:nowrap">' + (o.signal||'') + '</td>';
        h += '<td>' + (o.mode||'') + '</td><td>' + (o.vlan||'') + '</td>';
        h += '<td>' + (o.voip||'') + '</td><td>' + (o.tv||'') + '</td>';
        h += '<td>' + (o.onu_type_name||'') + '</td>';
        h += '<td style="white-space:nowrap">' + (o.auth_date||'') + '</td></tr>';
      });
      h += '</tbody></table></div>';
      var tp = r.last_page || 1;
      h += '<div class="text-center"><ul class="pagination pagination-sm">';
      for (var i = 1; i <= tp; i++) {
        h += '<li class="' + (i === pag ? 'active':'') + '"><a href="#" onclick="cargarConfigured(' + i + ');return false">' + i + '</a></li>';
      }
      h += '</ul></div>';
      var f = (pag-1)*100+1, t = Math.min(pag*100, r.total);
      h += '<div class="text-muted text-center" style="font-size:12px;padding:5px">' + f + '-' + t + ' ONUs of ' + r.total + ' displayed</div>';
      $('#onu_configured_list').html(h);
    },
    error: function() {
      $('#onu_configured_list').html('<div class="loading-wrap" style="color:#e06600"><i class="fa fa-exclamation-triangle"></i><br>Error loading ONUs</div>');
    }
  });
}
$(function() { cargarConfigured(1); });
</script>
</body>
</html>
