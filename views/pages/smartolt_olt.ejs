<body class="smartolt-site">
<script>
$(document).ready(function() {
  $.ajaxSetup({ cache: false });
  window.jqxhrs = [];
  window.registerJqxhr = function(j) { jqxhrs.push(j); };
  window.abortJqxhr = function() { for (var i = jqxhrs.length - 1; i >= 0; i--) { if (jqxhrs[i]) jqxhrs[i].abort(); } jqxhrs = []; };
  $(window).bind("beforeunload", function() { abortJqxhr(); });
  function unregisterJqxhr(e, j, s) { var idx = $.inArray(j, jqxhrs); if (idx != -1) jqxhrs.splice(idx, 1); }
  $(document).ajaxComplete(unregisterJqxhr);
  config = { X_TOKEN: 'ISPTOTAL' };
  
  // Eliminar OLT
  window.deleteOlt = function(id, name) {
    if (!confirm('Delete OLT "' + name + '" ID ' + id + '? This cannot be undone.')) return;
    $.post('/api/olt/delete', { id: id }).done(function(r) {
      if (r.success) { toast('✅ OLT deleted'); location.reload(); }
      else toast('❌ ' + (r.message || 'Error'));
    }).fail(function() { toast('❌ Delete failed'); });
  };
  
  // Test connection
  $(document).on('click', '.test-olt-btn', function() {
    var id = $(this).data('id');
    var btn = $(this);
    btn.find('i').removeClass('fa-plug').addClass('fa-spinner fa-spin');
    $.getJSON('/api/olt-detail?id=' + id, function(oltData) {
      if (!oltData.success || !oltData.data) { toast('❌ OLT not found'); btn.find('i').removeClass('fa-spinner fa-spin').addClass('fa-plug'); return; }
      var o = oltData.data;
      $.post('/api/olt/test-connection', { ip: o.olt_ip, port: o.olt_port || 23, username: o.olt_username || 'zte', password: 'zte' })
        .done(function(r) { toast(r.success ? '✅ ' + (r.message || 'Connected') : '❌ ' + (r.message || 'Failed')); })
        .fail(function() { toast('❌ Connection error'); })
        .always(function() { btn.find('i').removeClass('fa-spinner fa-spin').addClass('fa-plug'); });
    }).fail(function() { toast('❌ Error loading OLT'); btn.find('i').removeClass('fa-spinner fa-spin').addClass('fa-plug'); });
    return false;
  });
  
  // Cargar OLTs via AJAX
  $.getJSON('/api/olt-list', function(data) {
    if (!data || !data.success) return;
    var html = '';
    $.each(data.data, function(i, o) {
      var statusIcon = o.activo ? '<span class="label label-success">Online</span>' : '<span class="label label-danger">Offline</span>';
      html += '<tr>' +
        '<td><a href="/modulo?pagina=SmartoltSettings&olt_id=' + o.id + '" class="btn btn-success btn-sm">View</a></td>' +
        '<td>' + o.id + '</td>' +
        '<td>' + statusIcon + '</td>' +
        '<td>' + o.nombre + '</td>' +
        '<td>' + (o.olt_ip || '-') + '</td>' +
        '<td>23</td><td>161</td>' +
        '<td>' + (o.modelo || '-') + '</td>' +
        '<td>2.1.0</td>' +
        '<td>' +
        '<a href="/modulo?pagina=SmartoltSettings&olt_id=' + o.id + '" class="btn btn-link btn-sm" title="Edit"><i class="fa fa-pencil"></i></a>' +
        '<a href="#" class="btn btn-link btn-sm text-danger" onclick="deleteOlt(' + o.id + ',\'' + o.nombre + '\')" title="Delete"><i class="fa fa-trash"></i></a>' +
        '<a href="#" class="btn btn-link btn-sm test-olt-btn" data-id="' + o.id + '" title="Test connection"><i class="fa fa-plug"></i></a>' +
        '</td>' +
        '</tr>';
    });
    $('#olts-table tbody').html(html);
  });
});
</script>

