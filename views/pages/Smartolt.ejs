    <table class="table" id="tablaOnuTipos" style="display:none;">
        <thead><tr><th>Modelo</th><th>Tipo PON</th><th>Ethernet</th><th>WiFi</th><th class="text-right">Acciones</th></tr></thead>
        <tbody id="cuerpoOnuTipos"></tbody>
    </table>
    </div>
    <div id="onuVacio" style="display:none;padding:40px;text-align:center;color:#94a3b8;"><i class="fas fa-microchip" style="font-size:2rem;opacity:0.3;"></i><br><br>No hay modelos de ONU registrados.</div>
    <div id="onuError" style="display:none;padding:20px;text-align:center;color:#ef4444;"></div>
</div>

<!-- Modal OLT -->
<div class="modal-overlay" id="modalOLT">
    <div class="modal-content modal-wide animate-pop">
        <div class="modal-header"><h3 id="modalTituloOLT">Nueva OLT</h3><button onclick="cerrarModal('modalOLT')" class="close-btn">&times;</button></div>
        <form id="formOLT">
            <div class="tab-panel">
                <input type="hidden" id="oltId" value="0">
                <div class="section-title">Datos Generales</div>
                <div class="row"><div class="col-6"><label>Nombre</label><input type="text" id="oltNombre" class="form-control" required placeholder="Ej: OLT Principal"></div></div>

                <!-- Tabs: SmartOLT Cloud vs Directa -->
                <div style="display:flex;gap:0;margin:12px 0 8px;border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;">
                  <button type="button" id="tabSmartolt" class="olt-tab-btn active" onclick="toggleOltTab('smartolt')" style="flex:1;padding:10px;border:none;cursor:pointer;font-weight:700;font-size:0.88rem;background:#eff6ff;color:#2563eb;"><i class="fas fa-cloud"></i> SmartOLT Cloud</button>
                  <button type="button" id="tabDirecta" class="olt-tab-btn" onclick="toggleOltTab('directa')" style="flex:1;padding:10px;border:none;cursor:pointer;font-weight:600;font-size:0.88rem;background:transparent;color:#64748b;"><i class="fas fa-server"></i> Conexión Directa</button>
                </div>

                <!-- SmartOLT Cloud fields -->
                <div id="fieldsSmartolt">
                  <div class="section-title">Credenciales SmartOLT API</div>
                  <div class="row">
                      <div class="col-6">
                          <label>Subdominio</label>
                          <div style="display:flex;">
                              <span style="background:#e0e7ff;padding:9px 8px;border:1px solid #c7d2fe;border-right:0;border-radius:6px 0 0 6px;color:#4338ca;font-size:0.82rem;white-space:nowrap;">https://</span>
                              <input type="text" id="oltSubdominio" class="form-control" placeholder="miwisp" style="margin:0;border-radius:0;">
                              <span style="background:#e0e7ff;padding:9px 8px;border:1px solid #c7d2fe;border-left:0;border-radius:0 6px 6px 0;color:#4338ca;font-size:0.82rem;white-space:nowrap;">.smartolt.com</span>
                          </div>
                      </div>
                      <div class="col-6"><label>API Key</label><input type="password" id="oltApiKey" class="form-control" placeholder="API Key"></div>
                  </div>
                  <div class="row">
                      <div class="col-4"><label>ID OLT <small>(opcional)</small></label><input type="text" id="oltIdSmartolt" class="form-control" placeholder="Se auto-detecta"></div>
                      <div class="col-4"><label>VLAN ONU</label><input type="text" id="oltVlan" class="form-control" placeholder="Ej: 200"></div>
                      <div class="col-4"><label>VLAN TR069</label><input type="text" id="oltTr069Vlan" class="form-control" placeholder="Ej: 69"></div>
                      <div class="col-4"><label>Perfil TR069</label><input type="text" id="oltTr069Profile" class="form-control" placeholder="SmartOLT"></div>
                  </div>
                </div>

                <!-- Conexión Directa fields -->
                <div id="fieldsDirecta" style="display:none;">
                  <div class="section-title">Conexión Directa a OLT (Telnet/API)</div>
                  <div class="row">
                    <div class="col-4"><label>IP de la OLT</label><input type="text" id="oltIp" class="form-control" required placeholder="Ej: 192.168.20.80"></div>
                    <div class="col-4"><label>Puerto Telnet</label><input type="number" id="oltPort" class="form-control" value="23" placeholder="23"></div>
                    <div class="col-4"><label>Modelo</label>
                      <select id="oltModelo" class="form-control">
                        <option value="ZTE C300">ZTE C300</option>
                        <option value="Huawei">Huawei</option>
                        <option value="VSOL">VSOL</option>
                        <option value="C-Data">C-Data</option>
                        <option value="TP-Link">TP-Link</option>
                        <option value="Fiberhome">Fiberhome</option>
                        <option value="Otra">Otra</option>
                      </select>
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-6"><label>Usuario</label><input type="text" id="oltUser" class="form-control" placeholder="Ej: zte"></div>
                    <div class="col-6"><label>Contraseña</label><input type="password" id="oltPass" class="form-control" placeholder="Contraseña"></div>
                  </div>
                  <div class="section-title">Proxy SOCKS (Router MikroTik intermediario)</div>
                  <div class="row">
                    <div class="col-6"><label>Router intermediario</label>
                      <select id="oltRouterSelect" class="form-control" onchange="onOltRouterChange()">
                        <option value="">-- Seleccionar router --</option>
                      </select>
                    </div>
                    <div class="col-6"><label>IP del Proxy SOCKS</label><input type="text" id="oltSocksIp" class="form-control" placeholder="Ej: 172.30.105.2"></div>
                  </div>
                  <div class="row">
                    <div class="col-6"><label>Puerto SOCKS</label><input type="number" id="oltSocksPort" class="form-control" value="1080" placeholder="1080"></div>
                  </div>
                  <div style="margin-top:8px;padding:10px;background:#fefce8;border-radius:6px;font-size:0.82rem;color:#92400e;">
                    <i class="fas fa-info-circle"></i> El proxy SOCKS debe estar configurado en tu MikroTik. 
                    <a href="#" onclick="mostrarScriptSocks();return false;" style="color:#2563eb;text-decoration:underline;">¿Cómo configurarlo?</a>
                  </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-test" onclick="probarOLT()"><i class="fas fa-plug"></i> Probar</button>
