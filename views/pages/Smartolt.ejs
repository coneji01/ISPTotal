<!-- Modal Error -->
<div class="modal-overlay" id="modalError" style="z-index:20000;">
    <div class="modal-content error-modal animate-pop">
        <div class="modal-header"><h3><i class="fas fa-bug"></i> Detalle del Error</h3><button onclick="cerrarModal('modalError')" class="close-btn">&times;</button></div>
        <textarea id="txtErrorDetail" readonly></textarea>
        <div style="text-align:right;margin-top:10px;"><button class="btn-primary" onclick="cerrarModal('modalError')">Cerrar</button></div>
    </div>
</div>

<script>
var bandaSeleccionada = 'none';
var editandoOnuId = 0;
var erroresOLT = {};

function cerrarModal(id) { document.getElementById(id).style.display = 'none'; }

// Cargar routers en el selector de OLT directa
function cargarRoutersOlt() {
  var sel = document.getElementById('oltRouterSelect');
  if (!sel) return;
  fetch('/api/routers')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      sel.innerHTML = '<option value="">-- Seleccionar router --</option>';
      if (data && data.length > 0) {
        data.forEach(function(r) {
          var opt = document.createElement('option');
          opt.value = r.vpn_ip || r.ip || '';
          opt.textContent = r.name + ' (' + (r.vpn_ip || r.ip || 'sin IP') + ')';
          sel.appendChild(opt);
        });
      }
    })
    .catch(function(){});
}

function onOltRouterChange() {
  var ip = document.getElementById('oltRouterSelect').value;
  if (ip) {
    document.getElementById('oltSocksIp').value = ip;
  }
}

// ===== Tabs: SmartOLT vs Directa =====
function toggleOltTab(tab) {
  document.getElementById('tabSmartolt').className = 'olt-tab-btn' + (tab === 'smartolt' ? ' active' : '');
  document.getElementById('tabDirecta').className = 'olt-tab-btn' + (tab === 'directa' ? ' active' : '');
  document.getElementById('fieldsSmartolt').style.display = tab === 'smartolt' ? 'block' : 'none';
  document.getElementById('fieldsDirecta').style.display = tab === 'directa' ? 'block' : 'none';
  // Mark required fields
  document.getElementById('oltSubdominio').required = (tab === 'smartolt');
  document.getElementById('oltApiKey').required = (tab === 'smartolt');
  document.getElementById('oltIp').required = (tab === 'directa');
}

function mostrarScriptSocks() {
  var ip = document.getElementById('oltSocksIp').value || 'MIKROTIK_IP';
  var oltIp = document.getElementById('oltIp').value || 'OLT_IP';
  var script = [
    '# ===== Configurar SOCKS proxy en MikroTik =====',
    '/ip socks set enabled=yes port=1080',
    '/ip socks access add dst-address=' + oltIp + '/32 action=allow',
    '/ip firewall filter add chain=input src-address=0.0.0.0/0 protocol=tcp dst-port=1080 action=accept comment="SOCKS_ISPTotal"',
    '',
    ':log info "SOCKS proxy configurado para ISPTotal"'
  ].join('\n');
  
  var modal = document.getElementById('modalScriptSocks') || (function() {
    var d = document.createElement('div');
    d.id = 'modalScriptSocks';
    d.className = 'modal-overlay';
    d.style.cssText = 'display:flex;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:99999;justify-content:center;align-items:center;padding:10px;';
    d.innerHTML = '<div class="modal-content animate-pop" style="width:650px;max-width:100%;"><div class="modal-header"><h3><i class="fas fa-terminal"></i> Script para MikroTik</h3><button onclick="this.closest(\'.modal-overlay\').remove()" class="close-btn">&times;</button></div><div class="tab-panel"><p style="font-size:0.85rem;color:#64748b;margin-bottom:10px;">Copia y pega este script en la terminal de WinBox o en el terminal de tu MikroTik:</p><textarea id="txtScriptSocks" readonly style="width:100%;height:160px;border:1px solid #cbd5e1;border-radius:6px;padding:10px;font-family:monospace;font-size:0.85rem;background:#0f172a;color:#e2e8f0;box-sizing:border-box;"></textarea></div><div class="modal-footer"><button class="btn-primary" onclick="var t=document.getElementById(\'txtScriptSocks\');t.select();t.setSelectionRange(0,99999);document.execCommand(\'copy\');this.innerHTML=\'<i class=\\\'fas fa-check\\\'></i> Copiado\'">Copiar Script</button></div></div>';
    document.body.appendChild(d);
    return d;
  })();
  document.getElementById('txtScriptSocks').value = script;
  modal.style.display = 'flex';
}

// ===== OLTs =====
function cargarOLTs() {
  fetch('/api/olts').then(r=>r.json()).then(olts => {
    var tb = document.getElementById('tablaOlts');
    if (!olts || olts.length === 0) {
      tb.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:40px;color:#94a3b8;">No hay OLTs configuradas.<br><small>Haga clic en "Nueva OLT" para agregar una.</small></td></tr>';
      return;
    }
    var h = '';
    olts.forEach(function(olt) {
      var esDirecta = olt.tipo === 'local' || (olt.olt_ip && olt.olt_ip !== '');
      h += '<tr>';
      h += '<td><div class="olt-name">' + (olt.nombre || 'Sin nombre') + '</div><div class="olt-model"><i class="fas fa-' + (esDirecta ? 'server' : 'cloud') + '"></i> ' + (esDirecta ? 'Directa: ' + (olt.olt_ip || olt.ip || '') : 'SmartOLT') + (olt.vlan_default ? ' | VLAN: ' + olt.vlan_default : '') + '</div></td>';
      h += '<td id="estado_' + olt.id + '"><span class="loading-pulse">Verificando...</span></td>';
      h += '<td><div class="ip-addr"><i class="fas fa-' + (esDirecta ? 'server' : 'globe') + '"></i> ' + (esDirecta ? (olt.olt_ip || olt.ip || '') : (olt.smartolt_subdomain || '') + '.smartolt.com') + '</div></td>';
      h += '<td class="text-right">';
      h += '<button class="btn-action btn-orange" onclick="editarOLT(' + olt.id + ')" title="Editar"><i class="fas fa-cog"></i></button>';
      h += '<button class="btn-action btn-red" onclick="eliminarOLT(' + olt.id + ',\'' + (olt.nombre||'').replace(/'/g,"\\'") + '\')" title="Eliminar"><i class="fas fa-trash"></i></button>';
      h += '</td></tr>';
    });
    tb.innerHTML = h;
    olts.forEach(function(olt) {
      if (olt.smartolt_subdomain && olt.smartolt_api_key) {
        verificarEstado(olt.id, olt.smartolt_subdomain, olt.smartolt_api_key);
      } else if (olt.tipo === 'local' || (olt.olt_ip && olt.olt_ip !== '')) {
        verificarEstadoLocal(olt.id, olt.olt_ip || olt.ip, olt.olt_port || 23, olt.socks_host, olt.socks_port || 1080);
      }
    });
  }).catch(function() {});
}

function verificarEstado(id, sub, key) {
  var el = document.getElementById('estado_' + id);
  if (!el) return;
  fetch('/api/smartolt/test', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({subdomain:sub, api_key:key}) })
  .then(r=>r.json()).then(d => {
    el.innerHTML = d.success
      ? '<div class="status-ok"><i class="fas fa-circle" style="font-size:0.6rem;margin-right:4px;"></i> Conectada</div>'
      : '<div class="status-err" onclick="verError(' + id + ',\'' + (d.message || '').replace(/'/g, '') + '\')"><i class="fas fa-exclamation-triangle"></i> Error</div>';
    if (!d.success) erroresOLT[id] = d.message || 'Error';
  }).catch(function(e) {
    erroresOLT[id] = e.message;
    el.innerHTML = '<div class="status-err" onclick="verError(' + id + ',\'' + e.message.replace(/'/g, '') + '\')"><i class="fas fa-exclamation-triangle"></i> Error</div>';
  });
}

function verificarEstadoLocal(id, ip, port, socksHost, socksPort) {
  var el = document.getElementById('estado_' + id);
  if (!el) return;
  fetch('/api/olts/test-connection', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({olt_ip: ip, olt_port: port, socks_host: socksHost, socks_port: socksPort}) })
  .then(r=>r.json()).then(d => {
    el.innerHTML = d.success
      ? '<div class="status-ok"><i class="fas fa-circle" style="font-size:0.6rem;margin-right:4px;"></i> ' + (d.info || 'Conectada') + '</div>'
      : '<div class="status-err" onclick="verError(' + id + ',\'' + (d.message || '').replace(/'/g, '') + '\')"><i class="fas fa-exclamation-triangle"></i> Error</div>';
    if (!d.success) erroresOLT[id] = d.message || 'Error';
  }).catch(function(e) {
    erroresOLT[id] = e.message;
    el.innerHTML = '<div class="status-err" onclick="verError(' + id + ',\'' + e.message.replace(/'/g, '') + '\')"><i class="fas fa-exclamation-triangle"></i> Error</div>';
  });
}

function verError(id, msg) {
  document.getElementById('txtErrorDetail').value = msg || erroresOLT[id] || 'Error desconocido';
  document.getElementById('modalError').style.display = 'flex';
}

function abrirModalOLT() {
  document.getElementById('formOLT').reset();
  document.getElementById('oltId').value = '0';
  document.getElementById('modalTituloOLT').innerText = 'Nueva OLT';
  document.getElementById('resultadoOLT').innerHTML = '';
  document.getElementById('btnGuardarOLT').disabled = false;
  document.getElementById('btnGuardarOLT').innerHTML = '<i class="fas fa-save"></i> Guardar';
  toggleOltTab('smartolt');
  document.getElementById('modalOLT').style.display = 'flex';
  cargarRoutersOlt();
}

function editarOLT(id) {
  fetch('/api/olts').then(r=>r.json()).then(olts => {
    var olt = null;
    for (var i = 0; i < olts.length; i++) { if (olts[i].id == id) { olt = olts[i]; break; } }
    if (!olt) return;
    document.getElementById('modalTituloOLT').innerText = 'Editar: ' + (olt.nombre || '');
    document.getElementById('oltId').value = olt.id;
    document.getElementById('oltNombre').value = olt.nombre || '';
    document.getElementById('oltSubdominio').value = olt.smartolt_subdomain || '';
    document.getElementById('oltApiKey').value = olt.smartolt_api_key || '';
    document.getElementById('oltIdSmartolt').value = olt.smartolt_olt_id || '';
    document.getElementById('oltVlan').value = olt.vlan_default || '';
    document.getElementById('oltTr069Vlan').value = olt.tr069_vlan || '';
    document.getElementById('oltTr069Profile').value = olt.tr069_profile || 'SmartOLT';
    // Campos conexion directa
    document.getElementById('oltIp').value = olt.olt_ip || '';
    document.getElementById('oltPort').value = olt.olt_port || 23;
    document.getElementById('oltUser').value = olt.olt_username || '';
    document.getElementById('oltPass').value = olt.olt_password || '';
    document.getElementById('oltSocksIp').value = olt.socks_host || '';
    document.getElementById('oltSocksPort').value = olt.socks_port || 1080;
    if (olt.modelo) document.getElementById('oltModelo').value = olt.modelo;
    // Switch to correct tab
    var esDirecta = olt.tipo === 'local' || (olt.olt_ip && olt.olt_ip !== '');
    toggleOltTab(esDirecta ? 'directa' : 'smartolt');
    document.getElementById('resultadoOLT').innerHTML = '';
    document.getElementById('btnGuardarOLT').disabled = false;
    document.getElementById('btnGuardarOLT').innerHTML = '<i class="fas fa-save"></i> Guardar Cambios';
    document.getElementById('modalOLT').style.display = 'flex';
  });
}

function eliminarOLT(id, nombre) {
  if (!confirm('Eliminar ' + nombre + '?')) return;
  fetch('/api/olts/' + id + '/delete', { method:'POST' }).then(r=>r.json()).then(function() { cargarOLTs(); });
}

document.getElementById('formOLT').addEventListener('submit', function(e) {
  e.preventDefault();
  var id = parseInt(document.getElementById('oltId').value) || 0;
  var tab = document.getElementById('tabDirecta').classList.contains('active') ? 'directa' : 'smartolt';
  var data = {
    id: id,
    nombre: document.getElementById('oltNombre').value.trim(),
    tipo: tab
  };
  if (tab === 'smartolt') {
    data.smartolt_subdomain = document.getElementById('oltSubdominio').value.trim();
    data.smartolt_api_key = document.getElementById('oltApiKey').value.trim();
    data.smartolt_olt_id = document.getElementById('oltIdSmartolt').value.trim();
    data.vlan_default = document.getElementById('oltVlan').value.trim();
    data.tr069_vlan = document.getElementById('oltTr069Vlan').value.trim();
    data.tr069_profile = document.getElementById('oltTr069Profile').value.trim();
  } else {
    data.olt_ip = document.getElementById('oltIp').value.trim();
    data.olt_port = parseInt(document.getElementById('oltPort').value) || 23;
    data.olt_username = document.getElementById('oltUser').value.trim();
    data.olt_password = document.getElementById('oltPass').value.trim();
    data.socks_host = document.getElementById('oltSocksIp').value.trim();
    data.socks_port = parseInt(document.getElementById('oltSocksPort').value) || 1080;
    data.modelo = document.getElementById('oltModelo').value;
  }
  var btn = document.getElementById('btnGuardarOLT');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
  fetch('/api/olts/save', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) })
  .then(r=>r.json()).then(function(d) {
    if (d.success) {
      document.getElementById('resultadoOLT').innerHTML = '<div style="color:#16a34a;font-weight:bold;padding:8px 0;"><i class="fas fa-check-circle"></i> OLT guardada</div>';
      setTimeout(function() { cerrarModal('modalOLT'); cargarOLTs(); }, 800);
    } else {
      document.getElementById('resultadoOLT').innerHTML = '<div style="color:#ef4444;padding:8px 0;">' + (d.message || 'Error') + '</div>';
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar';
    }
  }).catch(function(e) {
    document.getElementById('resultadoOLT').innerHTML = '<div style="color:#ef4444;">Error: ' + e.message + '</div>';
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Guardar';
  });
});

function probarOLT() {
  var btn = document.querySelector('.btn-test');
  var res = document.getElementById('resultadoOLT');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Conectando...'; res.innerHTML = '';
  fetch('/api/smartolt/test', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({
    subdomain: document.getElementById('oltSubdominio').value.trim(),
    api_key: document.getElementById('oltApiKey').value.trim()
  })}).then(r=>r.json()).then(function(d) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-plug"></i> Probar Conexion';
    var h = '';
    if (d.success && d.olts && d.olts.length > 0) {
      h = '<div style="margin-top:8px;font-size:0.85rem;">';
      for (var i = 0; i < d.olts.length; i++) {
        h += '<div style="padding:4px 8px;background:#f0fdf4;border-radius:4px;margin:3px 0;">ID: <b>' + (d.olts[i].id || '?') + '</b> - ' + (d.olts[i].name || '') + '</div>';
      }
      h += '</div>';
      if (d.olts.length === 1) document.getElementById('oltIdSmartolt').value = d.olts[0].id;
    }
    res.innerHTML = d.success
      ? '<div style="color:#16a34a;font-weight:bold;padding:8px 0;"><i class="fas fa-check-circle"></i> ' + d.message + '</div>' + h
      : '<div style="color:#ef4444;padding:8px 0;"><i class="fas fa-times-circle"></i> ' + (d.message || 'Error') + '</div>';
  }).catch(function(e) {
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-plug"></i> Probar Conexion';
    res.innerHTML = '<div style="color:#ef4444;">Error: ' + e.message + '</div>';
  });
}

// ===== ONU Types =====
function cargarTiposONU() {
  fetch('/api/smartolt/onu-types').then(r=>r.json()).then(function(d) {
    document.getElementById('onuCargando').style.display = 'none';
    document.getElementById('onuError').style.display = 'none';
    document.getElementById('onuVacio').style.display = 'none';
    if (!d.success) {
      document.getElementById('onuError').style.display = 'block';
      document.getElementById('onuError').innerHTML = '<i class="fas fa-exclamation-triangle"></i> ' + (d.message || 'Error');
      return;
    }
    var tipos = d.data || [];
    if (tipos.length === 0) {
      document.getElementById('onuVacio').style.display = 'block';
      document.getElementById('tablaOnuTipos').style.display = 'none';
      return;
    }
    var tb = document.getElementById('cuerpoOnuTipos');
    var h = '';
    for (var i = 0; i < tipos.length; i++) {
      var t = tipos[i];
      var badge = (t.wifi_band === 'dual')
        ? '<span class="onu-wifi-badge onu-wifi-dual"><i class="fas fa-broadcast-tower"></i> 2.4 + 5 GHz</span>'
        : (t.wifi_band === '2.4ghz')
          ? '<span class="onu-wifi-badge onu-wifi-24"><i class="fas fa-wifi"></i> 2.4 GHz</span>'
          : '<span class="onu-wifi-badge onu-wifi-none"><i class="fas fa-ban"></i> Sin WiFi</span>';
      h += '<tr><td><span style="font-weight:700;">' + (t.name || '-') + '</span></td>';
      h += '<td><span class="onu-type-badge">' + (t.pon_type || 'gpon').toUpperCase() + '</span></td>';
      h += '<td>' + (t.ethernet_ports || '-') + '</td><td>' + badge + '</td>';
      h += '<td class="text-right"><button class="btn-action btn-orange" onclick="editarTipoONU(' + t.id + ',\'' + (t.name||'').replace(/'/g,"\\'") + '\',\'' + (t.pon_type||'gpon') + '\',' + (t.ethernet_ports||4) + ',\'' + (t.wifi_band||'none') + '\')"><i class="fas fa-pencil-alt"></i></button></td></tr>';
    }
    tb.innerHTML = h;
    document.getElementById('tablaOnuTipos').style.display = 'table';
  }).catch(function(e) {
    document.getElementById('onuCargando').style.display = 'none';
    document.getElementById('onuError').style.display = 'block';
    document.getElementById('onuError').innerHTML = '<i class="fas fa-exclamation-triangle"></i> ' + e.message;
  });
}

function abrirModalONU() {
  editandoOnuId = 0;
  document.getElementById('onuEditId').value = '0';
  document.getElementById('modalTituloONU').innerHTML = '<i class="fas fa-microchip"></i> Agregar Modelo de ONU';
  document.getElementById('onuModelo').value = '';
  document.getElementById('onuPonType').value = 'gpon';
  document.getElementById('onuEth').value = '4';
  bandaSeleccionada = 'none';
  var opts = document.querySelectorAll('.onu-band-opt');
  for (var i = 0; i < opts.length; i++) opts[i].classList.remove('active');
  document.querySelector('.onu-band-opt').classList.add('active');
  document.getElementById('resultadoONU').innerHTML = '';
  document.getElementById('btnGuardarONU').disabled = false;
  document.getElementById('btnGuardarONU').innerHTML = '<i class="fas fa-plus"></i> Agregar';
  document.getElementById('modalONU').style.display = 'flex';
}

function editarTipoONU(id, name, pon, eth, band) {
  editandoOnuId = id;
  document.getElementById('onuEditId').value = id;
  document.getElementById('modalTituloONU').innerHTML = '<i class="fas fa-pencil-alt"></i> Editar: ' + name;
  document.getElementById('onuModelo').value = name;
  document.getElementById('onuPonType').value = pon;
  document.getElementById('onuEth').value = eth;
  bandaSeleccionada = band || 'none';
  var opts = document.querySelectorAll('.onu-band-opt');
  for (var i = 0; i < opts.length; i++) {
    opts[i].classList.remove('active');
    var inp = opts[i].querySelector('input');
    if (inp && inp.value === bandaSeleccionada) { opts[i].classList.add('active'); inp.checked = true; }
  }
  document.getElementById('resultadoONU').innerHTML = '';
  document.getElementById('btnGuardarONU').disabled = false;
  document.getElementById('btnGuardarONU').innerHTML = '<i class="fas fa-save"></i> Guardar';
  document.getElementById('modalONU').style.display = 'flex';
}

function seleccionarBanda(el, val) {
  bandaSeleccionada = val;
  var opts = document.querySelectorAll('.onu-band-opt');
  for (var i = 0; i < opts.length; i++) opts[i].classList.remove('active');
  el.classList.add('active');
}

function guardarONU() {
  var name = document.getElementById('onuModelo').value.trim();
  if (!name) { document.getElementById('resultadoONU').innerHTML = '<div style="color:#ef4444;padding:6px 0;">Ingrese el modelo</div>'; return; }
  var btn = document.getElementById('btnGuardarONU');
  var isEdit = editandoOnuId > 0;
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ' + (isEdit ? 'Guardando...' : 'Agregando...');
  fetch('/api/smartolt/onu-types/save', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({
    id: isEdit ? editandoOnuId : 0,
    name: name,
    pon_type: document.getElementById('onuPonType').value,
    ethernet_ports: parseInt(document.getElementById('onuEth').value),
    wifi_band: bandaSeleccionada
  })}).then(r=>r.json()).then(function(d) {
    if (d.success) {
      document.getElementById('resultadoONU').innerHTML = '<div style="color:#16a34a;padding:8px 10px;background:#f0fdf4;border-radius:6px;font-weight:600;"><i class="fas fa-check-circle"></i> Guardado</div>';
      setTimeout(function() { cerrarModal('modalONU'); cargarTiposONU(); }, 800);
    } else {
      btn.disabled = false; btn.innerHTML = isEdit ? '<i class="fas fa-save"></i> Guardar' : '<i class="fas fa-plus"></i> Agregar';
      document.getElementById('resultadoONU').innerHTML = '<div style="color:#ef4444;">' + (d.message || 'Error') + '</div>';
    }
  }).catch(function(e) {
    btn.disabled = false; btn.innerHTML = isEdit ? '<i class="fas fa-save"></i> Guardar' : '<i class="fas fa-plus"></i> Agregar';
    document.getElementById('resultadoONU').innerHTML = '<div style="color:#ef4444;">Error: ' + e.message + '</div>';
  });
}

function filtrarOnuTipos() {
  var q = document.getElementById('buscarOnu').value.toLowerCase().trim();
  var rows = document.querySelectorAll('#cuerpoOnuTipos tr');
  for (var i = 0; i < rows.length; i++) {
    rows[i].style.display = (!q || rows[i].textContent.toLowerCase().indexOf(q) >= 0) ? '' : 'none';
  }
}

document.addEventListener('DOMContentLoaded', function() { cargarOLTs(); cargarTiposONU(); });
</script>
