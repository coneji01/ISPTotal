<!-- Excel Modal -->
<div class="modal-overlay" id="excelModal" style="display:none;">
    <div class="modal-content" style="width:550px;max-width:95vw;max-height:90vh;overflow-y:auto;padding:30px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;border-bottom:1px solid #e2e8f0;padding-bottom:12px;">
            <h3 style="margin:0;font-size:1.1rem;color:#1e293b;"><i class="fas fa-file-excel" style="color:#16a34a;"></i> Importar / Exportar Clientes</h3>
            <button onclick="closeExcelModal()" style="background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;">&times;</button>
        </div>

        <!-- EXPORT -->
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:18px;margin-bottom:16px;">
            <h4 style="margin:0 0 8px;color:#166534;font-size:0.95rem;"><i class="fas fa-download"></i> Exportar Clientes</h4>
            <p style="font-size:0.82rem;color:#475569;margin:0 0 12px;">Descarga todos los clientes con sus datos: nombre, apodo, cédula, teléfono, dirección, zona, servicios y deuda.</p>
            <button onclick="exportarExcel()" class="btn btn-primary" style="background:#16a34a;border:none;">
                <i class="fas fa-file-excel"></i> Descargar Excel
            </button>
        </div>

        <!-- IMPORT -->
        <div style="background:#fefce8;border:1px solid #fde68a;border-radius:10px;padding:18px;margin-bottom:16px;">
            <h4 style="margin:0 0 8px;color:#92400e;font-size:0.95rem;"><i class="fas fa-upload"></i> Importar Clientes</h4>
            <p style="font-size:0.82rem;color:#475569;margin:0 0 8px;">Sube un archivo Excel con columnas: <b>Nombre</b>, Apodo, Cedula, Telefono, Direccion, Zona.</p>
            <div style="margin-bottom:10px;">
                <a href="/api/clientes/import/template" class="btn btn-default" style="font-size:0.8rem;padding:6px 12px;">
                    <i class="fas fa-download"></i> Descargar plantilla
                </a>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <input type="file" id="excelFileInput" accept=".xlsx,.xls" style="flex:1;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:0.82rem;">
                <button onclick="importarExcel()" class="btn btn-primary" style="background:#d97706;border:none;white-space:nowrap;">
                    <i class="fas fa-upload"></i> Importar
                </button>
            </div>
            <div id="importResult" style="display:none;margin-top:10px;padding:10px;border-radius:6px;font-size:0.82rem;"></div>
        </div>

        <button onclick="closeExcelModal()" class="btn" style="width:100%;">Cerrar</button>
    </div>
</div>

<script>
function openExcelModal() {
    document.getElementById('excelModal').style.display = 'flex';
    document.getElementById('importResult').style.display = 'none';
}
function closeExcelModal() {
    document.getElementById('excelModal').style.display = 'none';
}

function exportarExcel() {
    var btn = event.target.tagName === 'BUTTON' ? event.target : event.target.closest('button');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Descargando...';
    btn.disabled = true;

    var link = document.createElement('a');
    link.href = '/api/clientes/export/excel';
    link.download = 'clientes.xlsx';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    setTimeout(function() {
        btn.innerHTML = '<i class="fas fa-file-excel"></i> Descargar Excel';
        btn.disabled = false;
    }, 2000);
}

function importarExcel() {
    var input = document.getElementById('excelFileInput');
    if (!input.files || !input.files[0]) {
        alert('Seleccione un archivo Excel primero');
        return;
    }

    var btn = event.target.tagName === 'BUTTON' ? event.target : event.target.closest('button');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Importando...';
    btn.disabled = true;

    var fd = new FormData();
    fd.append('file', input.files[0]);

    var resultDiv = document.getElementById('importResult');
    resultDiv.style.display = 'block';
    resultDiv.style.background = '#f0f9ff';
    resultDiv.style.color = '#1e40af';
    resultDiv.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando archivo...';

    fetch('/api/clientes/import/excel', { method: 'POST', body: fd })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        btn.innerHTML = '<i class="fas fa-upload"></i> Importar';
        btn.disabled = false;

        if (d.status === 'success') {
            resultDiv.style.background = '#f0fdf4';
            resultDiv.style.color = '#166534';
            var html = '<i class="fas fa-check-circle"></i> ' + d.msg;
            if (d.errores && d.errores.length > 0) {
                html += '<br><small style="color:#dc2626;">' + d.errores.join('<br>') + '</small>';
            }
            resultDiv.innerHTML = html;
        } else {
            resultDiv.style.background = '#fef2f2';
            resultDiv.style.color = '#991b1b';
            resultDiv.innerHTML = '<i class="fas fa-times-circle"></i> ' + (d.msg || 'Error al importar');
        }
    })
    .catch(function() {
        btn.innerHTML = '<i class="fas fa-upload"></i> Importar';
        btn.disabled = false;
        resultDiv.style.background = '#fef2f2';
        resultDiv.style.color = '#991b1b';
        resultDiv.innerHTML = '<i class="fas fa-times-circle"></i> Error de conexión';
    });
}

document.getElementById('excelModal').addEventListener('click', function(e) {
    if (e.target === this) closeExcelModal();
});
</script>

