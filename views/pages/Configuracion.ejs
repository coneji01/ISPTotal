function openConfig(sectionId) {
  const section = configSections[sectionId];
  if (!section) return;
  
  document.getElementById('configSectionTitle').innerHTML = '<i class="fas ' + section.icon + '"></i> ' + section.title;
  document.getElementById('configSectionContainer').style.display = 'block';
  
  let html = '';
  
  if (section.description) {
    html += '<p style="color:var(--text-gray);margin-bottom:16px;">' + section.description + '</p>';
  }
  
  if (section.buttons) {
    html += '<div class="btn-group" style="margin-bottom:16px;">';
    section.buttons.forEach(b => {
      html += '<button class="btn ' + (b.class || 'btn-primary') + '" onclick="' + b.action + '">' + b.label + '</button>';
    });
    html += '</div>';
  }
  
  if (section.textarea) {
    html += '<form id="configForm" onsubmit="saveConfig(event, \'' + sectionId + '\')">';
    section.fields.forEach(f => {
      html += '<div class="form-group">';
      html += '<label>' + f.label + '</label>';
      html += '<textarea name="' + f.name + '" class="form-control" rows="' + (f.rows || 5) + '">' + (f.value || '') + '</textarea>';
      html += '</div>';
    });
    html += '<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar</button>';
    html += '</form>';
  } else if (section.table) {
    html += '<div class="table-container"><table><thead><tr>';
    section.columns.forEach(c => { html += '<th>' + c + '</th>'; });
    html += '</tr></thead><tbody>';
    html += '<tr><td colspan="' + section.columns.length + '" class="loading"><i class="fas fa-spinner fa-spin"></i> Cargando...</td></tr>';
    html += '</tbody></table></div>';
  } else if (section.fields) {
    html += '<form id="configForm" onsubmit="saveConfig(event, \'' + sectionId + '\')">';
    section.fields.forEach(f => {
      html += '<div class="form-group">';
      html += '<label>' + f.label + '</label>';
      if (f.type === 'select') {
        html += '<select name="' + f.name + '" class="form-control">';
        (f.options || []).forEach(o => {
          html += '<option value="' + o + '" ' + (f.value === o ? 'selected' : '') + '>' + o + '</option>';
        });
        html += '</select>';
      } else if (f.type === 'color') {
        html += '<input type="color" name="' + f.name + '" value="' + (f.value || '#000000') + '" style="width:60px;height:40px;padding:2px;">';
      } else if (f.type === 'button') {
        html += '<button type="button" class="btn btn-warning btn-sm" onclick="generateToken()">' + f.label + '</button>';
      } else if (f.type === 'file') {
        html += '<input type="file" name="' + f.name + '" class="form-control" style="padding:8px;">';
      } else if (f.type === 'textarea') {
        html += '<textarea name="' + f.name + '" class="form-control" rows="' + (f.rows || 3) + '" placeholder="' + (f.placeholder || '') + '">' + (f.value || '') + '</textarea>';
      } else if (f.type === 'password') {
        html += '<input type="password" name="' + f.name + '" class="form-control" placeholder="' + (f.placeholder || '') + '" value="' + (f.value || '') + '" ' + (f.readonly ? 'readonly' : '') + '>';
      } else {
        html += '<input type="' + f.type + '" name="' + f.name + '" class="form-control" placeholder="' + (f.placeholder || '') + '" value="' + (f.value || '') + '" ' + (f.readonly ? 'readonly' : '') + '>';
      }
      html += '</div>';
    });
    html += '<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar Cambios</button>';
    html += '</form>';
  }
  
  document.getElementById('configSectionBody').innerHTML = html;
}

function closeConfigSection() {
  document.getElementById('configSectionContainer').style.display = 'none';
}

function saveConfig(e, sectionId) {
  e.preventDefault();
  const form = document.getElementById('configForm');
  const data = new FormData(form);
  const obj = Object.fromEntries(data);
  
  fetch('/api/config/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ section: sectionId, data: obj })
  }).then(r => r.json()).then(res => {
    if (res.success) showToast('Configuración guardada');
    else showToast('Error al guardar', 'error');
  }).catch(() => showToast('Error de conexión', 'error'));
}

function generateToken() {
  const token = Array.from({length: 40}, () => Math.random().toString(36)[2]).join('');
  showToast('Nuevo token generado: ' + token.substring(0, 10) + '...');
}

function downloadBackup() { showToast('Descargando backup...'); }
function restoreBackup() { showToast('Función de restauración'); }
function checkUpdates() { showToast('Buscando actualizaciones...'); }
function installUpdate() { showToast('Instalando actualización...'); }
