function openConfig(sectionId) {
  const section = configSections[sectionId];
  if (!section) return;
  
  document.getElementById('configSectionTitle').innerHTML = '<i class="fas ' + section.icon + '"></i> ' + section.title;
  document.getElementById('configSectionContainer').style.display = 'block';
  
  let html = '';
  
  if (section.description) {
    html += '<p style="color:var(--text-gray);margin-bottom:16px;">' + section.description + '</p>';
  }
  
  if (section.buttons) {
    html += '<div class="btn-group" style="margin-bottom:16px;">';
    section.buttons.forEach(b => {
      html += '<button class="btn ' + (b.class || 'btn-primary') + '" onclick="' + b.action + '">' + b.label + '</button>';
    });
    html += '</div>';
  }
  
  if (section.routerPanel) {
    html += '<form id="configForm" onsubmit="saveConfig(event, \'' + sectionId + '\')">';
    section.fields.forEach(f => {
      html += '<div class="form-group">';
      html += '<label>' + f.label + '</label>';
      if (f.type === 'select') {
        html += '<select name="' + f.name + '" class="form-control">';
        (f.options || []).forEach(o => { html += '<option value="' + o + '">' + o + '</option>'; });
        html += '</select>';
      } else if (f.type === 'password') {
        html += '<input type="password" name="' + f.name + '" class="form-control" placeholder="' + (f.placeholder || '') + '">';
      } else {
        html += '<input type="' + f.type + '" name="' + f.name + '" class="form-control" placeholder="' + (f.placeholder || '') + '" value="' + (f.value || '') + '">';
      }
      html += '</div>';
    });
    html += '<div class="btn-group" style="margin-top:16px;">';
    html += '<button type="button" class="btn btn-primary" onclick="testRouterConnection()"><i class="fas fa-plug"></i> Probar Conexión</button>';
    html += '<button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Guardar</button>';
    html += '</div>';
    html += '<div id="routerStatus" style="margin-top:16px;"></div>';
    html += '</form>';
    html += '<div class="card mt-20"><div class="card-header"><i class="fas fa-network-wired"></i> Interfaces del Router</div><div class="card-body" id="routerInterfaces"><p class="loading"><i class="fas fa-spinner fa-spin"></i> Conecta y prueba para ver interfaces</p></div></div>';
    html += '<div class="card mt-20"><div class="card-header"><i class="fas fa-tasks"></i> DHCP Leases</div><div class="card-body" id="routerLeases"><p class="loading"><i class="fas fa-spinner fa-spin"></i> Conecta y prueba para ver leases</p></div></div>';
  } else if (section.textarea) {
    html += '<form id="configForm" onsubmit="saveConfig(event, \'' + sectionId + '\')">';
    section.fields.forEach(f => {
      html += '<div class="form-group">';
      html += '<label>' + f.label + '</label>';
      html += '<textarea name="' + f.name + '" class="form-control" rows="' + (f.rows || 5) + '">' + (f.value || '') + '</textarea>';
      html += '</div>';
    });
    html += '<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar</button>';
    html += '</form>';
  } else if (section.table) {
    html += '<div class="table-container"><table><thead><tr>';
    section.columns.forEach(c => { html += '<th>' + c + '</th>'; });
    html += '</tr></thead><tbody>';
    html += '<tr><td colspan="' + section.columns.length + '" class="loading"><i class="fas fa-spinner fa-spin"></i> Cargando...</td></tr>';
    html += '</tbody></table></div>';
  } else if (section.fields) {
    html += '<form id="configForm" onsubmit="saveConfig(event, \'' + sectionId + '\')">';
    section.fields.forEach(f => {
      html += '<div class="form-group">';
      html += '<label>' + f.label + '</label>';
      if (f.type === 'separator') {
        html = html.substring(0, html.length - '</div>'.length); // remove the </div> we just added
        html += '<hr style="margin:16px 0;border:none;border-top:2px solid #e2e8f0;">';
        if (f.label) {
          html += '<h4 style="font-size:.85rem;color:#6366f1;margin-bottom:12px;">' + f.label + '</h4>';
        }
        html += '</div>';
      } else if (f.type === 'select') {
        html += '<select name="' + f.name + '" class="form-control">';
        (f.options || []).forEach(o => {
          html += '<option value="' + o + '" ' + (f.value === o ? 'selected' : '') + '>' + o + '</option>';
        });
        html += '</select>';
      } else if (f.type === 'color') {
        html += '<input type="color" name="' + f.name + '" value="' + (f.value || '#000000') + '" style="width:60px;height:40px;padding:2px;">';
      } else if (f.type === 'button') {
        html += '<button type="button" class="btn btn-warning btn-sm" onclick="generateToken()">' + f.label + '</button>';
      } else if (f.type === 'file') {
        html += '<input type="file" name="' + f.name + '" class="form-control" style="padding:8px;">';
      } else if (f.type === 'textarea') {
        html += '<textarea name="' + f.name + '" class="form-control" rows="' + (f.rows || 3) + '" placeholder="' + (f.placeholder || '') + '">' + (f.value || '') + '</textarea>';
      } else if (f.type === 'password') {
        html += '<input type="password" name="' + f.name + '" class="form-control" placeholder="' + (f.placeholder || '') + '" value="' + (f.value || '') + '" ' + (f.readonly ? 'readonly' : '') + '>';
      } else if (f.type === 'bancos-dinamico') {
        // Bancos dinámicos
        html += '<div id="bancosContainer"></div>';
        html += '<button type="button" class="btn-add-banco" onclick="agregarBanco()"><i class="fas fa-plus"></i> Agregar banco</button>';
        html += '<input type="hidden" name="bancos_data" id="bancosDataInput" value="">';
      } else {
        html += '<input type="' + f.type + '" name="' + f.name + '" class="form-control" placeholder="' + (f.placeholder || '') + '" value="' + (f.value || '') + '" ' + (f.readonly ? 'readonly' : '') + '>';
      }
      html += '</div>';
    });
    html += '<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Guardar Cambios</button>';
    html += '</form>';
  }
  
  // Si es la sección API, agregar panel OpenWa después
  if (sectionId === 'api' && section.openwa) {
    var owa = section.openwa;
    html += '<div style="margin-top:30px;padding-top:24px;border-top:2px solid #e2e8f0;">';
    html += '<h3 style="display:flex;align-items:center;gap:10px;font-size:1rem;margin-bottom:6px;">';
    html += '<i class="fab fa-whatsapp" style="color:#25D366;font-size:1.3rem;"></i> ' + owa.title + '</h3>';
    html += '<p style="font-size:0.82rem;color:#64748b;margin-bottom:14px;">' + (owa.description || '') + '</p>';
    html += '<div class="form-group" style="display:flex;align-items:center;gap:14px;margin-bottom:10px;">';
    html += '  <label style="font-weight:600;font-size:0.9rem;cursor:pointer;">' + owa.title + '</label>';
    html += '  <div class="owa-toggle-wrap" onclick="toggleOpenWa(this)" id="owaToggle" style="display:inline-flex;align-items:center;gap:8px;">';
    html += '    <button class="owa-toggle" id="owaToggleBtn"><div class="owa-toggle-knob"></div></button>';
    html += '    <span id="owaToggleLabel" style="font-size:0.8rem;color:#94a3b8;">Desactivado</span>';
    html += '  </div>';
    html += '</div>';
    html += '<p style="font-size:0.82rem;color:#64748b;margin-bottom:14px;">' + (owa.description || '') + '</p>';
    html += '<div id="openwaStatusBox" style="padding:12px 16px;border-radius:10px;font-size:0.85rem;display:none;"></div>';
    html += '<div id="openwaQrBox" style="margin-top:14px;display:none;text-align:center;">';
    html += '  <p style="font-size:0.82rem;color:#64748b;margin-bottom:8px;">Escanea este código QR con WhatsApp para conectar:</p>';
    html += '  <div id="openwaQrImage" style="background:#fff;display:inline-block;padding:12px;border-radius:12px;border:2px solid #e2e8f0;"></div>';
    html += '</div>';
    html += '</div>';
  }
  
  document.getElementById('configSectionBody').innerHTML = html;
  
  // Cargar valores guardados para todas las secciones con fields (excepto routerPanel y table)
  if (section.fields && !section.routerPanel && !section.table && !section.textarea) {
    loadConfigValues(sectionId);
  }
  // Cargar valores de OpenWa si es la sección API
  if (sectionId === 'api') { loadOpenWaConfig(); }
}

var openwaMonitorTimer = null;

function closeConfigSection() {
  document.getElementById('configSectionContainer').style.display = 'none';
  // Detener el monitor de OpenWa al cerrar la sección
  if (openwaMonitorTimer) {
    clearTimeout(openwaMonitorTimer);
    openwaMonitorTimer = null;
  }
}

async function saveConfig(e, sectionId) {
  e.preventDefault();
  const form = document.getElementById('configForm');
  const data = new FormData(form);
  const obj = Object.fromEntries(data);

  // Para OLT, también guardar en el endpoint específico de SmartOLT
  // (usa SMARTOLT_API_KEY con guiones entre palabras, correcto)
  if (sectionId === 'olt') {
    fetch('/api/smartolt/config/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        subdomain: obj.smartolt_subdomain || '',
        api_key: obj.smartolt_api_key || '',
        olt_id: obj.smartolt_olt_id || ''
      })
    }).catch(() => {});
  }

  fetch('/api/config/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ section: sectionId, data: obj })
  }).then(r => r.json()).then(res => {
    if (res.success) {
      showToast('Configuración guardada');
      // Recargar los valores guardados para que el formulario los muestre
      if (sectionId !== 'routers' && sectionId !== 'zonas' && sectionId !== 'planes' && sectionId !== 'log') {
        setTimeout(function() { loadConfigValues(sectionId); }, 100);
      }
    }
    else showToast('Error al guardar', 'error');
  }).catch(() => showToast('Error de conexión', 'error'));
}

function loadConfigValues(sectionId) {
  fetch('/api/config/get')
    .then(r => r.json())
    .then(config => {
      const section = configSections[sectionId];
      if (!section || !section.fields) return;

      section.fields.forEach(f => {
        if (f.type === 'separator' || f.type === 'bancos-dinamico') return;
        const el = document.querySelector('[name="' + f.name + '"]');
        if (!el) return;
        const savedVal = config[f.name];
        if (savedVal !== undefined && savedVal !== null && savedVal !== '') {
          if (el.tagName === 'SELECT') {
            for (let opt of el.options) {
              const optVal = opt.value;
              if (optVal === savedVal || optVal === savedVal.toString()) {
                el.value = optVal;
                break;
              }
            }
          } else if (el.type === 'color') {
            el.value = savedVal || '#000000';
          } else if (el.type !== 'password' && el.type !== 'file' && !el.readOnly) {
            el.value = savedVal;
          }
        }
      });
      
      // Cargar bancos dinámicos si aplica
      if (sectionId === 'empresa' && config.bancos_data) {
        loadBancosData(config.bancos_data);
      }
    })
    .catch(() => {});
}

function generateToken() {
  const token = Array.from({length: 40}, () => Math.random().toString(36)[2]).join('');
  showToast('Nuevo token generado: ' + token.substring(0, 10) + '...');
}

