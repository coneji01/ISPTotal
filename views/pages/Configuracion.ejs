<!-- Config Modals (inline) -->
<div id="configModal" class="config-modal">
    <div class="config-modal-content">
        <div class="config-modal-header">
            <h3 id="configModalTitle">Configuración</h3>
            <span class="config-modal-close" onclick="closeConfig()">&times;</span>
        </div>
        <div id="configModalBody">
            <p>Cargando...</p>
        </div>
    </div>
</div>

<script>
var configCache = {};

function openConfig(seccion) {
    var titles = {
        empresa: 'Empresa',
        personal: 'Gestión de Personal',
        vpn: 'VPN',
        facturacion: 'Facturación Electrónica',
        pagos_online: 'Pagos en Línea',
        presets: 'Presets',
        mensajeria: 'Mensajería',
        portal_cliente: 'App del Cliente',
        api: 'API',
        backup: 'Backup'
    };
    
    document.getElementById('configModalTitle').textContent = titles[seccion] || seccion;
    document.getElementById('configModalBody').innerHTML = '<p><i class="fas fa-spinner fa-spin"></i> Cargando...</p>';
    document.getElementById('configModal').classList.add('active');
    
    // Try to load from cache or server
    if (configCache[seccion]) {
        document.getElementById('configModalBody').innerHTML = configCache[seccion];
        return false;
    }
    
    fetch('/modulo?pagina=Configuracion&ajax=config_section&section=' + seccion)
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.status === 'success') {
                configCache[seccion] = d.html;
                document.getElementById('configModalBody').innerHTML = d.html;
            } else {
                document.getElementById('configModalBody').innerHTML = '<p style="color:#dc2626;">Error: ' + (d.msg || 'No disponible') + '</p>';
            }
        })
        .catch(function(e) {
            document.getElementById('configModalBody').innerHTML = '<p style="color:#dc2626;">Error de conexión</p>';
        });
    
    return false;
}

function closeConfig() {
    document.getElementById('configModal').classList.remove('active');
}

// Close modal on overlay click
document.getElementById('configModal')?.addEventListener('click', function(e) {
    if (e.target === this) closeConfig();
});

function openTenantProfile() {
    document.getElementById('configModalTitle').textContent = 'Mi Cuenta';
    var body = document.getElementById('configModalBody');
    
    fetch('/api/tenant/profile')
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.status === 'success') {
            body.innerHTML = '<div style="padding:10px 0;">'
                + '<p style="color:#64748b;font-size:0.85rem;margin-bottom:16px;">Configura tu cuenta y revisa el estado de tu licencia.</p>'
                + '<div id="tenantProfileMsg" style="display:none;padding:10px;border-radius:8px;margin-bottom:12px;font-size:0.82rem;"></div>'
                + '<div class="form-group">'
                + '<label class="form-label">Usuario</label>'
                + '<input type="text" class="form-control" value="' + d.username + '" disabled>'
                + '</div>'
                + '<div class="form-group">'
                + '<label class="form-label">Empresa</label>'
                + '<input type="text" class="form-control" value="' + d.company_name + '" disabled>'
                + '</div>'
                + '<div class="form-group">'
                + '<label class="form-label">Correo</label>'
                + '<input type="email" id="tpEmail" class="form-control" value="' + d.email + '">'
                + '</div>'
                + '<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px;margin:16px 0;">'
                + '<h4 style="margin:0 0 8px;font-size:0.9rem;color:#166534;"><i class="fas fa-id-card"></i> Licencia</h4>'
                + '<div style="font-size:0.82rem;color:#334155;">'
                + '<b>Estado:</b> <span style="color:' + (d.license_active ? '#16a34a' : '#dc2626') + ';">' + (d.license_active ? '\u2705 Activa' : '\u274c Inactiva') + '</span><br>'
                + '<b>Clientes actuales:</b> ' + d.client_count + '<br>'
                + '<b>L' + '\u00ed' + 'mite:</b> ' + d.max_clients + ' clientes<br>'
                + '<b>Registrado:</b> ' + d.created_at + '<br>'
                + '</div>'
                + '</div>'
                + '<hr style="border-color:#e2e8f0;margin:16px 0;">'
                + '<h4 style="font-size:0.85rem;color:#1e293b;margin:0 0 12px;">Cambiar Contrase' + '\u00f1' + 'a</h4>'
                + '<div class="form-group">'
                + '<label class="form-label">Contrase' + '\u00f1' + 'a actual</label>'
                + '<input type="password" id="tpCurrentPw" class="form-control" placeholder="Obligatorio">'
                + '</div>'
                + '<div class="form-group">'
                + '<label class="form-label">Nueva contrase' + '\u00f1' + 'a</label>'
                + '<input type="password" id="tpNewPw" class="form-control" placeholder="M' + '\u00ed' + 'n. 6 caracteres">'
                + '</div>'
                + '<div class="form-group">'
                + '<label class="form-label">Confirmar contrase' + '\u00f1' + 'a</label>'
                + '<input type="password" id="tpNewPw2" class="form-control" placeholder="Repite la contrase' + '\u00f1' + 'a">'
                + '</div>'
                + '<div class="form-group">'
                + '<button class="btn btn-primary" onclick="saveTenantProfile()" style="width:100%;"><i class="fas fa-save"></i> Guardar Cambios</button>'
                + '</div>'
                + '</div>';
        } else {
            body.innerHTML = '<p style="color:#dc2626;">Error: ' + (d.msg || 'No disponible') + '</p>';
        }
    })
    .catch(function() {
        body.innerHTML = '<p style="color:#dc2626;">Error de conexi' + '\u00f3' + 'n</p>';
    });
    
    document.getElementById('configModal').classList.add('active');
}

function saveTenantProfile() {
    var email = document.getElementById('tpEmail').value.trim();
    var currentPw = document.getElementById('tpCurrentPw').value;
    var newPw = document.getElementById('tpNewPw').value;
    
    if (!currentPw) { showToast('Ingresa tu contrase' + '\u00f1' + 'a actual', 'error'); return; }
    if (!email) { showToast('El correo es obligatorio', 'error'); return; }
    
    var data = { email: email, current_password: currentPw };
    if (newPw) {
        var newPw2 = document.getElementById('tpNewPw2').value;
        if (newPw !== newPw2) { showToast('Las contrase' + '\u00f1' + 'as no coinciden', 'error'); return; }
        if (newPw.length < 6) { showToast('La nueva contrase' + '\u00f1' + 'a debe tener al menos 6 caracteres', 'error'); return; }
        data.new_password = newPw;
    }
    
    fetch('/api/tenant/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        var msg = document.getElementById('tenantProfileMsg');
        if (d.status === 'success') {
            msg.style.background = '#f0fdf4'; msg.style.color = '#166534'; msg.style.border = '1px solid #bbf7d0';
            msg.innerHTML = '<i class="fas fa-check-circle"></i> ' + d.msg;
            msg.style.display = 'block';
        } else {
            msg.style.background = '#fef2f2'; msg.style.color = '#dc2626'; msg.style.border = '1px solid #fecaca';
            msg.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + d.msg;
            msg.style.display = 'block';
        }
    })
    .catch(function() {
        showToast('Error de conexi' + '\u00f3' + 'n', 'error');
    });
}

function openServerDate() {
    document.getElementById('configModalTitle').textContent = 'Fecha/Hora del Servidor';
    var body = document.getElementById('configModalBody');
    
    fetch('/api/server/date')
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.status === 'success') {
            body.innerHTML = '<div style="padding:10px 0;">'
                + '<p style="color:#64748b;font-size:0.85rem;margin-bottom:16px;">Configura la fecha/hora del servidor para realizar pruebas. Esto solo afecta a las tareas programadas (cron) y generaci' + '\u00f3' + 'n de facturas. <strong>Solo visible para admin.</strong></p>'
                + '<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:14px;margin-bottom:16px;">'
                + '<div style="font-size:0.8rem;color:#64748b;margin-bottom:4px;">Fecha/Hora real del servidor:</div>'
                + '<div style="font-size:1rem;font-weight:600;color:var(--text-main);">' + d.real + '</div>'
                + '</div>'
                + '<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:14px;margin-bottom:16px;">'
                + '<div style="font-size:0.8rem;color:#64748b;margin-bottom:4px;">Fecha/Hora usada por el sistema:</div>'
                + '<div id="serverDateDisplay" style="font-size:1rem;font-weight:600;color:' + (d.overridden ? '#d97706' : '#16a34a') + ';">' + d.current + '</div>'
                + '<div style="margin-top:4px;font-size:0.78rem;color:' + (d.overridden ? '#d97706' : '#16a34a') + ';">' + (d.overridden ? '\u26a0\ufe0f SOBREESCRITA - Modo pruebas' : '\u2705 Fecha real del servidor') + '</div>'
                + '</div>'
                + '<div class="form-group">'
                + '<label class="form-label">Nueva Fecha (YYYY-MM-DD)</label>'
                + '<input type="date" class="form-control" id="srvDateInput" value="' + (d.current_date_only || d.real_date_only) + '">'
                + '</div>'
                + '<div class="form-group">'
                + '<label class="form-label">Hora (HH:MM)</label>'
                + '<input type="time" class="form-control" id="srvTimeInput" value="' + (d.current_time || '12:00') + '">'
                + '</div>'
                + '<div style="display:flex;gap:8px;">'
                + '<button class="btn btn-primary" onclick="applyServerDate()" style="flex:1;"><i class="fas fa-save"></i> Aplicar Fecha</button>'
                + '<button class="btn btn-secondary" onclick="resetServerDate()" style="flex:1;"><i class="fas fa-undo"></i> Restaurar Real</button>'
                + '</div>'
                + '</div>';
        } else {
            body.innerHTML = '<p style="color:#dc2626;">Error al obtener fecha del servidor</p>';
        }
    })
    .catch(function() {
        body.innerHTML = '<p style="color:#dc2626;">Error de conexi' + '\u00f3' + 'n</p>';
    });
    
    document.getElementById('configModal').classList.add('active');
}

function applyServerDate() {
    var dateVal = document.getElementById('srvDateInput').value;
    var timeVal = document.getElementById('srvTimeInput').value || '12:00';
    if (!dateVal) { showToast('Selecciona una fecha', 'error'); return; }
    fetch('/api/server/date', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ date: dateVal, time: timeVal })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.status === 'success') {
            showToast('Fecha cambiada a ' + dateVal);
            document.getElementById('serverDateDisplay').textContent = d.current;
            document.getElementById('serverDateDisplay').style.color = '#d97706';
            closeConfig();
        } else {
            showToast('Error: ' + (d.msg || ''), 'error');
        }
    })
    .catch(function() { showToast('Error de conexi' + '\u00f3' + 'n', 'error'); });
}

function resetServerDate() {
    fetch('/api/server/date/reset', { method: 'POST' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.status === 'success') {
            showToast('Fecha restaurada a la real');
            document.getElementById('serverDateDisplay').textContent = d.current;
            document.getElementById('serverDateDisplay').style.color = '#16a34a';
            closeConfig();
        }
    })
    .catch(function() { showToast('Error de conexi' + '\u00f3' + 'n', 'error'); });
}

function saveConfig(section) {
    var form = document.getElementById('cfg' + section.charAt(0).toUpperCase() + section.slice(1) + 'Form');
    if (!form) {
        showToast('Formulario no encontrado', 'error');
        return false;
    }
    
    var formData = new FormData(form);
    formData.append('section', section);
    formData.append('ajax', 'save_config');
    
    fetch('/modulo?pagina=Configuracion&ajax=save_config', {
        method: 'POST',
        body: new URLSearchParams(formData)
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.status === 'success') {
            showToast(d.msg || 'Guardado correctamente');
            // Clear cache for this section
            delete configCache[section];
        } else {
            showToast('Error: ' + (d.msg || 'Desconocido'), 'error');
        }
    })
    .catch(function(e) {
        showToast('Error de conexión: ' + e.message, 'error');
    });
    
    return false;
}
</script>