// ============ OpenWa ============
function loadOpenWaConfig() {
  fetch('/api/openwa/status').then(function(r) { return r.json(); }).then(function(d) {
    var cfg = d.config || {};
    var fields = ['openwa_enabled','openwa_port','openwa_api_key','openwa_session_id','openwa_webhook'];
    fields.forEach(function(k) {
      var el = document.querySelector('[name="' + k + '"]');
      if (!el) return;
      if (cfg[k] !== undefined) el.value = cfg[k];
    });
    // Mostrar estado actual inmediatamente
    if (d.running) {
      updateOpenWaUI(d);
    }
  }).catch(function() {});
}

// Actualizar UI de OpenWa según estado
function updateOpenWaUI(d) {
  var box = document.getElementById('openwaStatusBox');
  var btn = document.getElementById('owaToggleBtn');
  var label = document.getElementById('owaToggleLabel');
  if (!box) return;
  
  if (d.running && d.state === 'qr' && d.qr) {
    box.style.display = 'block';
    box.style.background = '#fef3c7';
    box.style.border = '1px solid #fde68a';
    box.style.color = '#92400e';
    box.innerHTML = '<i class="fas fa-qrcode"></i> <strong>Escanea el QR con WhatsApp</strong>';
    document.getElementById('openwaQrBox').style.display = 'block';
    document.getElementById('openwaQrImage').innerHTML = '<img src="' + d.qr + '?t=' + Date.now() + '" style="width:260px;height:auto;max-width:100%;border-radius:8px;">';
    if (label) { label.textContent = 'Esperando QR...'; label.style.color = '#d97706'; }
    if (btn && !btn.classList.contains('on')) btn.classList.add('on');
  } else if (d.running && d.state === 'connected') {
    box.style.display = 'block';
    box.style.background = '#f0fdf4';
    box.style.border = '1px solid #bbf7d0';
    box.style.color = '#166534';
    box.innerHTML = '<i class="fas fa-check-circle"></i> <strong>OpenWa conectado</strong>';
    document.getElementById('openwaQrBox').style.display = 'none';
    if (label) { label.textContent = 'Conectado'; label.style.color = '#16a34a'; }
    if (btn && !btn.classList.contains('on')) btn.classList.add('on');
  } else if (d.running) {
    box.style.display = 'block';
    box.style.background = '#eff6ff';
    box.style.border = '1px solid #bfdbfe';
    box.style.color = '#1e40af';
    box.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <strong>Iniciando...</strong>';
  } else {
    box.style.display = 'block';
    box.style.background = '#fef2f2';
    box.style.border = '1px solid #fecaca';
    box.style.color = '#991b1b';
    box.innerHTML = '<i class="fas fa-times-circle"></i> <strong>OpenWa detenido</strong>';
    document.getElementById('openwaQrBox').style.display = 'none';
    if (btn) btn.classList.remove('on');
    if (label) { label.textContent = 'Desconectado'; label.style.color = '#dc2626'; }
  }
}

function toggleOpenWa(el) {
  var btn = document.getElementById('owaToggleBtn');
  var label = document.getElementById('owaToggleLabel');
  var isOn = btn.classList.contains('on');
  
  if (isOn) {
    // Apagar
    btn.classList.remove('on');
    label.textContent = 'Desactivado';
    label.style.color = '#94a3b8';
    // Parar el monitoreo
    if (openwaMonitorTimer) {
      clearTimeout(openwaMonitorTimer);
      openwaMonitorTimer = null;
    }
    fetch('/api/openwa/config', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ openwa_enabled: '0' })
    }).then(function() {
      return fetch('/api/openwa/stop', {method:'POST'});
    }).then(function() {
      showToast('OpenWa desactivado');
      var box = document.getElementById('openwaStatusBox');
      if (box) {
        box.style.display = 'block';
        box.style.background = '#fef2f2';
        box.style.border = '1px solid #fecaca';
        box.style.color = '#991b1b';
        box.innerHTML = '<i class="fas fa-times-circle"></i> <strong>OpenWa detenido</strong>';
      }
      document.getElementById('openwaQrBox').style.display = 'none';
    });
  } else {
    // Encender
    btn.classList.add('on');
    label.textContent = 'Iniciando...';
    label.style.color = '#16a34a';
    
    // Primero verificar estado actual
    fetch('/api/openwa/status').then(function(r) { return r.json(); }).then(function(s) {
      if (s.running && s.state === 'connected') {
        // Ya está conectado, solo actualizar UI
        label.textContent = 'Conectado';
        showToast('OpenWa ya estaba conectado');
        monitorOpenWa();
        return;
      }
      
      // Guardar config
      fetch('/api/openwa/config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ openwa_enabled: '1' })
      }).then(function() {
        // Preguntar estado actual antes de intentar arrancar
        return fetch('/api/openwa/status');
      }).then(function(r) { return r.json(); }).then(function(s) {
        if (s.running && (s.state === 'qr' || s.state === 'connected' || s.state === 'starting')) {
          // Ya está corriendo, mostrar estado inmediatamente
          updateOpenWaUI(s);
          showToast('OpenWa ya está en ejecución');
          monitorOpenWa();
          return;
        }
        // Si no está corriendo, arrancar
        return fetch('/api/openwa/start', {method:'POST'}).then(function(r) { return r.json(); });
      }).then(function(d) {
        if (!d) return;
        if (d.success) {
          showToast(d.msg);
          // Mostrar QR de inmediato
          fetch('/api/openwa/status').then(function(r) { return r.json(); }).then(function(s) {
            updateOpenWaUI(s);
            monitorOpenWa();
          });
        } else {
          showToast('Error: ' + d.msg, 'error');
          btn.classList.remove('on');
          label.textContent = 'Error';
          label.style.color = '#dc2626';
        }
      }).catch(function(e) {
        showToast('Error: ' + e.message, 'error');
        btn.classList.remove('on');
        label.textContent = 'Error';
        label.style.color = '#dc2626';
      });
    }).catch(function() {
      // Si falla el status, intentar arrancar directamente
      fetch('/api/openwa/start', {method:'POST'});
    });
  }
}

function monitorOpenWa() {
  var container = document.getElementById('configSectionContainer');
  if (!container || container.style.display === 'none') {
    openwaMonitorTimer = null;
    return;
  }
  
  fetch('/api/openwa/status').then(function(r) { return r.json(); }).then(function(d) {
    updateOpenWaUI(d);
    
    // Seguir monitoreando SOLO si está en estado 'starting' o 'qr' (transitorios)
    // Si está connected o detenido, dejar de molestar
    var btn = document.getElementById('owaToggleBtn');
    var seguir = false;
    if (d.running && (d.state === 'starting' || d.state === 'qr')) {
      seguir = true;
    } else if (!d.running && btn && btn.classList.contains('on')) {
      // Si el toggle está ON pero no corre, reintentar
      seguir = true;
    }
    
    if (seguir) {
      openwaMonitorTimer = setTimeout(monitorOpenWa, 3000);
    } else {
      openwaMonitorTimer = null;
    }
  }).catch(function() {
    openwaMonitorTimer = setTimeout(monitorOpenWa, 5000);
  });
}

// ====== BANCOS DINÁMICOS ======
let bancosList = [];

function agregarBanco() {
  bancosList.push({ nombre: '', titular: '', numero: '', tipo: 'Corriente', cedula: '' });
  renderBancos();
}

function eliminarBanco(idx) {
  bancosList.splice(idx, 1);
  renderBancos();
}

function renderBancos() {
  const container = document.getElementById('bancosContainer');
  if (!container) return;
  
  if (bancosList.length === 0) {
    container.innerHTML = '<div class="banco-empty"><i class="fas fa-university"></i>No hay cuentas bancarias registradas.<br>Haz clic en "+ Agregar banco" para añadir una.</div>';
    const input = document.getElementById('bancosDataInput');
    if (input) input.value = '[]';
    return;
  }
  
  let html = '';
  bancosList.forEach(function(b, i) {
    html += '<div class="banco-card" data-idx="' + i + '">';
    html += '  <div class="banco-card-header">';
    html += '    <div class="banco-card-title"><i class="fas fa-university" style="color:#6366f1;margin-right:6px;"></i>Banco ' + (i + 1) + '</div>';
    html += '    <button type="button" class="banco-card-remove" onclick="eliminarBanco(' + i + ')" title="Eliminar"><i class="fas fa-times"></i></button>';
    html += '  </div>';
    html += '  <div class="banco-card-grid">';
    html += '    <div class="field-group"><label>Nombre del banco</label>';
    html += '      <input type="text" class="banco-input" data-idx="' + i + '" data-field="nombre" value="' + escHtml(b.nombre) + '" placeholder="Ej: Banco Popular">';
    html += '    </div>';
    html += '    <div class="field-group"><label>Titular de la cuenta</label>';
    html += '      <input type="text" class="banco-input" data-idx="' + i + '" data-field="titular" value="' + escHtml(b.titular) + '" placeholder="Nombre del titular">';
    html += '    </div>';
    html += '    <div class="field-group"><label>Número de cuenta</label>';
    html += '      <input type="text" class="banco-input" data-idx="' + i + '" data-field="numero" value="' + escHtml(b.numero) + '" placeholder="Cuenta">';
    html += '    </div>';
    html += '    <div class="field-group"><label>Tipo de cuenta</label>';
    html += '      <select class="banco-input" data-idx="' + i + '" data-field="tipo">';
    html += '        <option value="Corriente" ' + (b.tipo === 'Corriente' ? 'selected' : '') + '>Corriente</option>';
    html += '        <option value="Ahorros" ' + (b.tipo === 'Ahorros' ? 'selected' : '') + '>Ahorros</option>';
    html += '      </select>';
    html += '    </div>';
    html += '    <div class="field-group"><label>Cédula / RNC</label>';
    html += '      <input type="text" class="banco-input" data-idx="' + i + '" data-field="cedula" value="' + escHtml(b.cedula) + '" placeholder="Cédula del titular">';
    html += '    </div>';
    html += '  </div>';
    html += '</div>';
  });
  
  container.innerHTML = html;
  
  // Attach change listeners
  document.querySelectorAll('.banco-input').forEach(function(el) {
    el.addEventListener('change', function() {
      var idx = parseInt(this.getAttribute('data-idx'));
      var field = this.getAttribute('data-field');
      if (bancosList[idx]) bancosList[idx][field] = this.value;
      saveBancosData();
    });
    el.addEventListener('input', function() {
      var idx = parseInt(this.getAttribute('data-idx'));
      var field = this.getAttribute('data-field');
      if (bancosList[idx]) bancosList[idx][field] = this.value;
      saveBancosData();
    });
  });
  
  saveBancosData();
}

function saveBancosData() {
  const input = document.getElementById('bancosDataInput');
  if (input) input.value = JSON.stringify(bancosList);
}

function loadBancosData(raw) {
  try {
    bancosList = JSON.parse(raw) || [];
  } catch(e) {
    bancosList = [];
  }
  renderBancos();
}

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
