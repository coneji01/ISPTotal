<script type="text/javascript">

$( document ).ready(function() {
	
	// Hide new version dot if user has already seen this version
	var currentVersion = '3.53.0';
	var lastSeenVersion = localStorage.getItem('lastSeenVersion');
	if (lastSeenVersion === currentVersion) {
		$('.new-version-dot').hide();
	}

	
	$('#smartolt-update-banner-changelog').on('click', function(e) {
		e.preventDefault();
		localStorage.setItem('lastSeenVersion', currentVersion);
		$('.new-version-dot').hide();
				window.location.href = '/changelog';
			});

	$('#smartolt-update-banner-dismiss').on('click', function() {
		localStorage.setItem('lastSeenVersion', currentVersion);
		$('.new-version-dot').hide();
		$('#smartolt-update-banner').slideUp(300);
	});

	$('#footer-changelog-link').on('click', function() {
		localStorage.setItem('lastSeenVersion', currentVersion);
		$('.new-version-dot').hide();
	});

	//hide alert-success after 5 seconds
	/*setTimeout(function(){
		$('.alert-success').not('.nofade').fadeOut();
	},5000);*/
	
	var waitingForOLT   = $("<div>", {
	    id      : "waitingOLT",
	    css     : {
	        "font-size" : "50px",
			"white-space" : "nowrap"
	    },
	    text    : "Waiting for OLT"
	});

	var loadingOverlaySettings = {
		    image       : "",
		    fontawesome : "fa fa-spinner fa-spin",
		    custom  : waitingForOLT,
		    resizeInterval : 0
		};

	$.LoadingOverlay("append", loadingOverlaySettings);

	window.showLoadingOverlay = function(loadingText = null) {
		if(loadingText != null) {
			$("#waitingOLT").text(loadingText);
		}
		else {
			$("#waitingOLT").text("Waiting for OLT");
		}
		
		$.LoadingOverlay("show", loadingOverlaySettings);
	}

	window.hideLoadingOverlay = function() {
		$.LoadingOverlay("hide");
	}

	window.isLoadingOverlayVisible = function() {
		return $('.loadingoverlay').is(":visible");
	}
	
	//hide loading overlay when ajax request finishes
	/*$(document).ajaxStop(function(){
		hideLoadingOverlay();
	});*/

	//show toast with error
	$(document).ajaxError(function(requestObject, error, errorThrown) {
		if(error.status != 404 && error != undefined && error.responseJSON != undefined && 
				error.responseJSON.error != undefined && error.responseJSON.error.length > 0) {
			toast(error.responseJSON.error);
		}
	});

	//confirm message box
	window.MessageBoxConfirm = function(message){
	    return $.MessageBox({
	        buttonDone  : "OK",
	        buttonFail  : "Cancel",
	        message     : message
	    });
	}

	window.getSelectedText = function() {
        if (window.getSelection) {
            return window.getSelection().toString();
        } 
        else if (document.selection) {
            return document.selection.createRange().text;
        }
        return '';
    }

	//close navbar menu when clicking outside of it
	$(document).click(function (event) {
		var clickover = $(event.target);
		var $nav = $("div.navbar-collapse");
        var _opened = $nav.hasClass("in");

        if (_opened === true && !clickover.hasClass("navbar-toggle")) {
			$nav.collapse('hide');
        }
    });

	/*https://www.quirksmode.org/blog/archives/2014/02/mouse_event_bub.html
	  Safari on iOS only allows the mouse events, including click, to bubble up in the following situations:
	  1. The target element of the event is a link or a form field.
	  2. The target element, or any of its ancestors up to but not including the <body>, has an explicit event handler set for any of the mouse events. This event handler may be an empty function.
      3. The target element, or any of its ancestors up to and including the document has a cursor: pointer CSS declarations. */
	$("#content-wrapper").click(function (event) {
		//this is here only for iOS to allow mouse events to bubble up so we can close navbar menu when clicking outside of it
    });

	// check navbar menu top offset
    function closeMenuIfOpened() {
		var $nav = $("div.navbar-collapse");
    	var _opened = $nav.hasClass("in");

        if (_opened === true && $(".navbar").offset().top > 50) {
			$nav.collapse('hide');
        }
    }

    //for touch devices, detect zoom in/out events and close the navbar menu if opened
    var tracks = [];
    $(window).on("touchmove", function (event) {
	
	    //only run code if the user has two fingers touching
	    if (event.originalEvent.touches.length === 2) {
	
	        //track the touches, I'm setting each touch as an array inside the tracks array
	        //each touch array contains an X and Y coordinate
	        tracks.push([ [event.originalEvent.touches[0].pageX, event.originalEvent.touches[0].pageY], [event.originalEvent.touches[1].pageX, event.originalEvent.touches[1].pageY] ]);
	    }
	}).on("touchstart", function () {
	    //start-over
	    tracks = [];
	}).on("touchend", function () {
	    if(tracks.length > 0) {
			var $nav = $("div.navbar-collapse");
	    	var _opened = $nav.hasClass("in");
	        if (_opened === true) {
				$nav.collapse('hide');
	        }
	    }
	});

	// COPY TO CLIPBOARD
	// Attempts to use .execCommand('copy') on a created text field
	// Falls back to a selectable alert if not supported
	// Attempts to display status in Bootstrap tooltip
	// ------------------------------------------------------------------------------

	function copyToClipboard(text, el) {
	  var copyTest = document.queryCommandSupported('copy');
	  var elOriginalText = el.attr('data-original-title');

	  if (copyTest === true) {
	    var copyTextArea = document.createElement("textarea");
	    copyTextArea.value = text;
	    document.body.appendChild(copyTextArea);
	    copyTextArea.select();
	    try {
	      var successful = document.execCommand('copy');
	      var msg = successful ? "Copied!" : "Whoops, not copied!";
	      el.attr('data-original-title', msg).tooltip('show');
	    } 
	    catch (err) {
	      console.log("Oops, unable to copy");
	    }
	    document.body.removeChild(copyTextArea);
	    el.attr('data-original-title', elOriginalText);
	  } 
	  else {
	    // Fallback if browser doesn't support .execCommand('copy')
	    window.prompt("Copy to clipboard", text);
	  }
	}

	function copyToClipboard2(text, el) {
		  if (document.queryCommandSupported('copy') === true) {
			var elOriginalText = el.attr('data-original-title');
	 	    var copyTextArea = document.createElement("textarea");
		    copyTextArea.textContent = text.text();
		    document.body.appendChild(copyTextArea);

		    var selection = document.getSelection();
		    var range = document.createRange();
		    range.selectNode(copyTextArea);
		    selection.removeAllRanges();
		    selection.addRange(range);
		    
		    try {
		      var successful = document.execCommand('copy');
			  var msg;

			  if (successful) {
				  msg = "Copied!";
			  } 
			  else {
				msg = "Whoops, not copied!";
				el.removeClass('not-selectable');
			  }
		      el.attr('data-original-title', msg).tooltip('show');
		    } 
		    catch (err) {
		      console.log("Oops, unable to copy");
		    }
		    selection.removeAllRanges();
		    document.body.removeChild(copyTextArea);
		    el.attr('data-original-title', elOriginalText);
		  } 
		  else {
			$('.not-selectable').removeClass('not-selectable');
		    // Fallback if browser doesn't support .execCommand('copy')
		    window.prompt("Copy to clipboard", text.text());
		  }
		}

	// Initialize
   // ---------------------------------------------------------------------

   // Tooltips
   // Requires Bootstrap 3 for functionality
   $('.js-tooltip').tooltip();

   // Copy to clipboard
   // Grab any text in the attribute 'data-copy' and pass it to the 
   // copy function
   $('.js-copy').click(function() {
     var text = $(this).attr('data-copy');
     var el = $(this);
     copyToClipboard(text, el);
   });

   $(document).on('click','.comma-copy', function() {
	   $(this).removeClass('btn-primary').addClass('btn-default');
	     var el = $('#'+$(this).attr('data-idtag'));
	     copyToClipboard2(el, $(this));
	     el.removeClass('text-primary').addClass('text-muted');
	   });

   //trim white spaces when paste in any input
   $(document).on('paste', 'input[type=text]', function(e) {
	  // prevent copying action
	  e.preventDefault();
	  
	  var pastedText = e.originalEvent.clipboardData.getData('Text');
	  var withoutSpaces = pastedText;
	  if(pastedText) {
		  withoutSpaces = pastedText.trim();
	  }

	  //remove all spaces, including from inside the text
	  if($(this).hasClass('no_spaces')) {
		  withoutSpaces = withoutSpaces.replace(/\s/g, '');
	  }
	  
	  $(this).insertAtCaret(withoutSpaces);
	});

   $.fn.insertAtCaret = function(text) {
	    return this.each(function() {
	        if (document.selection && this.tagName == 'TEXTAREA') {
	            //IE textarea support
	            this.focus();
	            sel = document.selection.createRange();
	            sel.text = text;
	            this.focus();
	        } else if (this.selectionStart || this.selectionStart == '0') {
	            //MOZILLA/NETSCAPE support
	            startPos = this.selectionStart;
	            endPos = this.selectionEnd;
	            scrollTop = this.scrollTop;
	            this.value = this.value.substring(0, startPos) + text + this.value.substring(endPos, this.value.length);
	            this.focus();
	            this.selectionStart = startPos + text.length;
	            this.selectionEnd = startPos + text.length;
	            this.scrollTop = scrollTop;
	        } else {
	            // IE input[type=text] and other browsers
	            this.value += text;
	            this.focus();
	            this.value = this.value;    // forces cursor to end
	        }
	    });
	};
    
	
  $('.save-configuration-button').click(function (){
    var button = $('.save-configuration-anchor');

    button.toggleClass('active');
    button.attr('disabled', true);
    button.text("Saving...");
    $('#saveConfigModal').modal('hide');

    $.ajax({
        method: "GET",
        beforeSend: function(request) {
		    request.setRequestHeader("X-Token", config.X_TOKEN);
		  },
        url: "/api/system/write",
      })
      .done(function( response ) {
        $.MessageBox((response && response.response) ? response.response : "Save initiated. It could take the OLT up to 5 minutes to write the config!");
        button.text("Save config");
        setTimeout(function () {
          button.toggleClass('active');
          button.attr('disabled', false);
          button.text("Save config");
        }, 1000);
      })
      .fail(function(jqXHR, textStatus) {
    	  if(jqXHR.responseJSON) {
				$.MessageBox(jqXHR.responseJSON.error);
			}
			else {
				$.MessageBox(jqXHR.responseText);
			}
	        setTimeout(function () {
	        	 button.toggleClass('active');
	             button.attr('disabled', false);
	             button.text("Save config");
	        }, 1000);
      });
  });

    
});
</script>

