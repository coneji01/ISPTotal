<!-- Include the shared presets JS file -->
<script src="/public/smartolt-files/onu_authorization_presets.js"></script>

<script>
$(document).ready(function() {
	var currentStep = 1;
	var totalSteps = 6;

	// Open wizard modal
	$('#openWizardBtn, #openWizardBtnTop').on('click', function() {
		resetWizard();
		$('#presetWizardModal').modal('show');
	});

	// Template buttons
	$('.use-template-btn').on('click', function() {
		var template = $(this).data('template');
		resetWizard();
		applyTemplate(template);
		$('#presetWizardModal').modal('show');
	});

	// Apply template data
	function applyTemplate(template) {
		switch(template) {
			case 'residential_gpon':
				$('#name').val('Residential GPON');
				$('#description').val('Standard residential GPON setup with routing mode');
				$('input[name="pon_type"][value="gpon"]').prop('checked', true).trigger('change');
				$('input[name="mode"][value="Routing"]').prop('checked', true);
				$('#location_name').val('{zone} - {sn}');
				$('#description_pattern').val('Auto-authorized: {onu_type}');
				break;

			case 'business_fiber':
				$('#name').val('Business Fiber');
				$('#description').val('Business fiber setup with bridging mode');
				$('input[name="pon_type"][value="gpon"]').prop('checked', true).trigger('change');
				$('input[name="mode"][value="Bridging"]').prop('checked', true);
				$('#location_name').val('{zone} - Business');
				$('#description_pattern').val('Business client - {sn}');
				break;

			case 'sn_filtered':
				$('#name').val('Huawei ONUs Only');
				$('#description').val('Only authorize Huawei ONUs (HWTC serial prefix)');
				$('input[name="pon_type"][value="gpon"]').prop('checked', true).trigger('change');
				$('input[name="mode"][value="Routing"]').prop('checked', true);
				$('#sn_pattern').val('HWTC');
				$('#location_name').val('{zone} - Huawei');
				break;
		}
	}

	// Next button
	$('#wizardNextBtn').on('click', function() {
		if (validateCurrentStep()) {
			if (currentStep < totalSteps) {
				currentStep++;
				updateWizardUI();

				if (currentStep === totalSteps) {
					generateSummary();
				}
			}
		}
	});

	// Previous button
	$('#wizardPrevBtn').on('click', function() {
		if (currentStep > 1) {
			currentStep--;
			updateWizardUI();
		}
	});

	// Submit button
	$('#wizardSubmitBtn').on('click', function() {
		$(this).prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Creating...');
		// Enable tag_transform_mode before submit to ensure value is sent
		$("#tag_transform_mode").attr("disabled", false);
		$('#wizard_preset_form').submit();
	});

	// Validate current step
	function validateCurrentStep() {
		switch(currentStep) {
			case 1:
				var name = $('#name').val().trim();
				if (!name) {
					$.MessageBox(lang_please_enter_preset_name);
					$('#name').focus();
					return false;
				}
				return true;
			case 2: // Conditions step
				// Validate Fallback ONU Type is selected when ONU Type is auto-detect
				var onuTypeId = $('#onu_type_id').val();
				if (!onuTypeId || onuTypeId === '') {
					var fallbackOnuTypeId = $('#fallback_onu_type_id').val();
					if (!fallbackOnuTypeId || fallbackOnuTypeId === '') {
						$.MessageBox(lang_fallback_onu_type_required);
						$('#fallback_onu_type_id').closest('.form-group').addClass('has-error');
						setTimeout(function() {
							$('#fallback_onu_type_id').closest('.form-group').removeClass('has-error');
						}, 3000);
						return false;
					}
				}
				return true;
			case 3: // ONU Settings step
				// Validate User VLAN
				var vlanId = $('#vlan_id').val();
				if (!vlanId || vlanId === '') {
					$.MessageBox(lang_user_vlan_required);
					$('#vlan_id').closest('.form-group').addClass('has-error');
					setTimeout(function() {
						$('#vlan_id').closest('.form-group').removeClass('has-error');
					}, 3000);
					return false;
				}
				return true;
			case 4: // TR069 & Mgmt step
				// Validate Management IP settings
				var mgmtIPMode = $('input[name="mgmt_ip_mode"]:checked').val();
				if (mgmtIPMode && mgmtIPMode !== 'Inactive') {
					var mgmtVlanId = $('#mgmt_ip_vlan_id').val();
					if (!mgmtVlanId || mgmtVlanId === '') {
						$.MessageBox(lang_mgmt_vlan_required_when_mode_set.replace('{mode}', mgmtIPMode));
						// Scroll to the management VLAN field
						$('#mgmt_ip_vlan_id').closest('.form-group').addClass('has-error');
						setTimeout(function() {
							$('#mgmt_ip_vlan_id').closest('.form-group').removeClass('has-error');
						}, 3000);
						return false;
					}
				}
				return true;
			case 5: // WiFi step
				// Validate WiFi settings using the shared validation function
				if (typeof validateWifiSettings === 'function') {
					var wifiValidation = validateWifiSettings(''); // Empty suffix for wizard
					if (!wifiValidation.valid) {
						$.MessageBox(wifiValidation.message);
						return false;
					}
				}
				return true;
			default:
				return true;
		}
	}

	// Update wizard UI based on current step
	function updateWizardUI() {
		// Update progress bar
		var progress = (currentStep / totalSteps) * 100;
		$('#wizardProgressBar').css('width', progress + '%');

		// Update step indicators
		$('.wizard-steps li').removeClass('active completed');
		$('.wizard-steps li').each(function() {
			var step = $(this).data('step');
			if (step < currentStep) {
				$(this).addClass('completed');
			} else if (step === currentStep) {
				$(this).addClass('active');
			}
		});

		// Show/hide steps
		$('.wizard-step').hide();
		$('.wizard-step[data-step="' + currentStep + '"]').show();

		// Update WiFi availability when entering step 5
		if (currentStep === 5) {
			updateWifiAvailability();
		}

		// Update buttons
		if (currentStep === 1) {
			$('#wizardPrevBtn').hide();
		} else {
			$('#wizardPrevBtn').show();
		}

		if (currentStep === totalSteps) {
			$('#wizardNextBtn').hide();
			$('#wizardSubmitBtn').show();
		} else {
			$('#wizardNextBtn').show();
			$('#wizardSubmitBtn').hide();
		}
	}

	// Reset wizard to initial state
	function resetWizard() {
		currentStep = 1;
		$('#wizard_preset_form')[0].reset();

		// Re-trigger the shared JS to reinitialize the form
		var initial_olt_id = $('#olt_id').val();
		if (initial_olt_id && typeof oltChange === 'function') {
			oltChange(initial_olt_id);
			if (typeof setup_boards_and_ports_datalist === 'function') {
				setup_boards_and_ports_datalist(initial_olt_id, true);
			}
		}

		// Reset PON type to GPON and trigger ONU types refresh
		$('input[name="pon_type"][value="gpon"]').prop('checked', true);
		if (typeof fillOnuTypes === 'function') {
			fillOnuTypes('gpon', '');
		}

		// Update TR-069 and Management IP availability for wizard
		if (typeof updateTR069AndMgmtIPAvailability === 'function') {
			updateTR069AndMgmtIPAvailability();
		}

		updateWizardUI();
		$('#wizardSubmitBtn').prop('disabled', false).html('<i class="fa fa-check"></i> Create Preset');
	}

	// Generate summary for review step
	function generateSummary() {
		var summary = '';

		// Basic info
		summary += '<div class="summary-row"><div class="summary-label">' + lang_preset_name + '</div><div class="summary-value">' + escapeHtml($('#name').val() || '-') + '</div></div>';
		summary += '<div class="summary-row"><div class="summary-label">' + lang_description + '</div><div class="summary-value">' + escapeHtml($('#description').val() || '-') + '</div></div>';

		// Is default
		if ($('#wizard_is_default').is(':checked')) {
			summary += '<div class="summary-row"><div class="summary-label">' + lang_default_preset + '</div><div class="summary-value"><span class="label label-primary"><i class="fa fa-star"></i> ' + lang_yes + '</span></div></div>';
		}

		// OLT info
		var oltText = $('#olt_id option:selected').text();
		summary += '<div class="summary-row"><div class="summary-label">' + lang_olt + '</div><div class="summary-value">' + escapeHtml(oltText) + '</div></div>';

		var board = $('#board').val();
		var port = $('#port').val();
		var location = board || port ? (board ? lang_board + ' ' + board : '') + (board && port ? ', ' : '') + (port ? lang_port + ' ' + port : '') : lang_all_boards_ports;
		summary += '<div class="summary-row"><div class="summary-label">' + lang_board_port + '</div><div class="summary-value">' + location + '</div></div>';

		// PON info
		var ponType = $('input[name="pon_type"]:checked').val().toUpperCase();
		var channelType = $('input[name="channel_type"]:checked').val().toUpperCase();
		summary += '<div class="summary-row"><div class="summary-label">' + lang_pon_type + '</div><div class="summary-value">' + ponType + ' / ' + channelType + '</div></div>';

		// ONU info
		var onuTypeId = $('#onu_type_id').val();
		var onuType = $('#onu_type_id option:selected').text();
		var mode = $('input[name="mode"]:checked').val();
		summary += '<div class="summary-row"><div class="summary-label">' + lang_onu_type + '</div><div class="summary-value">' + escapeHtml(onuType) + '</div></div>';

		// Fallback ONU Type (if auto-detect and fallback is set)
		if (!onuTypeId || onuTypeId === '' || onuTypeId === '0') {
			var fallbackOnuTypeId = $('#fallback_onu_type_id').val();
			var fallbackOnuType = $('#fallback_onu_type_id option:selected').text();
			if (fallbackOnuTypeId && fallbackOnuType && fallbackOnuType.trim() !== '') {
				summary += '<div class="summary-row"><div class="summary-label">' + lang_fallback_onu_type + '</div><div class="summary-value">' + escapeHtml(fallbackOnuType) + '</div></div>';
			}
		}

		summary += '<div class="summary-row"><div class="summary-label">' + lang_mode + '</div><div class="summary-value"><span class="label label-' + (mode === 'Routing' ? 'info' : 'bridge') + '">' + mode + '</span></div></div>';

		// Custom Profile (only show if enabled)
		if ($('#custom_profile').is(':checked')) {
			var customTemplateId = $('#custom_template_id').val();
			var customTemplateName = $('#custom_template_id option:selected').text();
			if (customTemplateId && customTemplateName) {
				summary += '<div class="summary-row"><div class="summary-label">' + lang_custom_profile + '</div><div class="summary-value">' + escapeHtml(customTemplateName) + '</div></div>';
			}
		}

		var snPattern = $('#sn_pattern').val();
		if (snPattern) {
			summary += '<div class="summary-row"><div class="summary-label">' + lang_sn_pattern + '</div><div class="summary-value"><code>' + escapeHtml(snPattern) + '</code></div></div>';
		}

		// Network info
		var vlanText = $('#vlan_id option:selected').text();
		summary += '<div class="summary-row"><div class="summary-label">' + lang_vlan + '</div><div class="summary-value">' + escapeHtml(vlanText) + '</div></div>';

		// SVLAN info
		if ($('#use_svlan').is(':checked')) {
			var svlanText = $('#svlan_id option:selected').text();
			var tagTransformMode = $('#tag_transform_mode').val();
			var svlanDisplay = escapeHtml(svlanText);
			// Show tag transform mode for Huawei OLTs (when tag_transform_mode has a value)
			if (tagTransformMode) {
				svlanDisplay += ' <small class="text-muted">(' + escapeHtml(tagTransformMode) + ')</small>';
			}
			summary += '<div class="summary-row"><div class="summary-label">' + lang_svlan + '</div><div class="summary-value">' + svlanDisplay + '</div></div>';

			// Use other-all TLS VLAN
			if ($('#use_other_all_tls_vlan').is(':checked')) {
				summary += '<div class="summary-row"><div class="summary-label">' + lang_tls_vlan + '</div><div class="summary-value"><span class="label label-info">other-all</span></div></div>';
			}
		}

		// CVLAN info
		if ($('#use_cvlan').is(':checked')) {
			var cvlanText = $('#cvlan_id option:selected').text();
			summary += '<div class="summary-row"><div class="summary-label">' + lang_cvlan + '</div><div class="summary-value">' + escapeHtml(cvlanText) + '</div></div>';
		}

		var downloadSpeed = $('#download_speed_id option:selected').text() || lang_none;
		var uploadSpeed = $('#upload_speed_id option:selected').text() || lang_none;
		summary += '<div class="summary-row"><div class="summary-label">' + lang_speed_profiles + '</div><div class="summary-value"><i class="fa fa-arrow-down text-success"></i> ' + escapeHtml(downloadSpeed) + ' / <i class="fa fa-arrow-up text-primary"></i> ' + escapeHtml(uploadSpeed) + '</div></div>';

		// Location info
		var zone = $('#location_id option:selected').text() || lang_none;
		var odb = $('#odb_id option:selected').text() || lang_none;
		summary += '<div class="summary-row"><div class="summary-label">' + lang_zone + '</div><div class="summary-value">' + escapeHtml(zone) + '</div></div>';
		summary += '<div class="summary-row"><div class="summary-label">' + lang_odb + '</div><div class="summary-value">' + escapeHtml(odb) + '</div></div>';

		// Naming patterns
		var namePattern = $('#location_name').val();
		var addressPattern = $('#description_pattern').val();
		if (namePattern) {
			summary += '<div class="summary-row"><div class="summary-label">' + lang_name_pattern + '</div><div class="summary-value"><code>' + escapeHtml(namePattern) + '</code></div></div>';
		}
		if (addressPattern) {
			summary += '<div class="summary-row"><div class="summary-label">' + lang_address_pattern + '</div><div class="summary-value"><code>' + escapeHtml(addressPattern) + '</code></div></div>';
		}

		// TR-069 Profile
		var tr069ProfileId = $('#tr069_profile_id').val();
		var tr069ProfileName = $('#tr069_profile_id option:selected').text();
		if (tr069ProfileId && tr069ProfileName && tr069ProfileName !== lang_none) {
			summary += '<div class="summary-row"><div class="summary-label">' + lang_tr069_profile + '</div><div class="summary-value">' + escapeHtml(tr069ProfileName) + '</div></div>';
		}

		// Management IP
		var mgmtIpMode = $('input[name="mgmt_ip_mode"]:checked').val();
		if (mgmtIpMode && mgmtIpMode !== 'Inactive') {
			var mgmtLabel = mgmtIpMode === 'Static'
				? '<span class="label label-success">' + lang_static_ip + '</span>'
				: '<span class="label label-info">' + lang_dhcp + '</span>';

			var mgmtSummary = mgmtLabel;

			// Build VLAN info parts
			var vlanParts = [];
			var mgmtVlanId = $('#mgmt_ip_vlan_id').val();
			var mgmtVlanNumber = $('#mgmt_ip_vlan_id option:selected').text();
			if (mgmtVlanId && mgmtVlanNumber) {
				vlanParts.push(lang_vlan + ' ' + escapeHtml(mgmtVlanNumber));
			}

			// Mgmt IP SVLAN (only show if use_mgmt_ip_svlan is checked)
			if ($('#use_mgmt_ip_svlan').is(':checked')) {
				var mgmtSvlanId = $('#mgmt_ip_svlan_id').val();
				var mgmtSvlanNumber = $('#mgmt_ip_svlan_id option:selected').text();
				if (mgmtSvlanId && mgmtSvlanNumber) {
					var svlanInfo = lang_svlan + ' ' + escapeHtml(mgmtSvlanNumber);
					var mgmtTagTransformMode = $('#mgmt_ip_tag_transform_mode').val();
					if (mgmtTagTransformMode) {
						svlanInfo += ' ' + escapeHtml(mgmtTagTransformMode);
					}
					vlanParts.push(svlanInfo);
				}
			}

			// Mgmt IP CVLAN (only show if use_mgmt_ip_cvlan is checked)
			if ($('#use_mgmt_ip_cvlan').is(':checked')) {
				var mgmtCvlanId = $('#mgmt_ip_cvlan_id').val();
				var mgmtCvlanNumber = $('#mgmt_ip_cvlan_id option:selected').text();
				if (mgmtCvlanId && mgmtCvlanNumber) {
					vlanParts.push(lang_cvlan + ' ' + escapeHtml(mgmtCvlanNumber));
				}
			}

			if (vlanParts.length > 0) {
				mgmtSummary += ' <small class="text-muted">(' + vlanParts.join(', ') + ')</small>';
			}

			summary += '<div class="summary-row"><div class="summary-label">' + lang_mgmt_ip + '</div><div class="summary-value">' + mgmtSummary + '</div></div>';
		}

		// WiFi Settings
		var wifiEnabled = $('input[name="wifi_enabled"]:checked').val();
		if (wifiEnabled === '1') {
			var wifiConfigJson = $('#wifi_config').val();
			if (wifiConfigJson) {
				try {
					var wifiConfig = JSON.parse(wifiConfigJson);
					if (wifiConfig && wifiConfig.length > 0) {
						var enabledPorts = wifiConfig.filter(function(p) { return p.is_enabled; });
						if (enabledPorts.length > 0) {
							var wifiSummary = '<span class="label label-info">' + lang_enabled + '</span>';
							wifiSummary += ' <small class="text-muted">(' + enabledPorts.length + ' ' + (enabledPorts.length !== 1 ? lang_ports : lang_port) + ')</small>';

							// Show details for each enabled port
							enabledPorts.forEach(function(port) {
								// Get port name from the rendered WiFi port panel
								var portName = '';
								var $portPanel = $('#wifi_ports_container .wifi-port-config[data-port-id="' + port.wifi_port_id + '"]');
								if ($portPanel.length) {
									// Clone the header h4, remove the status span, then get the text
									var $title = $portPanel.find('.section-panel-header h4').clone();
									$title.find('.wifi-port-status').remove();
									portName = $title.text().trim();
								}

								// Build port details string
								var portDetails = [];
								if (port.ssid) portDetails.push('SSID: ' + escapeHtml(port.ssid));
								if (port.auth_mode) portDetails.push(port.auth_mode.toUpperCase());
								if (port.mode && port.mode !== 'LAN') portDetails.push(port.mode);
								// Add VLAN info
								if (port.vlan_id) {
									var vlanText = $('#vlan_id option[value="' + port.vlan_id + '"]').text();
									if (vlanText) portDetails.push('VLAN: ' + escapeHtml(vlanText));
								}
								// Add Allowed VLANs info for Hybrid/Trunk modes
								if (port.extra_vlans && port.extra_vlans.length > 0) {
									var extraVlanTexts = [];
									port.extra_vlans.forEach(function(vlanId) {
										var vText = $('#vlan_id option[value="' + vlanId + '"]').text();
										if (vText) extraVlanTexts.push(vText);
									});
									if (extraVlanTexts.length > 0) {
										portDetails.push('Allowed VLANs: ' + escapeHtml(extraVlanTexts.join(', ')));
									}
								}

								// Always show the port name, even if no additional details
								if (portName) {
									var detailsStr = portDetails.length > 0 ? ': ' + portDetails.join(', ') : '';
									wifiSummary += '<br><small class="text-muted" style="margin-left: 10px;">• ' + escapeHtml(portName) + detailsStr + '</small>';
								} else if (portDetails.length > 0) {
									wifiSummary += '<br><small class="text-muted" style="margin-left: 10px;">• ' + portDetails.join(', ') + '</small>';
								}
							});

							summary += '<div class="summary-row"><div class="summary-label">' + lang_wifi + '</div><div class="summary-value">' + wifiSummary + '</div></div>';
						}
					}
				} catch (e) {
					// Invalid JSON, skip WiFi summary
				}
			}
		}

		// Web User/Password
		var webUser = $('#wizard_web_user').val();
		var webPassword = $('#wizard_web_password').val();
		if (webUser) {
			summary += '<div class="summary-row"><div class="summary-label">' + lang_web_user + '</div><div class="summary-value">' + escapeHtml(webUser) + '</div></div>';
		}
		if (webPassword) {
			summary += '<div class="summary-row"><div class="summary-label">' + lang_web_pass + '</div><div class="summary-value">••••••••</div></div>';
		}

		$('#wizardSummary').html(summary);
	}

	// Escape HTML helper
	function escapeHtml(text) {
		if (!text) return '';
		var div = document.createElement('div');
		div.appendChild(document.createTextNode(text));
		return div.innerHTML;
	}

	// ===========================================
	// WiFi Settings handlers (using shared functions from onu_authorization_presets.js)
	// ===========================================
	// WiFi enable/disable toggle
	$('input[name="wifi_enabled"]').on('change', function() {
		if ($(this).val() === '1') {
			$('#wifi_config_container').slideDown(200);
			// Load WiFi ports when enabling
			var onuTypeId = $('#onu_type_id').val();
			if (onuTypeId && typeof loadWifiPorts === 'function') {
				loadWifiPorts(onuTypeId, ''); // Empty suffix for wizard
			}
		} else {
			$('#wifi_config_container').slideUp(200);
		}
	});

});
</script>
