    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <title>OLT settings - ISPTotal</title>
  <link href="/public/smartolt-files/bootstrap-custom.css?v=3.53.0.24" rel="stylesheet">
  <link href="/public/smartolt-files/bootstrap-multiselect.css?v=3.53.0.20" rel="stylesheet">
  <link href="/public/smartolt-files/styles.css?v=3.53.0.35" rel="stylesheet">
  <link href="/public/smartolt-files/toast.css?v=3.53.0.20" rel="stylesheet">
  <link href="/public/smartolt-files/font-awesome.min.css" rel="stylesheet">
  <link href="/public/smartolt-files/messagebox.css" rel="stylesheet">
  <link href="/public/smartolt-files/inter-fonts.css?v=3.53.0.1" rel="stylesheet">
  <link href="/public/smartolt-files/dashboard-smartolt-night.css?v=3.53.0.314" rel="stylesheet">
  <script src="/public/smartolt-files/jquery.min.js"></script>
  <script src="/public/smartolt-files/toast.js"></script>
</head>
<body class="smartolt-site">
<script>
$(document).ready(function() {
  $.ajaxSetup({ cache: false });
  var oltId = <%= locals.olt_id || 0 %>;
  
  function loadOltDetails() {
    $.getJSON('/api/olt-detail?id=' + oltId, function(data) {
      if (!data || !data.success) return;
      var o = data.data;
      if (!o) return;
      $('#olt-name').text(o.nombre || '--');
      $('#olt-ip').text(o.olt_ip || '--');
      $('#olt-tcp').text(o.olt_port || '23');
      $('#olt-username').text(o.olt_username || '--');
      $('#olt-model').text(o.modelo || '--');
      $('#olt-vlan').text(o.vlan_default || '--');
    });
  }
  loadOltDetails();
});
</script>

<div class="smartolt-landing-hero-bg" aria-hidden="true"></div>
<div id="content-wrapper">
  <div class="navbar navbar-default navbar-fixed-top default-menu">
    <div class="container">
      <div class="navbar-header">
        <button class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-main">
          <span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span>
        </button>
        <a class="navbar-brand" href="/modulo?pagina=GPONManager">Dashboard</a>
      </div>
      <div class="collapse navbar-collapse" id="navbar-main">
        <ul class="nav navbar-nav">
          <li><a href="/modulo?pagina=smartolt_olt">OLTs</a></li>
          <li class="active"><a href="#">OLT details</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container">
    <h2>OLT details</h2>
    <a href="/modulo?pagina=smartolt_olt" class="btn btn-success margin-bottom">Back to OLTs list</a>
    
    <ul class="nav nav-tabs">
      <li class="active"><a href="#">OLT details</a></li>
      <li><a href="/modulo?pagina=smartolt_olt_cards&olt_id=<%= locals.olt_id || 0 %>">OLT cards</a></li>
      <li><a href="/modulo?pagina=smartolt_olt_pon_ports&olt_id=<%= locals.olt_id || 0 %>">PON ports</a></li>
      <li><a href="/modulo?pagina=smartolt_olt_uplink_ports&olt_id=<%= locals.olt_id || 0 %>">Uplink</a></li>
      <li><a href="/modulo?pagina=smartolt_olt_vlans&olt_id=<%= locals.olt_id || 0 %>">VLANs</a></li>
      <li><a href="/modulo?pagina=smartolt_olt_ip_pools&olt_id=<%= locals.olt_id || 0 %>">ONU IP Pools</a></li>
    </ul>

    <div class="panel panel-default">
      <div class="panel-heading">
        <div class="pull-right">
          <a href="#" class="btn btn-primary btn-sm">Edit OLT settings</a>
          <a href="#" class="btn btn-default btn-sm">See history</a>
          <button class="btn btn-default btn-sm"><i class="fa fa-terminal"></i> Cli</button>
        </div>
      </div>
      <div class="panel-body">
        <table class="table table-striped">
          <thead><tr><th>OLT setting</th><th>Value</th></tr></thead>
          <tbody>
            <tr><td>Name</td><td id="olt-name">Cargando...</td></tr>
            <tr><td>OLT IP</td><td id="olt-ip">Cargando...</td></tr>
            <tr><td>Reachable via VPN tunnel</td><td>Yes</td></tr>
            <tr><td>Telnet TCP port</td><td id="olt-tcp">23</td></tr>
            <tr><td>OLT telnet username</td><td id="olt-username">******</td></tr>
            <tr><td>OLT telnet password</td><td>******</td></tr>
            <tr><td>SNMP UDP port</td><td>161</td></tr>
            <tr><td>OLT hardware version</td><td id="olt-model">Cargando...</td></tr>
            <tr><td>Default VLAN</td><td id="olt-vlan">--</td></tr>
