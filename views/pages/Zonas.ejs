<div class="page-header">
    <h2 class="page-title">Gestión de Zonas</h2>
    <button class="btn btn-primary" onclick="zonAbrirModal()" style="background:var(--accent); padding:10px 20px; border-radius:8px; font-weight:600; box-shadow:0 2px 8px rgba(99,102,241,0.3);">
        <i class="fas fa-plus"></i> Nueva Zona
    </button>
</div>

<div class="card">
    <!-- Buscador -->
    <div style="padding:15px 20px 10px; border-bottom:1px solid #f1f5f9;">
        <div style="position:relative; max-width:400px;">
            <i class="fas fa-search" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:0.85rem;"></i>
            <input type="text" id="buscarZona" placeholder="Buscar por nombre, router, OLT o VLAN..." oninput="filtrarZonas()" style="width:100%; padding:9px 12px 9px 36px; border:1px solid #e2e8f0; border-radius:8px; font-size:0.88rem; box-sizing:border-box; outline:none; transition:border-color 0.15s;" onfocus="this.style.borderColor='#2563eb'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,0.1)'" onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'">
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Nombre de la Zona</th>
                <th>Router Asociado</th>
                <th>OLT</th>
                <th>Zona en OLT</th>
                <th>VLAN</th>
                <th>Activos</th>
                <th>Suspendidos</th>
                <th>Total</th>
                <th style="text-align:right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% if (zonas && zonas.length) { zonas.forEach(function(z) { %>
                <tr>
                    <td><strong style="font-size:1rem; color:var(--text-main);"><%= z.nombre %></strong></td>
                    <td>
                        <% if (z.router_nombre) { %>
                            <span class="badge" style="background:#f0f9ff; color:#0369a1; border:1px solid #bae6fd;"><i class="fas fa-server"></i> <%= z.router_nombre %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (z.olt_nombre) { %>
                            <span class="badge" style="background:#f3e8ff; color:#7c3aed; border:1px solid #d8b4fe;"><i class="fas fa-cloud"></i> <%= z.olt_nombre %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (z.smartolt_zone) { %>
                            <span class="badge" style="background:#fef3c7; color:#92400e; border:1px solid #fcd34d;"><i class="fas fa-map-marker-alt"></i> <%= z.smartolt_zone %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (z.vlan_onu) { %>
                            <span class="badge" style="background:#e0f2fe; color:#0369a1;">VLAN <%= z.vlan_onu %></span>
                        <% } else { %>
                            <span style="color:#94a3b8;">—</span>
                        <% } %>
                    </td>
                    <td><span class="badge badge-success"><%= z.activos || 0 %></span></td>
                    <td><span class="badge badge-danger"><%= z.suspendidos || 0 %></span></td>
                    <td><strong><%= (parseInt(z.activos||0) + parseInt(z.suspendidos||0)) %></strong></td>
                    <td style="text-align:right; white-space:nowrap;">
                        <button class="btn-icon" style="color:var(--accent-primary);" onclick="zonAbrirModalEditar(<%= z.id %>, '<%= z.nombre.replace(/'/g,"\\'") %>', '<%= z.vlan_onu || '' %>', '<%= z.router_id || '' %>', '<%= z.smartolt_profile_id || '' %>', '<%= z.smartolt_zone || '' %>')" title="Editar"><i class="fas fa-edit"></i></button>
                        <button class="btn-icon" style="color:var(--accent-danger);" onclick="zonConfirmarEliminar(<%= z.id %>, '<%= z.nombre.replace(/'/g,"\\'") %>', <%= (parseInt(z.activos||0) + parseInt(z.suspendidos||0)) %>)" title="Eliminar"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            <% }); } else { %>
                <tr><td colspan="9" style="padding:30px; text-align:center; color:#94a3b8;">No hay zonas registradas</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- MODAL -->
<div class="modal-overlay" id="modalZona" style="display:none; background:rgba(0,0,0,0.5);">
    <div class="modal-content" style="width:540px; max-width:540px; padding:24px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:20px; border-bottom:1px solid var(--border-color,#e2e8f0); padding-bottom:12px;">
            <h3 style="margin:0;" id="zonModalTitle">Nueva Zona</h3>
            <button onclick="zonCerrarModal()" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:#94a3b8;">&times;</button>
        </div>
        <form method="POST" action="/modulo?pagina=Zonas" id="zonForm" onsubmit="return guardarZona(event)">
            <input type="hidden" name="accion" value="guardar_zona">
            <input type="hidden" name="id_zona" id="zonId" value="">
            <div class="form-group">
                <label class="form-label">Nombre del Sector / Zona</label>
                <input type="text" name="nombre" id="zonNombre" class="form-control" required placeholder="Ej: Centro Ciudad">
            </div>
            <div class="form-group">
                <label class="form-label">Router Asociado (Opcional)</label>
                <select name="router_id" id="zonRouter" class="form-control">
                    <option value="">-- Ninguno (Selección Manual) --</option>
                    <% (routers || []).forEach(function(r) { %>
                        <option value="<%= r.id %>"><%= r.name %></option>
                    <% }); %>
                </select>
                <small style="color:#64748b; font-size:0.75rem;">Si seleccionas uno, se cargará automáticamente al crear órdenes.</small>
            </div>
            <div class="form-group">
                <label class="form-label">OLT (Opcional)</label>
                <select name="smartolt_profile_id" id="zonProfile" class="form-control" onchange="">
                    <option value="">-- Ninguno --</option>
                    <% (olts || []).forEach(function(o) { %>
                        <option value="<%= o.id %>"><%= o.nombre %></option>
                    <% }); %>
                </select>
                <small style="color:#64748b; font-size:0.75rem;">Instancia de OLT asociada a esta zona.</small>
            </div>
            <div class="form-group" id="zonZoneGroup" style="display:none;">
                <label class="form-label">Zona en OLT <span style="color:#ef4444;">*</span></label>
                <div style="position:relative;">
                    <input type="text" name="smartolt_zone" id="zonZone" class="form-control" placeholder="Nombre de la zona en la OLT (opcional)">
                </div>
                <small style="color:#64748b; font-size:0.75rem;">Nombre de la zona configurada en la OLT (opcional).</small>
            </div>
            <div class="form-group">
                <label class="form-label">VLAN ONU <span style="color:#94a3b8; font-size:0.75rem;">(Opcional)</span></label>
                <input type="number" name="vlan_onu" id="zonVlan" class="form-control" placeholder="Ej: 100" min="1" max="4094">
                <small style="color:#64748b; font-size:0.75rem; display:block; margin-top:3px;">VLAN asignada a la ONU en esta zona.</small>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; margin-top:10px; padding:12px; background:var(--accent); font-weight:600; border-radius:8px;">
                <i class="fas fa-save"></i> Guardar
            </button>
        </form>
    </div>
</div>

<script>
function filtrarZonas() {
    var q = document.getElementById('buscarZona').value.toLowerCase().trim();
    document.querySelectorAll('.card table tbody tr').forEach(function(row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}

function zonAbrirModal() {
    document.getElementById('zonModalTitle').textContent = 'Nueva Zona';
    document.getElementById('zonId').value = '';
    document.getElementById('zonForm').reset();
    document.getElementById('zonZoneGroup').style.display = 'none';
    document.getElementById('modalZona').style.display = 'flex';
}

function zonAbrirModalEditar(id, nombre, vlan, routerId, profileId, zone) {
    document.getElementById('zonModalTitle').textContent = 'Editar Zona';
    document.getElementById('zonId').value = id;
    document.getElementById('zonNombre').value = nombre;
    document.getElementById('zonVlan').value = vlan || '';
    document.getElementById('zonRouter').value = routerId || '';
    if (profileId) {
        document.getElementById('zonProfile').value = profileId;
        document.getElementById('zonZoneGroup').style.display = 'block';
        document.getElementById('zonZone').value = zone || '';
    } else {
        document.getElementById('zonProfile').value = '';
        document.getElementById('zonZoneGroup').style.display = 'none';
    }
    document.getElementById('modalZona').style.display = 'flex';
}

function zonCerrarModal() {
    document.getElementById('modalZona').style.display = 'none';
}

function zonOnProfileChange() {
    var profileId = document.getElementById('zonProfile').value;
    var zoneGroup = document.getElementById('zonZoneGroup');
    if (profileId) {
        zoneGroup.style.display = 'block';
        var zoneSelect = document.getElementById('zonZone');
        zoneSelect.innerHTML = '<option value="">-- Seleccione zona --</option>';
        fetch('/api/smartolt/zones?profile_id=' + profileId)
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.status === 'success' && d.data) {
                    d.data.forEach(function(z) {
                        zoneSelect.innerHTML += '<option value="' + z.replace(/'/g,"\\'") + '">' + z + '</option>';
                    });
                }
            })
            .catch(function() {});
    } else {
        zoneGroup.style.display = 'none';
    }
}

function zonConfirmarEliminar(id, nombre, total) {
    if (total > 0) {
        if (!confirm('La zona "' + nombre + '" tiene ' + total + ' servicio(s). Se eliminara la zona pero los servicios quedaran sin zona asignada. Continuar?')) return;
    } else {
        if (!confirm('Eliminar zona "' + nombre + '"?')) return;
    }
    
    fetch('/api/zonas/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
        if (res.success) {
            showToast('Zona eliminada');
            location.reload();
        } else {
            showToast('Error al eliminar', 'error');
        }
    })
    .catch(function() {
        showToast('Error de conexión', 'error');
    });
}

// Guardar zona via API (fetch en lugar de form POST tradicional)
function guardarZona(event) {
  event.preventDefault();
  var id = document.getElementById('zonId').value;
  var nombre = document.getElementById('zonNombre').value.trim();
  var router_id = document.getElementById('zonRouter').value;
  var vlan_onu = document.getElementById('zonVlan').value;
  var smartolt_profile_id = document.getElementById('zonProfile').value;
  var smartolt_zone = document.getElementById('zonZone').value;
  
  if (!nombre) { showToast('Ingrese el nombre de la zona', 'error'); return false; }
  
  fetch('/api/zonas/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: id || null, nombre: nombre, router_id: router_id || null, vlan_onu: vlan_onu || null, smartolt_profile_id: smartolt_profile_id || null, smartolt_zone: smartolt_zone || '' })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Zona guardada');
      zonCerrarModal();
      location.reload();
    } else {
      showToast('Error: ' + (res.message || 'No se pudo guardar'), 'error');
    }
  })
  .catch(function(e) {
    showToast('Error de conexión', 'error');
  });
  return false;
}

// Close modal on overlay click
document.getElementById('modalZona').addEventListener('click', function(e) {
    if (e.target === this) zonCerrarModal();
});
</script>