            <div class="cc-result-title"><i class="fas fa-check-circle"></i> Cuadre Generado</div>
            <div class="cc-result-amount" id="ccResTotal"></div>
        </div>
        <div class="cc-result-body">
            <div style="display:flex; gap:20px; flex-wrap:wrap; margin-bottom:12px; font-size:0.88rem; color:var(--text-gray);">
                <div><strong>Usuario:</strong> <span id="ccResUsuario"></span></div>
                <div><strong>Fecha:</strong> <span id="ccResFecha"></span></div>
                <div><strong>Pagos:</strong> <span id="ccResCantidad"></span></div>
                <div><strong>Desde:</strong> <span id="ccResDesde"></span></div>
            </div>
            <div id="ccResDesglose" style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px;"></div>
            <table class="cc-result-table">
                <thead><tr><th>Cliente</th><th>Descripcion</th><th>Fecha Pago</th><th>Metodo</th><th style="text-align:right;">Monto</th></tr></thead>
                <tbody id="ccResDetalles"></tbody>
            </table>
        </div>
        <div class="cc-result-actions">
            <button class="btn-print" onclick="ccImprimirCuadre(ccUltimoCuadreId)"><i class="fas fa-print"></i> Imprimir</button>
            <button class="btn-cuadrar" onclick="ccNuevoOtroCuadre()" style="font-size:0.88rem; padding:10px 18px;"><i class="fas fa-plus"></i> Nuevo Cuadre</button>
        </div>
    </div>
</div>

</div><!-- /tabCaja -->

