            <table class="cc-table">
                <thead><tr><th>#</th><th>Usuario</th><th>Desde</th><th>Hasta</th><th>Pagos</th><th>Total</th><th style="text-align:right;">Accion</th></tr></thead>
                <tbody id="ccHistorialBody">
                    <tr><td colspan="7" class="empty-state"><i class="fas fa-spinner fa-spin"></i><br>Cargando...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
/* ===== MODAL CONTEO BILLETES - ESTILO CRISTAL MEJORADO ===== */
.cc-modal-overlay {
    display:none; position:fixed; top:0; left:0; width:100%; height:100%;
    background:rgba(0,0,0,0.55);
    z-index:99999; align-items:center; justify-content:center;
    backdrop-filter:blur(3px);
    animation:ccModalFadeIn 0.2s ease-out;
}
@keyframes ccModalFadeIn {
    from { opacity:0; } to { opacity:1; }
}
@keyframes ccModalSlideUp {
    from { opacity:0; transform:translateY(30px) scale(0.97); }
    to { opacity:1; transform:translateY(0) scale(1); }
}
.cc-modal-glass {
    width:540px; max-width:94%; max-height:92vh;
    background:rgba(255,255,255,0.75);
    backdrop-filter:blur(20px);
    -webkit-backdrop-filter:blur(20px);
    border-radius:18px;
    border:1px solid rgba(255,255,255,0.5);
    box-shadow:
        0 25px 80px rgba(0,0,0,0.25),
        inset 0 1px 0 rgba(255,255,255,0.6);
    overflow:hidden;
    animation:ccModalSlideUp 0.3s ease-out;
}
.cc-modal-glass.dark {
    background:rgba(30,41,59,0.85);
    backdrop-filter:blur(20px);
    border:1px solid rgba(255,255,255,0.08);
    box-shadow:0 25px 80px rgba(0,0,0,0.4);
}

/* Header */
.cc-modal-header {
    padding:20px 26px 16px;
    display:flex; align-items:flex-start; justify-content:space-between;
}
.cc-modal-header-left {
    display:flex; flex-direction:column; gap:2px;
}
.cc-modal-header-title {
    font-size:1.15rem; font-weight:700; color:var(--text-main);
    display:flex; align-items:center; gap:10px;
}
.cc-modal-header-title i {
    color:var(--cc-green);
    font-size:1.2rem;
    filter:drop-shadow(0 2px 4px rgba(16,185,129,0.3));
}
.cc-modal-header-badge {
    font-size:0.75rem; color:var(--text-gray);
    display:flex; align-items:center; gap:5px;
    margin-top:2px;
}

/* Pendiente pill */
.cc-modal-pendiente-box {
    text-align:right;
    background:rgba(16,185,129,0.08);
    border:1px solid rgba(16,185,129,0.15);
    border-radius:10px;
    padding:6px 14px;
}
.cc-modal-pendiente-label {
    font-size:0.7rem; font-weight:600; text-transform:uppercase;
    letter-spacing:0.4px; color:var(--text-gray);
}
.cc-modal-pendiente-monto {
    font-size:1.15rem; font-weight:800; color:var(--cc-green-dark);
}

/* Body */
.cc-modal-body {
    padding:0 26px 8px;
    overflow-y:auto;
    max-height:calc(92vh - 250px);
}
.cc-modal-body::-webkit-scrollbar {
    width:5px;
}
.cc-modal-body::-webkit-scrollbar-track {
    background:transparent;
}
.cc-modal-body::-webkit-scrollbar-thumb {
    background:rgba(0,0,0,0.12);
    border-radius:3px;
}

/* Divider con Monedas label */
.cc-divider {
    display:flex; align-items:center; gap:12px;
    margin:14px 0 10px;
    padding:0 2px;
}
.cc-divider::before,
.cc-divider::after {
    content:''; flex:1; height:1px;
    background:linear-gradient(to right, transparent, var(--border-color), transparent);
}
.cc-divider-label {
    font-size:0.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:1px; color:var(--text-gray);
