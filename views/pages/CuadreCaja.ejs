}

/* Card resumen */
.cc-resumen-card {
    margin-top:16px; margin-bottom:8px;
    padding:16px 20px;
    background:linear-gradient(135deg, rgba(16,185,129,0.06), rgba(5,150,105,0.1));
    border:1.5px solid rgba(16,185,129,0.2);
    border-radius:12px;
    backdrop-filter:blur(4px);
}
.cc-resumen-row {
    display:flex; justify-content:space-between; align-items:center;
    flex-wrap:wrap; gap:10px;
}
.cc-resumen-left {
    display:flex; flex-direction:column; gap:2px;
}
.cc-resumen-label {
    font-size:0.75rem; font-weight:600; text-transform:uppercase;
    letter-spacing:0.5px; color:var(--text-gray);
}
.cc-resumen-total-contado {
    font-weight:700; font-size:1.3rem; color:var(--cc-green-dark);
}
.cc-resumen-right {
    text-align:right;
}
.cc-resumen-diff {
    font-weight:700; font-size:0.9rem;
    padding:4px 12px; border-radius:6px;
    display:inline-block;
}
.cc-resumen-diff.sobrante {
    background:rgba(217,119,6,0.1); color:#d97706;
    border:1px solid rgba(217,119,6,0.2);
}
.cc-resumen-diff.faltante {
    background:rgba(220,38,38,0.1); color:#dc2626;
    border:1px solid rgba(220,38,38,0.2);
}
.cc-resumen-diff.exacto {
    background:rgba(5,150,105,0.1); color:#059669;
    border:1px solid rgba(5,150,105,0.2);
}

/* Footer */
.cc-modal-footer {
    padding:14px 26px 18px;
    border-top:1px solid var(--border-color);
    display:flex; gap:10px; justify-content:flex-end;
    background:rgba(0,0,0,0.02);
}
.cc-modal-footer .btn-cancelar {
    padding:10px 22px;
    border:1.5px solid var(--border-color);
    border-radius:10px;
    background:transparent;
    color:var(--text-gray); font-weight:600;
    cursor:pointer; font-size:0.88rem;
    transition:all 0.2s;
}
.cc-modal-footer .btn-cancelar:hover {
    background:rgba(0,0,0,0.04);
    color:var(--text-main);
}
.cc-modal-footer .btn-confirmar {
    background:linear-gradient(135deg,var(--cc-green),var(--cc-green-dark));
