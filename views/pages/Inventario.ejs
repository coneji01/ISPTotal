}

/* ===== MOVER ARTICULO ===== */
async function invMoverArticulo() {
  var articuloId = document.getElementById('invMovArticulo').value;
  var origenId = document.getElementById('invMovOrigen').value;
  var destinoId = document.getElementById('invMovDestino').value;
  var cantidad = parseInt(document.getElementById('invMovCantidad').value) || 1;

  if (!articuloId) { invToast('Seleccione un artículo', 'error'); return; }
  if (!origenId) { invToast('Seleccione oficina origen', 'error'); return; }
  if (!destinoId) { invToast('Seleccione oficina destino', 'error'); return; }
  if (origenId === destinoId) { invToast('Origen y destino deben ser diferentes', 'error'); return; }
  if (cantidad < 1) { invToast('Cantidad inválida', 'error'); return; }

  var res = await invAPI('mover', {
    inventario_id: parseInt(articuloId),
    oficina_origen_id: parseInt(origenId),
    oficina_destino_id: parseInt(destinoId),
    cantidad: cantidad
  });

  if (res.success) {
    invToast('Artículo movido exitosamente', 'success');
    document.getElementById('invFormMover').reset();
  } else {
    invToast(res.message || 'Error al mover artículo', 'error');
  }
}

/* ===== HISTORIAL ===== */
async function invCargarHistorial() {
  var search = document.getElementById('invHistSearch').value.trim();
  var tipo = document.getElementById('invHistFiltroTipo').value;

  document.getElementById('invHistBody').innerHTML = '<tr><td colspan="10" class="inv-loading"><i class="fas fa-spinner fa-spin"></i><br>Cargando historial...</td></tr>';
  document.getElementById('invHistPagination').style.display = 'none';

  var res = await invAPI('historial', {
    search: search || null,
    tipo: tipo || null,
    page: invHistPage
  });

  if (res.success) {
    invHistItems = res.items || [];
    invHistTotalPages = res.totalPages || 1;
    invHistTotalItems = res.total || 0;
    invHistRenderTable(invHistItems);
    invHistRenderPagination();
  } else {
    document.getElementById('invHistBody').innerHTML = '<tr><td colspan="10" style="text-align:center;padding:30px;color:#94a3b8;">' + (res.message || 'Error al cargar') + '</td></tr>';
  }
}

function invHistRenderTable(items) {
  var body = document.getElementById('invHistBody');
  if (!items.length) {
    body.innerHTML = '<tr><td colspan="10" class="inv-empty"><i class="fas fa-inbox"></i><p>No hay registros en el historial</p></td></tr>';
    return;
  }
  var html = '';
  items.forEach(function(h) {
    var tipoLabel = invEsc(h.tipo || h.accion || '');
    var tipoBadge = 'inv-badge-blue';
    if (tipoLabel === 'entrada' || tipoLabel === 'Entrada') tipoBadge = 'inv-badge-green';
    else if (tipoLabel === 'salida' || tipoLabel === 'Salida') tipoBadge = 'inv-badge-red';
    else if (tipoLabel === 'asignacion' || tipoLabel === 'Asignación') tipoBadge = 'inv-badge-purple';
    else if (tipoLabel === 'devolucion' || tipoLabel === 'Devolución') tipoBadge = 'inv-badge-yellow';
    else if (tipoLabel === 'movimiento' || tipoLabel === 'Movimiento') tipoBadge = 'inv-badge-blue';

    html += '<tr>'
      + '<td class="inv-cell-check"><input type="checkbox" class="inv-hist-check" value="' + (h.id || '') + '" onchange="invHistUpdateBulk()"></td>'
      + '<td>' + (h.id || '') + '</td>'
      + '<td><strong>' + invEsc(h.articulo_nombre || h.nombre_articulo || '') + '</strong><br><span style="font-size:0.7rem;color:#94a3b8;">' + invEsc(h.codigo || '') + '</span></td>'
      + '<td><span class="inv-badge ' + tipoBadge + '">' + tipoLabel + '</span></td>'
      + '<td>' + (parseInt(h.cantidad) || '-') + '</td>'
      + '<td>' + invEsc(h.tecnico_nombre || h.tecnico || '') + '</td>'
      + '<td>' + invEsc(h.cliente_nombre || h.cliente || '') + '</td>'
      + '<td>' + invEsc(h.oficina_nombre || h.oficina || '') + '</td>'
      + '<td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + invEsc(h.nota || h.motivo || '') + '">' + invEsc(h.nota || h.motivo || '') + '</td>'
      + '<td style="white-space:nowrap;font-size:0.78rem;">' + invDateStr(h.fecha || h.created_at || '') + '</td>'
      + '</tr>';
  });
  body.innerHTML = html;
  invHistUpdateBulk();
}

function invHistRenderPagination() {
  var pag = document.getElementById('invHistPagination');
  var info = document.getElementById('invHistPageInfo');
  var prev = document.getElementById('invHistPrevBtn');
  var next = document.getElementById('invHistNextBtn');
  if (invHistTotalPages <= 1) { pag.style.display = 'none'; return; }
  pag.style.display = 'flex';
  info.textContent = 'Página ' + invHistPage + ' de ' + invHistTotalPages;
  prev.disabled = invHistPage <= 1;
  next.disabled = invHistPage >= invHistTotalPages;

  var tot = document.getElementById('invHistTotal');
  if (invHistTotalItems > 0) { tot.style.display = 'inline'; tot.textContent = 'Total: ' + invHistTotalItems; }
  else { tot.style.display = 'none'; }
}

function invHistCambiarPag(d) {
  var n = invHistPage + d;
  if (n >= 1 && n <= invHistTotalPages) { invHistPage = n; invCargarHistorial(); }
}

/* Bulk actions */
function invHistToggleAll() {
  var checked = document.getElementById('invHistSelectAll').checked;
  document.querySelectorAll('.inv-hist-check').forEach(function(cb){ cb.checked = checked; });
  invHistUpdateBulk();
}
function invHistUpdateBulk() {
  var checks = document.querySelectorAll('.inv-hist-check:checked');
  var count = checks.length;
  var bar = document.getElementById('invBulkBar');
  document.getElementById('invBulkCount').textContent = count + ' seleccionado(s)';
  bar.style.display = count > 0 ? 'flex' : 'none';
}
async function invBulkAction(action) {
  var checks = document.querySelectorAll('.inv-hist-check:checked');
  var ids = [];
  checks.forEach(function(cb){ ids.push(cb.value); });
  if (!ids.length) { invToast('Seleccione al menos un registro', 'info'); return; }
  if (action === 'eliminar' && !confirm('¿Eliminar ' + ids.length + ' registro(s) del historial?')) return;
  var res = await invAPI('bulk_' + action, { ids: ids });
  if (res.success) {
    invToast('Acción ejecutada en ' + ids.length + ' registro(s)', 'success');
    invCargarHistorial();
  } else {
    invToast(res.message || 'Error al ejecutar acción', 'error');
  }
}
function invBulkDeseleccionar() {
  document.querySelectorAll('.inv-hist-check').forEach(function(cb){ cb.checked = false; });
  document.getElementById('invHistSelectAll').checked = false;
  invHistUpdateBulk();
}

/* ===== REPORTES ===== */
async function invGenerarReporte() {
  var tecnicoId = document.getElementById('invRepTecnico').value;
  var desde = document.getElementById('invRepDesde').value;
  var hasta = document.getElementById('invRepHasta').value;

  var res = await invAPI('reporte', {
    tecnico_id: tecnicoId ? parseInt(tecnicoId) : null,
    desde: desde || null,
    hasta: hasta || null
  });

  if (res.success && res.items && res.items.length > 0) {
    invRepData = res.items;
    var html = '';
    res.items.forEach(function(r) {
      html += '<tr>'
        + '<td>' + (r.id || '') + '</td>'
        + '<td>' + invEsc(r.articulo_nombre || r.nombre || '') + '</td>'
        + '<td>' + invEsc(r.tecnico_nombre || r.tecnico || '') + '</td>'
        + '<td>' + invEsc(r.accion || r.tipo || '') + '</td>'
        + '<td>' + (parseInt(r.cantidad) || '-') + '</td>'
        + '<td>' + invEsc(r.cliente_nombre || r.cliente || '') + '</td>'
        + '<td>' + invDateStr(r.fecha || r.created_at || '') + '</td>'
        + '</tr>';
    });
    document.getElementById('invRepBody').innerHTML = html;
    document.getElementById('invRepResultCard').style.display = 'block';
  } else {
    document.getElementById('invRepBody').innerHTML = '<tr><td colspan="7" class="inv-empty"><i class="fas fa-search"></i><p>Sin resultados para este reporte</p></td></tr>';
    document.getElementById('invRepResultCard').style.display = 'block';
  }
}

function invExportarReporte() {
  if (!invRepData.length) { invToast('No hay datos para exportar', 'info'); return; }
  var csv = 'ID,Artículo,Técnico,Acción,Cantidad,Cliente,Fecha\n';
  invRepData.forEach(function(r) {
    csv += (r.id || '') + ',"' + (r.articulo_nombre || r.nombre || '') + '","' + (r.tecnico_nombre || r.tecnico || '') + '","' + (r.accion || r.tipo || '') + '",' + (parseInt(r.cantidad) || 0) + ',"' + (r.cliente_nombre || r.cliente || '') + '","' + invDateStr(r.fecha || r.created_at || '') + '"\n';
  });
  var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  var link = document.createElement('a');
  link.href = URL.createObjectURL(blob);
  link.download = 'reporte_inventario_' + new Date().toISOString().slice(0,10) + '.csv';
  link.click();
}

function invImprimirReporte() {
  var content = document.getElementById('invRepResultCard');
  if (!content || content.style.display === 'none') { invToast('No hay reporte para imprimir', 'info'); return; }
  var w = window.open('', '_blank', 'width=900,height=600');
  w.document.write('<html><head><title>Reporte Inventario</title>');
  w.document.write('<style>body{font-family:Arial;padding:20px;}table{width:100%;border-collapse:collapse;font-size:12px;}th,td{border:1px solid #ccc;padding:6px 8px;text-align:left;}th{background:#f5f5f5;}</style>');
  w.document.write('</head><body>');
  w.document.write('<h2>Reporte de Inventario</h2>');
  w.document.write('<p>' + new Date().toLocaleDateString('es-DO') + '</p>');
  w.document.write(document.getElementById('invRepTable').outerHTML);
  w.document.write('</body></html>');
  w.document.close();
  w.print();
}

/* ===== CONFIGURACION ===== */
async function invCargarConfiguracion() {
  // Cargar valores por defecto de configuración
  try {
    var res = await invAPI('config_get', {});
    if (res.success && res.data) {
      if (res.data.stock_min) document.getElementById('invConfigStockMin').value = res.data.stock_min;
      if (res.data.notif_correo) document.getElementById('invConfigNotifCorreo').checked = res.data.notif_correo == 1;
      if (res.data.notif_whatsapp) document.getElementById('invConfigNotifWhatsApp').checked = res.data.notif_whatsapp == 1;
      if (res.data.correo) document.getElementById('invConfigCorreo').value = res.data.correo;
      if (res.data.correos_adicionales) document.getElementById('invConfigCorreosAdicionales').value = res.data.correos_adicionales;
      if (res.data.whatsapp_numero) document.getElementById('invConfigWhatsAppNum').value = res.data.whatsapp_numero;
      if (res.data.whatsapp_api) document.getElementById('invConfigWhatsAppApi').value = res.data.whatsapp_api;
    }
  } catch(e) {}
  invCargarConfigCategorias();
  invCargarConfigOficinas();
  invCargarConfigPersonal();
}

async function invCargarConfigCategorias() {
  try {
    var res = await invAPI('listar_categorias', {});
    var body = document.getElementById('invConfigCategoriasBody');
    if (res.success && res.items && res.items.length > 0) {
      var html = '';
      res.items.forEach(function(c) {
        html += '<tr><td>' + invEsc(c.nombre) + '</td><td>' + (parseInt(c.total_articulos) || 0) + '</td>'
          + '<td><button class="inv-btn inv-btn-xs inv-btn-danger" onclick="invConfigEliminarCategoria(' + c.id + ')"><i class="fas fa-trash"></i></button></td></tr>';
      });
      body.innerHTML = html;
    } else {
      body.innerHTML = '<tr><td colspan="3" class="inv-empty"><p>Sin categorías registradas</p></td></tr>';
    }
  } catch(e) {
    document.getElementById('invConfigCategoriasBody').innerHTML = '<tr><td colspan="3" style="text-align:center;padding:20px;color:#ef4444;">Error al cargar</td></tr>';
  }
}

function invConfigAgregarCategoria() {
  invAbrirModal(
    '<div class="inv-form-group"><label class="inv-label">Nombre de la categoría</label><input type="text" id="invNuevaCategoriaInput" class="inv-input" placeholder="Ej: Fibra Óptica"></div>',
    {
      title: '<i class="fas fa-tags" style="color:#4338ca;"></i> Nueva Categoría',
      footer: '<button class="inv-btn inv-btn-secondary" onclick="invCerrarModal()">Cancelar</button><button class="inv-btn inv-btn-primary" onclick="invGuardarNuevaCategoria()"><i class="fas fa-save"></i> Guardar</button>',
      sm: true
    }
  );
  setTimeout(function(){ document.getElementById('invNuevaCategoriaInput').focus(); }, 100);
}

async function invGuardarNuevaCategoria() {
  var nombre = document.getElementById('invNuevaCategoriaInput').value.trim();
  if (!nombre) { invToast('Ingrese un nombre', 'error'); return; }
  var res = await invAPI('categoria_guardar', { nombre: nombre });
  if (res.success) {
    invToast('Categoría guardada', 'success');
    invCerrarModal();
    invCargarConfigCategorias();
  } else {
    invToast(res.message || 'Error al guardar', 'error');
  }
