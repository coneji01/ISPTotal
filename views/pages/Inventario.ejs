  <!-- ==================== TAB: HISTORIAL ==================== -->
  <div class="inv-tab-content" data-tab="historial">
    <!-- Bulk bar -->
    <div class="inv-bulk-bar" id="invBulkBar" style="display:none;">
      <span class="inv-bulk-count" id="invBulkCount">0 seleccionado(s)</span>
      <div style="display:flex; gap:6px; flex-wrap:wrap;">
        <button class="inv-btn inv-btn-sm inv-btn-success" onclick="invBulkAction('activar')"><i class="fas fa-check"></i> Activar</button>
        <button class="inv-btn inv-btn-sm inv-btn-danger" onclick="invBulkAction('eliminar')"><i class="fas fa-trash"></i> Eliminar</button>
        <button class="inv-btn inv-btn-sm inv-btn-secondary" onclick="invBulkDeseleccionar()"><i class="fas fa-times"></i> Deseleccionar</button>
      </div>
    </div>

    <!-- Search row -->
    <div class="inv-search-row">
      <div class="inv-input-wrap">
        <i class="fas fa-search"></i>
        <input type="text" id="invHistSearch" class="inv-input" placeholder="Buscar en historial..." onkeyup="invHistPage=1; invCargarHistorial();">
      </div>
      <select id="invHistFiltroTipo" class="inv-select" style="width:auto; min-width:130px;" onchange="invHistPage=1; invCargarHistorial();">
        <option value="">Todos los tipos</option>
        <option value="entrada">Entrada</option>
        <option value="salida">Salida</option>
        <option value="asignacion">Asignación</option>
        <option value="devolucion">Devolución</option>
        <option value="movimiento">Movimiento</option>
        <option value="ajuste">Ajuste</option>
      </select>
      <span class="inv-badge inv-badge-blue" id="invHistTotal" style="display:none;">Total: 0</span>
    </div>

    <!-- Table -->
    <div class="inv-card">
      <div class="inv-table-wrap">
        <table class="inv-table" id="invHistTable">
          <thead>
            <tr>
              <th class="inv-cell-check"><input type="checkbox" id="invHistSelectAll" onchange="invHistToggleAll()"></th>
              <th>ID</th>
              <th>Artículo</th>
              <th>Tipo</th>
              <th>Cantidad</th>
              <th>Técnico</th>
              <th>Cliente</th>
              <th>Oficina</th>
              <th>Nota</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody id="invHistBody">
            <tr><td colspan="10" class="inv-loading"><i class="fas fa-spinner fa-spin"></i><br>Cargando historial...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <div class="inv-pagination" id="invHistPagination" style="display:none;">
      <button class="inv-btn inv-btn-sm inv-btn-secondary" onclick="invHistCambiarPag(-1)" id="invHistPrevBtn" disabled><i class="fas fa-chevron-left"></i> Anterior</button>
      <span class="inv-page-info" id="invHistPageInfo">Página 1 de 1</span>
      <button class="inv-btn inv-btn-sm inv-btn-secondary" onclick="invHistCambiarPag(1)" id="invHistNextBtn" disabled>Siguiente <i class="fas fa-chevron-right"></i></button>
    </div>
  </div>

  <!-- ==================== TAB: REPORTES ==================== -->
  <div class="inv-tab-content" data-tab="reportes">
    <div class="inv-card">
      <div class="inv-card-header"><h3><i class="fas fa-file-alt" style="color:#6366f1;"></i> Generar Reporte</h3></div>
      <div class="inv-card-body">
        <form id="invFormReporte" onsubmit="event.preventDefault(); invGenerarReporte();">
          <div class="inv-row">
            <div class="inv-col inv-col-3">
              <div class="inv-form-group">
                <label class="inv-label">Técnico</label>
                <select id="invRepTecnico" class="inv-select">
                  <option value="">Todos los técnicos</option>
                  <% (empleados || []).forEach(function(e) { %>
                  <option value="<%= e.id %>"><%= e.nombre %></option>
                  <% }); %>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-3">
              <div class="inv-form-group">
                <label class="inv-label">Desde</label>
                <input type="date" id="invRepDesde" class="inv-input">
              </div>
            </div>
            <div class="inv-col inv-col-3">
              <div class="inv-form-group">
                <label class="inv-label">Hasta</label>
                <input type="date" id="invRepHasta" class="inv-input">
              </div>
            </div>
          </div>
          <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <button type="submit" class="inv-btn inv-btn-primary"><i class="fas fa-search"></i> Generar Reporte</button>
            <button type="button" class="inv-btn inv-btn-success" onclick="invExportarReporte()"><i class="fas fa-file-excel"></i> Exportar Excel</button>
            <button type="button" class="inv-btn inv-btn-secondary" onclick="invImprimirReporte()"><i class="fas fa-print"></i> Imprimir</button>
          </div>
        </form>
      </div>
    </div>

    <div class="inv-card" id="invRepResultCard" style="display:none;">
      <div class="inv-card-header"><h4><i class="fas fa-table" style="color:#6366f1;"></i> Resultado del Reporte</h4></div>
      <div class="inv-table-wrap">
        <table class="inv-table" id="invRepTable">
          <thead>
            <tr><th>ID</th><th>Artículo</th><th>Técnico</th><th>Acción</th><th>Cantidad</th><th>Cliente</th><th>Fecha</th></tr>
          </thead>
          <tbody id="invRepBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ==================== TAB: CONFIGURACION ==================== -->
  <div class="inv-tab-content" data-tab="configuracion">
    <div class="inv-card">
      <div class="inv-card-header"><h3><i class="fas fa-cog" style="color:#64748b;"></i> Configuración del Módulo</h3></div>
      <div class="inv-card-body">
        <div class="inv-sub-tabs" id="invConfigTabs">
          <button class="inv-sub-tab active" data-subtab="categorias"><i class="fas fa-tags"></i> Categorías</button>
          <button class="inv-sub-tab" data-subtab="oficinas"><i class="fas fa-building"></i> Oficinas</button>
          <button class="inv-sub-tab" data-subtab="personal"><i class="fas fa-users-cog"></i> Personal</button>
          <button class="inv-sub-tab" data-subtab="alertas"><i class="fas fa-bell"></i> Alertas</button>
          <button class="inv-sub-tab" data-subtab="correo"><i class="fas fa-envelope"></i> Correo</button>
          <button class="inv-sub-tab" data-subtab="whatsapp"><i class="fab fa-whatsapp"></i> WhatsApp</button>
          <button class="inv-sub-tab" data-subtab="impresion"><i class="fas fa-print"></i> Impresión</button>
        </div>

        <!-- Categorías -->
        <div class="inv-sub-content active" data-subtab="categorias">
          <div class="inv-card">
            <div class="inv-card-header"><h4><i class="fas fa-tags" style="color:#4338ca;"></i> Gestionar Categorías</h4><button class="inv-btn inv-btn-sm inv-btn-primary" onclick="invConfigAgregarCategoria()"><i class="fas fa-plus"></i> Nueva</button></div>
            <div class="inv-card-body" style="padding:0;">
              <table class="inv-table">
                <thead><tr><th>Nombre</th><th>Artículos</th><th>Acciones</th></tr></thead>
                <tbody id="invConfigCategoriasBody"><tr><td colspan="3" class="inv-loading"><i class="fas fa-spinner fa-spin"></i> Cargando...</td></tr></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Oficinas -->
        <div class="inv-sub-content" data-subtab="oficinas">
          <div class="inv-card">
            <div class="inv-card-header"><h4><i class="fas fa-building" style="color:#0369a1;"></i> Gestionar Oficinas</h4><button class="inv-btn inv-btn-sm inv-btn-primary" onclick="invConfigAgregarOficina()"><i class="fas fa-plus"></i> Nueva</button></div>
            <div class="inv-card-body" style="padding:0;">
              <table class="inv-table">
                <thead><tr><th>Nombre</th><th>Dirección</th><th>Acciones</th></tr></thead>
                <tbody id="invConfigOficinasBody"><tr><td colspan="3" class="inv-loading"><i class="fas fa-spinner fa-spin"></i> Cargando...</td></tr></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Personal -->
        <div class="inv-sub-content" data-subtab="personal">
          <div class="inv-card">
            <div class="inv-card-header"><h4><i class="fas fa-users-cog" style="color:#6d28d9;"></i> Personal con Acceso a Inventario</h4></div>
            <div class="inv-card-body" style="padding:0;">
              <table class="inv-table">
                <thead><tr><th>Nombre</th><th>Cargo</th><th>Permiso</th><th>Acciones</th></tr></thead>
                <tbody id="invConfigPersonalBody"><tr><td colspan="4" class="inv-loading"><i class="fas fa-spinner fa-spin"></i> Cargando...</td></tr></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Alertas -->
        <div class="inv-sub-content" data-subtab="alertas">
          <div class="inv-card">
            <div class="inv-card-header"><h4><i class="fas fa-bell" style="color:#b45309;"></i> Configurar Alertas de Stock</h4></div>
            <div class="inv-card-body">
              <div class="inv-form-group">
                <label class="inv-label">Límite mínimo de stock</label>
                <input type="number" id="invConfigStockMin" class="inv-input" min="0" value="5" style="max-width:120px;">
                <p style="font-size:0.75rem; color:#94a3b8; margin-top:4px;">Notificar cuando el stock esté por debajo de este valor</p>
              </div>
              <div class="inv-form-group">
                <label class="inv-checkbox-label">
                  <input type="checkbox" id="invConfigNotifCorreo" checked>
                  <i class="fas fa-envelope" style="color:#3b82f6;"></i> Notificar por correo electrónico
                </label>
              </div>
              <div class="inv-form-group">
                <label class="inv-checkbox-label">
                  <input type="checkbox" id="invConfigNotifWhatsApp">
                  <i class="fab fa-whatsapp" style="color:#25D366;"></i> Notificar por WhatsApp
                </label>
              </div>
              <button class="inv-btn inv-btn-primary" onclick="invConfigGuardarAlertas()"><i class="fas fa-save"></i> Guardar Configuración</button>
            </div>
          </div>
        </div>

        <!-- Correo -->
        <div class="inv-sub-content" data-subtab="correo">
          <div class="inv-card">
            <div class="inv-card-header"><h4><i class="fas fa-envelope" style="color:#3b82f6;"></i> Configuración de Correo</h4></div>
            <div class="inv-card-body">
              <div class="inv-form-group">
                <label class="inv-label">Correo de notificación</label>
                <input type="email" id="invConfigCorreo" class="inv-input" placeholder="inventario@tudominio.com" style="max-width:350px;">
              </div>
              <div class="inv-form-group">
                <label class="inv-label">Correos adicionales (separados por coma)</label>
                <input type="text" id="invConfigCorreosAdicionales" class="inv-input" placeholder="correo1@dom.com, correo2@dom.com">
              </div>
              <button class="inv-btn inv-btn-primary" onclick="invConfigGuardarCorreo()"><i class="fas fa-save"></i> Guardar</button>
            </div>
          </div>
        </div>

        <!-- WhatsApp -->
        <div class="inv-sub-content" data-subtab="whatsapp">
