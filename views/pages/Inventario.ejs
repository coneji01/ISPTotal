            <div class="inv-card-header"><h4><i class="fab fa-whatsapp" style="color:#25D366;"></i> Configuración de WhatsApp</h4></div>
            <div class="inv-card-body">
              <div class="inv-form-group">
                <label class="inv-label">Número de WhatsApp (con código de país)</label>
                <input type="text" id="invConfigWhatsAppNum" class="inv-input" placeholder="+18091234567" style="max-width:220px;">
              </div>
              <div class="inv-form-group">
                <label class="inv-label">API Key (si aplica)</label>
                <input type="text" id="invConfigWhatsAppApi" class="inv-input" placeholder="Token o API Key" style="max-width:350px;">
