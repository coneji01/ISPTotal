async function invCargarConfigPersonal() {
  try {
    var res = await invAPI('listar_personal', {});
    var body = document.getElementById('invConfigPersonalBody');
    if (res.success && res.items && res.items.length > 0) {
      var html = '';
      res.items.forEach(function(p) {
        var permiso = p.permiso_inventario;
        var permisoLabel = permiso == 1 ? '<span class="inv-badge inv-badge-green"><i class="fas fa-check"></i> Acceso completo</span>' : '<span class="inv-badge inv-badge-gray"><i class="fas fa-times"></i> Sin acceso</span>';
        html += '<tr><td>' + invEsc(p.nombre) + '</td><td>' + invEsc(p.cargo || '') + '</td><td>' + permisoLabel + '</td>'
          + '<td><button class="inv-btn inv-btn-xs inv-btn-primary" onclick="invConfigTogglePermiso(' + p.id + ',' + (permiso == 1 ? 0 : 1) + ')"><i class="fas fa-' + (permiso == 1 ? 'times' : 'check') + '"></i> ' + (permiso == 1 ? 'Quitar' : 'Dar') + ' acceso</button></td></tr>';
      });
      body.innerHTML = html;
    } else {
      body.innerHTML = '<tr><td colspan="4" class="inv-empty"><p>Sin personal configurado</p></td></tr>';
    }
  } catch(e) {
    document.getElementById('invConfigPersonalBody').innerHTML = '<tr><td colspan="4" style="text-align:center;padding:20px;color:#ef4444;">Error al cargar</td></tr>';
  }
}

async function invConfigTogglePermiso(userId, nuevoPermiso) {
  var res = await invAPI('personal_permiso', { usuario_id: userId, permiso_inventario: nuevoPermiso });
  if (res.success) {
    invToast('Permiso actualizado', 'success');
    invCargarConfigPersonal();
  } else {
    invToast(res.message || 'Error al actualizar permiso', 'error');
  }
}

