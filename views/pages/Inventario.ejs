async function invConfigEliminarCategoria(id) {
  if (!confirm('¿Eliminar esta categoría?')) return;
  var res = await invAPI('categoria_eliminar', { id: id });
  if (res.success) {
    invToast('Categoría eliminada', 'success');
    invCargarConfigCategorias();
  } else {
    invToast(res.message || 'Error al eliminar', 'error');
  }
}

