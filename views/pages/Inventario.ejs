</div>

<script>
/* ===================================================================
   INVENTARIO — DomISP-style full module
   INV_API = '/modulo?pagina=InventarioAPI&action='
   =================================================================== */
const INV_API = '/modulo?pagina=InventarioAPI&action=';

// State
let invHistPage = 1, invHistTotalPages = 1, invHistTotalItems = 0;
let invHistItems = [];
let invRepData = [];

/* ===== UTILITIES ===== */
function invEsc(t) {
  if (t == null) return '';
  return t.toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}
function invDateStr(d) {
  if (!d) return '';
  const dt = new Date(d);
  const y = dt.getFullYear();
  const m = String(dt.getMonth()+1).padStart(2,'0');
  const day = String(dt.getDate()).padStart(2,'0');
  return day + '/' + m + '/' + y;
}
function invToast(msg, type) {
  const el = document.createElement('div');
  el.className = 'inv-toast inv-toast-' + (type || 'info');
  const icon = type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle';
  el.innerHTML = '<i class="fas ' + icon + '"></i> ' + invEsc(msg);
  document.body.appendChild(el);
  setTimeout(function(){ el.style.opacity='0'; el.style.transition='opacity 0.3s'; setTimeout(function(){ el.remove(); },400); }, 3000);
}

/* ===== API ===== */
async function invAPI(action, payload) {
  try {
    const url = INV_API + encodeURIComponent(action);
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload || {})
    });
    return await res.json();
  } catch(e) {
    return { success: false, message: 'Error de conexión: ' + e.message };
  }
}

/* ===== TABS ===== */
function invMostrar(tabName) {
  // Tabs
  document.querySelectorAll('.inv-tab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.inv-tab-content').forEach(function(t){ t.classList.remove('active'); });
  const tabBtn = document.querySelector('.inv-tab[data-tab="' + tabName + '"]');
  const tabContent = document.querySelector('.inv-tab-content[data-tab="' + tabName + '"]');
  if (tabBtn) tabBtn.classList.add('active');
  if (tabContent) tabContent.classList.add('active');
}
document.getElementById('invTabs').addEventListener('click', function(e) {
  const btn = e.target.closest('.inv-tab');
  if (!btn) return;
  const tab = btn.getAttribute('data-tab');
  invMostrar(tab);
  if (tab === 'dashboard') invGenerarDashboard();
  if (tab === 'historial') invCargarHistorial();
  if (tab === 'configuracion') invCargarConfiguracion();
  if (tab === 'registrar') invCargarOficinasSelect('invRegOficina');
  if (tab === 'asignar') { invCargarSelectArticulos('invAsigArticulo'); invCargarOficinasSelect(); }
  if (tab === 'devolver') invCargarSelectArticulos('invDevArticulo');
  if (tab === 'mover') { invCargarSelectArticulos('invMovArticulo'); invCargarOficinasSelect('invMovOrigen'); invCargarOficinasSelect('invMovDestino'); }
});

/* ===== SUB-TABS (Config) ===== */
document.addEventListener('click', function(e) {
  const subBtn = e.target.closest('.inv-sub-tab');
  if (!subBtn) return;
  const tab = subBtn.getAttribute('data-subtab');
  document.querySelectorAll('.inv-sub-tab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.inv-sub-content').forEach(function(t){ t.classList.remove('active'); });
  subBtn.classList.add('active');
  var content = document.querySelector('.inv-sub-content[data-subtab="' + tab + '"]');
  if (content) content.classList.add('active');
  if (tab === 'categorias') invCargarConfigCategorias();
  if (tab === 'oficinas') invCargarConfigOficinas();
  if (tab === 'personal') invCargarConfigPersonal();
});

/* ===== MODAL ===== */
function invAbrirModal(html, opts) {
  opts = opts || {};
  document.getElementById('invModalTitle').innerHTML = opts.title || '<i class="fas fa-info-circle"></i> Información';
  document.getElementById('invModalBody').innerHTML = html;
  var footer = document.getElementById('invModalFooter');
  if (opts.footer) {
    footer.innerHTML = opts.footer;
    footer.style.display = 'flex';
  } else {
    footer.innerHTML = '<button class="inv-btn inv-btn-secondary" onclick="invCerrarModal()">Cerrar</button>';
    footer.style.display = 'flex';
  }
  var box = document.getElementById('invModalBox');
  box.className = 'inv-modal-box';
  if (opts.wide) box.classList.add('inv-modal-wide');
  if (opts.sm) box.classList.add('inv-modal-sm');
  document.getElementById('invModalContainer').classList.add('open');
}
function invCerrarModal() {
  document.getElementById('invModalContainer').classList.remove('open');
}
// Close modal on overlay click
document.getElementById('invModalContainer').addEventListener('click', function(e) {
  if (e.target === this) invCerrarModal();
});

/* ===== GENERAR CODIGO ===== */
function invGenerarCodigo(inputId) {
  var prefix = 'INV';
  var rand = Math.floor(Math.random() * 9000) + 1000;
  var code = prefix + '-' + rand;
  document.getElementById(inputId).value = code;
}

/* ===== CARGAR DATOS COMUNES ===== */
async function invCargarDatos() {
  // No-op por ahora, los datos se cargan bajo demanda
}

async function invCargarOficinasSelect(selectId) {
  try {
    var res = await invAPI('listar_oficinas', {});
    if (res.success && res.items) {
      var sel = document.getElementById(selectId);
      if (!sel) return;
      var val = sel.value;
      sel.innerHTML = '<option value="">Seleccione oficina</option>';
      res.items.forEach(function(o) {
        sel.innerHTML += '<option value="' + invEsc(o.id) + '">' + invEsc(o.nombre) + '</option>';
      });
      if (val) sel.value = val;
    }
  } catch(e) {}
}

async function invCargarSelectArticulos(selectId) {
  try {
    var res = await invAPI('listar', { all: '1' });
    if (res.success && res.items) {
      var sel = document.getElementById(selectId);
      if (!sel) return;
      var val = sel.value;
      sel.innerHTML = '<option value="">Seleccione artículo</option>';
      res.items.forEach(function(a) {
        var stock = parseInt(a.stock) || 0;
        sel.innerHTML += '<option value="' + a.id + '">' + invEsc(a.codigo || '') + ' — ' + invEsc(a.nombre) + ' (Stock: ' + stock + ')</option>';
      });
      if (val) sel.value = val;
    }
  } catch(e) {}
}

/* ===== TOGGLE "OTRA" CATEGORIA ===== */
function invToggleOtraCategoria(selectId, inputId) {
  var sel = document.getElementById(selectId);
  var inp = document.getElementById(inputId);
  if (!sel || !inp) return;
  if (sel.value === 'Otro') {
    inp.style.display = 'block';
    inp.focus();
  } else {
    inp.style.display = 'none';
    inp.value = '';
  }
}

/* ===== CLIENT SEARCH ===== */
async function invBuscarCliente(query, resultId, hiddenId) {
  var resultEl = document.getElementById(resultId);
  var hiddenEl = document.getElementById(hiddenId);
  if (!query || query.length < 2) {
    resultEl.innerHTML = '';
    if (hiddenEl) hiddenEl.value = '';
    return;
  }
  try {
    var res = await invAPI('buscar_cliente', { q: query });
    if (res.success && res.items && res.items.length > 0) {
      var html = '';
      res.items.forEach(function(c) {
        var nombre = c.nombre || c.Nombre || 'Desconocido';
        html += '<div class="inv-client-result" style="cursor:pointer;" onclick="invSeleccionarCliente(' + (c.id || c.ID) + ',\'' + invEsc(nombre) + '\',\'' + resultId + '\',\'' + hiddenId + '\')">'
          + '<i class="fas fa-user-circle" style="font-size:28px;color:#94a3b8;"></i>'
          + '<div class="inv-client-info"><strong>' + invEsc(nombre) + '</strong>'
          + '<span>' + invEsc(c.cedula || c.Cedula || c.telefono || c.Telefono || '') + '</span></div>'
          + '</div>';
      });
      resultEl.innerHTML = html;
    } else {
      resultEl.innerHTML = '<div style="padding:8px 0;font-size:0.8rem;color:#94a3b8;">Sin resultados</div>';
    }
  } catch(e) {
    resultEl.innerHTML = '<div style="padding:8px 0;font-size:0.8rem;color:#ef4444;">Error al buscar</div>';
  }
}

function invSeleccionarCliente(id, nombre, resultId, hiddenId) {
  var resultEl = document.getElementById(resultId);
  var hiddenEl = document.getElementById(hiddenId);
  if (hiddenEl) hiddenEl.value = id;
  resultEl.innerHTML = '<div class="inv-client-result">'
    + '<i class="fas fa-user-circle" style="font-size:28px;color:#6366f1;"></i>'
    + '<div class="inv-client-info"><strong>' + invEsc(nombre) + '</strong>'
    + '<span style="color:#6366f1;">✓ Seleccionado</span></div>'
    + '<button class="inv-btn inv-btn-xs inv-btn-secondary" onclick="document.getElementById(\'' + hiddenId + '\').value=\'\';document.getElementById(\'' + resultId + '\').innerHTML=\'\';">&times;</button>'
    + '</div>';
}

/* ===== DASHBOARD ===== */
async function invGenerarDashboard() {
  try {
    var res = await invAPI('dashboard', {});
    if (!res.success) return;
    var d = res.data || {};
    document.getElementById('invDashTotalItems').textContent = d.total_items || 0;
    document.getElementById('invDashTotalValor').textContent = '$' + (parseFloat(d.total_valor) || 0).toFixed(2);
    document.getElementById('invDashLowStock').textContent = d.low_stock || 0;
    document.getElementById('invDashTecnicos').textContent = d.total_tecnicos || 0;
    document.getElementById('invDashCategorias').textContent = d.total_categorias || 0;

    // Chart: items por técnico
    var chartBars = document.getElementById('invChartBars');
    chartBars.innerHTML = '';
    if (d.tecnicos_chart && d.tecnicos_chart.length > 0) {
      var maxVal = Math.max.apply(null, d.tecnicos_chart.map(function(t){ return parseInt(t.cantidad) || 0; }));
      maxVal = Math.max(maxVal, 1);
      d.tecnicos_chart.forEach(function(t) {
        var val = parseInt(t.cantidad) || 0;
        var pct = (val / maxVal) * 140;
        var color = '#6366f1';
        if (val === 0) color = '#e2e8f0';
        chartBars.innerHTML += '<div class="inv-chart-bar" style="height:' + Math.max(pct,6) + 'px;background:' + color + ';">'
          + '<span class="inv-bar-val">' + val + '</span>'
          + '<span class="inv-bar-label">' + invEsc(t.nombre || '?') + '</span></div>';
      });
    } else {
      chartBars.innerHTML = '<p style="color:#94a3b8;width:100%;">Sin datos de asignaciones</p>';
    }

    // Empty materials table
    var emptyBody = document.getElementById('invDashEmptyBody');
    if (d.agotados && d.agotados.length > 0) {
      var html = '';
      d.agotados.forEach(function(a) {
        var stock = parseInt(a.stock) || 0;
        var badgeClass = stock <= 0 ? 'inv-badge-red' : 'inv-badge-yellow';
        html += '<tr><td>' + invEsc(a.codigo || '') + '</td><td>' + invEsc(a.nombre || '') + '</td>'
          + '<td><span class="inv-badge ' + badgeClass + '">' + stock + '</span></td></tr>';
      });
      emptyBody.innerHTML = html;
    } else {
      emptyBody.innerHTML = '<tr><td colspan="3" class="inv-empty"><i class="fas fa-check-circle" style="color:#22c55e;"></i><p>Sin materiales agotados</p></td></tr>';
    }
  } catch(e) {
    console.error('Dashboard error:', e);
  }
}

/* ===== REGISTRAR ARTICULO ===== */
async function invRegistrarArticulo() {
  var codigo = document.getElementById('invRegCodigo').value.trim();
  var nombre = document.getElementById('invRegNombre').value.trim();
  var oficinaId = document.getElementById('invRegOficina').value;
  var categoria = document.getElementById('invRegCategoria').value;
  var categoriaOtra = document.getElementById('invRegCategoriaOtra').value.trim();
  var esVenta = document.getElementById('invRegVenta').checked ? 1 : 0;
  var precio = parseFloat(document.getElementById('invRegPrecio').value) || 0;
  var cantidad = parseInt(document.getElementById('invRegCantidad').value) || 1;
  var serial = document.getElementById('invRegSerial').value.trim();

  if (!codigo) { invToast('El código es obligatorio', 'error'); return; }
  if (!nombre) { invToast('El nombre del artículo es obligatorio', 'error'); return; }

  // Si seleccionó "Otro" y puso un valor, usar ese
  if (categoria === 'Otro' && categoriaOtra) categoria = categoriaOtra;
  if (!categoria) { invToast('Seleccione una categoría', 'error'); return; }

  var payload = {
    codigo: codigo,
    nombre: nombre,
    categoria: categoria,
    oficina_id: oficinaId || null,
    es_venta: esVenta,
    precio: precio,
    cantidad: cantidad,
    serial: serial || null
  };

  var res = await invAPI('registrar', payload);
  if (res.success) {
    invToast('Artículo registrado exitosamente', 'success');
    invLimpiarForm('invFormRegistrar');
    invGenerarCodigo('invRegCodigo');
  } else {
    invToast(res.message || 'Error al registrar artículo', 'error');
  }
}

/* ===== GENERAR CODIGO ===== */
function invLimpiarForm(formId) {
  var form = document.getElementById(formId);
  if (!form) return;
  var inputs = form.querySelectorAll('input:not([type="hidden"]), select, textarea');
  inputs.forEach(function(inp) {
    if (inp.type === 'checkbox' || inp.type === 'radio') inp.checked = false;
    else if (inp.tagName === 'SELECT') inp.selectedIndex = 0;
    else inp.value = '';
  });
}

/* ===== IMPRIMIR CODIGO ===== */
function invImprimirCodigo() {
  var codigo = document.getElementById('invRegCodigo').value.trim();
  var nombre = document.getElementById('invRegNombre').value.trim();
  if (!codigo) { invToast('Primero registre o genere un código', 'info'); return; }
  var w = window.open('', '_blank', 'width=400,height=300');
  w.document.write('<html><head><style>body{font-family:Arial;text-align:center;padding:40px;}h1{font-size:2rem;letter-spacing:3px;}.label{font-size:0.9rem;color:#666;margin:8px 0;}hr{margin:20px;}</style></head><body>');
  w.document.write('<h1>' + invEsc(codigo) + '</h1>');
  w.document.write('<div class="label">' + invEsc(nombre) + '</div>');
  w.document.write('<hr><p style="color:#999;">Código de inventario</p>');
  w.document.write('</body></html>');
  w.document.close();
  w.print();
}

/* ===== ASIGNAR ARTICULO ===== */
async function invAsignarArticulo() {
  var articuloId = document.getElementById('invAsigArticulo').value;
  var tecnicoId = document.getElementById('invAsigTecnico').value;
  var uso = document.getElementById('invAsigUso').value;
  var clienteId = document.getElementById('invAsigClienteId').value;

  if (!articuloId) { invToast('Seleccione un artículo', 'error'); return; }
  if (!tecnicoId) { invToast('Seleccione un técnico', 'error'); return; }
  if (!uso) { invToast('Seleccione el motivo de uso', 'error'); return; }

  var res = await invAPI('asignar', {
    inventario_id: parseInt(articuloId),
    tecnico_id: parseInt(tecnicoId),
    uso: uso,
    cliente_id: clienteId ? parseInt(clienteId) : null
  });

  if (res.success) {
    invToast('Artículo asignado exitosamente', 'success');
    document.getElementById('invFormAsignar').reset();
    document.getElementById('invAsigClienteBuscar').value = '';
    document.getElementById('invAsigClienteResult').innerHTML = '';
    document.getElementById('invAsigClienteId').value = '';
  } else {
    invToast(res.message || 'Error al asignar', 'error');
  }
}

/* ===== DEVOLVER ARTICULO ===== */
async function invRegistrarDevolucion() {
  var articuloId = document.getElementById('invDevArticulo').value;
  var tecnicoId = document.getElementById('invDevTecnico').value;
  var motivo = document.getElementById('invDevMotivo').value;
  var clienteId = document.getElementById('invDevClienteId').value;

  if (!articuloId) { invToast('Seleccione un artículo', 'error'); return; }
  if (!tecnicoId) { invToast('Seleccione el técnico', 'error'); return; }
  if (!motivo) { invToast('Seleccione el motivo de devolución', 'error'); return; }

  var res = await invAPI('devolver', {
    inventario_id: parseInt(articuloId),
    tecnico_id: parseInt(tecnicoId),
    motivo: motivo,
    cliente_id: clienteId ? parseInt(clienteId) : null
  });

  if (res.success) {
    invToast('Devolución registrada exitosamente', 'success');
    document.getElementById('invFormDevolver').reset();
    document.getElementById('invDevClienteBuscar').value = '';
    document.getElementById('invDevClienteResult').innerHTML = '';
    document.getElementById('invDevClienteId').value = '';
  } else {
    invToast(res.message || 'Error al registrar devolución', 'error');
