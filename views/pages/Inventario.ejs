            <button type="submit" class="inv-btn inv-btn-primary"><i class="fas fa-save"></i> Guardar Artículo</button>
            <button type="button" class="inv-btn inv-btn-secondary" onclick="invLimpiarForm('invFormRegistrar')"><i class="fas fa-eraser"></i> Limpiar</button>
            <button type="button" class="inv-btn inv-btn-info" onclick="invImprimirCodigo()"><i class="fas fa-print"></i> Imprimir Código</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ==================== TAB: ASIGNAR ==================== -->
  <div class="inv-tab-content" data-tab="asignar">
    <div class="inv-card">
      <div class="inv-card-header"><h3><i class="fas fa-hand-holding" style="color:#6366f1;"></i> Asignar Artículo a Técnico</h3></div>
      <div class="inv-card-body">
        <form id="invFormAsignar" onsubmit="event.preventDefault(); invAsignarArticulo();">
          <div class="inv-row">
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Artículo (Código) <span class="inv-required">*</span></label>
                <select id="invAsigArticulo" class="inv-select" required>
                  <option value="">Seleccione un artículo</option>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Técnico <span class="inv-required">*</span></label>
                <select id="invAsigTecnico" class="inv-select" required>
                  <option value="">Seleccione técnico</option>
                  <% (empleados || []).forEach(function(e) { %>
                  <option value="<%= e.id %>"><%= e.nombre %></option>
                  <% }); %>
                </select>
              </div>
            </div>
          </div>
          <div class="inv-row">
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Motivo de Uso <span class="inv-required">*</span></label>
                <select id="invAsigUso" class="inv-select" required>
                  <option value="">Seleccione</option>
                  <option value="Instalación">Instalación</option>
                  <option value="Reparación">Reparación</option>
                  <option value="Mantenimiento">Mantenimiento</option>
                  <option value="Cambio">Cambio de equipo</option>
                  <option value="Nueva Venta">Nueva Venta</option>
                  <option value="Reposición">Reposición</option>
                  <option value="Otro">Otro</option>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Cliente (opcional)</label>
                <div style="display:flex; gap:6px;">
                  <input type="text" id="invAsigClienteBuscar" class="inv-input" placeholder="Buscar cliente por nombre o cédula..." style="flex:1;" onkeyup="invBuscarCliente(this.value,'invAsigClienteResult','invAsigClienteId')">
                  <button type="button" class="inv-btn inv-btn-sm inv-btn-secondary" onclick="document.getElementById('invAsigClienteBuscar').value=''; document.getElementById('invAsigClienteResult').innerHTML=''; document.getElementById('invAsigClienteId').value='';"><i class="fas fa-times"></i></button>
                </div>
                <input type="hidden" id="invAsigClienteId" value="">
                <div id="invAsigClienteResult"></div>
              </div>
            </div>
          </div>
          <div style="display:flex; gap:8px; margin-top:4px;">
            <button type="submit" class="inv-btn inv-btn-primary"><i class="fas fa-check"></i> Asignar</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ==================== TAB: DEVOLVER ==================== -->
  <div class="inv-tab-content" data-tab="devolver">
    <div class="inv-card">
      <div class="inv-card-header"><h3><i class="fas fa-undo-alt" style="color:#f59e0b;"></i> Registrar Devolución</h3></div>
      <div class="inv-card-body">
        <form id="invFormDevolver" onsubmit="event.preventDefault(); invRegistrarDevolucion();">
          <div class="inv-row">
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Artículo <span class="inv-required">*</span></label>
                <select id="invDevArticulo" class="inv-select" required>
                  <option value="">Seleccione artículo</option>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Técnico que devuelve <span class="inv-required">*</span></label>
                <select id="invDevTecnico" class="inv-select" required>
                  <option value="">Seleccione técnico</option>
                  <% (empleados || []).forEach(function(e) { %>
                  <option value="<%= e.id %>"><%= e.nombre %></option>
                  <% }); %>
                </select>
              </div>
            </div>
          </div>
          <div class="inv-row">
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Motivo de Devolución <span class="inv-required">*</span></label>
                <select id="invDevMotivo" class="inv-select" required>
                  <option value="">Seleccione motivo</option>
                  <option value="No utilizado">No utilizado</option>
                  <option value="Defectuoso / Dañado">Defectuoso / Dañado</option>
                  <option value="Cliente canceló">Cliente canceló</option>
                  <option value="Equipo equivocado">Equipo equivocado</option>
                  <option value="Reposición de bodega">Reposición de bodega</option>
                  <option value="Cambio de equipo">Cambio de equipo</option>
                  <option value="Otro">Otro</option>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Cliente (opcional)</label>
                <input type="text" id="invDevClienteBuscar" class="inv-input" placeholder="Buscar cliente..." onkeyup="invBuscarCliente(this.value,'invDevClienteResult','invDevClienteId')">
                <input type="hidden" id="invDevClienteId" value="">
                <div id="invDevClienteResult"></div>
              </div>
            </div>
          </div>
          <div style="display:flex; gap:8px; margin-top:4px;">
            <button type="submit" class="inv-btn inv-btn-warning"><i class="fas fa-undo-alt"></i> Registrar Devolución</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ==================== TAB: MOVER ==================== -->
  <div class="inv-tab-content" data-tab="mover">
    <div class="inv-card">
      <div class="inv-card-header"><h3><i class="fas fa-arrows-alt-h" style="color:#3b82f6;"></i> Mover Artículo entre Oficinas</h3></div>
      <div class="inv-card-body">
        <form id="invFormMover" onsubmit="event.preventDefault(); invMoverArticulo();">
          <div class="inv-row">
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Artículo <span class="inv-required">*</span></label>
                <select id="invMovArticulo" class="inv-select" required>
                  <option value="">Seleccione artículo</option>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-4">
              <div class="inv-form-group">
                <label class="inv-label">Oficina Origen <span class="inv-required">*</span></label>
                <select id="invMovOrigen" class="inv-select" required>
                  <option value="">Seleccione origen</option>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-4">
              <div class="inv-form-group">
                <label class="inv-label">Oficina Destino <span class="inv-required">*</span></label>
                <select id="invMovDestino" class="inv-select" required>
                  <option value="">Seleccione destino</option>
                </select>
              </div>
            </div>
