<% 
// Inventario.ejs — DomISP-style full inventory management
// Backend: case 'InventarioAPI' → INV_API = '/modulo?pagina=InventarioAPI&action='
%>
<style>
/* ===== INVENTARIO DOMISP STYLES (inv- prefix) ===== */

/* Wrap */
.inv-wrap {
  padding: 4px 0;
}
.inv-wrap h2 {
  font-size: 1.3rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 6px 0;
  display: flex;
  align-items: center;
  gap: 8px;
}
.inv-wrap .inv-subtitle {
  color: #94a3b8;
  font-size: 0.82rem;
  margin-bottom: 16px;
}

/* Tabs */
.inv-tabs {
  display: flex;
  gap: 3px;
  overflow-x: auto;
  padding-bottom: 2px;
  margin-bottom: 18px;
  background: #f1f5f9;
  border-radius: 12px;
  padding: 4px;
}
.inv-tab {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 9px 16px;
  border: none;
  background: transparent;
  border-radius: 10px;
  font-size: 0.82rem;
  font-weight: 500;
  color: #64748b;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.18s;
}
.inv-tab:hover {
  background: rgba(99,102,241,0.08);
  color: #4f46e5;
}
.inv-tab.active {
  background: #fff;
  color: #4f46e5;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  font-weight: 600;
}
.inv-tab i {
  font-size: 0.85rem;
}
.inv-tab-content {
  display: none;
  animation: invFadeIn 0.25s ease;
}
.inv-tab-content.active { display: block; }
@keyframes invFadeIn {
  from { opacity:0; transform:translateY(6px); }
  to { opacity:1; transform:translateY(0); }
}

/* Cards */
.inv-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  overflow: hidden;
  margin-bottom: 16px;
}
.inv-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  border-bottom: 1px solid #f1f5f9;
  flex-wrap: wrap;
  gap: 8px;
}
.inv-card-header h3, .inv-card-header h4 {
  margin: 0;
  font-size: 0.95rem;
  font-weight: 600;
  color: #1e293b;
  display: flex;
  align-items: center;
  gap: 7px;
}
.inv-card-body {
  padding: 16px 18px;
}

/* Layout helpers */
.inv-row {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.inv-row > * { min-width: 0; }
.inv-col {
  flex: 1;
  min-width: 200px;
}
.inv-col-2 { flex: 0 0 calc(50% - 8px); }
.inv-col-3 { flex: 0 0 calc(33.333% - 11px); }
.inv-col-4 { flex: 0 0 calc(25% - 12px); }
@media(max-width:768px) {
  .inv-col-2, .inv-col-3, .inv-col-4 { flex: 1 1 100%; }
}

/* Summary cards (dashboard) */
.inv-summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
  gap: 14px;
  margin-bottom: 20px;
}
.inv-summary-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 16px 18px;
  display: flex;
  align-items: center;
  gap: 14px;
  transition: all 0.2s;
}
.inv-summary-card:hover {
  box-shadow: 0 4px 14px rgba(0,0,0,0.07);
  transform: translateY(-2px);
}
.inv-summary-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}
.inv-summary-info h4 {
  margin: 0;
  font-size: 1.3rem;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.2;
}
.inv-summary-info p {
  margin: 2px 0 0;
  font-size: 0.75rem;
  color: #94a3b8;
  font-weight: 500;
}

/* Buttons */
.inv-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  border: none;
  border-radius: 8px;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.18s;
  white-space: nowrap;
}
.inv-btn:active { transform: scale(0.97); }
.inv-btn-primary {
  background: linear-gradient(135deg,#6366f1,#8b5cf6);
  color: #fff;
}
.inv-btn-primary:hover { box-shadow: 0 3px 10px rgba(99,102,241,0.3); }
.inv-btn-secondary {
  background: #f1f5f9;
  color: #475569;
}
.inv-btn-secondary:hover { background: #e2e8f0; }
.inv-btn-success {
  background: #22c55e;
  color: #fff;
}
.inv-btn-success:hover { background: #16a34a; }
.inv-btn-danger {
  background: #ef4444;
  color: #fff;
}
.inv-btn-danger:hover { background: #dc2626; }
.inv-btn-warning {
  background: #f59e0b;
  color: #fff;
}
.inv-btn-warning:hover { background: #d97706; }
.inv-btn-info {
  background: #3b82f6;
  color: #fff;
}
.inv-btn-info:hover { background: #2563eb; }
.inv-btn-sm {
  padding: 5px 12px;
  font-size: 0.78rem;
  border-radius: 6px;
}
.inv-btn-xs {
  padding: 3px 8px;
  font-size: 0.72rem;
  border-radius: 5px;
}
.inv-btn-green {
  background: #25D366;
  color: #fff;
}
.inv-btn-green:hover { background: #1da851; }

/* Form groups */
.inv-form-group {
  margin-bottom: 14px;
}
.inv-label {
  display: block;
  font-weight: 600;
  font-size: 0.8rem;
  color: #374151;
  margin-bottom: 4px;
}
.inv-label .inv-required { color: #ef4444; margin-left: 1px; }
.inv-input, .inv-select, .inv-textarea {
  width: 100%;
  padding: 8px 12px;
  border: 1.5px solid #e2e8f0;
  border-radius: 8px;
  font-size: 0.85rem;
  color: #1e293b;
  background: #fff;
  transition: border-color 0.18s, box-shadow 0.18s;
  box-sizing: border-box;
}
.inv-input:focus, .inv-select:focus, .inv-textarea:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
}
.inv-input-error { border-color: #ef4444 !important; }
.inv-textarea { min-height: 70px; resize: vertical; }
.inv-checkbox-label {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 0.82rem;
  color: #374151;
  cursor: pointer;
  font-weight: 500;
}
.inv-checkbox-label input[type="checkbox"] {
  width: 17px;
  height: 17px;
  accent-color: #6366f1;
  cursor: pointer;
}

/* Tables */
.inv-table-wrap {
  overflow-x: auto;
}
.inv-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
}
.inv-table thead th {
  background: #f8fafc;
  padding: 10px 10px;
  text-align: left;
  font-weight: 600;
  color: #64748b;
  border-bottom: 2px solid #e2e8f0;
  white-space: nowrap;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}
.inv-table tbody td {
  padding: 9px 10px;
  border-bottom: 1px solid #f1f5f9;
  color: #334155;
  vertical-align: middle;
}
.inv-table tbody tr:hover { background: #f8fafc; }
.inv-table tbody tr:last-child td { border-bottom: none; }
.inv-table .inv-cell-check { width: 36px; text-align: center; }
.inv-table .inv-cell-check input[type="checkbox"] {
  width: 16px; height: 16px;
  accent-color: #6366f1;
  cursor: pointer;
}

/* Badges */
.inv-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 0.72rem;
  font-weight: 600;
}
.inv-badge-green { background: #dcfce7; color: #15803d; }
.inv-badge-yellow { background: #fef3c7; color: #b45309; }
.inv-badge-red { background: #fef2f2; color: #dc2626; }
.inv-badge-blue { background: #e0e7ff; color: #4338ca; }
.inv-badge-gray { background: #f1f5f9; color: #64748b; }
.inv-badge-purple { background: #ede9fe; color: #6d28d9; }

/* Pagination */
.inv-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid #e2e8f0;
}
.inv-pagination button:disabled { opacity: 0.4; cursor: not-allowed; }
.inv-page-info {
  font-size: 0.82rem;
  color: #64748b;
  font-weight: 600;
}

/* Bulk bar */
.inv-bulk-bar {
  display: flex;
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: 10px;
  padding: 10px 16px;
  margin-bottom: 14px;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
}
.inv-bulk-bar .inv-bulk-count {
  font-size: 0.85rem;
  font-weight: 600;
  color: #166534;
}

/* Search row */
.inv-search-row {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 14px;
}
.inv-search-row .inv-input-wrap {
  position: relative;
  flex: 1;
  min-width: 180px;
}
.inv-search-row .inv-input-wrap i {
  position: absolute;
  left: 11px;
  top: 50%;
  transform: translateY(-50%);
  color: #94a3b8;
  font-size: 0.8rem;
}
.inv-search-row .inv-input-wrap .inv-input {
  padding-left: 30px;
}

/* Client search result */
.inv-client-result {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  margin-top: 8px;
}
.inv-client-result img {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  object-fit: cover;
}
.inv-client-result .inv-client-info { flex: 1; }
.inv-client-result .inv-client-info strong { display: block; font-size: 0.85rem; color: #1e293b; }
.inv-client-result .inv-client-info span { font-size: 0.75rem; color: #94a3b8; }

/* Sub-tabs (solo config) */
.inv-sub-tabs {
  display: flex;
  gap: 3px;
  margin-bottom: 16px;
  background: #f8fafc;
  border-radius: 8px;
  padding: 3px;
  overflow-x: auto;
}
.inv-sub-tab {
  padding: 7px 14px;
  border: none;
  background: transparent;
  border-radius: 7px;
  font-size: 0.8rem;
  font-weight: 500;
  color: #64748b;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.15s;
}
.inv-sub-tab:hover { background: rgba(99,102,241,0.06); color: #4f46e5; }
.inv-sub-tab.active {
  background: #fff;
  color: #4f46e5;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  font-weight: 600;
}
.inv-sub-content { display: none; }
.inv-sub-content.active { display: block; animation: invFadeIn 0.2s ease; }

/* Chart placeholder */
.inv-chart-box {
  background: #f8fafc;
  border: 1px dashed #d1d5db;
  border-radius: 10px;
  padding: 30px;
  text-align: center;
  color: #94a3b8;
  font-size: 0.85rem;
  min-height: 200px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.inv-chart-box .inv-chart-bar-container {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  height: 160px;
  padding: 0 10px;
  margin-top: 12px;
}
.inv-chart-bar {
  flex: 1;
  max-width: 50px;
  border-radius: 6px 6px 0 0;
  min-height: 4px;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  transition: height 0.5s ease;
}
.inv-chart-bar .inv-bar-label {
  position: absolute;
  bottom: -22px;
  font-size: 0.65rem;
  color: #64748b;
  white-space: nowrap;
  font-weight: 500;
}
.inv-chart-bar .inv-bar-val {
  font-size: 0.68rem;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 4px;
}

/* Empty state */
.inv-empty {
  text-align: center;
  padding: 40px 20px;
  color: #94a3b8;
}
.inv-empty i { font-size: 2.5rem; margin-bottom: 10px; opacity: 0.5; }
.inv-empty p { font-size: 0.9rem; margin: 0; }

/* Loading */
.inv-loading {
  text-align: center;
  padding: 40px;
  color: #94a3b8;
}
.inv-loading i { font-size: 1.4rem; }

/* Modales DomISP */
#invModalContainer {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 10000;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(2px);
}
#invModalContainer.open { display: flex; }
.inv-modal-box {
  background: #fff;
  border-radius: 16px;
  width: 90%;
  max-width: 520px;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  animation: invModalIn 0.22s ease;
}
.inv-modal-box.inv-modal-wide { max-width: 680px; }
.inv-modal-box.inv-modal-sm { max-width: 400px; }
@keyframes invModalIn {
  from { opacity:0; transform:scale(0.94) translateY(10px); }
  to { opacity:1; transform:scale(1) translateY(0); }
}
.inv-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 22px;
  border-bottom: 1px solid #f1f5f9;
}
.inv-modal-header h3 {
  margin: 0;
  font-size: 1.05rem;
  font-weight: 600;
  color: #1e293b;
  display: flex;
  align-items: center;
  gap: 8px;
}
.inv-modal-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: #f1f5f9;
  border-radius: 8px;
  font-size: 1.2rem;
  color: #94a3b8;
  cursor: pointer;
  transition: all 0.15s;
}
.inv-modal-close:hover { background: #e2e8f0; color: #64748b; }
.inv-modal-body { padding: 18px 22px; }
.inv-modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 14px 22px;
  border-top: 1px solid #f1f5f9;
}

/* Toast / notification */
.inv-toast {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 99999;
  padding: 12px 22px;
  border-radius: 10px;
  font-size: 0.85rem;
  font-weight: 500;
  box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  display: flex;
  align-items: center;
  gap: 10px;
  animation: invToastIn 0.25s ease;
  max-width: 380px;
}
.inv-toast-success { background: #dcfce7; color: #15803d; border-left: 4px solid #22c55e; }
.inv-toast-error { background: #fef2f2; color: #dc2626; border-left: 4px solid #ef4444; }
.inv-toast-info { background: #e0e7ff; color: #4338ca; border-left: 4px solid #6366f1; }
@keyframes invToastIn {
  from { opacity:0; transform:translateX(30px); }
  to { opacity:1; transform:translateX(0); }
}

/* Responsive */
@media(max-width:640px) {
  .inv-summary-grid { grid-template-columns: repeat(2,1fr); }
  .inv-tabs { flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .inv-tab { padding: 8px 12px; font-size: 0.75rem; }
  .inv-modal-box { width: 95%; max-width: 100%; border-radius: 12px; margin: 10px; }
}
</style>

<div class="inv-wrap">
  <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:10px; margin-bottom:8px;">
    <div>
      <h2><i class="fas fa-boxes" style="color:#6366f1;"></i> Inventario</h2>
      <p class="inv-subtitle">Gestión completa de artículos, asignaciones, devoluciones y reportes</p>
    </div>
  </div>

  <!-- Tabs -->
  <div class="inv-tabs" id="invTabs">
    <button class="inv-tab active" data-tab="dashboard"><i class="fas fa-chart-pie"></i> Dashboard</button>
    <button class="inv-tab" data-tab="registrar"><i class="fas fa-plus-circle"></i> Registrar</button>
    <button class="inv-tab" data-tab="asignar"><i class="fas fa-hand-holding"></i> Asignar</button>
    <button class="inv-tab" data-tab="devolver"><i class="fas fa-undo-alt"></i> Devolver</button>
    <button class="inv-tab" data-tab="mover"><i class="fas fa-arrows-alt-h"></i> Mover</button>
    <button class="inv-tab" data-tab="historial"><i class="fas fa-history"></i> Historial</button>
    <button class="inv-tab" data-tab="reportes"><i class="fas fa-file-alt"></i> Reportes</button>
    <button class="inv-tab" data-tab="configuracion"><i class="fas fa-cog"></i> Configuración</button>
  </div>

  <!-- ==================== TAB: DASHBOARD ==================== -->
  <div class="inv-tab-content active" data-tab="dashboard">
    <div class="inv-summary-grid" id="invDashSummary">
      <div class="inv-summary-card"><div class="inv-summary-icon" style="background:#e0e7ff;color:#4338ca;"><i class="fas fa-box"></i></div><div class="inv-summary-info"><h4 id="invDashTotalItems">0</h4><p>Total Artículos</p></div></div>
      <div class="inv-summary-card"><div class="inv-summary-icon" style="background:#dcfce7;color:#15803d;"><i class="fas fa-dollar-sign"></i></div><div class="inv-summary-info"><h4 id="invDashTotalValor">$0</h4><p>Valor Total</p></div></div>
      <div class="inv-summary-card"><div class="inv-summary-icon" style="background:#fef3c7;color:#b45309;"><i class="fas fa-exclamation-triangle"></i></div><div class="inv-summary-info"><h4 id="invDashLowStock">0</h4><p>Stock Bajo</p></div></div>
      <div class="inv-summary-card"><div class="inv-summary-icon" style="background:#ede9fe;color:#6d28d9;"><i class="fas fa-users"></i></div><div class="inv-summary-info"><h4 id="invDashTecnicos">0</h4><p>Técnicos</p></div></div>
      <div class="inv-summary-card"><div class="inv-summary-icon" style="background:#e0f2fe;color:#0369a1;"><i class="fas fa-tags"></i></div><div class="inv-summary-info"><h4 id="invDashCategorias">0</h4><p>Categorías</p></div></div>
    </div>

    <div class="inv-row">
      <div class="inv-col inv-col-2">
        <div class="inv-card">
          <div class="inv-card-header"><h4><i class="fas fa-chart-bar" style="color:#6366f1;"></i> Artículos por Técnico</h4></div>
          <div class="inv-card-body">
            <div class="inv-chart-box" id="invDashChart">
              Cargando gráfico...
              <div class="inv-chart-bar-container" id="invChartBars"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="inv-col inv-col-2">
        <div class="inv-card">
          <div class="inv-card-header"><h4><i class="fas fa-exclamation-circle" style="color:#ef4444;"></i> Materiales Agotados</h4></div>
          <div class="inv-card-body" style="padding:0;">
            <div class="inv-table-wrap">
              <table class="inv-table" id="invDashEmptyTable">
                <thead><tr><th>Código</th><th>Nombre</th><th>Stock</th></tr></thead>
                <tbody id="invDashEmptyBody"><tr><td colspan="3" class="inv-empty"><i class="fas fa-check-circle" style="color:#22c55e;"></i><p>Sin materiales agotados</p></td></tr></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ==================== TAB: REGISTRAR ==================== -->
  <div class="inv-tab-content" data-tab="registrar">
    <div class="inv-card">
      <div class="inv-card-header"><h3><i class="fas fa-plus-circle" style="color:#22c55e;"></i> Registrar Nuevo Artículo</h3></div>
      <div class="inv-card-body">
        <form id="invFormRegistrar" onsubmit="event.preventDefault(); invRegistrarArticulo();">
          <div class="inv-row">
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Código <span class="inv-required">*</span></label>
                <div style="display:flex; gap:6px;">
                  <input type="text" id="invRegCodigo" class="inv-input" placeholder="INV-001" required style="flex:1;">
                  <button type="button" class="inv-btn inv-btn-sm inv-btn-secondary" onclick="invGenerarCodigo('invRegCodigo')" title="Generar código automático"><i class="fas fa-sync-alt"></i></button>
                </div>
              </div>
            </div>
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Nombre del Artículo <span class="inv-required">*</span></label>
                <input type="text" id="invRegNombre" class="inv-input" placeholder="Ej: ONU Huawei HG8245" required>
              </div>
            </div>
          </div>
          <div class="inv-row">
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Oficina / Sucursal</label>
                <select id="invRegOficina" class="inv-select">
                  <option value="">Seleccione oficina</option>
                </select>
              </div>
            </div>
            <div class="inv-col inv-col-2">
              <div class="inv-form-group">
                <label class="inv-label">Categoría <span class="inv-required">*</span></label>
                <div style="display:flex; gap:6px;">
                  <select id="invRegCategoria" class="inv-select" onchange="invToggleOtraCategoria('invRegCategoria','invRegCategoriaOtra')" style="flex:1;">
                    <option value="">Seleccione</option>
                    <option value="ONU">ONU</option>
                    <option value="Router">Router</option>
                    <option value="Caja TV">Caja TV</option>
                    <option value="Repetidor WiFi">Repetidor WiFi</option>
                    <option value="UPS">UPS</option>
                    <option value="Cable">Cable</option>
                    <option value="Conectores">Conectores</option>
                    <option value="Splitter">Splitter</option>
                    <option value="Antena">Antena</option>
                    <option value="Switch">Switch</option>
                    <option value="Micronodo">Micronodo</option>
                    <option value="Caja Nap">Caja Nap</option>
                    <option value="Manga">Manga</option>
                    <option value="Fibra Óptica">Fibra Óptica</option>
                    <option value="Herramienta">Herramienta</option>
                    <option value="Otro">Otro...</option>
                  </select>
                  <input type="text" id="invRegCategoriaOtra" class="inv-input" placeholder="Nueva categoría" style="display:none; flex:1;">
                </div>
              </div>
            </div>
          </div>
          <div class="inv-row">
            <div class="inv-col inv-col-3">
              <div class="inv-form-group">
                <label class="inv-label">¿Es de Venta?</label>
                <label class="inv-checkbox-label">
                  <input type="checkbox" id="invRegVenta">
                  <i class="fas fa-dollar-sign" style="color:#22c55e;"></i> Sí, se vende al público
                </label>
              </div>
            </div>
            <div class="inv-col inv-col-3">
              <div class="inv-form-group">
                <label class="inv-label">Precio ($)</label>
                <input type="number" id="invRegPrecio" class="inv-input" min="0" step="0.01" value="0" placeholder="0.00">
              </div>
            </div>
            <div class="inv-col inv-col-3">
              <div class="inv-form-group">
                <label class="inv-label">Cantidad Inicial <span class="inv-required">*</span></label>
                <input type="number" id="invRegCantidad" class="inv-input" min="1" value="1" required>
              </div>
            </div>
          </div>
          <div class="inv-form-group">
            <label class="inv-label">Número de Serie (opcional)</label>
            <input type="text" id="invRegSerial" class="inv-input" placeholder="Serial / IMEI / MAC" style="max-width:350px;">
