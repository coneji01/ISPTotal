<style>
.st-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px}
.st-title{font-size:1.3rem;font-weight:700;color:#1e293b;display:flex;align-items:center;gap:10px}
.st-title i{color:#0ea5e9}
.st-filters{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.st-mode-toggle{display:flex;border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;background:#f8fafc}
.st-mode-opt{display:flex;align-items:center;gap:5px;padding:6px 14px;font-size:0.82rem;font-weight:600;color:#64748b;cursor:pointer;user-select:none;margin:0}
.st-mode-opt input{display:none}
.st-mode-opt.active{background:#0ea5e9;color:#fff}
.st-mode-opt:hover:not(.active){background:#f1f5f9}
.st-select{padding:7px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:0.85rem;color:#475569;background:#fff;cursor:pointer}
.st-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
.st-card{background:#fff;border-radius:12px;padding:14px;border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.04);cursor:pointer;transition:transform .15s,box-shadow .15s}
.st-card:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.st-card-inner{display:flex;align-items:center;gap:10px}
.st-card-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.st-card-icon i{font-size:0.9rem}
.st-card-text{min-width:0;flex:1}
.st-card-val{font-size:1.1rem;font-weight:800;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.st-card-label{font-size:0.72rem;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.3px}
.st-card-sub{font-size:0.68rem;color:#94a3b8;margin-top:3px}
.st-num-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.st-num-card{background:#fff;border-radius:10px;padding:12px 10px;border:1px solid #e2e8f0;text-align:center}
.st-num-val{font-size:1.3rem;font-weight:800;line-height:1.2}
.st-num-label{font-size:0.7rem;color:#64748b;font-weight:500;text-transform:uppercase;letter-spacing:.3px;margin-top:2px}
.st-section{margin-bottom:24px}
.st-section-title{font-size:1rem;font-weight:700;color:#334155;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.st-section-title i{color:#0ea5e9;font-size:0.9rem}
.st-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.st-panel{background:#fff;border-radius:12px;padding:16px;border:1px solid #e2e8f0}
.st-bar-wrap{margin-bottom:8px}
.st-bar-label{display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:4px}
.st-bar-name{color:#334155;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.st-bar-val{color:#64748b;font-weight:600;flex-shrink:0;margin-left:8px}
.st-bar-track{height:8px;background:#f1f5f9;border-radius:8px;overflow:hidden}
.st-bar-fill{height:100%;border-radius:8px;transition:width .6s ease}
.st-table{width:100%;border-collapse:collapse;font-size:0.85rem}
.st-table th{text-align:left;padding:8px 10px;font-size:0.75rem;font-weight:600;color:#64748b;text-transform:uppercase;border-bottom:2px solid #e2e8f0}
.st-table td{padding:8px 10px;border-bottom:1px solid #f1f5f9;color:#334155}
.st-table tr:hover{background:#f8fafc}
.st-chart{height:140px;display:flex;align-items:flex-end;gap:2px;padding:10px 0}
.st-chart-bar{flex:1;border-radius:3px 3px 0 0;min-height:2px;transition:height .4s ease;cursor:pointer;position:relative}
.st-chart-bar:hover{opacity:.8}
.st-chart-bar:hover::after{content:attr(data-tip);position:absolute;bottom:100%;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:3px 8px;border-radius:4px;font-size:0.65rem;white-space:nowrap;margin-bottom:4px;z-index:10}
.st-chart-labels{display:flex;gap:2px;font-size:0.55rem;color:#94a3b8;text-align:center}
.st-chart-labels span{flex:1;overflow:hidden;text-overflow:ellipsis}
.st-loading{padding:60px;text-align:center;color:#94a3b8}
.st-tabs{display:flex;gap:0;margin-bottom:18px;background:#fff;border-radius:10px;border:1px solid #e2e8f0;overflow:hidden;width:fit-content}
.st-tab{padding:10px 22px;font-size:0.88rem;font-weight:600;color:#64748b;cursor:pointer;display:flex;align-items:center;gap:7px;border-right:1px solid #e2e8f0;user-select:none}
.st-tab:last-child{border-right:none}
.st-tab:hover{background:#f8fafc;color:#334155}
.st-tab.active{background:#0ea5e9;color:#fff}
.st-modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:3000;display:none;align-items:center;justify-content:center;padding:16px}
.st-modal{background:#fff;border-radius:14px;width:100%;max-width:700px;max-height:85vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.st-modal-head{padding:16px 20px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:center}
.st-modal-head h3{margin:0;font-size:1rem;color:#1e293b}
.st-modal-close{cursor:pointer;font-size:1.4rem;color:#94a3b8;line-height:1}
.st-modal-close:hover{color:#ef4444}
.st-modal-toolbar{padding:10px 20px;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.st-modal-body{overflow-y:auto;flex:1}
.st-modal-foot{padding:10px 20px;border-top:1px solid #e2e8f0;display:flex;justify-content:center}
.st-inv-row{display:flex;justify-content:space-between;align-items:center;padding:10px 20px;border-bottom:1px solid #f8fafc;font-size:0.85rem}
.st-inv-row:hover{background:#f8fafc}
.st-modal-search{padding:5px 10px;border:1px solid #e2e8f0;border-radius:6px;font-size:0.82rem;outline:none}
.st-modal-search:focus{border-color:#0ea5e9}
.st-pag{display:flex;gap:4px;align-items:center;flex-wrap:wrap}
.st-pag-btn{min-width:32px;height:32px;display:inline-flex;align-items:center;justify-content:center;border:1px solid #e2e8f0;border-radius:6px;background:#fff;color:#475569;font-size:0.8rem;cursor:pointer;font-weight:500}
.st-pag-btn:hover:not(:disabled){background:#f1f5f9}
.st-pag-btn:disabled{opacity:.3;cursor:not-allowed}
.st-pag-active{background:#0ea5e9;color:#fff;border-color:#0ea5e9;font-weight:700}
@media(max-width:900px){.st-grid{grid-template-columns:repeat(2,1fr)}.st-num-grid{grid-template-columns:repeat(4,1fr)}.st-row{grid-template-columns:1fr}}
@media(max-width:600px){.st-grid{grid-template-columns:1fr 1fr}.st-num-grid{grid-template-columns:repeat(2,1fr)}}
</style>

<div class="st-header">
  <div class="st-title"><i class="fas fa-chart-line"></i> Estadisticas</div>
  <div class="st-filters">
    <div class="st-mode-toggle" id="stRangeToggle">
      <label class="st-mode-opt active" onclick="stSetFilterMode('periodo')"><input type="radio" name="stFilterMode" checked><span>Periodo</span></label>
      <label class="st-mode-opt" onclick="stSetFilterMode('rango')"><input type="radio" name="stFilterMode"><span>Rango</span></label>
    </div>
    <div id="stFilterPeriodo"><select class="st-select" id="stPeriodo" onchange="stLoad()"></select></div>
    <div id="stFilterRango" style="display:none;gap:6px;align-items:center;">
      <input type="date" class="st-select" id="stDesde" onchange="stLoad()" style="padding:6px 10px;">
      <span style="color:#94a3b8;font-size:0.8rem;">a</span>
      <input type="date" class="st-select" id="stHasta" onchange="stLoad()" style="padding:6px 10px;">
    </div>
    <select class="st-select" id="stZona" onchange="stLoad()">
      <option value="0">Todas las zonas</option>
      <% (zonas || []).forEach(function(z){ %>
      <option value="<%= z.id %>"><%= z.nombre %></option>
      <% }); %>
    </select>
  </div>
</div>

<div class="st-tabs">
  <div class="st-tab active" onclick="stSwitchTab('finanzas',this)"><i class="fas fa-dollar-sign"></i> Finanzas</div>
  <div class="st-tab" onclick="stSwitchTab('clientes',this)"><i class="fas fa-users"></i> Clientes</div>
</div>

<div id="stTabFinanzas"><div class="st-loading" id="stFinanzasContent"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;margin-bottom:10px;display:block;"></i>Cargando...</div></div>
<div id="stTabClientes" style="display:none;"><div class="st-loading" id="stClientesContent"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;margin-bottom:10px;display:block;"></i>Cargando...</div></div>

<div class="st-modal-overlay" id="stModal">
  <div class="st-modal">
    <div class="st-modal-head"><h3 id="stModalTitle">Detalle</h3><span class="st-modal-close" onclick="stCloseModal()">&times;</span></div>
    <div class="st-modal-toolbar">
      <div class="st-modal-total" id="stModalTotal"></div>
      <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
        <input type="text" class="st-modal-search" id="stModalSearch" placeholder="Buscar..." onkeyup="stModalSearchFn()">
        <select class="st-select" id="stModalOrden" onchange="stLoadDetail(1)" style="font-size:0.8rem;padding:4px 8px;">
          <option value="desc">Monto mayor</option>
          <option value="asc">Monto menor</option>
        </select>
      </div>
    </div>
    <div class="st-modal-body" id="stModalBody"></div>
    <div class="st-modal-foot" id="stModalPag"></div>
  </div>
</div>

<script>
var stPeriodos = <%- JSON.stringify(periodos || []) %>;
var mesesNombres = ['','Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
var stFilterMode = 'periodo';
var stCurrentMode = 'mes';
var stModalData = [];
var stModalPage = 1;
var stModalPerPage = 15;
var stModalType = '';
var stModalTimer = null;

// Inicializar selector de periodo
(function(){
  var sel = document.getElementById('stPeriodo');
  if (!stPeriodos || !stPeriodos.length) {
    var now = new Date();
    sel.innerHTML = '<option value="' + (now.getMonth()+1) + '-' + now.getFullYear() + '">' + mesesNombres[now.getMonth()+1] + ' ' + now.getFullYear() + '</option>';
    return;
  }
  var h = '';
  for (var i = 0; i < stPeriodos.length; i++) {
    var p = stPeriodos[i];
    h += '<option value="' + p.mes + '-' + p.anio + '"' + (i===0?' selected':'') + '>' + mesesNombres[parseInt(p.mes)] + ' ' + p.anio + '</option>';
  }
  sel.innerHTML = h;
})();

function stSetFilterMode(mode) {
  stFilterMode = mode;
  document.querySelectorAll('#stRangeToggle .st-mode-opt').forEach(function(el){el.classList.toggle('active', el.onclick.toString().includes(mode))});
  document.getElementById('stFilterPeriodo').style.display = mode === 'periodo' ? '' : 'none';
  document.getElementById('stFilterRango').style.display = mode === 'rango' ? 'flex' : 'none';
  if (mode === 'rango') {
    var pv = document.getElementById('stPeriodo').value.split('-');
    var m = parseInt(pv[0]), a = parseInt(pv[1]);
    document.getElementById('stDesde').value = a + '-' + String(m).padStart(2,'0') + '-01';
    var last = new Date(a, m, 0);
    document.getElementById('stHasta').value = a + '-' + String(m).padStart(2,'0') + '-' + String(last.getDate()).padStart(2,'0');
  }
  stLoad();
}

function stSwitchTab(tab, el) {
  document.querySelectorAll('.st-tab').forEach(function(t){t.classList.remove('active')});
  el.classList.add('active');
  document.getElementById('stTabFinanzas').style.display = tab === 'finanzas' ? '' : 'none';
  document.getElementById('stTabClientes').style.display = tab === 'clientes' ? '' : 'none';
  if (stCurrentMode !== 'ciclo') stLoad();
}

function stCard(val, label, sub, color, icon, tipo) {
  var click = tipo ? ' onclick="stOpenModal(\'' + tipo + '\')"' : '';
  return '<div class="st-card"' + click + '><div class="st-card-inner"><div class="st-card-icon" style="background:' + color + '15;"><i class="fas ' + icon + '" style="color:' + color + ';"></i></div><div class="st-card-text"><div class="st-card-val" style="color:' + color + ';">' + val + '</div><div class="st-card-label">' + label + '</div><div class="st-card-sub">' + sub + '</div></div></div></div>';
}

function stNum(val, label, color) {
  return '<div class="st-num-card"><div class="st-num-val" style="color:' + color + ';">' + val + '</div><div class="st-num-label">' + label + '</div></div>';
}

function stSetMode(mode) {
  stCurrentMode = mode;
  document.querySelectorAll('#stModeToggle .st-mode-opt').forEach(function(el){el.classList.remove('active')});
  document.getElementById('stMode' + (mode==='ciclo'?'Ciclo':'Mes')).classList.add('active');
  stLoad();
}

function stLoad() {
  var pv = document.getElementById('stPeriodo').value.split('-');
  var mes = pv[0], anio = pv[1], zona = document.getElementById('stZona').value;
  var wrapF = document.getElementById('stFinanzasContent');
  var wrapC = document.getElementById('stClientesContent');
  wrapF.innerHTML = '<div class="st-loading"><i class="fas fa-spinner fa-spin"></i> Cargando...</div>';
  wrapC.innerHTML = wrapF.innerHTML;

  var params = '&mes=' + mes + '&anio=' + anio + '&zona=' + zona + '&mode=' + stCurrentMode;
  if (stFilterMode === 'rango') {
    var desde = document.getElementById('stDesde').value;
    var hasta = document.getElementById('stHasta').value;
    if (desde && hasta) params += '&desde=' + desde + '&hasta=' + hasta;
  }

  Promise.all([
    fetch('/modulo?pagina=Estadisticas&ajax=get_stats' + params + '&modo=finanzas').then(function(r){return r.json()}),
    fetch('/modulo?pagina=Estadisticas&ajax=get_stats' + params + '&modo=clientes').then(function(r){return r.json()})
  ])
  .then(function(results){
    var df = results[0], dc = results[1];
    if (!df.success || !dc.success) { wrapF.innerHTML = '<div class="st-loading">Error</div>'; return; }
    var f = df, c = dc;
    var fmt = function(n){return '$' + parseFloat(n||0).toLocaleString('es-DO',{minimumFractionDigits:2})};
    var modeLabel = stFilterMode === 'rango' ? 'este rango' : (stCurrentMode === 'mes' ? 'este mes' : 'este ciclo');

    // ===== TAB FINANZAS =====
    var hf = '<div class="st-grid">';
    hf += stCard(fmt((f.cobradoTotal||0)+(f.pendienteTotal||0)), 'Facturado', 'En ' + modeLabel, '#6366f1', 'fa-file-invoice-dollar', 'facturado');
    hf += stCard(fmt(f.cobradoTotal || 0), 'Cobrado', 'En ' + modeLabel, '#16a34a', 'fa-hand-holding-usd', 'cobrado');
    hf += stCard(fmt(f.cobradoHoy || 0), 'Cobrado Hoy', new Date().toLocaleDateString('es-DO'), '#8b5cf6', 'fa-calendar-day', 'cobrado_hoy');
    hf += stCard(fmt(f.pendienteTotal || 0), 'Pendiente', 'De ' + modeLabel, '#f59e0b', 'fa-clock', 'pendiente');
    hf += stCard(fmt(f.total_vencido || 0), 'Vencido', 'De ' + modeLabel, '#dc2626', 'fa-exclamation-triangle', 'vencido');
    hf += stCard(fmt(f.gastosTotal || 0), 'Gastos', 'De ' + modeLabel, '#7c3aed', 'fa-shopping-cart', null);
    hf += '</div>';

    // Gráfico Cobrado vs Gastado
    if (stCurrentMode === 'mes' || stFilterMode === 'rango') {
      var cob = parseFloat(f.cobradoTotal || 0), gas = parseFloat(f.gastosTotal || 0);
      var bal = cob - gas, maxV = Math.max(cob, gas, 1);
      var pctC = Math.round((cob/maxV)*100), pctG = Math.round((gas/maxV)*100);
      hf += '<div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:20px;margin-bottom:14px;">'
        + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">'
        + '<div style="font-size:0.85rem;font-weight:700;color:#1e293b;"><i class="fas fa-chart-bar" style="color:#6366f1;margin-right:6px;"></i>Ingresos vs Gastos</div>'
        + '</div>';
      hf += '<div><div style="display:flex;justify-content:space-between;margin-bottom:5px;"><span style="font-size:0.78rem;font-weight:600;color:#16a34a;"><i class="fas fa-hand-holding-usd"></i> Cobrado</span><span style="font-size:0.85rem;font-weight:800;color:#16a34a;">'+fmt(cob)+'</span></div>'
        + '<div style="background:#f0fdf4;border-radius:8px;height:28px;overflow:hidden;"><div style="background:linear-gradient(90deg,#16a34a,#22c55e);height:100%;width:'+Math.max(pctC,2)+'%;border-radius:8px;"></div></div></div>';
      hf += '<div style="margin-top:10px;"><div style="display:flex;justify-content:space-between;margin-bottom:5px;"><span style="font-size:0.78rem;font-weight:600;color:#7c3aed;"><i class="fas fa-shopping-cart"></i> Gastado</span><span style="font-size:0.85rem;font-weight:800;color:#7c3aed;">'+fmt(gas)+'</span></div>'
        + '<div style="background:#f5f3ff;border-radius:8px;height:28px;overflow:hidden;"><div style="background:linear-gradient(90deg,#7c3aed,#8b5cf6);height:100%;width:'+Math.max(pctG,2)+'%;border-radius:8px;"></div></div></div>';
      var balColor = bal >= 0 ? '#16a34a' : '#dc2626';
      hf += '<div style="margin-top:14px;padding-top:12px;border-top:1px solid #e2e8f0;display:flex;justify-content:space-between;">'
        + '<div><div style="font-size:0.72rem;color:#94a3b8;text-transform:uppercase;">' + (bal >= 0 ? 'Ganancia' : 'Deficit') + '</div>'
        + '<div style="font-size:1.1rem;font-weight:800;color:'+balColor+';">'+fmt(Math.abs(bal))+'</div></div>'
        + '<div style="text-align:right;"><div style="font-size:0.72rem;color:#94a3b8;text-transform:uppercase;">Margen</div>'
        + '<div style="font-size:1.1rem;font-weight:800;color:'+balColor+';">'+ (cob > 0 ? Math.round((bal/cob)*100) : 0) + '%</div></div></div>';
      hf += '</div>';
    }

    wrapF.innerHTML = hf;

    // ===== TAB CLIENTES =====
    var hc = '';
    // Suspend months selector
    var suspMonths = 3;
    hc += '<div style="margin-bottom:14px;display:flex;align-items:center;gap:8px;font-size:0.85rem;color:#475569;">'
      + '<span>Mostrar suspendidos con mas de</span>'
      + '<select class="st-select" id="stSuspMonths" style="width:80px;padding:5px 8px;" onchange="stLoad()">'
      + '<option value="1">1</option><option value="2">2</option><option value="3" selected>3</option><option value="6">6</option><option value="12">12</option>'
      + '</select><span>mes(es)</span></div>';

    hc += '<div class="st-num-grid">';
    hc += stNum(c.activos || 0, 'Activos', '#16a34a');
    hc += stNum(c.suspendidos || 0, 'Suspendidos', '#f59e0b');
    hc += stNum(c.suspendidos_largos || 0, 'Susp. >'+suspMonths+'m', '#dc2626');
    hc += stNum(c.nuevos_anio || 0, 'Nuevos (ano)', '#6366f1');
    hc += stNum(c.nuevos_mes || 0, 'Nuevos (mes)', '#0ea5e9');
    hc += stNum(c.suspendidos_mes || 0, 'Susp. (mes)', '#f59e0b');
    hc += stNum(c.reactivados_mes || 0, 'Reactivados', '#8b5cf6');
    hc += stNum(c.retiradosMes || 0, 'Retirados (mes)', '#dc2626');
    hc += '</div>';

    // Grafico 12 meses
    if (c.instaladosMes && c.instaladosMes.length) {
      hc += '<div class="st-section"><div class="st-section-title"><i class="fas fa-chart-bar"></i> Instalaciones (este mes)</div>';
      var maxM = Math.max.apply(null, c.instaladosMes.map(function(x){return x.total})) || 1;
      hc += '<div class="st-chart">';
      for (var i = 0; i < c.instaladosMes.length; i++) {
        var pct2 = Math.max((c.instaladosMes[i].total / maxM * 100), 2);
        hc += '<div class="st-chart-bar" style="height:'+pct2+'%;background:#0ea5e9;" data-tip="' + (c.instaladosMes[i].mes||'') + ': ' + c.instaladosMes[i].total + '"></div>';
      }
      hc += '</div><div class="st-chart-labels">';
      for (var i = 0; i < c.instaladosMes.length; i++) {
        hc += '<span>' + (c.instaladosMes[i].mes||'').substring(0,3) + '</span>';
      }
      hc += '</div></div>';
    }

    // Nuevos por zona + Top planes
    hc += '<div class="st-row">';
    hc += '<div class="st-panel"><div class="st-section-title"><i class="fas fa-map-marker-alt"></i> Servicios por Zona</div>';
    if (c.serviciosPorZona && c.serviciosPorZona.length) {
      var maxZ = Math.max.apply(null, c.serviciosPorZona.map(function(x){return x.total || x.activos || 0})) || 1;
      c.serviciosPorZona.forEach(function(z){
        var total = z.total || z.activos || 0;
        var pctZ = (total/maxZ*100);
        hc += '<div class="st-bar-wrap"><div class="st-bar-label"><span class="st-bar-name">' + (z.zona||'Sin zona') + '</span><span class="st-bar-val">' + total + '</span></div><div class="st-bar-track"><div class="st-bar-fill" style="width:'+pctZ+'%;background:#6366f1;"></div></div></div>';
      });
    } else hc += '<div style="color:#94a3b8;text-align:center;padding:20px;">Sin datos</div>';
    hc += '</div>';

    hc += '<div class="st-panel"><div class="st-section-title"><i class="fas fa-tachometer-alt"></i> Servicios por Plan</div>';
    if (c.serviciosPorPlan && c.serviciosPorPlan.length) {
      var maxP = Math.max.apply(null, c.serviciosPorPlan.map(function(x){return x.total || x.activos || 0})) || 1;
      c.serviciosPorPlan.forEach(function(p){
        var total = p.total || p.activos || 0;
        var pctP = (total/maxP*100);
        hc += '<div class="st-bar-wrap"><div class="st-bar-label"><span class="st-bar-name">' + (p.plan||'Sin plan') + '</span><span class="st-bar-val">' + total + '</span></div><div class="st-bar-track"><div class="st-bar-fill" style="width:'+pctP+'%;background:#0ea5e9;"></div></div></div>';
      });
    } else hc += '<div style="color:#94a3b8;text-align:center;padding:20px;">Sin datos</div>';
    hc += '</div></div>';

    wrapC.innerHTML = hc;
  });
}

function stOpenModal(tipo) {
  stModalType = tipo;
  stModalPage = 1;
  document.getElementById('stModalTitle').textContent = tipo.charAt(0).toUpperCase() + tipo.slice(1);
  document.getElementById('stModalSearch').value = '';
  document.getElementById('stModal').style.display = 'flex';
  stLoadDetail(1);
}

function stCloseModal() {
  document.getElementById('stModal').style.display = 'none';
  stModalData = [];
}

function stModalSearchFn() {
  clearTimeout(stModalTimer);
  stModalTimer = setTimeout(function(){ stLoadDetail(1); }, 400);
}

function stLoadDetail(page) {
  stModalPage = page || 1;
  var q = document.getElementById('stModalSearch').value.trim();
  var orden = document.getElementById('stModalOrden').value;
  var params = '&tipo=' + stModalType + '&page=' + stModalPage + '&orden=' + orden + '&per_page=' + stModalPerPage;
  if (q) params += '&q=' + encodeURIComponent(q);

  var pv = document.getElementById('stPeriodo').value.split('-');
  params += '&mes=' + pv[0] + '&anio=' + pv[1];

  fetch('/modulo?pagina=Estadisticas&ajax=get_invoices_detail' + params)
  .then(function(r){return r.json()})
  .then(function(d){
    if (!d.success) { document.getElementById('stModalBody').innerHTML = '<div class="st-loading">Error</div>'; return; }
    stModalData = d.data || [];
    var body = document.getElementById('stModalBody');
    var totalEl = document.getElementById('stModalTotal');
    var totalCount = d.total_count || stModalData.length;
    totalEl.textContent = 'Total: $' + (d.total || 0).toFixed(2) + ' (' + totalCount + ' registros)';

    if (!stModalData.length) {
      body.innerHTML = '<div class="st-loading">Sin resultados</div>';
      document.getElementById('stModalPag').innerHTML = '';
      return;
    }

    var h = '';
    stModalData.forEach(function(r){
      h += '<div class="st-inv-row"><div><div style="font-weight:600;color:#1e293b;">' + (r.cliente_nombre || 'N/A') + '</div><div style="font-size:0.75rem;color:#94a3b8;">' + (r.plan_nombre || r.estado_legible || '') + '</div></div><div style="text-align:right;"><div style="font-weight:700;color:#059669;">$' + parseFloat(r.monto || 0).toFixed(2) + '</div><div style="font-size:0.72rem;color:#64748b;">' + (r.fecha_pago ? new Date(r.fecha_pago).toLocaleDateString('es-DO') : r.created_at ? new Date(r.created_at).toLocaleDateString('es-DO') : '') + '</div></div></div>';
    });
    body.innerHTML = h;

    // Pagination
    var totalPages = d.pages || d.total_pages || 1;
    var pag = '<button class="st-pag-btn" onclick="stLoadDetail(' + (stModalPage-1) + ')" ' + (stModalPage <= 1 ? 'disabled' : '') + '>‹</button>';
    for (var p = 1; p <= totalPages && p <= 10; p++) {
      pag += '<button class="st-pag-btn' + (p === stModalPage ? ' st-pag-active' : '') + '" onclick="stLoadDetail(' + p + ')">' + p + '</button>';
    }
    pag += '<button class="st-pag-btn" onclick="stLoadDetail(' + (stModalPage+1) + ')" ' + (stModalPage >= totalPages ? 'disabled' : '') + '>›</button>';
    document.getElementById('stModalPag').innerHTML = pag;
  });
}

stLoad();
</script>
