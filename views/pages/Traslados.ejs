<style>
/* ====== Traslados - DomISP style ====== */
.tr-wrapper { max-width: 750px; margin: 0 auto; }
.tr-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 28px; }
.tr-section-title { font-size: 0.95rem; font-weight: 700; color: #2563eb; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
.tr-label { font-size: 0.85rem; font-weight: 600; color: #334155; margin-bottom: 5px; display: block; }
.tr-input, .tr-select { width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.88rem; transition: border-color 0.15s; box-sizing: border-box; background: #fff; }
.tr-input:focus, .tr-select:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.1); }

.tr-svc-card { border: 2px solid #e2e8f0; border-radius: 8px; padding: 12px 16px; margin-bottom: 8px; cursor: pointer; transition: all 0.15s; display: flex; align-items: center; gap: 12px; }
.tr-svc-card:hover { border-color: #7c3aed; background: #faf5ff; }
.tr-svc-card.selected { border-color: #7c3aed; background: #f5f3ff; }
.tr-svc-badge { font-size: 0.7rem; padding: 2px 8px; border-radius: 12px; font-weight: 700; }
.tr-svc-active { background: #dcfce7; color: #166534; }
.tr-svc-suspended { background: #fee2e2; color: #991b1b; }

.client-result-item { padding: 14px 16px; cursor: pointer; border-bottom: 1px solid #f1f5f9; }
.client-result-item:hover { background: #faf5ff; }
.client-result-item:last-child { border-bottom: none; }

.tr-btn { padding: 10px 22px; border-radius: 8px; border: none; font-size: 0.88rem; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 7px; transition: all 0.15s; }
.tr-btn-primary { background: #7c3aed; color: #fff; }
.tr-btn-primary:hover { background: #6d28d9; }
.tr-btn-secondary { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; }
.tr-btn-secondary:hover { background: #e2e8f0; }
.tr-btn-success { background: #16a34a; color: #fff; }
.tr-btn-success:hover { background: #15803d; }

.tr-cliente-info { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 12px 16px; margin-bottom: 18px; }

/* Modals */
.tr-modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 99999; display: none; align-items: center; justify-content: center; backdrop-filter: blur(2px); }
.tr-modal { background: #fff; width: 90%; max-width: 420px; border-radius: 12px; padding: 28px; text-align: center; box-shadow: 0 15px 30px rgba(0,0,0,0.2); }
.tr-modal-success { border-top: 4px solid #16a34a; }
.tr-modal-warning { border-top: 4px solid #f59e0b; }

.tr-search-wrapper { position: relative; }
.tr-search-results { display: none; position: fixed; background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; max-height: 340px; overflow-y: auto; z-index: 99990; box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
</style>

<div class="tr-wrapper">
  <div class="page-header">
    <h2 class="page-title" style="font-size:1.1rem;"><i class="fas fa-truck-moving" style="color:#7c3aed;"></i> Traslado de Servicio</h2>
  </div>

  <div class="tr-card">
    <!-- BUSCAR CLIENTE -->
    <h4 class="tr-section-title"><i class="fas fa-search"></i> Buscar Cliente</h4>
    <div class="tr-search-wrapper">
      <input type="text" id="trSearch" class="tr-input" placeholder="Nombre, apodo, cédula o NIC..." autocomplete="off" oninput="trSearchInput()" style="padding-right:38px;">
      <i class="fas fa-search" style="position:absolute; right:12px; top:11px; color:#94a3b8; pointer-events:none;"></i>
    </div>

    <!-- Info cliente seleccionado -->
    <div id="trClienteInfo" class="tr-cliente-info" style="display:none;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
          <div style="font-weight:700; color:#166534; font-size:0.95rem;" id="trClienteNombre"></div>
          <div style="font-size:0.8rem; color:#64748b; margin-top:2px;" id="trClienteDetalle"></div>
        </div>
        <button onclick="trLimpiar()" style="background:none; border:none; color:#94a3b8; cursor:pointer; font-size:1.1rem;" title="Cambiar cliente"><i class="fas fa-times"></i></button>
      </div>
    </div>

    <!-- SERVICIOS -->
    <div id="trServiciosBox" style="display:none; margin-bottom:20px;">
      <h4 style="font-size:0.9rem; font-weight:700; color:#475569; margin-bottom:10px;"><i class="fas fa-wifi"></i> Seleccionar Servicio a Trasladar</h4>
      <div id="trServiciosList"></div>
    </div>

    <!-- FORMULARIO TRASLADO -->
    <div id="trFormBox" style="display:none;">
      <input type="hidden" id="trClienteId" value="">
      <input type="hidden" id="trServiceId" value="">

      <h4 class="tr-section-title" style="margin-top:20px;"><i class="fas fa-map-marker-alt"></i> Datos del Traslado</h4>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
        <div>
          <label class="tr-label">Zona Nueva <span style="color:red;">*</span></label>
          <select id="trZona" class="tr-select" required>
            <option value="">-- Seleccionar zona --</option>
            <% (zonas || []).forEach(function(z) { %>
            <option value="<%= z.id %>"><%= z.nombre %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="tr-label">Costo de Traslado</label>
          <input type="number" id="trPrecio" class="tr-input" value="500" step="0.01" min="0" placeholder="0.00">
        </div>
      </div>

      <div class="form-group" style="margin-top:14px;">
        <label class="tr-label">Dirección Nueva <span style="color:red;">*</span></label>
        <input type="text" id="trDireccion" class="tr-input" placeholder="Calle, número, referencia..." required>
      </div>

      <div class="form-group" style="margin-top:14px;">
        <label class="tr-label">Observaciones</label>
        <input type="text" id="trObservaciones" class="tr-input" placeholder="Observaciones opcionales...">
      </div>

      <div style="text-align:right; margin-top:24px; display:flex; gap:10px; justify-content:flex-end;">
        <button type="button" onclick="trLimpiar()" class="tr-btn tr-btn-secondary"><i class="fas fa-arrow-left"></i> Cancelar</button>
        <button type="button" id="btnTrasladar" onclick="trEnviar()" class="tr-btn tr-btn-primary"><i class="fas fa-truck-moving"></i> Trasladar</button>
      </div>
    </div>
  </div>
</div>

<!-- Dropdown búsqueda -->
<div id="trSearchResults" class="tr-search-results"></div>

<!-- MODAL: Costo de Traslado -->
<div id="trModal" class="tr-modal-overlay">
  <div class="tr-modal tr-modal-warning">
    <div style="font-size:2.5rem; color:#f59e0b; margin-bottom:10px;"><i class="fas fa-truck-moving"></i></div>
    <div style="font-size:1.05rem; font-weight:700; color:#1e293b; margin-bottom:6px;">Costo de Traslado</div>
    <div style="color:#64748b; margin-bottom:6px; font-size:0.85rem;">Este traslado tiene un costo de</div>
    <div style="font-size:1.6rem; font-weight:800; color:#7c3aed; margin-bottom:14px;" id="trModalPrecio">$0.00</div>
    <div style="font-size:0.85rem; color:#475569; margin-bottom:16px;">¿El cliente pagará ahora?</div>
    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
      <button onclick="trAgregarFactura()" class="tr-btn tr-btn-secondary" style="font-size:0.82rem;"><i class="fas fa-file-invoice"></i> No, agregar a factura</button>
      <button onclick="trPagarAhora()" class="tr-btn tr-btn-success" style="font-size:0.82rem;"><i class="fas fa-money-bill"></i> Sí, pagar ahora</button>
    </div>
    <div style="margin-top:16px; font-size:0.75rem; color:#94a3b8;">
      <i class="fas fa-info-circle"></i> Puede cambiar el costo antes de continuar
    </div>
  </div>
</div>

<!-- MODAL: Confirmar Pago -->
<div id="trPagoModal" class="tr-modal-overlay">
  <div class="tr-modal" style="border-top:4px solid #16a34a;">
    <div style="font-size:2.5rem; color:#16a34a; margin-bottom:10px;"><i class="fas fa-money-bill-wave"></i></div>
    <div style="font-size:1.05rem; font-weight:700; color:#1e293b; margin-bottom:6px;">Confirmar Pago de Traslado</div>
    <div style="color:#64748b; margin-bottom:4px; font-size:0.85rem;">Monto a cobrar:</div>
    <div style="font-size:1.6rem; font-weight:800; color:#16a34a; margin-bottom:18px;" id="trPagoMonto">$0.00</div>
    <div style="display:flex; gap:10px; justify-content:center;">
      <button onclick="document.getElementById('trPagoModal').style.display='none'" class="tr-btn tr-btn-secondary">Cancelar</button>
      <button id="btnTrConfPago" onclick="trConfirmarPago()" class="tr-btn tr-btn-success"><i class="fas fa-check"></i> Confirmar Pago</button>
    </div>
  </div>
</div>

<!-- MODAL: Resultado -->
<div id="trResultModal" class="tr-modal-overlay">
  <div class="tr-modal tr-modal-success">
    <div style="font-size:3rem; color:#16a34a; margin-bottom:10px;"><i class="fas fa-check-circle"></i></div>
    <div style="font-size:1.1rem; font-weight:700; color:#1e293b; margin-bottom:8px;">Traslado Registrado</div>
    <div style="color:#475569; margin-bottom:22px; font-size:0.88rem;">La orden de traslado fue creada exitosamente.</div>
    <div style="display:flex; gap:10px; justify-content:center;">
      <button onclick="trResultCerrar()" class="tr-btn tr-btn-secondary">Cerrar</button>
      <button onclick="window.location.href='/modulo?pagina=Ordenes'" class="tr-btn tr-btn-success"><i class="fas fa-clipboard-list"></i> Ir a Órdenes</button>
    </div>
  </div>
</div>

<script>
let trSearchTimer = null;
let trResuelta = false;

function escH(s) { if (!s) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

function trSearchInput() {
  clearTimeout(trSearchTimer);
  const q = document.getElementById('trSearch').value.trim();
  if (q.length < 2) { document.getElementById('trSearchResults').style.display = 'none'; return; }
  trSearchTimer = setTimeout(function() { trBuscar(q); }, 300);
}

function trBuscar(q) {
  const input = document.getElementById('trSearch');
  const box   = document.getElementById('trSearchResults');
  const rect  = input.getBoundingClientRect();
  box.style.top    = (rect.bottom + 4) + 'px';
  box.style.left   = rect.left + 'px';
  box.style.width  = rect.width + 'px';
  box.innerHTML = '<div style="padding:14px; color:#94a3b8; font-size:0.88rem;"><i class="fas fa-spinner fa-spin"></i> Buscando...</div>';
  box.style.display = 'block';

  fetch('/api/traslados/buscar-cliente?q=' + encodeURIComponent(q))
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (!data.length) {
      box.innerHTML = '<div style="padding:14px; color:#94a3b8; font-size:0.88rem;">Sin resultados</div>';
      return;
    }
    box.innerHTML = data.map(function(c) {
      return '<div class="client-result-item" onclick="trSeleccionarCliente(' + c.id + ', \'' + escH(c.name).replace(/'/g,"\\'") + '\', \'' + escH(c.cedula).replace(/'/g,"\\'") + '\', \'' + escH(c.phone).replace(/'/g,"\\'") + '\')">' +
        '<div style="font-weight:600; color:#1e293b; font-size:0.95rem;">' + escH(c.name) + '</div>' +
        '<div style="font-size:0.82rem; color:#64748b; margin-top:3px;">' +
        (c.cedula ? 'Céd: ' + escH(c.cedula) + ' &nbsp;' : '') +
        (c.phone ? 'Tel: ' + escH(c.phone) : '') +
        (c.nics ? ' &nbsp;NIC: ' + escH(c.nics) : '') +
        ' &nbsp;<span style="color:#7c3aed; font-weight:600;">' + c.service_count + ' servicio(s)</span>' +
        '</div></div>';
    }).join('');
  })
  .catch(function() { box.innerHTML = '<div style="padding:14px; color:#ef4444; font-size:0.88rem;">Error al buscar</div>'; });
}

function trSeleccionarCliente(id, nombre, cedula, phone) {
  document.getElementById('trSearchResults').style.display = 'none';
  document.getElementById('trSearch').value = nombre;
  document.getElementById('trClienteId').value = id;
  document.getElementById('trClienteNombre').textContent = nombre;
  document.getElementById('trClienteDetalle').textContent = [cedula ? 'Céd: ' + cedula : '', phone ? 'Tel: ' + phone : ''].filter(Boolean).join('  ·  ');
  document.getElementById('trClienteInfo').style.display = 'block';
  trCargarServicios(id);
}

function trCargarServicios(clientId) {
  const list = document.getElementById('trServiciosList');
  list.innerHTML = '<div style="padding:10px; color:#94a3b8; font-size:0.85rem;"><i class="fas fa-spinner fa-spin"></i> Cargando servicios...</div>';
  document.getElementById('trServiciosBox').style.display = 'block';
  document.getElementById('trFormBox').style.display = 'none';
  document.getElementById('trPrecio').value = 500;

  fetch('/api/traslados/servicios/' + clientId)
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.status !== 'success' || !d.data.length) {
      list.innerHTML = '<div style="padding:12px; color:#ef4444; font-size:0.85rem;"><i class="fas fa-exclamation-circle"></i> Este cliente no tiene servicios activos o suspendidos.</div>';
      return;
    }
    list.innerHTML = d.data.map(function(s) {
      var badgeClass = s.status === 'active' ? 'tr-svc-active' : 'tr-svc-suspended';
      var badgeText  = s.status === 'active' ? 'Activo' : 'Suspendido';
      return '<div class="tr-svc-card" onclick="trSeleccionarServicio(' + s.id + ', this)">' +
        '<div style="flex:1;">' +
        '<div style="font-weight:700; color:#334155; font-size:0.92rem;">' + escH(s.plan_name || 'Sin plan') +
        '<span class="tr-svc-badge ' + badgeClass + '" style="margin-left:6px;">' + badgeText + '</span></div>' +
        '<div style="font-size:0.8rem; color:#64748b; margin-top:2px;">' +
        (s.zona_nombre ? '<i class="fas fa-map-marker-alt"></i> ' + escH(s.zona_nombre) + ' &nbsp;' : '') +
        (s.address ? escH(s.address) : 'Sin dirección') +
        '</div></div>' +
        '<i class="fas fa-chevron-right" style="color:#c4b5fd;"></i></div>';
    }).join('');
  })
  .catch(function() { list.innerHTML = '<div style="padding:12px; color:#ef4444; font-size:0.85rem;">Error al cargar servicios.</div>'; });
}

function trSeleccionarServicio(serviceId, el) {
  document.querySelectorAll('.tr-svc-card').forEach(function(c) { c.classList.remove('selected'); });
  el.classList.add('selected');
  document.getElementById('trServiceId').value = serviceId;
  document.getElementById('trFormBox').style.display = 'block';
  document.getElementById('trPrecio').focus();
  document.getElementById('trFormBox').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function trLimpiar() {
  document.getElementById('trSearch').value = '';
  document.getElementById('trClienteId').value = '';
  document.getElementById('trServiceId').value = '';
  document.getElementById('trClienteInfo').style.display = 'none';
  document.getElementById('trServiciosBox').style.display = 'none';
  document.getElementById('trFormBox').style.display = 'none';
  document.getElementById('trZona').value = '';
  document.getElementById('trDireccion').value = '';
  document.getElementById('trObservaciones').value = '';
  document.getElementById('trPrecio').value = 500;
  trResuelta = false;
}

function trEnviar() {
  const zona     = document.getElementById('trZona').value;
  const direccion = document.getElementById('trDireccion').value.trim();
  const clientId  = document.getElementById('trClienteId').value;
  const serviceId = document.getElementById('trServiceId').value;
  const precio    = parseFloat(document.getElementById('trPrecio').value) || 0;

  if (!clientId)   { trToast('Seleccione un cliente', 'error'); return; }
  if (!serviceId)  { trToast('Seleccione un servicio', 'error'); return; }
  if (!zona)       { trToast('La zona nueva es obligatoria', 'error'); return; }
  if (!direccion)  { trToast('La dirección nueva es obligatoria', 'error'); return; }

  // Si tiene costo, mostrar modal de pago
  if (precio > 0 && !trResuelta) {
    document.getElementById('trModalPrecio').textContent = '$' + precio.toFixed(2);
    document.getElementById('trModal').style.display = 'flex';
    return;
  }

  trGuardarOrden();
}

function trPagarAhora() {
  document.getElementById('trModal').style.display = 'none';
  document.getElementById('trPagoMonto').textContent = '$' + (parseFloat(document.getElementById('trPrecio').value) || 0).toFixed(2);
  document.getElementById('trPagoModal').style.display = 'flex';
}

function trAgregarFactura() {
  document.getElementById('trModal').style.display = 'none';
  trResuelta = true;
  trGuardarOrden();
}

function trConfirmarPago() {
  var btn = document.getElementById('btnTrConfPago');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';
  trResuelta = true;
  document.getElementById('trPagoModal').style.display = 'none';
  trGuardarOrden();
}

function trGuardarOrden() {
  var btn = document.getElementById('btnTrasladar');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Registrando...';

  var precio = parseFloat(document.getElementById('trPrecio').value) || 0;
  var esPagada = document.getElementById('trPagoModal').style.display === 'none' && trResuelta && precio > 0;

  fetch('/api/traslados/guardar', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      client_id: parseInt(document.getElementById('trClienteId').value),
      service_id: parseInt(document.getElementById('trServiceId').value),
      sector_id: parseInt(document.getElementById('trZona').value),
      address: document.getElementById('trDireccion').value.trim(),
      observations: document.getElementById('trObservaciones').value.trim(),
      crear_factura: trResuelta && precio > 0 ? 1 : 0,
      precio_traslado: precio,
      traslado_pagada: esPagada ? 1 : 0
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-truck-moving"></i> Trasladar';
    if (d.status === 'success') {
      document.getElementById('trResultModal').style.display = 'flex';
    } else {
      trToast(d.msg || 'Error al registrar traslado', 'error');
    }
  })
  .catch(function(err) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-truck-moving"></i> Trasladar';
    trToast('Error de red: ' + err.message, 'error');
  });
}

function trResultCerrar() {
  document.getElementById('trResultModal').style.display = 'none';
  trLimpiar();
}

function trToast(msg, type) {
  var t = document.createElement('div');
  t.style.cssText = 'position:fixed;top:20px;right:20px;z-index:99999;padding:12px 20px;border-radius:8px;font-size:0.88rem;font-weight:600;color:#fff;box-shadow:0 4px 15px rgba(0,0,0,0.15);display:flex;align-items:center;gap:8px;';
  t.style.background = type === 'success' ? '#16a34a' : '#dc2626';
  t.innerHTML = '<i class="fas fa-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + '"></i> ' + msg;
  document.body.appendChild(t);
  setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(function() { t.remove(); }, 300); }, 3000);
}

// Cerrar dropdown al hacer click fuera
document.addEventListener('click', function(e) {
  if (!document.getElementById('trSearch').contains(e.target) &&
      !document.getElementById('trSearchResults').contains(e.target)) {
    document.getElementById('trSearchResults').style.display = 'none';
  }
});

window.addEventListener('scroll', function() {
  var box = document.getElementById('trSearchResults');
  if (box.style.display === 'none') return;
  var input = document.getElementById('trSearch');
  var rect  = input.getBoundingClientRect();
  box.style.top  = (rect.bottom + 4) + 'px';
  box.style.left = rect.left + 'px';
}, true);
</script>
