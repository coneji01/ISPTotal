<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>VPN & TR069 - System Config</title>
    <link rel="stylesheet" href="/public/css/bootstrap.min.css">
    <link rel="stylesheet" href="/public/css/font-awesome.min.css">
    <link rel="stylesheet" href="/public/css/styles.css">
    <script src="/public/js/jquery.min.js"></script>
    <script src="/public/js/bootstrap.min.js"></script>
</head>
<body>

<div class="container-fluid">
    <h1 class="page-header">VPN & TR069</h1>

    <!-- ======================== -->
    <!-- SECTION 1: VPN Profiles  -->
    <!-- ======================== -->
    <div class="panel panel-default">
        <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-lock"></i> VPN Profiles</h3>
        </div>
        <div class="panel-body">
            <div class="table-responsive">
                <table class="table table-striped table-bordered" id="vpnTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Server</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Main Office</td>
                            <td>OpenVPN</td>
                            <td>vpn.example.com:1194</td>
                            <td><span class="label label-success">Connected</span></td>
                            <td>
                                <button class="btn btn-danger btn-sm btn-disconnect">Disconnect</button>
                                <button class="btn btn-danger btn-sm btn-delete-vpn">Delete</button>
                            </td>
                        </tr>
                        <tr>
                            <td>Backup Site</td>
                            <td>WireGuard</td>
                            <td>backup.example.com:51820</td>
                            <td><span class="label label-default">Disconnected</span></td>
                            <td>
                                <button class="btn btn-success btn-sm btn-connect">Connect</button>
                                <button class="btn btn-danger btn-sm btn-delete-vpn">Delete</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <button class="btn btn-primary" id="btnAddVPN"><i class="fa fa-plus"></i> Add VPN Profile</button>
        </div>
    </div>

    <!-- ========================== -->
    <!-- SECTION 2: TR069 Settings  -->
    <!-- ========================== -->
    <div class="panel panel-default">
        <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-cogs"></i> TR069 Settings</h3>
        </div>
        <div class="panel-body">
            <form id="tr069Form" class="form-horizontal">
                <div class="form-group">
                    <div class="col-sm-offset-2 col-sm-10">
                        <div class="checkbox">
                            <label>
                                <input type="checkbox" id="enableTR069" checked> Enable TR069
                            </label>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="mgmtVlan" class="col-sm-2 control-label">Management VLAN</label>
                    <div class="col-sm-4">
                        <select id="mgmtVlan" class="form-control">
                            <option value="">-- Select VLAN --</option>
                            <option value="1">1 (Default)</option>
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="100" selected>100</option>
                            <option value="200">200</option>
                            <option value="300">300</option>
                            <option value="400">400</option>
                            <option value="500">500</option>
                            <option value="999">999</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="acsUrl" class="col-sm-2 control-label">ACS URL</label>
                    <div class="col-sm-6">
                        <input type="text" class="form-control" id="acsUrl" value="http://10.69.69.1:14501/" placeholder="http://acs.example.com:8080/">
                    </div>
                </div>
                <div class="form-group">
                    <label for="acsUsername" class="col-sm-2 control-label">ACS Username</label>
                    <div class="col-sm-4">
                        <input type="text" class="form-control" id="acsUsername" value="admin" placeholder="Username">
                    </div>
                </div>
                <div class="form-group">
                    <label for="acsPassword" class="col-sm-2 control-label">ACS Password</label>
                    <div class="col-sm-4">
                        <input type="password" class="form-control" id="acsPassword" value="password123" placeholder="Password">
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-sm-offset-2 col-sm-10">
                        <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- ================================ -->
    <!-- SECTION 3: Management IP Pool     -->
    <!-- ================================ -->
    <div class="panel panel-default">
        <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-globe"></i> Management IP Pool</h3>
        </div>
        <div class="panel-body">
            <div class="table-responsive">
                <table class="table table-striped table-bordered" id="ipPoolTable">
                    <thead>
                        <tr>
                            <th>Start IP</th>
                            <th>End IP</th>
                            <th>Netmask</th>
                            <th>VLAN</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>10.0.0.10</td>
                            <td>10.0.0.100</td>
                            <td>255.255.255.0</td>
                            <td>100</td>
                            <td><button class="btn btn-danger btn-sm btn-delete-pool">Delete</button></td>
                        </tr>
                        <tr>
                            <td>192.168.10.20</td>
                            <td>192.168.10.200</td>
                            <td>255.255.255.0</td>
                            <td>200</td>
                            <td><button class="btn btn-danger btn-sm btn-delete-pool">Delete</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <button class="btn btn-primary" id="btnAddRange"><i class="fa fa-plus"></i> Add Range</button>
        </div>
    </div>
</div>

<!-- ====================== -->
<!-- MODAL: Add VPN Profile -->
<!-- ====================== -->
<div class="modal fade" id="addVpnModal" tabindex="-1" role="dialog" aria-labelledby="addVpnModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="addVpnModalLabel">Add VPN Profile</h4>
            </div>
            <div class="modal-body">
                <form id="addVpnForm" class="form-horizontal">
                    <div class="form-group">
                        <label for="vpnName" class="col-sm-3 control-label">Name</label>
                        <div class="col-sm-7">
                            <input type="text" class="form-control" id="vpnName" placeholder="Profile name">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="vpnType" class="col-sm-3 control-label">Type</label>
                        <div class="col-sm-7">
                            <select id="vpnType" class="form-control">
                                <option value="openvpn">OpenVPN</option>
                                <option value="wireguard">WireGuard</option>
                                <option value="ipsec">IPsec</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="vpnServer" class="col-sm-3 control-label">Server</label>
                        <div class="col-sm-7">
                            <input type="text" class="form-control" id="vpnServer" placeholder="server.example.com:1194">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="vpnCert" class="col-sm-3 control-label">Certificate / Key</label>
                        <div class="col-sm-7">
                            <textarea class="form-control" id="vpnCert" rows="4" placeholder="Paste certificate or key here..."></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveVpnProfile"><i class="fa fa-save"></i> Save Profile</button>
            </div>
        </div>
    </div>
</div>

<!-- ======================== -->
<!-- MODAL: Add IP Range      -->
<!-- ======================== -->
<div class="modal fade" id="addRangeModal" tabindex="-1" role="dialog" aria-labelledby="addRangeModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="addRangeModalLabel">Add IP Range</h4>
            </div>
            <div class="modal-body">
                <form id="addRangeForm" class="form-horizontal">
                    <div class="form-group">
                        <label for="rangeStartIp" class="col-sm-3 control-label">Start IP</label>
                        <div class="col-sm-7">
                            <input type="text" class="form-control" id="rangeStartIp" placeholder="e.g. 10.0.0.10">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="rangeEndIp" class="col-sm-3 control-label">End IP</label>
                        <div class="col-sm-7">
                            <input type="text" class="form-control" id="rangeEndIp" placeholder="e.g. 10.0.0.100">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="rangeNetmask" class="col-sm-3 control-label">Netmask</label>
                        <div class="col-sm-7">
                            <input type="text" class="form-control" id="rangeNetmask" placeholder="e.g. 255.255.255.0">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="rangeVlan" class="col-sm-3 control-label">VLAN</label>
                        <div class="col-sm-7">
                            <input type="number" class="form-control" id="rangeVlan" placeholder="e.g. 100" min="1" max="4094">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveIpRange"><i class="fa fa-save"></i> Add Range</button>
            </div>
        </div>
    </div>
</div>

<!-- ========================== -->
<!-- JavaScript                 -->
<!-- ========================== -->
<script>
$(document).ready(function() {

    // ---- Add VPN Profile modal ----
    $('#btnAddVPN').on('click', function() {
        $('#addVpnModal').modal('show');
    });

    $('#saveVpnProfile').on('click', function() {
        var name = $('#vpnName').val().trim();
        var type = $('#vpnType').val();
        var server = $('#vpnServer').val().trim();

        if (!name || !server) {
            alert('Please fill in Name and Server fields.');
            return;
        }

        // Add row to the table
        var newRow = '<tr>' +
            '<td>' + escapeHtml(name) + '</td>' +
            '<td>' + escapeHtml(type) + '</td>' +
            '<td>' + escapeHtml(server) + '</td>' +
            '<td><span class="label label-default">Disconnected</span></td>' +
            '<td>' +
                '<button class="btn btn-success btn-sm btn-connect">Connect</button> ' +
                '<button class="btn btn-danger btn-sm btn-delete-vpn">Delete</button>' +
            '</td>' +
            '</tr>';

        $('#vpnTable tbody').append(newRow);

        // Reset and close
        $('#addVpnForm')[0].reset();
        $('#addVpnModal').modal('hide');
    });

    // ---- Add IP Range modal ----
    $('#btnAddRange').on('click', function() {
        $('#addRangeModal').modal('show');
    });

    $('#saveIpRange').on('click', function() {
        var startIp = $('#rangeStartIp').val().trim();
        var endIp = $('#rangeEndIp').val().trim();
        var netmask = $('#rangeNetmask').val().trim();
        var vlan = $('#rangeVlan').val().trim();

        if (!startIp || !endIp || !netmask || !vlan) {
            alert('Please fill in all fields.');
            return;
        }

        // Add row to the IP pool table
        var newRow = '<tr>' +
            '<td>' + escapeHtml(startIp) + '</td>' +
            '<td>' + escapeHtml(endIp) + '</td>' +
            '<td>' + escapeHtml(netmask) + '</td>' +
            '<td>' + escapeHtml(vlan) + '</td>' +
            '<td><button class="btn btn-danger btn-sm btn-delete-pool">Delete</button></td>' +
            '</tr>';

        $('#ipPoolTable tbody').append(newRow);

        // Reset and close
        $('#addRangeForm')[0].reset();
        $('#addRangeModal').modal('hide');
    });

    // ---- Delete VPN row ----
    $(document).on('click', '.btn-delete-vpn', function() {
        if (confirm('Delete this VPN profile?')) {
            $(this).closest('tr').remove();
        }
    });

    // ---- Connect/Disconnect VPN ----
    $(document).on('click', '.btn-connect', function() {
        var $td = $(this).closest('tr').find('td').eq(3);
        $td.html('<span class="label label-success">Connected</span>');
        $(this).removeClass('btn-success btn-connect').addClass('btn-danger btn-disconnect').text('Disconnect');
    });

    $(document).on('click', '.btn-disconnect', function() {
        var $td = $(this).closest('tr').find('td').eq(3);
        $td.html('<span class="label label-default">Disconnected</span>');
        $(this).removeClass('btn-danger btn-disconnect').addClass('btn-success btn-connect').text('Connect');
    });

    // ---- Delete IP pool row ----
    $(document).on('click', '.btn-delete-pool', function() {
        if (confirm('Delete this IP range?')) {
            $(this).closest('tr').remove();
        }
    });

    // ---- TR069 Save ----
    $('#tr069Form').on('submit', function(e) {
        e.preventDefault();
        var data = {
            enable_tr069: $('#enableTR069').is(':checked') ? 1 : 0,
            management_vlan: $('#mgmtVlan').val(),
            acs_url: $('#acsUrl').val().trim(),
            acs_username: $('#acsUsername').val().trim(),
            acs_password: $('#acsPassword').val()
        };
        console.log('Saving TR069 settings:', data);
        alert('TR069 settings saved successfully.');
    });

    // ---- Helper: escape HTML ----
    function escapeHtml(str) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }

});
</script>

</body>
</html>
