<script src="/public/smartolt-files/common.js?v=3.53.0.22"></script>
<script src="/public/smartolt-files/olt_unconfigured.js?v=3.53.0.28"></script>

<script type="text/javascript">
$(document).ready(function() {

	form_data = {
		olt_id: [1],
		pon: "",
	};

	overwriteFormDataFromUrlParameters();

	var multiselectOptions = {
		enableHTML: true,
		buttonClass: '',
		inheritClass: true,
		disableIfEmpty: true,
		enableCaseInsensitiveFiltering: true,
		buttonContainer:'<div class="btn-group input-220"/>',
		nonSelectedText: 'Select OLT(s)',
		numberDisplayed: 2,
		widthSynchronizationMode: 'always',
		buttonTextAlignment: 'left',
		maxHeight: 500,
		includeSelectAllOption: true,
		selectAllText: 'Select All',
		templates: {
			button: '<button type="button" class="multiselect dropdown-toggle overflow-hidden " data-toggle="dropdown"><span class="multiselect-selected-text"></span> <b class="caret"></b></button>',
			li: '<li><a href="#" tabindex="0"><label class="full-width"></label></a></li>',
		},
		zIndex: 10000
	};

	$('#olt').multiselect(multiselectOptions);

	$('.continueAuthButton').click(function(){
		showLoadingOverlay();
	});	

	$('.saveMoveOnuButton').click(function(){
		showLoadingOverlay();
	});	

	initFilterActionsNoSubmit('getUnconfigured');

	initOltUnconfigured("#unconfigured_div", '/onu_authorization/continue_authorize', '/onu/get_unconfigured_for_olt/', '/onu/move_onu/', '/onu/rebuild/');

	var _initialOlts = Array.isArray(form_data['olt_id']) ? form_data['olt_id'] : (form_data['olt_id'] ? [form_data['olt_id']] : []);
	if (_initialOlts.length > 0) {
		// Skip direct call when exactly one OLT + PON are both set: getPonList
		// will call getUnconfigured() after restoring the PON selection.
		if (!(_initialOlts.length === 1 && form_data['pon'])) {
			getUnconfigured();
		}
	} else {
		showSelectOltMessage();
	}

	$(document).on('click', '.toggledisabled', function(event) {
		
		var linkText = $(this).text();
		
		if ($(this).text().includes('Show')) {
			linkText = linkText.replace('Show', 'Hide');
		} else {
			linkText = linkText.replace('Hide', 'Show');
		}

		$(this).text(linkText);

		$(this).closest('div').find('.label-info').closest('tr').toggleClass('hidden');
		event.preventDefault();
	});

	$('#unconfigured_div').on('click', '.onu-type-add', function() {
		var msg = "This ONU type is not defined in SmartOLT database. <a href='/onu_types/add/{onu_type_name}'>Click here</a> or go to Settings -> ONU types and Add this specific model with correct number of ports and capabilities";

		msg = msg.replace("{onu_type_name}", $(this).data('onu-type-name'));

		$.MessageBox(msg);
	});

	// ===========================
	// Apply Preset functionality
	// ===========================
	var currentOnuData = null;
	var selectedPresetId = null;
	var presetsCheckInterval = null;
	var presetsData = {}; // Store preset data for accessing location_name

	$(document).on('click', '.apply-preset-btn', function(e) {
		e.preventDefault();

		// Store ONU data
		currentOnuData = {
			board: $(this).data('board'),
			port: $(this).data('port'),
			sn: $(this).data('sn'),
			ponType: $(this).data('pon-type'),
			onuTypeId: $(this).data('onu-type-id'),
			oltId: $(this).data('olt-id')
		};

		// Reset selected preset and name field
		selectedPresetId = null;
		presetsData = {};
		$('#preset_onu_name').val('');
		$('#preset_name_hint').hide();
		$('#applyPresetBtn').prop('disabled', true);

		// Update modal with ONU info
		$('#preset-modal-sn').text(currentOnuData.sn);
		$('#preset-modal-board').text(currentOnuData.board);
		$('#preset-modal-port').text(currentOnuData.port);

		// Get OLT name from the button's data attribute and display as "ID - Name"
		var oltName = $(this).data('olt-name') || '';
		var oltDisplay = oltName ? currentOnuData.oltId + ' - ' + oltName : 'OLT #' + currentOnuData.oltId;
		$('#preset-modal-olt').text(oltDisplay);

		// Load presets for this OLT and ONU
		loadPresetsForModal(currentOnuData);

		// Show modal
		$('#applyPresetModal').modal('show');

		// Start checking for window focus to reload presets when user comes back
		startPresetsAutoRefresh();
	});

	// When modal is hidden, stop auto-refresh
	$('#applyPresetModal').on('hidden.bs.modal', function() {
		stopPresetsAutoRefresh();
	});

	// Auto-refresh presets when window regains focus
	function startPresetsAutoRefresh() {
		stopPresetsAutoRefresh(); // Clear any existing interval

		$(window).on('focus.presetsRefresh', function() {
			// Only refresh if modal is still open
			if ($('#applyPresetModal').is(':visible') && currentOnuData) {
				console.log('Window regained focus - refreshing presets');
				loadPresetsForModal(currentOnuData);
			}
		});
	}

	function stopPresetsAutoRefresh() {
		$(window).off('focus.presetsRefresh');
		if (presetsCheckInterval) {
			clearInterval(presetsCheckInterval);
			presetsCheckInterval = null;
		}
	}

	function loadPresetsForModal(onuData) {
		$('#presetsListContainer').html('<div class="text-center"><i class="fa fa-spinner fa-spin fa-2x"></i><p>Loading presets...</p></div>');

		$.ajax({
			url: '/onu_authorization_presets/get_presets_for_apply',
			type: 'GET',
			data: {
				olt_id: onuData.oltId,
				pon_type: onuData.ponType,
				board: onuData.board,
				port: onuData.port,
				sn: onuData.sn,
				onu_type_id: onuData.onuTypeId
			},
			success: function(response) {
				if (response.presets && response.presets.length > 0) {
					renderPresetsList(response.presets);
				}
				else {
					// Build "Create Preset" URL with pre-filled parameters
					var createUrl = '/onu_authorization_presets/add?olt_id=' + onuData.oltId + '&pon_type=' + onuData.ponType;
					if (onuData.board !== null && onuData.board !== undefined && onuData.board !== '') createUrl += '&board=' + onuData.board;
					if (onuData.port !== null && onuData.port !== undefined && onuData.port !== '') createUrl += '&port=' + onuData.port;
					// Add ONU type ID if available (only if it's in SmartOLT database)
					if (currentOnuData.onuTypeId && currentOnuData.onuTypeId !== '0' && currentOnuData.onuTypeId !== 0) {
						createUrl += '&onu_type_id=' + currentOnuData.onuTypeId;
					}
											$('#presetsListContainer').html(
							'<div class="text-center" style="padding: 20px;">' +
							'<p class="text-muted">' +
							'<i class="fa fa-info-circle"></i> No matching presets found for this OLT/Board/Port combination.' +
							'</p>' +
							'<a href="' + createUrl + '" target="_blank" class="btn btn-primary" style="margin-top: 10px;">' +
							'<i class="fa fa-plus"></i> Create New Preset' +
							'</a>' +
							'</div>'
						);
									}
			},
			error: function() {
				$('#presetsListContainer').html('<div class="alert alert-danger"><i class="fa fa-exclamation-triangle"></i> Error loading presets. Please try again.</div>');
			}
		});
	}

	function renderPresetsList(presets) {
		var html = '<h5 style="margin-bottom: 15px; font-weight: 600;"><i class="fa fa-list"></i> Available Presets</h5>';
		html += '<div class="list-group">';

		// Store presets data for later access and find the default preset
		var defaultPresetId = null;
		presets.forEach(function(preset) {
			presetsData[preset.id] = preset;
			if (preset.is_default == 1 || preset.is_default === '1' || preset.is_default === true) {
				defaultPresetId = preset.id;
			}
		});

		presets.forEach(function(preset) {
			var presetSummary = buildPresetSummaryForModal(preset);
			var isDefault = preset.is_default == 1 || preset.is_default === '1' || preset.is_default === true;

			html += '<label class="list-group-item preset-item">';
			html += '<input type="radio" name="preset_selection" value="' + preset.id + '" class="preset-radio"' + (isDefault ? ' checked' : '') + '>';
			html += '<span class="preset-radio-custom"></span>';
			html += '<span class="preset-content">';
			html += '<strong>' + escapeHtml(preset.name) + '</strong>';
			if (isDefault) {
				html += ' <span class="label label-primary"><i class="fa fa-star"></i> Default</span>';
			}
			if (preset.description) {
				html += ' <small class="text-muted">' + escapeHtml(preset.description) + '</small>';
			}
			html += '<div style="margin-top: 5px;">' + presetSummary + '</div>';
			html += '</span>';
			html += '</label>';
		});

		html += '</div>';
		$('#presetsListContainer').html(html);

		// If a default preset was auto-selected and no preset was previously selected, set the selected preset ID
		if (defaultPresetId && !selectedPresetId) {
			selectedPresetId = defaultPresetId;
			$('#applyPresetBtn').prop('disabled', false);
			// Prefill name from default preset
			updateNameFieldFromPreset(defaultPresetId);
		}
	}

	// Update the name field based on selected preset
	function updateNameFieldFromPreset(presetId) {
		var preset = presetsData[presetId];
		if (preset && preset.location_name) {
			$('#preset_onu_name').val(preset.location_name);
			$('#preset_name_hint_text').text('Prefilled from preset pattern: ' + preset.location_name);
			$('#preset_name_hint').show();
		} else {
			// Clear the field when selecting a preset without location_name
			$('#preset_onu_name').val('');
			$('#preset_name_hint').hide();
		}
	}

function buildPresetSummaryForModal(preset) {
		var parts = [];

		// Board/Port
		if (preset.board !== null || preset.port !== null) {
			var locationParts = [];
			if (preset.board !== null) locationParts.push('Board ' + preset.board);
			if (preset.port !== null) locationParts.push('Port ' + preset.port);
			parts.push('<div><strong>Board/Port:</strong> ' + locationParts.join(', ') + '</div>');
		}

		// PON Type
		parts.push('<div><strong>PON:</strong> ' + preset.pon_type.toUpperCase() + '</div>');

		// ONU Type
		if (preset.onu_type_name) {
			parts.push('<div><strong>ONU Type:</strong> ' + escapeHtml(preset.onu_type_name) + '</div>');
		} else {
			parts.push('<div><strong>ONU Type:</strong> <em>Auto-detect</em></div>');
		}

		// SN Pattern
		if (preset.sn_pattern) {
			parts.push('<div><strong>SN Pattern:</strong> <code>' + escapeHtml(preset.sn_pattern) + '</code></div>');
		}

		// Fallback ONU Type (when ONU type is auto-detect)
		if (preset.fallback_onu_type_name) {
			parts.push('<div><strong>Fallback ONU Type:</strong> ' + escapeHtml(preset.fallback_onu_type_name) + '</div>');
		}

		// Mode
		var modeLabel = preset.mode === 'Routing' ? '<span class="label label-info">Routing</span>' : '<span class="label label-default">Bridging</span>';
		parts.push('<div><strong>Mode:</strong> ' + modeLabel + '</div>');

		// VLAN
		if (preset.vlan_number) {
			parts.push('<div><strong>VLAN:</strong> ' + preset.vlan_number + '</div>');
		}

		// SVLAN
		if (preset.use_svlan && preset.svlan_number) {
			var svlanInfo = preset.svlan_number;
			if (preset.tag_transform_mode) {
				svlanInfo += ' <small class="text-muted">(' + escapeHtml(preset.tag_transform_mode) + ')</small>';
			}
			parts.push('<div><strong>SVLAN:</strong> ' + svlanInfo + '</div>');

			// Use other-all TLS VLAN
			if (preset.use_other_all_tls_vlan) {
				parts.push('<div><strong>TLS VLAN:</strong> <span class="label label-info">other-all</span></div>');
			}
		}

		// CVLAN
		if (preset.use_cvlan && preset.cvlan_number) {
			parts.push('<div><strong>CVLAN:</strong> ' + preset.cvlan_number + '</div>');
		}

		// Speed profiles
		if (preset.download_speed_name || preset.upload_speed_name) {
			var speeds = [];
			if (preset.download_speed_name) speeds.push('<i class="fa fa-arrow-down text-success"></i> ' + escapeHtml(preset.download_speed_name));
			if (preset.upload_speed_name) speeds.push('<i class="fa fa-arrow-up text-primary"></i> ' + escapeHtml(preset.upload_speed_name));
			parts.push('<div><strong>Speed:</strong> ' + speeds.join(' / ') + '</div>');
		}

		// Zone
		if (preset.zone_name) {
			parts.push('<div><strong>Zone:</strong> ' + escapeHtml(preset.zone_name) + '</div>');
		}

		// ODB
		if (preset.odb_name) {
			var odbInfo = escapeHtml(preset.odb_name);
			if (preset.odb_port) {
				odbInfo += ' <span class="label label-info">Auto-port</span>';
			}
			parts.push('<div><strong>ODB:</strong> ' + odbInfo + '</div>');
		}

		// Name pattern
		if (preset.location_name) {
			var nameDisplay = preset.location_name.length > 30 ? escapeHtml(preset.location_name.substring(0, 30)) + '...' : escapeHtml(preset.location_name);
			var nameTitle = preset.location_name.length > 30 ? ' title="' + escapeHtml(preset.location_name) + '"' : '';
			parts.push('<div><strong>Name:</strong> <code' + nameTitle + '>' + nameDisplay + '</code></div>');
		}

		// Description pattern
		if (preset.description_pattern) {
			var descDisplay = preset.description_pattern.length > 30 ? escapeHtml(preset.description_pattern.substring(0, 30)) + '...' : escapeHtml(preset.description_pattern);
			var descTitle = preset.description_pattern.length > 30 ? ' title="' + escapeHtml(preset.description_pattern) + '"' : '';
			parts.push('<div><strong>Address:</strong> <code' + descTitle + '>' + descDisplay + '</code></div>');
		}

		// TR069 Profile
		if (preset.tr069_profile_name) {
			parts.push('<div><strong>TR069:</strong> ' + escapeHtml(preset.tr069_profile_name) + '</div>');
		}

		// Management IP
		if (preset.mgmt_ip_mode && preset.mgmt_ip_mode !== 'Inactive') {
			var mgmtLabel = preset.mgmt_ip_mode === 'Static'
				? '<span class="label label-success">Static IP</span>'
				: '<span class="label label-info">DHCP</span>';
			var mgmtInfo = mgmtLabel;
			if (preset.mgmt_ip_vlan_number) {
				mgmtInfo += ' <small class="text-muted">(VLAN ' + preset.mgmt_ip_vlan_number + ')</small>';
			}
			parts.push('<div><strong>Mgmt IP:</strong> ' + mgmtInfo + '</div>');
		}

		// WiFi Settings
		if (preset.wifi_config) {
			try {
				var wifiConfig = typeof preset.wifi_config === 'string' ? JSON.parse(preset.wifi_config) : preset.wifi_config;
				if (wifiConfig && wifiConfig.length > 0) {
					var wifiInfo = '<span class="label label-info">Enabled</span>';
					wifiInfo += ' <small class="text-muted">(' + wifiConfig.length + ' port' + (wifiConfig.length !== 1 ? 's' : '') + ')</small>';
					parts.push('<div><strong>WiFi:</strong> ' + wifiInfo + '</div>');

					// Show details for each port
					wifiConfig.forEach(function(port) {
						// Get port name
						var portName = '';
						if (port.wifi_port_id && preset.wifi_ports && preset.wifi_ports[port.wifi_port_id]) {
							portName = preset.wifi_ports[port.wifi_port_id];
						}

						var portDetails = [];
						if (port.ssid) portDetails.push('SSID: ' + escapeHtml(port.ssid));
						if (port.auth_mode) portDetails.push(port.auth_mode.toUpperCase());
						if (port.mode && port.mode !== 'LAN') portDetails.push(port.mode);
						// Add VLAN info
						if (port.vlan_id && preset.wifi_vlans && preset.wifi_vlans[port.vlan_id]) {
							portDetails.push('VLAN: ' + escapeHtml(preset.wifi_vlans[port.vlan_id]));
						} else if (port.vlan_id) {
							portDetails.push('VLAN ID: ' + port.vlan_id);
						}
						// Add Allowed VLANs info
						if (port.extra_vlans && port.extra_vlans.length > 0) {
							var extraVlanNames = [];
							port.extra_vlans.forEach(function(vlanId) {
								if (preset.wifi_vlans && preset.wifi_vlans[vlanId]) {
									extraVlanNames.push(preset.wifi_vlans[vlanId]);
								} else {
									extraVlanNames.push(vlanId);
								}
							});
							if (extraVlanNames.length > 0) {
								portDetails.push('Allowed VLANs: ' + escapeHtml(extraVlanNames.join(', ')));
							}
						}
						if (portDetails.length > 0) {
							var bullet = portName ? '&bull; ' + escapeHtml(portName) + ': ' : '&bull; ';
							parts.push('<div style="margin-left: 15px;"><small class="text-muted">' + bullet + portDetails.join(', ') + '</small></div>');
						}
					});
				}
			} catch (e) {
				// Invalid JSON, skip WiFi
			}
		}

		// Web User/Password
		if (preset.web_user) {
			parts.push('<div><strong>Web User:</strong> ' + escapeHtml(preset.web_user) + '</div>');
		}
		if (preset.web_password) {
			parts.push('<div><strong>Web Pass:</strong> ••••••••</div>');
		}

		return parts.join('');
	}

	// Handle radio button change for preset selection
	$(document).on('change', 'input[name="preset_selection"]', function() {
		selectedPresetId = $(this).val();
		$('#applyPresetBtn').prop('disabled', false);
		// Update name field from selected preset
		updateNameFieldFromPreset(selectedPresetId);
	});

	// Handle Apply button click
	$('#applyPresetBtn').click(function() {
		if (selectedPresetId) {
			applyPresetToOnu(selectedPresetId);
		}
	});

	function applyPresetToOnu(presetId) {
		$('#applyPresetModal').modal('hide');
		showLoadingOverlay();

		// Get name from input field
		var onuName = $('#preset_onu_name').val().trim();

		$.ajax({
			url: '/onu_authorization/authorize_with_preset',
			type: 'POST',
			data: {
				preset_id: presetId,
				board: currentOnuData.board,
				port: currentOnuData.port,
				sn: currentOnuData.sn,
				pon_type: currentOnuData.ponType,
				onu_type_id: currentOnuData.onuTypeId,
				olt_id: currentOnuData.oltId,
				location_name: onuName
			},
			success: function(response) {
				hideLoadingOverlay();

				response = JSON.parse(response);
				if (response.status) {
					toast('ONU authorized successfully with preset');

					// Refresh unconfigured list by triggering the refresh button
					$('#unconfigured_div a.get-unconfigured').trigger('click');
				}
				else {
					toast(response.message || 'Error applying preset');
				}
			},
			error: function() {
				hideLoadingOverlay();
				toast('Error applying preset. Please try again.');
			}
		});
	}

	function escapeHtml(text) {
		if (!text) return '';
		var div = document.createElement('div');
		div.appendChild(document.createTextNode(text));
		return div.innerHTML;
	}

});
</script>

