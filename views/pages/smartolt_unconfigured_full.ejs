						<div style="margin-left: 25px;">
							<div><strong>OLT:</strong> <span id="preset-modal-olt"></span></div>
							<div><strong>Board:</strong> <span id="preset-modal-board"></span></div>
							<div><strong>Port:</strong> <span id="preset-modal-port"></span></div>
							<div><strong>SN:</strong> <span id="preset-modal-sn"></span></div>
							<div style="margin-top: 10px;">
								<strong>Name:</strong> <input type="text" class="form-control form-control-sm input-sm" id="preset_onu_name" placeholder="Enter ONU name" style="display: inline-block; width: 300px; margin-left: 5px;">
								<small class="text-muted" id="preset_name_hint" style="display: none; margin-left: 10px;">
