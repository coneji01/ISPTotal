<script type="text/javascript">
$(document).ready(function() {
    // Adaptive auto-refresh cadence
    var ACTIVE_REFRESH_MS = 10000;   // 10s when there is at least one active task
    var IDLE_REFRESH_MS = 300000;    // 5min when the active-tasks list is empty
    var currentRefreshMs = IDLE_REFRESH_MS;
    var refreshPoller = null;  // SmartOLTPolling controller; pauses on hidden tab

    // Load active tasks asynchronously
    loadActiveTasks();

    // Start auto-refresh
    startAutoRefresh();

    $("#auto-actions").click(function () {
		abortJqxhr();
		display_modal("Auto actions", "/onu/add_task", "auto_actions_form");
	});

    // Stop auto actions button
    $("#stop-auto-actions").click(function () {
        var selectedTaskActions = [];
        $('.task-checkbox:checked').each(function() {
            selectedTaskActions.push($(this).val());
        });

        if (selectedTaskActions.length === 0) {
            $.MessageBox('Please select at least one task action to stop');
            return;
        }

        var confirmMsg = "Are you sure you want to stop {count} task action(s)?";
        confirmMsg = confirmMsg.replace('{count}', selectedTaskActions.length);
        MessageBoxConfirm(confirmMsg).done(function() {
            showLoadingOverlay();

            // Send all task action IDs in one request
            $.ajax({
                type: 'POST',
                url: '/onu/stop_task_actions',
                data: { task_action_ids: selectedTaskActions },
                dataType: 'json',
                success: function(response) {
                    hideLoadingOverlay();
                    toast('Task actions stopped successfully');
                    loadActiveTasks(true);

                    updateStopButtonState();

                    // Open the accordion if not already open
                    if (!$('#tasksList').hasClass('in')) {
                        $('#tasksList').collapse('show');
                    }
                },
                error: function() {
                    hideLoadingOverlay();
                    toast('Error stopping task actions');
                }
            });
        });
    });

    // Select all checkboxes functionality (delegated event)
    $(document).on('change', '#select-all-tasks', function() {
        $('.task-checkbox').prop('checked', $(this).prop('checked'));
        updateStopButtonState();
    });

    // Update stop button state when individual checkboxes change
    $(document).on('change', '.task-checkbox', function() {
        updateStopButtonState();
    });

    // Function to enable/disable stop button based on selected checkboxes
    function updateStopButtonState() {
        var checkedCount = $('.task-checkbox:checked').length;
        $('#stop-auto-actions').prop('disabled', checkedCount === 0);

        // Stop auto-refresh if any checkboxes are checked, otherwise start it
        if (checkedCount > 0) {
            stopAutoRefresh();
        } else {
            startAutoRefresh();
        }
    }

    // Handle Edit button clicks for tasks (delegated event for dynamic content)
    $(document).on('click', 'a[id^="edit_task_"]', function(e) {
        e.preventDefault();

        var taskId = $(this).attr('id').replace('edit_task_', '');

        abortJqxhr();
        display_modal("Task Details", "/onu/update_auto_task/" + taskId, "task_details_form");
    });

    // Stop auto-refresh when modal is shown
    $('#autoActionsModal').on('show.bs.modal', function () {
        stopAutoRefresh();
    });

    // Reload tasks and open accordion when modal is closed
    $('#autoActionsModal').on('hidden.bs.modal', function () {
        // Reload active tasks
        loadActiveTasks(true);

        // Open the accordion if not already open
        if (!$('#tasksList').hasClass('in')) {
            $('#tasksList').collapse('show');
        }

        // Restart auto-refresh after modal is closed
        startAutoRefresh();
    });

    function loadActiveTasks(letSpinnerShowLonger = false) {
        // Only add opacity to existing content instead of replacing it
        $('#active-tasks-container').css('opacity', '0.5');

        if(letSpinnerShowLonger) {
            setTimeout(function() {
                getActiveTasks();
                    }, 500); //wait 500 ms before polling the server, for the loader to display nicely
        }
        else {
            getActiveTasks();
        }
    }

    function getActiveTasks() {
        $.ajax({
                type: 'GET',
                url: '/onu/get_active_tasks_on_unconfigured',
                timeout: 30000,
                success: function(response) {
                    $('#active-tasks-container').html(response).css('opacity', '1');
                    // Init Bootstrap tooltips on freshly-rendered rows
                    $('#active-tasks-container [data-toggle="tooltip"]').tooltip();
                    adjustRefreshCadence();
                },
                error: function() {
                    $('#active-tasks-container').html().css('opacity', '1');
                }
            });
    }

    // Re-evaluate the desired polling cadence based on whether any active
    // tasks are rendered. If the cadence changes and the timer is currently
    // running (i.e. not paused by a checked checkbox or open modal),
    // restart it with the new interval.
    function adjustRefreshCadence() {
        var activeCount = $('#active-tasks-container .task-checkbox').length;
        var desiredMs = activeCount > 0 ? ACTIVE_REFRESH_MS : IDLE_REFRESH_MS;

        // Show the auto-refresh hint only when there are active tasks
        // (matches the cadence — there's nothing to refresh otherwise).
        $('.active-tasks-refresh-hint').toggle(activeCount > 0);

        if (desiredMs !== currentRefreshMs) {
            currentRefreshMs = desiredMs;
            if (refreshPoller) {
                startAutoRefresh();
            }
        }
    }

    function display_modal(title, getUrl, formId) {

		$('#autoActionsModalTitle').html(title);

		$.ajax({
			type: 'GET',
			url: getUrl,
			timeout: 30000,
			success: function(response)
			{
				$('#autoActionsModalContent').html(response);

				// Ensure modal has fade class before showing
				if (!$('#autoActionsModal').hasClass('fade')) {
					$('#autoActionsModal').addClass('fade');
				}

				// Show modal with fade effect
				$('#autoActionsModal').modal('show');
			}
		});
	}

    // Start auto-refresh at the most recently observed cadence.
    // SmartOLTPolling pauses while the tab is hidden.
    function startAutoRefresh() {
        if (refreshPoller) {
            refreshPoller.stop();
        }

        refreshPoller = SmartOLTPolling.register(function () {
            loadActiveTasks(true);
        }, currentRefreshMs);
    }

    function stopAutoRefresh() {
        if (refreshPoller) {
            refreshPoller.stop();
            refreshPoller = null;
        }
    }
});
</script>

