<!DOCTYPE html>
<html>
<head>
  <title>Perfiles y Tipos ONU - ISPTotal</title>
  <style>
    .container { padding: 20px; max-width: 1200px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .header h2 { margin: 0; color: #e2e8f0; font-size: 22px; font-weight: 600; }
    .btn-primary { background: rgba(29,139,255,0.18); color: #8cc8ff; border: 1px solid rgba(29,139,255,0.3); padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .btn-primary:hover { background: rgba(29,139,255,0.3); }
    .btn-danger { background: rgba(220,38,38,0.15); color: #fca5a5; border: 1px solid rgba(220,38,38,0.3); padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 12px; }
    .btn-danger:hover { background: rgba(220,38,38,0.3); }
    .btn-sm { padding: 4px 8px; font-size: 12px; }
    .btn-success { background: rgba(34,197,94,0.15); color: #86efac; border: 1px solid rgba(34,197,94,0.3); padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .btn-success:hover { background: rgba(34,197,94,0.3); }
    table { width: 100%; border-collapse: collapse; background: #0b1528; border-radius: 8px; overflow: hidden; }
    th { background: rgba(255,255,255,0.05); color: #64748b; padding: 10px 12px; text-align: left; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; }
    td { padding: 10px 12px; border-top: 1px solid rgba(255,255,255,0.06); color: #e2e8f0; font-size: 13px; }
    tr:hover td { background: rgba(255,255,255,0.03); }
    .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(6,22,47,0.85); z-index: 1000; }
    .modal-content { background: #0b1528; margin: 10% auto; padding: 25px; border-radius: 12px; max-width: 500px; border: 1px solid rgba(255,255,255,0.08); }
    .modal-content h3 { margin-top: 0; color: #e2e8f0; font-size: 18px; }
    .modal-content label { display: block; color: #64748b; margin-top: 14px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .modal-content input, .modal-content select { width: 100%; padding: 8px 10px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: #e2e8f0; border-radius: 6px; margin-top: 4px; box-sizing: border-box; font-size: 14px; }
    .modal-content input:focus, .modal-content select:focus { border-color: rgba(29,139,255,0.5); outline: none; }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }
    .btn-cancel { background: rgba(255,255,255,0.06); color: #64748b; border: 1px solid rgba(255,255,255,0.1); padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .btn-cancel:hover { background: rgba(255,255,255,0.1); }
    .tab-bar { display: flex; gap: 0; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .tab { padding: 10px 20px; cursor: pointer; color: #64748b; border-bottom: 2px solid transparent; font-size: 13px; font-weight: 500; }
    .tab.active { color: #8cc8ff; border-bottom-color: #8cc8ff; }
    .tab:hover { color: #a9d6ff; }
    .section { display: none; }
    .section.active { display: block; }
    .badge-up { background: rgba(34,197,94,0.15); color: #86efac; padding: 2px 8px; border-radius: 10px; font-size: 11px; }
    .badge-down { background: rgba(29,139,255,0.15); color: #8cc8ff; padding: 2px 8px; border-radius: 10px; font-size: 11px; }
    .sn-prefix { font-family: monospace; background: rgba(255,255,255,0.06); padding: 2px 6px; border-radius: 4px; color: #a9d6ff; }
  </style>
</head>
<body>
<div class="container">
  <div class="tab-bar">
    <div class="tab active" onclick="showTab('profiles')">Speed Profiles</div>
    <div class="tab" onclick="showTab('types')">Tipos de ONU</div>
  </div>

  <!-- Speed Profiles -->
  <div id="section-profiles" class="section active">
    <div class="header">
      <h2>Perfiles de Velocidad</h2>
      <div>
        <button class="btn-success" onclick="syncProfiles()" style="margin-right:8px">Sincronizar a OLT</button>
        <button class="btn-primary" onclick="openProfileModal()">+ Nuevo Perfil</button>
      </div>
    </div>
    <table>
      <thead><tr>
        <th>Nombre</th><th>Tipo</th><th>Velocidad</th><th>Descripción</th><th>Acciones</th>
      </tr></thead>
      <tbody id="profilesTable"></tbody>
    </table>
  </div>

  <!-- ONU Types -->
  <div id="section-types" class="section">
    <div class="header">
      <h2>Tipos de ONU</h2>
      <button class="btn-primary" onclick="openTypeModal()">+ Nuevo Tipo</button>
    </div>
    <table>
      <thead><tr>
        <th>Nombre</th><th>Prefijo SN</th><th>Descripción</th><th>Acciones</th>
      </tr></thead>
      <tbody id="typesTable"></tbody>
    </table>
  </div>
</div>

<!-- Modal Speed Profile -->
<div id="profileModal" class="modal">
  <div class="modal-content">
    <h3 id="profileModalTitle">Nuevo Perfil</h3>
    <label>Nombre</label>
    <input id="profNombre" placeholder="Ej: SMARTOLT-1G-UP">
    <label>Tipo</label>
    <select id="profTipo">
      <option value="up">Subida (UP)</option>
      <option value="down">Bajada (DOWN)</option>
    </select>
    <label>Velocidad</label>
    <input id="profVelocidad" placeholder="Ej: 1G, 500M, 30M">
    <label>Descripción</label>
    <input id="profDesc" placeholder="Opcional">
    <input type="hidden" id="profEditId">
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('profileModal')">Cancelar</button>
      <button class="btn-primary" onclick="saveProfile()">Guardar</button>
    </div>
  </div>
</div>

<!-- Modal ONU Type -->
<div id="typeModal" class="modal">
  <div class="modal-content">
    <h3 id="typeModalTitle">Nuevo Tipo de ONU</h3>
    <label>Nombre del modelo</label>
    <input id="typeNombre" placeholder="Ej: HS8545M5">
    <label>Prefijo SN</label>
    <input id="typePrefix" placeholder="Ej: HWTC (primeros 4 chars del SN)" maxlength="4">
    <label>Descripción</label>
    <input id="typeDesc" placeholder="Opcional">
    <input type="hidden" id="typeEditId">
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('typeModal')">Cancelar</button>
      <button class="btn-primary" onclick="saveType()">Guardar</button>
    </div>
  </div>
</div>

<script>
function showTab(tab) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelector('.tab[onclick*="'+tab+'"]').classList.add('active');
  document.getElementById('section-'+tab).classList.add('active');
}
function closeModal(id) { document.getElementById(id).style.display = 'none'; }
document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', function(e) { if (e.target === this) this.style.display = 'none'; }));

// ========= SPEED PROFILES =========
function openProfileModal(data) {
  document.getElementById('profileModalTitle').textContent = data ? 'Editar Perfil' : 'Nuevo Perfil';
  document.getElementById('profEditId').value = data ? data.id : '';
  document.getElementById('profNombre').value = data ? data.nombre : '';
  document.getElementById('profTipo').value = data ? data.tipo : 'up';
  document.getElementById('profVelocidad').value = data ? data.velocidad : '';
  document.getElementById('profDesc').value = data ? (data.descripcion||'') : '';
  document.getElementById('profileModal').style.display = 'block';
}

function loadProfiles() {
  fetch('/api/speed-profiles/list', { credentials: 'same-origin' })
    .then(r => r.json()).then(d => {
      if (!d.success) return;
      document.getElementById('profilesTable').innerHTML = d.data.map(p =>
        '<tr><td>'+p.nombre+'</td><td><span class="'+(p.tipo==='up'?'badge-up':'badge-down')+'">'+(p.tipo==='up'?'SUBIDA':'BAJADA')+'</span></td><td>'+p.velocidad+'</td><td>'+(p.descripcion||'')+'</td><td><button class="btn-danger btn-sm" onclick="deleteProfile('+p.id+')">Eliminar</button></td></tr>'
      ).join('');
    });
}

function saveProfile() {
  fetch('/api/speed-profiles/save', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      id: document.getElementById('profEditId').value || null,
      nombre: document.getElementById('profNombre').value,
      tipo: document.getElementById('profTipo').value,
      velocidad: document.getElementById('profVelocidad').value,
      descripcion: document.getElementById('profDesc').value
    })}).then(r=>r.json()).then(d => { if(d.success){ closeModal('profileModal'); loadProfiles(); } else alert(d.message); });
}

function deleteProfile(id) {
  if (!confirm('¿Eliminar este perfil?')) return;
  fetch('/api/speed-profiles/delete', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id}) })
    .then(r=>r.json()).then(d => { if(d.success) loadProfiles(); });
}

function syncProfiles() {
  alert('Función de sincronización a OLT próximamente');
}

// ========= ONU TYPES =========
function openTypeModal(data) {
  document.getElementById('typeModalTitle').textContent = data ? 'Editar Tipo' : 'Nuevo Tipo de ONU';
  document.getElementById('typeEditId').value = data ? data.id : '';
  document.getElementById('typeNombre').value = data ? data.nombre : '';
  document.getElementById('typePrefix').value = data ? data.sn_prefix : '';
  document.getElementById('typeDesc').value = data ? (data.descripcion||'') : '';
  document.getElementById('typeModal').style.display = 'block';
}

function loadTypes() {
  fetch('/api/onu-types/list', { credentials: 'same-origin' })
    .then(r => r.json()).then(d => {
      if (!d.success) return;
      document.getElementById('typesTable').innerHTML = d.data.map(t =>
        '<tr><td>'+t.nombre+'</td><td><span class="sn-prefix">'+t.sn_prefix+'</span></td><td>'+(t.descripcion||'')+'</td><td><button class="btn-danger btn-sm" onclick="deleteType('+t.id+')">Eliminar</button></td></tr>'
      ).join('');
    });
}

function saveType() {
  fetch('/api/onu-types/save', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      id: document.getElementById('typeEditId').value || null,
      nombre: document.getElementById('typeNombre').value,
      sn_prefix: document.getElementById('typePrefix').value,
      descripcion: document.getElementById('typeDesc').value
    })}).then(r=>r.json()).then(d => { if(d.success){ closeModal('typeModal'); loadTypes(); } else alert(d.message); });
}

function deleteType(id) {
  if (!confirm('¿Eliminar este tipo de ONU?')) return;
  fetch('/api/onu-types/delete', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id}) })
    .then(r=>r.json()).then(d => { if(d.success) loadTypes(); });
}

// Init
loadProfiles();
loadTypes();
</script>
</body>
</html>
