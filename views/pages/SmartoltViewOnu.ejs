<!--=====================================================================
  SmartoltViewOnu.ejs — SmartOLT-style ONU detail view
  Clone of joelwifi.smartolt.com/onu/view/{id}
======================================================================-->
<style>
  :root {
    --smartolt-bg: #f0f2f5;
    --smartolt-card: #fff;
    --smartolt-primary: #2d8cf0;
    --smartolt-success: #19be6b;
    --smartolt-danger: #ed4014;
    --smartolt-warning: #f90;
    --smartolt-text: #17233d;
    --smartolt-muted: #808695;
    --smartolt-border: #e8eaec;
  }
  * { box-sizing: border-box; }
  body { background: var(--smartolt-bg); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
  .onu-container { max-width: 1200px; margin: 20px auto; padding: 0 15px; }
  .onu-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .onu-header h2 { margin: 0; font-size: 22px; font-weight: 600; color: var(--smartolt-text); }
  .breadcrumb { color: var(--smartolt-muted); font-size: 13px; margin-bottom: 15px; }
  .breadcrumb a { color: var(--smartolt-primary); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .info-card { background: var(--smartolt-card); border-radius: 8px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
  .info-card h3 { font-size: 14px; color: var(--smartolt-muted); margin: 0 0 15px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }
  .info-row { display: flex; padding: 8px 0; border-bottom: 1px solid #f5f7f9; }
  .info-row:last-child { border-bottom: none; }
  .info-label { width: 140px; color: var(--smartolt-muted); font-size: 13px; flex-shrink: 0; }
  .info-value { flex: 1; color: var(--smartolt-text); font-size: 13px; font-weight: 500; }
  .info-value a { color: var(--smartolt-primary); text-decoration: none; }
  .info-value a:hover { text-decoration: underline; }

  .status-badge { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 4px; font-size: 12px; font-weight: 600; }
  .status-online { background: #f0fff4; color: var(--smartolt-success); border: 1px solid #b7eb8f; }
  .status-offline { background: #fff1f0; color: var(--smartolt-danger); border: 1px solid #ffa39e; }
  .status-warning { background: #fffbe6; color: var(--smartolt-warning); border: 1px solid #ffe58f; }

  .actions-bar { display: flex; gap: 10px; flex-wrap: wrap; margin: 20px 0; }
  .actions-bar .btn { padding: 6px 16px; border-radius: 4px; font-size: 13px; cursor: pointer; border: 1px solid var(--smartolt-border); background: var(--smartolt-card); color: var(--smartolt-text); transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
  .actions-bar .btn:hover { border-color: var(--smartolt-primary); color: var(--smartolt-primary); }
  .actions-bar .btn-danger { color: var(--smartolt-danger); border-color: var(--smartolt-danger); }
  .actions-bar .btn-danger:hover { background: var(--smartolt-danger); color: #fff; }
  .actions-bar .btn-primary { background: var(--smartolt-primary); color: #fff; border-color: var(--smartolt-primary); }
  .actions-bar .btn-primary:hover { opacity: 0.9; }

  .status-card { background: var(--smartolt-card); border-radius: 8px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); margin-bottom: 20px; }
  .status-stats { display: flex; gap: 30px; flex-wrap: wrap; }
  .stat-item { text-align: center; }
  .stat-label { font-size: 11px; color: var(--smartolt-muted); text-transform: uppercase; }
  .stat-value { font-size: 24px; font-weight: 700; color: var(--smartolt-text); }

  .compat-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .compat-table th { background: #f8f8f9; padding: 10px 12px; text-align: left; font-weight: 600; color: var(--smartolt-muted); border-bottom: 1px solid var(--smartolt-border); }
  .compat-table td { padding: 10px 12px; border-bottom: 1px solid #f5f7f9; color: var(--smartolt-text); }

  @media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } }

  .tag-vlan { display: inline-block; background: #e8f4ff; color: var(--smartolt-primary); padding: 2px 8px; border-radius: 3px; font-size: 12px; font-weight: 500; }
  .tag-mode { display: inline-block; background: #f0f5ff; color: #2d8cf0; padding: 2px 8px; border-radius: 3px; font-size: 12px; font-weight: 500; }
  .tag-mode-routing { background: #f0fff4; color: var(--smartolt-success); }
</style>

<div class="onu-container">
  <div class="breadcrumb">
    <a href="/modulo?pagina=GPONManager">Dashboard</a> &gt;
    <a href="/modulo?pagina=smartolt_configured_full&olt_id=1">Configured ONUs</a> &gt;
    View ONU
  </div>

  <div class="onu-header">
    <h2>View ONU</h2>
    <span><small style="color:var(--smartolt-muted)">ID: <%= onu.id %></small></span>
  </div>

  <div class="info-grid">
    <!-- Left column: Basic info -->
    <div class="info-card">
      <h3>ONU Information</h3>
      <div class="info-row">
        <div class="info-label">OLT</div>
        <div class="info-value"><a href="#">1 - JOEL WIFI</a></div>
      </div>
      <div class="info-row">
        <div class="info-label">Board</div>
        <div class="info-value"><a href="#"><%= board %></a></div>
      </div>
      <div class="info-row">
        <div class="info-label">Port</div>
        <div class="info-value"><a href="#"><%= port %></a></div>
      </div>
      <div class="info-row">
        <div class="info-label">ONU</div>
        <div class="info-value"><a href="#"><%= onuId %></a></div>
      </div>
      <div class="info-row">
        <div class="info-label">GPON channel</div>
        <div class="info-value">GPON</div>
      </div>
      <div class="info-row">
        <div class="info-label">SN</div>
        <div class="info-value"><a href="#"><%= onu.sn %></a></div>
      </div>
      <div class="info-row">
        <div class="info-label">ONU type</div>
        <div class="info-value"><%= onuType %></div>
      </div>
      <div class="info-row">
        <div class="info-label">Zone</div>
        <div class="info-value"><%= zona %></div>
      </div>
      <div class="info-row">
        <div class="info-label">ODB (Splitter)</div>
        <div class="info-value">None</div>
      </div>
      <div class="info-row">
        <div class="info-label">Name</div>
        <div class="info-value"><a href="#"><%= onu.nombre || 'N/A' %></a></div>
      </div>
      <div class="info-row">
        <div class="info-label">Address or comment</div>
        <div class="info-value">None</div>
      </div>
      <div class="info-row">
        <div class="info-label">Contact</div>
        <div class="info-value">None</div>
      </div>
      <div class="info-row">
        <div class="info-label">Authorization date</div>
        <div class="info-value"><%= onu.created_at || 'N/A' %></div>
      </div>
      <div class="info-row">
        <div class="info-label">ONU external ID</div>
        <div class="info-value"><%= onu.sn %></div>
      </div>
    </div>

    <!-- Right column: Status & details -->
    <div>
      <div class="info-card" style="margin-bottom:20px;">
        <h3>Status & Network</h3>
        <div class="info-row">
          <div class="info-label">Status</div>
          <div class="info-value">
            <span class="status-badge <%= onu.estado === 'working' ? 'status-online' : (onu.estado === 'offline' ? 'status-offline' : 'status-warning') %>">
              <i class="fa fa-globe"></i> <%= onu.estado === 'working' ? 'Online' : (onu.estado || 'Unknown') %>
            </span>
          </div>
        </div>
        <div class="info-row">
          <div class="info-label">ONU/OLT Rx signal</div>
          <div class="info-value"><%= onu.senial ? onu.senial + ' dBm' : 'N/A' %></div>
        </div>
        <div class="info-row">
          <div class="info-label">Attached VLANs</div>
          <div class="info-value">
            <% if (onu.vlan) { %>
              <% onu.vlan.split(',').forEach(function(v) { %>
                <span class="tag-vlan"><%= v.trim() %></span>
              <% }); %>
            <% } else { %>-<% } %>
          </div>
        </div>
        <div class="info-row">
          <div class="info-label">ONU mode</div>
          <div class="info-value">
            <span class="tag-mode <%= onu.modo === 'Routing' ? 'tag-mode-routing' : '' %>">
              <%= onu.modo || 'Bridge' %>
            </span>
          </div>
        </div>
        <div class="info-row">
          <div class="info-label">Puerto OLT</div>
          <div class="info-value"><%= onu.puerto_olt %></div>
        </div>
      </div>

      <!-- Client info if linked -->
      <% if (cliente) { %>
      <div class="info-card">
        <h3>Associated Client</h3>
        <div class="info-row">
          <div class="info-label">Name</div>
          <div class="info-value"><a href="/modulo?pagina=VerCliente&id=<%= cliente.id %>"><%= cliente.nombre %></a></div>
        </div>
        <div class="info-row">
          <div class="info-label">Phone</div>
          <div class="info-value"><%= cliente.telefono || 'N/A' %></div>
        </div>
        <div class="info-row">
          <div class="info-label">Direction</div>
          <div class="info-value"><%= cliente.direccion || 'N/A' %></div>
        </div>
        <% if (servicio) { %>
        <div class="info-row">
          <div class="info-label">Plan</div>
          <div class="info-value"><%= servicio.plan_nombre || 'N/A' %></div>
        </div>
        <div class="info-row">
          <div class="info-label">Plan price</div>
          <div class="info-value">$<%= parseFloat(servicio.plan_precio || 0).toFixed(2) %></div>
        </div>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Actions -->
  <div class="actions-bar">
    <a href="/modulo?pagina=smartolt_configured_full&olt_id=1" class="btn"><i class="fa fa-arrow-left"></i> Back to list</a>
    <a href="#" class="btn btn-primary" onclick="alert('Reboot functionality coming soon')"><i class="fa fa-refresh"></i> Reboot</a>
    <a href="#" class="btn btn-danger" onclick="if(confirm('Disable this ONU?'))alert('Disable coming soon')"><i class="fa fa-power-off"></i> Disable ONU</a>
  </div>
</div>
